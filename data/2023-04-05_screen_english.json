    },
    {
      "start": 601.58,
      "end": 603.02,
      "text": "내가 듣기로는"
    },
    {
      "start": 603.02,
      "end": 603.82,
      "text": "밤만 되면"
    },
    {
      "start": 603.82,
      "end": 606.08,
      "text": "뼈가 crunching"
    },
    {
      "start": 606.08,
      "end": 607.2,
      "text": "부서지는"
    },
    {
      "start": 607.2,
      "end": 608.86,
      "text": "부러지는 소리가 난다더라"
    },
    {
      "start": 608.86,
      "end": 610.88,
      "text": "or even worse"
    },
    {
      "start": 610.88,
      "end": 612.44,
      "text": "심지어 더 최악인 건"
    },
    {
      "start": 612.44,
      "end": 613.22,
      "text": "chips"
    },
    {
      "start": 613.22,
      "end": 615.28,
      "text": "감자칩 소리도 들린대"
    },
    {
      "start": 615.28,
      "end": 616.06,
      "text": "라는 거예요"
    },
    {
      "start": 616.06,
      "end": 617.08,
      "text": "bone crunch보다"
    },
    {
      "start": 617.08,
      "end": 618.22,
      "text": "chip crunch"
    },
    {
      "start": 618.22,
      "end": 619.5,
      "text": "무서워하는 거죠"
    },
    {
      "start": 619.5,
      "end": 622.6,
      "text": "자신의 그 소중한 감자칩을 먹는다고 생각하니까"
    },
    {
      "start": 622.6,
      "end": 623.6,
      "text": "내 건데"
    },
    {
      "start": 623.6,
      "end": 624.42,
      "text": "그러게요"
    },
    {
      "start": 624.42,
      "end": 625.62,
      "text": "my potato chips"
    },
    {
      "start": 625.62,
      "end": 626.74,
      "text": "여기서 끝난 게 아니었어요"
    },
    {
      "start": 626.74,
      "end": 627.48,
      "text": "하나 더 있잖아요"
    },
    {
      "start": 627.48,
      "end": 630.81,
      "text": "not to mention flying toasters"
    },
    {
      "start": 630.81,
      "end": 635.01,
      "text": "날아다니는 토스터기는 말할 것도 없고"
    },
    {
      "start": 635.01,
      "end": 636.25,
      "text": "라는 표현입니다"
    },
    {
      "start": 636.25,
      "end": 638.35,
      "text": "토스터들도"
    },
    {
      "start": 638.35,
      "end": 641.55,
      "text": "they make yummy toast"
    },
    {
      "start": 641.55,
      "end": 642.41,
      "text": "good food"
    },
    {
      "start": 642.41,
      "end": 643.77,
      "text": "he's thinking about food"
    },
    {
      "start": 643.77,
      "end": 644.41,
      "text": "그러게요"
    },
    {
      "start": 644.41,
      "end": 645.13,
      "text": "he's a foodie"
    },
    {
      "start": 645.13,
      "end": 647.01,
      "text": "음식을 너무 좋아해가지고"
    },
    {
      "start": 647.01,
      "end": 648.81,
      "text": "음식에 관련된 것들을"
    },
    {
      "start": 648.81,
      "end": 650.67,
      "text": "좀 이렇게 소중하게 생각하나 봐요"
    },
    {
      "start": 650.67,
      "end": 652.81,
      "text": "that house is haunted"
    },
    {
      "start": 652.81,
      "end": 654.97,
      "text": "네 이제 Mark가 말을 합니다"
    },
    {
      "start": 654.97,
      "end": 656.57,
      "text": "that house is haunted"
    },
    {
      "start": 656.57,
      "end": 658.97,
      "text": "그 집에는 귀신이 살아"
    },
    {
      "start": 658.97,
      "end": 660.41,
      "text": "and that means that"
    },
    {
      "start": 660.41,
      "end": 661.93,
      "text": "you're gonna need a brave"
    },
    {
      "start": 661.93,
      "end": 664.95,
      "text": "no incredibly brave friend"
    },
    {
      "start": 664.95,
      "end": 667.35,
      "text": "and that means"
    },
    {
      "start": 667.35,
      "end": 668.05,
      "text": "그 말은"
    },
    {
      "start": 668.05,
      "end": 669.93,
      "text": "that you're gonna need"
    },
    {
      "start": 669.93,
      "end": 672.03,
      "text": "너에겐 필요할 거라는 거야"
    },
    {
      "start": 672.03,
      "end": 673.11,
