    },
    {
      "start": 644.13,
      "end": 646.09,
      "text": "예 그래서 이렇게 대답을 합니다"
    },
    {
      "start": 646.09,
      "end": 647.07,
      "text": "come on"
    },
    {
      "start": 647.07,
      "end": 647.79,
      "text": "됐거든"
    },
    {
      "start": 647.79,
      "end": 650.97,
      "text": "everything has a logical explanation"
    },
    {
      "start": 650.97,
      "end": 654.03,
      "text": "모든 건 다 논리적으로 설명할 수 있어"
