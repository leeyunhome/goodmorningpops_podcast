    },
    {
      "start": 673.11,
      "end": 675.53,
      "text": "no incredibly brave friend"
    },
    {
      "start": 675.53,
      "end": 676.21,
      "text": "라고 있어요"
    },
    {
      "start": 676.21,
      "end": 678.23,
      "text": "그냥 용감한 정도가 아니고"
    },
    {
      "start": 678.23,
      "end": 680.79,
      "text": "incredibly brave friend"
    },
    {
      "start": 680.79,
      "end": 684.17,
      "text": "아주 아주 용감한 친구가 필요할 거라는 뜻이야"
