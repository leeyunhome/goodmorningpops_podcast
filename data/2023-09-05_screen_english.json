    {
      "start": 403.59,
      "end": 405.53,
      "text": "They're in hot water right now"
    },
    {
      "start": 405.53,
      "end": 406.57,
      "text": "너무너무 다른"
    },
    {
      "start": 406.57,
      "end": 407.81,
      "text": "그런 반응으로"
