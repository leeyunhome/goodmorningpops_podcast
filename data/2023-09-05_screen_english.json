    {
      "start": 388.61,
      "end": 390.01,
      "text": "No Christmas spirit"
    },
    {
      "start": 390.01,
      "end": 391.57,
      "text": "But when she's with her sons"
    },
    {
      "start": 391.57,
      "end": 393.05,
      "text": "she's really relaxed"
    },
    {
      "start": 393.05,
      "end": 393.43,
      "text": "그래요"
    },
    {
      "start": 393.43,
      "end": 393.47,
      "text": "그래요"
    },
    {
      "start": 393.47,
      "end": 394.15,
      "text": "그래서"
    },
    {
      "start": 394.15,
      "end": 396.29,
      "text": "I could feel her maternal love"
