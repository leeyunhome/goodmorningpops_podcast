    {
      "start": 442.31,
      "end": 443.75,
      "text": "Scarecrow"
    },
    {
      "start": 443.75,
      "end": 444.99,
      "text": "Scarecrow"
    },
    {
      "start": 444.99,
      "end": 446.59,
      "text": "이거 그대로 만약에"
    },
    {
      "start": 446.59,
      "end": 448.27,
      "text": "보이는 단어 그대로 해석을 한다면"
    },
    {
      "start": 448.27,
      "end": 450.15,
      "text": "약간 무서워하는"
    },
    {
      "start": 450.15,
      "end": 451.17,
