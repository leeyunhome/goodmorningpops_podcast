    },
    {
      "start": 438.17,
      "end": 438.67,
      "text": "그렇죠"
    },
    {
      "start": 438.67,
      "end": 439.79,
      "text": "누구보다도"
    },
    {
      "start": 439.79,
      "end": 440.71,
      "text": "가장 마지막에"
    },
    {
      "start": 440.71,
      "end": 442.31,
      "text": "돌아오는 거라는 거죠"
