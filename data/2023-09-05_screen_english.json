    {
      "start": 410.05,
      "end": 411.17,
      "text": "차차 우리가"
    },
    {
      "start": 411.17,
      "end": 411.95,
      "text": "그 장면도"
    },
    {
      "start": 411.95,
      "end": 413.49,
      "text": "알아보실 수가 있을 텐데"
    },
    {
      "start": 413.49,
      "end": 416.35,
      "text": "일단 오늘 들었던 장면 속에서"
    },
    {
      "start": 416.35,
      "end": 418.39,
      "text": "주요 표현이 뭐가 있을까요?"
    },
    {
      "start": 418.51,
      "end": 419.67,
      "text": "Last back"
