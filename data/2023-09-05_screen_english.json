    {
      "start": 396.29,
      "end": 397.79,
      "text": "toward her two sons"
    },
    {
      "start": 397.79,
      "end": 398.25,
      "text": "Yes, totally"
    },
    {
      "start": 398.25,
      "end": 399.99,
      "text": "She doesn't have the same"
