      "start": 267.4,
      "end": 269.06,
      "text": "she became pretty well known"
    },
    {
      "start": 269.06,
      "end": 270.4,
      "text": "as a child actress"
    },
    {
      "start": 270.4,
      "end": 273.06,
      "text": "and then she got tired of that"
    },
    {
      "start": 273.06,
      "end": 274.22,
      "text": "so she stopped"
