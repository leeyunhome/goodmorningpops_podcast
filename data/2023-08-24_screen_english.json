    {
      "start": 248.42,
      "end": 249.52,
      "text": "at the age of 4"
    },
    {
      "start": 249.52,
      "end": 250.32,
      "text": "4 years old"
    },
    {
      "start": 250.32,
      "end": 250.9,
      "text": "yes"
    },
    {
      "start": 250.9,
      "end": 252.26,
