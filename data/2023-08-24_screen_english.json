    {
      "start": 260.92,
      "end": 262.78,
      "text": "and I guess they didn't make a lot of money"
    },
    {
      "start": 262.78,
      "end": 264.08,
      "text": "so she started"
    },
    {
      "start": 264.08,
      "end": 265.56,
      "text": "really, really early"
    },
    {
      "start": 265.56,
      "end": 267.4,
      "text": "and she was"
