      "start": 346.6,
      "end": 347.62,
      "text": "good script"
    },
    {
      "start": 347.62,
      "end": 348.98,
      "text": "where she can play"
    },
    {
      "start": 348.98,
      "end": 349.9,
      "text": "a special character"
    },
    {
      "start": 349.9,
      "end": 351.42,
      "text": "so very special"
    },
    {
      "start": 351.42,
      "end": 352.34,
      "text": "type of actress"
    },
    {
      "start": 352.34,
      "end": 353.86,
      "text": "자, 이제"
    },
    {
      "start": 353.86,
      "end": 355.2,
      "text": "오늘 준비된 장면"
    },
    {
      "start": 355.2,
      "end": 356.6,
      "text": "듣고 오시죠"
    },
    {
      "start": 356.6,
      "end": 382.0,
      "text": "역시나 제가 좋아하는"
    },
    {
      "start": 382.0,
      "end": 383.24,
      "text": "이 대화 내용의"
    },
    {
      "start": 383.24,
      "end": 384.82,
      "text": "연장선상이었습니다"
    },
    {
      "start": 384.82,
      "end": 386.24,
      "text": "Oh, that makes you happy"
    },
    {
      "start": 386.24,
      "end": 387.48,
      "text": "Yeah, 그리고 약간"
    },
    {
      "start": 387.48,
      "end": 388.94,
      "text": "I got emotional"
    },
    {
      "start": 388.94,
      "end": 389.7,
      "text": "Oh, really?"
    },
    {
      "start": 389.78,
      "end": 390.12,
      "text": "Yeah"
    },
    {
      "start": 390.12,
      "end": 391.3,
      "text": "What did you think of"
    },
