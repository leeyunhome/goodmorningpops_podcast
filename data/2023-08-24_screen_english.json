    {
      "start": 252.26,
      "end": 252.66,
      "text": "yeah"
    },
    {
      "start": 252.66,
      "end": 253.9,
      "text": "she'd made commercials"
    },
    {
      "start": 253.9,
      "end": 256.4,
      "text": "to help pay the family bills"
    },
    {
      "start": 256.4,
      "end": 258.1,
