    },
    {
      "start": 238.58,
      "end": 240.86,
      "text": "so she's from an acting family"
    },
    {
      "start": 240.86,
      "end": 242.62,
      "text": "she has the acting genes"
    },
    {
      "start": 242.62,
      "end": 245.38,
      "text": "and she actually began"
    },
