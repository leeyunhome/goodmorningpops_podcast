    {
      "start": 869.88,
      "end": 894.89,
      "text": "네 잘 들어보셨죠?"
    },
    {
      "start": 895.49,
      "end": 896.99,
      "text": "이 정호우님께서"
    },
    {
      "start": 896.99,
      "end": 898.27,
      "text": "메시지 주셨네요."
    },
    {
      "start": 898.77,
      "end": 899.73,
      "text": "월요일이지만"
    },
    {
      "start": 899.73,
      "end": 901.17,
      "text": "두 분 목소리 들으니"
    },
    {
      "start": 901.17,
      "end": 902.07,
      "text": "힘이 나네요"
    },
    {
      "start": 902.07,
      "end": 903.63,
      "text": "라고 해주셨습니다."
    },
    {
      "start": 903.73,
      "end": 904.11,
      "text": "Oh yeah."
    },
    {
      "start": 904.17,
      "end": 905.25,
      "text": "Let's beat the Monday Blues."
    },
    {
      "start": 905.43,
      "end": 906.17,
      "text": "그러니까요."
    },
    {
      "start": 906.23,
      "end": 906.93,
      "text": "Let's be happy."
    },
    {
      "start": 907.21,
      "end": 907.41,
      "text": "네."
    },
    {
      "start": 907.59,
      "end": 908.97,
      "text": "우리와 함께 해주시면서"
    },
    {
      "start": 908.97,
      "end": 909.85,
      "text": "에너지를"
    },
    {
      "start": 909.85,
      "end": 910.95,
      "text": "완전 풀로"
    },
    {
      "start": 910.95,
      "end": 911.83,
      "text": "충전하시기를"
    },
    {
      "start": 911.83,
      "end": 912.47,
      "text": "응원하겠습니다."
    },
    {
      "start": 912.87,
      "end": 913.71,
      "text": "More energy than"
    },
    {
      "start": 913.71,
      "end": 914.39,
      "text": "Child's"
    },
    {
      "start": 914.39,
      "end": 915.47,
      "text": "in this conversation."
    },
    {
      "start": 915.71,
      "end": 916.35,
      "text": "당연하죠."
    },
    {
      "start": 916.45,
      "end": 917.09,
      "text": "You can do it."
    },
    {
      "start": 917.23,
      "end": 917.37,
      "text": "네."
    },
    {
      "start": 917.83,
      "end": 919.53,
      "text": "응원한 것 해드리면서요."
    },
    {
      "start": 919.89,
      "end": 920.73,
      "text": "우리 크쌤은"
    },
    {
      "start": 920.73,
      "end": 921.59,
      "text": "내일 다시 만나요."
    }
  ]
}