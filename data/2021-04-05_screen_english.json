    {
      "start": 832.46,
      "end": 832.64,
      "text": "Yeah."
    },
    {
      "start": 832.8,
      "end": 833.76,
      "text": "So it's hilarious."
    },
    {
      "start": 835.06,
      "end": 836.88,
      "text": "Let's get him, boys."
    },
    {
      "start": 836.98,
      "end": 837.18,
      "text": "네."
    },
    {
      "start": 837.38,
      "end": 839.94,
      "text": "이제 자기네들의 군단들에게 명령을 합니다."
    },
    {
      "start": 840.22,
      "end": 841.44,
      "text": "Let's get him, boys."
    },
    {
      "start": 842.1,
      "end": 842.74,
      "text": "쟤 잡아!"
    },
    {
      "start": 843.32,
      "end": 844.84,
      "text": "이라고 외치고 있는 거죠."
