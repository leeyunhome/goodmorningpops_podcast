    {
      "start": 848.76,
      "end": 849.14,
      "text": "네."
    },
    {
      "start": 849.14,
      "end": 851.02,
      "text": "우리 트러블이 과연 잡힐지"
    },
    {
      "start": 851.02,
      "end": 852.22,
      "text": "너무 궁금합니다."
    },
    {
      "start": 852.48,
      "end": 853.96,
      "text": "이 장면 한 번 더 확인해 볼게요."
    },
    {
      "start": 853.96,
      "end": 858.48,
      "text": "Nobody touches our nuts."
    },
    {
      "start": 859.05,
      "end": 862.83,
      "text": "I have a butler that can vacuum those up for you in a jiffy."
    },
    {
      "start": 863.39,
      "end": 866.88,
      "text": "Somebody has assaulted our nuts."
    },
    {
      "start": 867.54,
      "end": 869.48,
      "text": "You might need to work on your worrying room."
    },
    {
      "start": 870.56,
      "end": 871.82,
      "text": "James, help!"
    },
    {
      "start": 872.82,
      "end": 875.16,
      "text": "Mr. was all here to save up those nuts."
    },
    {
      "start": 875.48,
      "end": 876.26,
      "text": "And now they're gone."
    },
    {
      "start": 877.14,
      "end": 878.84,
      "text": "Wait, nuts just grow on trees or something?"
    },
    {
      "start": 881.22,
      "end": 883.34,
      "text": "Let's get him, boys!"
    },
    {
      "start": 883.34,
      "end": 888.61,
      "text": "네, 확실히 여기 다람쥐들은 마치 뭐 Army Corps 같았어요."
    },
    {
      "start": 888.99,
      "end": 890.13,
      "text": "The Army, Marine Corps."
    },
    {
      "start": 890.31,
      "end": 890.57,
      "text": "Yeah."
    },
    {
      "start": 890.83,
      "end": 891.85,
