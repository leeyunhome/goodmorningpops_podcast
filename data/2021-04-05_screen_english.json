    {
      "start": 1083.85,
      "end": 1084.03,
      "text": "Yeah."
    },
    {
      "start": 1084.19,
      "end": 1085.15,
      "text": "So it's hilarious."
    },
    {
      "start": 1086.45,
      "end": 1088.27,
      "text": "Let's get him, boys."
    },
    {
      "start": 1088.37,
