    },
    {
      "start": 813.9,
      "end": 814.94,
      "text": "막 물 쓰듯이 있으면"
    },
    {
      "start": 814.94,
      "end": 817.3,
      "text": "Do you think money grows on trees?"
    },
    {
      "start": 818.0,
      "end": 819.68,
      "text": "엄마한테 많이 혼나요 그런 식으로."
    },
    {
      "start": 819.68,
      "end": 822.42,
      "text": "그것을 응용을 한 표현이었군요."
    },
    {
      "start": 822.46,
      "end": 823.64,
      "text": "여기 말 장난처럼."
    },
    {
      "start": 823.78,
      "end": 823.92,
      "text": "네."
    },
    {
      "start": 824.24,
      "end": 824.6,
      "text": "Nuts."
    },
    {
      "start": 824.84,
      "end": 826.54,
      "text": "Do you think nuts just grow on trees?"
    },
    {
      "start": 826.92,
      "end": 826.98,
      "text": "Wow."
    },
    {
      "start": 827.12,
      "end": 828.6,
      "text": "Squirrel is so clever."
    },
    {
      "start": 829.1,
      "end": 829.36,
      "text": "Yeah."
    },
    {
      "start": 829.74,
      "end": 830.54,
      "text": "Nuts do."
    },
    {
      "start": 830.7,
      "end": 832.42,
      "text": "Many nuts do grow on trees."
