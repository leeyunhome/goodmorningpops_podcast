    {
      "start": 934.65,
      "end": 935.47,
      "text": "님께서요"
    },
    {
      "start": 935.47,
      "end": 936.25,
      "text": "월요일 아침"
    },
    {
      "start": 936.25,
      "end": 937.77,
      "text": "조쌤, 크쌤 목소리 들으니"
