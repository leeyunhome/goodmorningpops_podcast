    },
    {
      "start": 916.05,
      "end": 916.59,
      "text": "그래도요"
    },
    {
      "start": 916.59,
      "end": 917.89,
      "text": "이렇게 내용을 들어보니까"
    },
    {
      "start": 917.89,
      "end": 919.59,
      "text": "Anthony Gunn seems to have"
