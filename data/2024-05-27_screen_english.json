    {
      "start": 949.09,
      "end": 949.53,
      "text": "화이팅"
    },
    {
      "start": 949.53,
      "end": 951.83,
      "text": "Monday, let's beat the Monday blues"
    },
    {
      "start": 951.83,
      "end": 952.59,
      "text": "Come on"
    },
    {
      "start": 952.59,
      "end": 954.69,
      "text": "미국식으로 화이팅도 외쳐주세요"
    },
    {
