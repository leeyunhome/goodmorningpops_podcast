    {
      "start": 626.39,
      "end": 627.87,
      "text": "on my ankle"
    },
    {
      "start": 627.87,
      "end": 630.35,
      "text": "It did a big number"
    },
    {
      "start": 630.35,
      "end": 632.13,
      "text": "It did a number on my ankle"
    },
    {
      "start": 632.13,
      "end": 634.09,
      "text": "뭔가 문제가 생긴 상황인가 봐요"
