    },
    {
      "start": 963.79,
      "end": 964.89,
      "text": "Go, go"
    },
    {
      "start": 964.89,
      "end": 965.79,
      "text": "괜찮아요?"
    },
    {
      "start": 965.81,
      "end": 966.35,
      "text": "아, 그거 좋아요"
