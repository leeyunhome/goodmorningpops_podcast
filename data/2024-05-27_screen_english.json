    {
      "start": 958.99,
      "end": 959.89,
      "text": "쓰지 마세요"
    },
    {
      "start": 959.89,
      "end": 960.33,
      "text": "그렇죠"
    },
    {
      "start": 960.33,
      "end": 961.31,
      "text": "싸우는 중이야"
    },
    {
      "start": 961.31,
      "end": 962.09,
      "text": "네, 아니죠"
    },
    {
      "start": 962.09,
      "end": 962.83,
      "text": "그만해"
    },
    {
      "start": 962.83,
      "end": 963.79,
