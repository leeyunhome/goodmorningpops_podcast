      "start": 869.38,
      "end": 870.26,
      "text": "Did you?"
    },
    {
      "start": 870.52,
      "end": 871.12,
      "text": "넌 알았냐?"
    },
    {
      "start": 871.94,
      "end": 872.62,
      "text": "몰랐다"
    },
    {
      "start": 872.62,
      "end": 873.14,
