    },
    {
      "start": 922.73,
      "end": 924.79,
      "text": "He likes his caregiver"
    },
    {
      "start": 924.79,
      "end": 925.29,
      "text": "그렇죠"
    },
    {
      "start": 925.29,
      "end": 926.93,
