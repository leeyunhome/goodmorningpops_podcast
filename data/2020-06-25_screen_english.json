    },
    {
      "start": 658.69,
      "end": 659.61,
      "text": "그렇겠죠?"
    },
    {
      "start": 660.01,
      "end": 662.17,
      "text": "라고 질문하는 그런 문장이었어요"
    },
    {
      "start": 662.17,
      "end": 663.73,
      "text": "He had fun working with Edison"
    },
    {
      "start": 663.73,
      "end": 666.13,
      "text": "Yeah, he had the best chemistry with Edison"
    },
    {
      "start": 666.13,
      "end": 667.79,
      "text": "Unlike Tesla"
    },
    {
      "start": 667.79,
      "end": 669.31,
      "text": "Who did not like it"
    },
    {
      "start": 669.31,
      "end": 669.49,
      "text": "그래요"
    },
    {
      "start": 669.49,
      "end": 670.31,
      "text": "이렇게 보면은"
    },
    {
      "start": 670.31,
      "end": 673.05,
      "text": "서로 코드가 딱 잘 맞는 사람들이 있어요"
    },
    {
      "start": 673.05,
      "end": 673.91,
      "text": "우리처럼?"
    },
    {
      "start": 674.25,
      "end": 675.23,
      "text": "아, 그럼요"
    },
    {
      "start": 675.23,
      "end": 677.31,
      "text": "네, 이 내용 한 번 더 들어보겠습니다"
    },
    {
      "start": 677.31,
      "end": 697.29,
      "text": "진짜 좀 전에 말씀드린 것처럼"
    },
    {
      "start": 697.29,
      "end": 698.91,
      "text": "이 내용을 막 다루다 보니까"
    },
    {
      "start": 698.91,
      "end": 700.67,
      "text": "오늘 특별히"
    },
    {
      "start": 700.67,
      "end": 703.81,
      "text": "이 크리스 씨랑 저랑 케미가 잘 맞는다는 것에 대해서"
    },
    {
      "start": 703.81,
      "end": 704.79,
      "text": "너무 고마워요"
    },
    {
      "start": 704.79,
      "end": 706.51,
      "text": "아, 제가 고맙죠"
    },
    {
      "start": 706.51,
      "end": 708.25,
      "text": "갓은 고마워요"
    },
    {
      "start": 708.25,
      "end": 711.03,
      "text": "I would much rather work with you"
    },
    {
      "start": 711.03,
      "end": 713.03,
      "text": "than fill in the blank"
    },
    {
      "start": 713.03,
      "end": 714.17,
      "text": "any day"
    },
    {
      "start": 714.17,
      "end": 715.09,
      "text": "어, 그래요"
    },
    {
      "start": 715.09,
      "end": 716.39,
      "text": "fill in the blank 때문에"
    },
    {
      "start": 716.39,
      "end": 718.35,
      "text": "어쨌든 너무 감사합니다"
    },
    {
      "start": 718.35,
      "end": 720.07,
      "text": "그치적인 이름 언급하기 원란하니까"
    },
    {
      "start": 720.07,
      "end": 720.47,
      "text": "오케이"
    },
    {
      "start": 720.47,
      "end": 721.51,
      "text": "빈칸 채우기"
    },
    {
      "start": 721.51,
      "end": 721.93,
      "text": "오케이"
    },
    {
      "start": 721.93,
      "end": 724.67,
      "text": "자, 오늘 스크린 잉글리쉬는 훈훈하게"
    },
    {
      "start": 724.67,
      "end": 725.97,
      "text": "여기에서 마무리해보고요"
    }
  ]
}