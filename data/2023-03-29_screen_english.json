    },
    {
      "start": 400.74,
      "end": 401.02,
      "text": "네"
    },
    {
      "start": 401.02,
      "end": 401.92,
      "text": "그래서 결국"
    },
    {
      "start": 401.92,
      "end": 402.76,
      "text": "우리 마이클은"
    },
    {
      "start": 402.76,
      "end": 403.92,
      "text": "he decided to"
    },
    {
      "start": 403.92,
      "end": 405.54,
      "text": "leave the island"
    },
    {
      "start": 405.54,
      "end": 407.22,
      "text": "결국 이제"
    },
    {
      "start": 407.22,
      "end": 408.44,
      "text": "보딩스쿨로"
    },
    {
      "start": 408.44,
      "end": 409.4,
      "text": "가게 되는"
    },
    {
      "start": 409.4,
      "end": 410.64,
      "text": "상황이었죠"
    },
    {
      "start": 410.64,
      "end": 412.2,
      "text": "after Mr. Percival's death"
    },
    {
      "start": 412.2,
      "end": 412.6,
      "text": "yeah"
    },
    {
      "start": 412.6,
      "end": 413.32,
      "text": "okay I'm done"
    },
    {
      "start": 413.32,
      "end": 413.88,
      "text": "I'm leaving"
    },
    {
      "start": 413.88,
      "end": 415.16,
      "text": "I'm not coming back"
    },
    {
      "start": 415.16,
      "end": 416.06,
      "text": "he was angry"
