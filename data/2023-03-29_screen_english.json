    },
    {
      "start": 508.49,
      "end": 509.79,
      "text": "라는 문장이었어요"
    },
    {
      "start": 509.79,
      "end": 511.57,
      "text": "I love you dad"
    },
    {
      "start": 511.57,
      "end": 512.85,
      "text": "I want to make peace"
    },
    {
      "start": 512.85,
      "end": 513.97,
      "text": "I like him"
    },
    {
      "start": 513.97,
      "end": 514.37,
      "text": "네"
    },
    {
      "start": 514.37,
      "end": 515.27,
      "text": "이렇게 어필"
    },
    {
      "start": 515.27,
      "end": 515.97,
      "text": "좋습니다"
    },
    {
      "start": 515.97,
      "end": 517.05,
      "text": "후회하면 안 돼요"
    },
    {
      "start": 517.05,
      "end": 517.61,
      "text": "그럼요"
    },
    {
      "start": 517.61,
      "end": 518.29,
      "text": "no regrets"
    },
    {
      "start": 518.29,
      "end": 521.25,
      "text": "the biggest mistake of my life"
    },
    {
      "start": 521.25,
      "end": 524.19,
      "text": "the biggest mistake of my life"
    },
    {
      "start": 524.19,
      "end": 524.83,
      "text": "라고 했으니까"
    },
    {
      "start": 524.83,
      "end": 528.13,
      "text": "내 인생 최대의 실수"
    },
    {
      "start": 528.13,
      "end": 529.65,
      "text": "이렇게 해석하시면 되겠죠"
    },
    {
      "start": 529.65,
      "end": 531.65,
      "text": "그럼 이 장면 한 번 더 들어볼게요"
    },
    {
      "start": 531.65,
      "end": 534.29,
      "text": "well we've certainly delayed him for a while"
    },
    {
      "start": 534.29,
      "end": 536.57,
      "text": "but it's gonna be up to you to change his mind"
    },
    {
      "start": 536.57,
      "end": 538.57,
      "text": "he'll be lucky if I talk to him for a year"
    },
    {
      "start": 538.57,
      "end": 539.23,
