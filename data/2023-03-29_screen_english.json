    },
    {
      "start": 539.23,
      "end": 540.91,
      "text": "you have to talk to him"
    },
    {
      "start": 540.91,
      "end": 541.67,
      "text": "he's your father"
    },
    {
      "start": 541.67,
      "end": 542.87,
      "text": "don't I know it"
    },
    {
      "start": 542.87,
      "end": 544.53,
      "text": "he's not a bad man"
    },
    {
      "start": 544.53,
      "end": 546.67,
      "text": "he's just a business man"
    },
    {
      "start": 546.67,
      "end": 547.83,
      "text": "and your mom"
