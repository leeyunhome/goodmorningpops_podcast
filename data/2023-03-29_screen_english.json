    },
    {
      "start": 397.48,
      "end": 398.2,
      "text": "그렇긴 한데"
    },
    {
      "start": 398.2,
      "end": 399.28,
      "text": "이제 얼마 안 남았으니까"
    },
    {
      "start": 399.28,
      "end": 399.9,
