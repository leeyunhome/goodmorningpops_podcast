  "artwork_generated_url": "",
  "script": [
    {
      "start": 0.0,
      "end": 12.72,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 12.72,
      "end": 22.61,
      "text": "누군가 이런 말을 했습니다."
    },
    {
      "start": 23.13,
      "end": 24.89,
      "text": "Laughter is inner jogging."
    },
    {
      "start": 25.37,
      "end": 27.13,
      "text": "웃음은 마음의 조깅이다."
    },
    {
      "start": 28.02,
      "end": 31.4,
      "text": "조깅을 하면 근육도 생기고 몸이 건강해지죠."
    },
    {
      "start": 31.4,
      "end": 35.06,
      "text": "우리 마음 역시 운동을 해야 건강해질 수 있는데요."
    },
    {
      "start": 35.78,
      "end": 37.9,
      "text": "마음의 운동이 바로 웃음이라는 거죠."
    },
    {
      "start": 38.7,
      "end": 41.36,
      "text": "웃으면 스트레스 해소에 혈압도 낮아지고"
    },
    {
      "start": 41.36,
      "end": 44.48,
      "text": "면역력까지 좋아진다는 연구 결과도 있잖아요."
    },
    {
      "start": 44.48,
      "end": 49.46,
      "text": "오늘부턴 아침 운동하면서 마음의 조깅도 빼놓지 마세요."
    },
    {
      "start": 50.18,
      "end": 51.86,
      "text": "Laughter is inner jogging."
    },
    {
      "start": 58.44,
      "end": 59.86,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 59.86,
      "end": 62.88,
      "text": "첫 곡 레이 차이씨의 Unchained My Heart"
    },
    {
      "start": 62.88,
      "end": 70.63,
      "text": "일요일 첫 곡으로 레이 차이씨의 Unchained My Heart 들어보셨습니다."
    },
    {
      "start": 71.09,
      "end": 72.49,
      "text": "리듬 좀 타셨나요?"
    },
    {
      "start": 73.41,
      "end": 76.75,
      "text": "첫 번째 사연으로 미다리님께서 보내주셨는데요."
    },
    {
      "start": 77.25,
      "end": 80.19,
      "text": "정연쌤이 매일 알려주시는 표현들이 너무 좋아서"
    },
    {
      "start": 80.19,
      "end": 82.31,
      "text": "일주일 치를 다시 듣기로도 듣고"
    },
    {
      "start": 82.31,
      "end": 84.17,
      "text": "나만의 노트를 만들면서"
    },
    {
      "start": 84.17,
      "end": 87.01,
      "text": "나만의 문장, 교재를 만들고 있어요."
    },
    {
      "start": 87.01,
      "end": 89.05,
      "text": "오늘도 너무 설렙니다."
    },
    {
      "start": 90.05,
      "end": 92.95,
      "text": "와, 너무너무 잘 활용해지고 계시네요."
    },
    {
      "start": 93.75,
      "end": 97.17,
      "text": "그리고 오늘처럼 일요일에는 복습 시간인데"
    },
    {
      "start": 97.17,
      "end": 102.03,
      "text": "이 복습도 저랑 같이 할 수 있으니까 더 좋으시겠죠?"
    },
    {
      "start": 102.81,
      "end": 106.95,
      "text": "그리고 뭔가를 배우면서 이렇게 설렘을 가진다는 거"
    },
    {
      "start": 106.95,
      "end": 110.29,
      "text": "가슴이 뛰는 그런 설렘을 가진다는 거"
    },
    {
      "start": 110.29,
      "end": 111.79,
      "text": "참 멋진 것 같아요."
    },
    {
      "start": 112.31,
      "end": 115.85,
      "text": "우리 미다리님께는 아메리카노 모바일 쿠폰 보내드릴게요."
    },
    {
      "start": 116.71,
      "end": 119.29,
      "text": "이렇게 굿모닝 팝스에 사연 보내고 싶으신 분들은"
    },
    {
      "start": 119.29,
      "end": 121.05,
      "text": "홈페이지 청취자 게시판에 남겨주세요."
    },
    {
      "start": 122.31,
      "end": 125.73,
      "text": "실시간으로 듣고 계신 분들은 지금 바로 참여하실 수 있습니다."
    },
    {
      "start": 125.73,
      "end": 129.13,
      "text": "단문 50원과 장문 100원에 추가 요금이 부과되는"
    },
    {
      "start": 129.13,
      "end": 135.43,
      "text": "KBS 쿨 FM 문자샵 8910 아니면 KBS 2라디오 문자샵 1061로 보내주시거나"
    },
    {
      "start": 135.43,
      "end": 138.97,
      "text": "무료 KBS 애플리케이션 콩 또는 KBS 플러스로 참여해주세요."
    },
    {
      "start": 138.97,
      "end": 152.57,
      "text": "KBS 라디오 조정현의 굿모닝 팝스"
    },
    {
      "start": 152.57,
      "end": 172.72,
      "text": "KBS 라디오 조정현의 굿모닝 팝스"
    },
    {
      "start": 172.72,
      "end": 175.88,
      "text": "고티에이의 Somebody that I used to know 듣고 오셨고요."
    },
    {
      "start": 176.52,
      "end": 178.82,
      "text": "이어서 일요일 복습 시작해 볼게요."
    },
    {
      "start": 178.82,
      "end": 191.66,
      "text": "리뷰타임 Part 1 Screen English"
    },
    {
      "start": 191.66,
      "end": 209.7,
      "text": "함께하고 있는 영화 The Father"
    },
    {
      "start": 209.7,
      "end": 214.34,
      "text": "이 영화 속에 이번 주에 다뤘던 표현들을 하나하나 살펴보면서"
    },
    {
      "start": 214.34,
      "end": 216.26,
      "text": "복습 함께해 보겠습니다."
    },
    {
      "start": 216.98,
      "end": 220.08,
      "text": "먼저 5월 13일 월요일에 만나본 장면인데요."
    },
    {
      "start": 220.7,
      "end": 225.68,
      "text": "앤소니는 새로운 간병인이 자신의 둘째 딸을 닮았다고 생각하는데요."
    },
    {
      "start": 225.68,
      "end": 232.31,
      "text": "I have a distinct impression that I've seen you before."
    },
    {
      "start": 233.56,
      "end": 235.6,
      "text": "I have a distinct impression."
    },
    {
      "start": 235.6,
      "end": 240.72,
      "text": "뭔가 분명한 인상이 있다라는 말부터 들리셨고"
    },
    {
      "start": 240.72,
      "end": 244.16,
      "text": "That I've seen you before 이라고 이어졌으니까"
    },
    {
      "start": 244.16,
      "end": 249.0,
      "text": "이전에 당신을 본 것 같은 그런 분명한 인상이 있어."
    },
    {
      "start": 249.68,
      "end": 254.5,
      "text": "한마디로 낯이 이거 분명 낯이 이거요 라는 문장인 거죠."
    },
    {
      "start": 254.5,
      "end": 258.12,
      "text": "I have a distinct impression that I've seen you before."
    },
    {
      "start": 258.74,
      "end": 259.54,
      "text": "이해하실 수 있겠죠?"
    },
    {
      "start": 260.04,
      "end": 262.1,
      "text": "그럼 월요일 대화 장면 확인해 볼게요."
    },
    {
      "start": 265.79,
      "end": 269.43,
      "text": "Are you sure I have a distinct impression that I've seen you before?"
    },
    {
      "start": 269.61,
      "end": 272.97,
      "text": "So what Laura has come around to meet us"
    },
    {
      "start": 272.97,
      "end": 274.79,
      "text": "so that she can get an idea of how you live"
    },
    {
      "start": 274.79,
      "end": 276.97,
      "text": "and to what extent she might be able to help you?"
    },
    {
      "start": 277.13,
      "end": 278.03,
      "text": "I know, I know that."
    },
    {
      "start": 278.51,
      "end": 279.95,
      "text": "You've already told me a hundred times."
    },
    {
      "start": 280.95,
      "end": 284.75,
      "text": "My daughter has a tendency to repeat herself."
    },
    {
      "start": 284.75,
      "end": 288.87,
      "text": "다음은 5월 14일 화요일 장면입니다."
    },
    {
      "start": 289.21,
      "end": 292.91,
      "text": "앤토니는 간병인에게 자신의 딸들에 대해서 이야기하면서"
    },
    {
      "start": 292.91,
      "end": 295.99,
      "text": "특히 둘째 딸을 예뻐했다고 말하는데요."
    },
    {
      "start": 296.49,
      "end": 301.54,
      "text": "I hardly ever hear from the other one."
    },
    {
      "start": 302.59,
      "end": 305.55,
      "text": "I hardly ever hear from the other one."
    },
    {
      "start": 306.09,
      "end": 309.29,
      "text": "여기서 from the other one, 이 부분을"
    },
    {
      "start": 309.29,
      "end": 312.53,
      "text": "from my second daughter이라고 할 수도 있었을 텐데"
    },
    {
      "start": 312.53,
      "end": 317.37,
      "text": "이처럼 첫째 말고 다르네 이렇게 표현을 한 것이었죠."
    },
    {
      "start": 317.93,
      "end": 319.53,
      "text": "그러니까 둘째 딸로부터"
    },
    {
      "start": 319.53,
      "end": 322.97,
      "text": "I hardly ever hear from the other one."
    },
    {
      "start": 323.53,
      "end": 327.27,
      "text": "거의 소식을 듣지 못했다 라고 해석하면 되는 문장이었습니다."
    },
    {
      "start": 327.91,
      "end": 330.05,
      "text": "그럼 화요일 내용도 다시 들어볼까요?"
    },
    {
      "start": 330.05,
      "end": 355.5,
      "text": "리뷰타임 수요일 장면은 노래 한 곡 듣고 만나볼게요."
    },
    {
      "start": 355.8,
      "end": 357.04,
      "text": "제시카의 Goodbye."
    },
    {
      "start": 357.04,
      "end": 361.68,
      "text": "여러분은 지금 KBS 라디오 조정연의 Good Morning Pops 함께하고 계십니다."
    },
    {
      "start": 362.38,
      "end": 365.0,
      "text": "이어서 5월 15일 수요일 장면이에요."
    },
    {
      "start": 365.56,
      "end": 369.7,
      "text": "앤토니는 간병인에게 자신이 탭댄서였다는 허풍을 떠는데요."
    },
    {
      "start": 373.14,
      "end": 374.7,
      "text": "탭댄싱 was my specialty."
    },
    {
      "start": 375.61,
      "end": 378.21,
      "text": "탭댄싱 was my specialty."
    },
    {
      "start": 379.09,
      "end": 381.87,
      "text": "탭댄스가 was my specialty."
    },
    {
      "start": 382.57,
      "end": 384.59,
      "text": "나의 특출난 분야였다."
    },
    {
      "start": 384.71,
      "end": 386.43,
      "text": "나의 전문 분야였다."
    },
    {
      "start": 386.55,
      "end": 387.81,
      "text": "라고 말하고 있는 거였죠."
    },
    {
      "start": 387.81,
      "end": 390.05,
      "text": "탭댄싱 was my specialty."
    },
    {
      "start": 390.61,
      "end": 392.87,
      "text": "탭댄스가 내 전문 분야였어요."
    },
    {
      "start": 393.29,
      "end": 394.73,
      "text": "이렇게 해석하시면 되고요."
    },
    {
      "start": 395.27,
      "end": 399.05,
      "text": "이런 말을 했지만 그래도 아무도 믿지 않는 눈치였어요."
    },
    {
      "start": 399.55,
      "end": 400.55,
      "text": "그럼 다시 들어볼게요."
    },
    {
      "start": 400.55,
      "end": 424.63,
      "text": "5월 16일 목요일에 함께한 장면입니다."
    },
    {
      "start": 424.63,
      "end": 427.49,
      "text": "앤토니는 딸인 앤을 알아보지 못하고"
    },
    {
      "start": 427.49,
      "end": 432.49,
      "text": "앤이 낯선 남자와 자기 집으로 들어와서 살고 있다고 이야기하는데요."
    },
    {
      "start": 432.49,
      "end": 437.96,
      "text": "The next stage will be to send me away."
    },
    {
      "start": 437.96,
      "end": 441.72,
      "text": "The next stage will be to send me away."
    },
    {
      "start": 442.38,
      "end": 443.42,
      "text": "좀 슬픈 이야기죠."
    },
    {
      "start": 443.88,
      "end": 446.2,
      "text": "다음 stage는 다음번에는"
    },
    {
      "start": 446.2,
      "end": 448.84,
      "text": "will be to send me away."
    },
    {
      "start": 449.22,
      "end": 450.94,
      "text": "나를 멀리 보낼 거야."
    },
    {
      "start": 451.4,
      "end": 452.2,
      "text": "라는 문장입니다."
    },
    {
      "start": 452.68,
      "end": 456.44,
      "text": "다음 단계는 나를 멀리 보내는 것일 거다."
    },
    {
      "start": 456.72,
      "end": 457.56,
      "text": "라는 말이었어요."
    },
    {
      "start": 457.56,
      "end": 459.92,
      "text": "그럼 목요일 장면도 다시 들어볼게요."
    },
    {
      "start": 459.92,
      "end": 463.36,
      "text": "So she's moved in with me ostensibly to help me"
    },
    {
      "start": 463.36,
      "end": 465.16,
      "text": "with this man she met."
    },
    {
      "start": 465.74,
      "end": 466.46,
      "text": "Not long ago."
    },
    {
      "start": 466.84,
      "end": 468.22,
      "text": "Just after her divorce."
    },
    {
      "start": 468.94,
      "end": 469.14,
      "text": "Yeah."
    },
    {
      "start": 469.88,
      "end": 472.38,
      "text": "Her's a very bad influence on her."
    },
    {
      "start": 472.52,
      "end": 473.28,
      "text": "I have to tell you."
    },
    {
      "start": 473.52,
      "end": 474.7,
      "text": "What are you talking about, dad?"
    },
    {
      "start": 475.22,
      "end": 477.5,
      "text": "So now she would like to convince me that"
    },
    {
      "start": 477.5,
      "end": 480.4,
      "text": "I really cannot manage on my own."
    },
    {
      "start": 481.1,
      "end": 484.6,
      "text": "And the next stage will be to send me away."
    },
    {
      "start": 484.7,
      "end": 485.14,
      "text": "I don't know where."
    },
    {
      "start": 486.21,
      "end": 488.59,
      "text": "5월에 함께하고 있는 영화 The Father."
    },
    {
      "start": 488.59,
      "end": 492.29,
      "text": "Anthony는 딸의 얼굴조차 알아보지 못하면서"
    },
    {
      "start": 492.29,
      "end": 494.99,
      "text": "점점 더 상태가 악화되고 있죠."
    },
    {
      "start": 495.67,
      "end": 497.91,
      "text": "앞으로의 이야기는 어떻게 흘러가게 될지"
    },
    {
      "start": 497.91,
      "end": 500.11,
      "text": "내일 이야기도 기대해 주시고"
    },
    {
      "start": 500.11,
      "end": 501.15,
      "text": "꼭 함께해 주세요."
    },
    {
      "start": 501.77,
      "end": 503.03,
      "text": "그럼 노래 한 곡 듣고 올게요."
    },
    {
      "start": 503.39,
      "end": 505.49,
      "text": "Kings of Convenience의 Homesick"
    },
    {
      "start": 505.49,
      "end": 507.89,
      "text": "신형옥님"
    },
    {
      "start": 507.89,
      "end": 509.97,
      "text": "오늘은 일요일 출근이네요."
    },
    {
      "start": 510.53,
      "end": 513.05,
      "text": "출근 전 방송 들으며 하루를 시작합니다."
    },
    {
      "start": 513.59,
      "end": 515.77,
      "text": "항상 유익한 방송 감사드립니다."
    },
    {
      "start": 516.41,
      "end": 518.21,
      "text": "영어 정복을 위한 그날까지"
    },
    {
      "start": 518.21,
      "end": 519.73,
      "text": "웃음 웃음"
    },
    {
      "start": 519.73,
      "end": 523.09,
      "text": "일요일에도 변함없이"
    },
    {
      "start": 523.09,
      "end": 525.07,
      "text": "이른 출근을 하고 계시는데"
    },
    {
      "start": 525.07,
      "end": 527.67,
      "text": "밝은 에너지를 가지고 계신 것 같아서"
    },
    {
      "start": 527.67,
      "end": 528.97,
      "text": "너무 좋으네요."
    },
    {
      "start": 530.25,
      "end": 531.27,
      "text": "출퇴근길"
    },
    {
      "start": 531.27,
      "end": 533.83,
      "text": "일요일에 출퇴근길이면"
    },
    {
      "start": 533.83,
      "end": 536.35,
      "text": "그래도 그 덜 붐비잖아요."
    },
    {
