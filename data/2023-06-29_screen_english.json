      "text": "너무 좋은데요?"
    },
    {
      "start": 849.37,
      "end": 850.39,
      "text": "Cute fuzzy lovely animals"
    },
    {
      "start": 850.39,
      "end": 851.03,
      "text": "You like it?"
    },
    {
