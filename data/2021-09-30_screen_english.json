    },
    {
      "start": 690.39,
      "end": 691.53,
      "text": "I can accompany her."
    },
    {
      "start": 692.03,
      "end": 693.61,
      "text": "Sorry for interrupting."
    },
    {
      "start": 693.79,
      "end": 693.97,
      "text": "Hi."
    },
    {
      "start": 694.88,
      "end": 695.6,
      "text": "How are you?"
    },
    {
      "start": 696.36,
      "end": 698.22,
      "text": "I'm Bernardo Villalobos."
    },
    {
      "start": 698.74,
      "end": 699.64,
