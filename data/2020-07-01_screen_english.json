      "start": 598.16,
      "end": 598.48,
      "text": "Right."
    },
    {
      "start": 598.56,
      "end": 599.92,
      "text": "It means I got honors."
    },
    {
      "start": 600.02,
      "end": 601.92,
      "text": "I graduated with honors."
