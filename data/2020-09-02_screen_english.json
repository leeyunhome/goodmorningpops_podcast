    {
      "start": 172.42,
      "end": 172.9,
      "text": "Yeah"
    },
    {
      "start": 172.9,
      "end": 174.88,
      "text": "Oh, he's just 12 years old"
    },
    {
      "start": 174.88,
      "end": 177.28,
      "text": "And probably he might be so confused"
    },
    {
      "start": 177.28,
      "end": 179.32,
      "text": "정치상 혼란이 벌써 왔어요"
    },
    {
      "start": 179.32,
      "end": 179.74,
      "text": "Right"
    },
    {
      "start": 179.74,
      "end": 181.24,
      "text": "다행사리 하지도 않은데"
    },
    {
      "start": 181.24,
      "end": 182.18,
      "text": "그러게요"
    },
    {
      "start": 182.18,
      "end": 183.5,
      "text": "His family 마음대로"
    },
    {
      "start": 183.5,
      "end": 185.54,
      "text": "막 명칭 붙이고 부리니까"
    },
    {
      "start": 185.54,
      "end": 186.76,
      "text": "감정이입이 좀 됩니다"
    },
    {
      "start": 186.76,
      "end": 187.62,
      "text": "우리 에이브에게"
    },
    {
      "start": 187.62,
      "end": 190.81,
      "text": "자, 오늘 내용 듣고 올게요"
    },
    {
      "start": 190.81,
      "end": 191.45,
      "text": "Technically"
    },
    {
      "start": 191.45,
      "end": 193.69,
      "text": "You are a Jew"
