    {
      "start": 197.49,
      "end": 199.01,
      "text": "Because of his father"
    },
    {
      "start": 199.01,
      "end": 199.79,
      "text": "I'm sorry"
    },
    {
      "start": 199.79,
      "end": 202.09,
      "text": "Is atheism matrilineal"
