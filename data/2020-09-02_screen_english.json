    {
      "start": 202.09,
      "end": 203.23,
      "text": "Or patrilineal?"
    },
    {
      "start": 203.47,
      "end": 203.65,
      "text": "I don't know"
    },
    {
      "start": 203.65,
      "end": 204.35,
      "text": "Technically"
    },
    {
      "start": 204.35,
      "end": 205.61,
      "text": "I don't know"
    },
    {
      "start": 205.61,
      "end": 206.79,
      "text": "Yeah, so why don't we"
    },
    {
      "start": 206.79,
      "end": 208.91,
      "text": "Take this off the table for now"
    },
    {
      "start": 208.91,
      "end": 210.89,
      "text": "Oh, interestingly"
    },
    {
      "start": 210.89,
      "end": 212.27,
      "text": "What a family"
