    {
      "start": 235.93,
      "end": 237.03,
      "text": "We got together"
    },
    {
      "start": 237.03,
      "end": 239.41,
      "text": "For a big family reunion"
    },
    {
      "start": 239.41,
      "end": 242.11,
      "text": "So this is one of those times"
    },
    {
      "start": 242.11,
      "end": 242.45,
      "text": "Yeah"
    },
    {
      "start": 242.45,
      "end": 245.01,
      "text": "The whole family is sitting at one table"
    },
    {
      "start": 245.01,
      "end": 246.73,
      "text": "Mom's family, dad's family"
    },
    {
      "start": 246.73,
      "end": 246.95,
      "text": "Yeah"
    },
    {
      "start": 246.95,
      "end": 250.51,
      "text": "And things are not going so smoothly"
