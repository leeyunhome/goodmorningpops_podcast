    },
    {
      "start": 618.66,
      "end": 618.96,
      "text": "Yeah."
    },
    {
      "start": 619.04,
      "end": 619.7,
      "text": "He's trying to"
    },
    {
      "start": 619.7,
      "end": 620.52,
      "text": "fish it out."
    },
    {
      "start": 620.6,
      "end": 621.96,
      "text": "역시 good teacher입니다."
    },
    {
      "start": 622.36,
      "end": 622.86,
      "text": "Yeah."
    },
    {
      "start": 623.16,
      "end": 623.74,
      "text": "자, 이 내용"
    },
    {
      "start": 623.74,
      "end": 624.7,
      "text": "한 번 더 들어보시죠."
    },
    {
      "start": 625.38,
      "end": 626.1,
      "text": "Why did you"
    },
    {
      "start": 626.1,
      "end": 627.14,
      "text": "run out of my class?"
    },
    {
      "start": 627.64,
      "end": 628.48,
      "text": "I got scared."
    },
    {
      "start": 629.1,
      "end": 629.58,
      "text": "Of what?"
    },
    {
      "start": 630.36,
      "end": 631.0,
      "text": "Other kids?"
    },
    {
      "start": 631.74,
      "end": 632.08,
      "text": "Maybe."
    },
    {
      "start": 632.74,
      "end": 633.26,
      "text": "Or maybe"
    },
    {
      "start": 633.26,
      "end": 634.3,
      "text": "finding out that I'm bad."
    },
    {
      "start": 634.96,
      "end": 635.58,
      "text": "Do you know what"
    },
    {
      "start": 635.58,
      "end": 636.6,
      "text": "Bowie said about"
    },
    {
      "start": 636.6,
      "end": 637.02,
      "text": "Bob Dylan?"
    },
    {
      "start": 637.58,
      "end": 638.3,
      "text": "A voice like"
    },
    {
      "start": 638.3,
      "end": 639.42,
      "text": "sand and glue."
    },
    {
      "start": 639.42,
      "end": 641.04,
      "text": "There are plenty"
    },
    {
      "start": 641.04,
      "end": 641.7,
      "text": "of pretty voices"
    },
    {
      "start": 641.7,
      "end": 642.82,
      "text": "with nothing to say."
    },
    {
      "start": 643.4,
      "end": 643.86,
      "text": "Do you have"
    },
    {
      "start": 643.86,
      "end": 644.82,
      "text": "something to say?"
    },
    {
      "start": 645.26,
      "end": 646.1,
      "text": "I think so."
    },
    {
      "start": 647.69,
      "end": 648.89,
      "text": "자, 오늘 이렇게"
    },
    {
      "start": 648.89,
      "end": 649.87,
      "text": "장면을 들어보면서"
    },
    {
      "start": 649.87,
      "end": 650.89,
      "text": "다시 한 번 느끼지만"
    },
    {
      "start": 650.89,
      "end": 651.87,
      "text": "It's really important"
    },
    {
      "start": 651.87,
      "end": 653.71,
      "text": "to meet a good teacher"
    },
    {
      "start": 653.71,
      "end": 655.03,
      "text": "in our life."
    },
    {
      "start": 655.09,
      "end": 656.19,
      "text": "A teacher can change"
    },
    {
      "start": 656.19,
      "end": 656.69,
      "text": "your life."
    },
    {
      "start": 656.69,
      "end": 656.97,
      "text": "Yeah."
    },
    {
      "start": 657.11,
      "end": 657.89,
      "text": "The right teacher"
    },
    {
      "start": 657.89,
      "end": 659.63,
      "text": "who says the right things."
    },
    {
      "start": 659.77,
      "end": 660.03,
      "text": "Right."
    },
    {
      "start": 660.19,
      "end": 661.43,
      "text": "정말 좋은 선생님을"
    },
    {
      "start": 661.43,
      "end": 662.53,
      "text": "인생에서 만나는 것이"
    },
    {
      "start": 662.53,
      "end": 663.81,
      "text": "얼마나 중요한 일인지"
    },
    {
      "start": 663.81,
      "end": 665.59,
      "text": "오늘도 다시 깨닫게 되네요."
    },
    {
      "start": 665.79,
      "end": 667.01,
      "text": "오늘은 조크쌤과"
    },
    {
      "start": 667.01,
      "end": 668.31,
      "text": "맞습니다."
    },
    {
      "start": 668.31,
      "end": 670.07,
      "text": "그냥 good teachers 되도록"
    },
    {
      "start": 670.07,
      "end": 671.49,
      "text": "앞으로도 노력 많이 하겠습니다."
    },
    {
      "start": 672.03,
      "end": 673.15,
      "text": "I'll try my best."
    },
    {
      "start": 673.45,
      "end": 675.21,
      "text": "우리 내일 다시 만날게요."
    },
    {
      "start": 675.43,
      "end": 675.93,
      "text": "See you tomorrow."
    },
    {
      "start": 676.19,
      "end": 676.63,
      "text": "Bye."
    }
  ]
}