    },
    {
      "start": 725.27,
      "end": 727.47,
      "text": "진짜 이해를 못하고 계십니다"
    },
    {
      "start": 727.47,
      "end": 727.95,
      "text": "그죠?"
    },
    {
      "start": 728.19,
