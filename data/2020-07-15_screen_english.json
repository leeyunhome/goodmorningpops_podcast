    {
      "start": 701.1,
      "end": 703.0,
      "text": "당신이 이야기하는군요"
    },
    {
      "start": 703.0,
      "end": 705.78,
      "text": "대회가 폐지되어야 된다고"
    },
    {
      "start": 705.78,
      "end": 707.14,
      "text": "These beauty competitions"
