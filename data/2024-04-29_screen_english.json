    {
      "start": 333.84,
      "end": 334.58,
      "text": "맞습니다"
    },
    {
      "start": 334.58,
      "end": 336.34,
      "text": "꼭 뭐 인간고 인간"
    },
    {
      "start": 336.34,
      "end": 337.96,
      "text": "뭐 벨루가와 벨루가"
    },
    {
      "start": 337.96,
      "end": 338.7,
      "text": "이게 아니고"
    },
    {
      "start": 338.7,
      "end": 340.46,
      "text": "교감 is something bigger"
    },
    {
      "start": 340.46,
      "end": 341.16,
      "text": "맞습니다"
    },
    {
      "start": 341.16,
      "end": 342.48,
      "text": "bigger than just language"
    },
    {
      "start": 342.48,
      "end": 343.12,
      "text": "맞습니다"
    },
    {
      "start": 343.12,
      "end": 346.54,
      "text": "이렇게 잘 설명을 해주셔서 감사드리고요"
    },
    {
      "start": 346.54,
      "end": 348.04,
      "text": "그럼 오늘 준비된 장면"
    },
    {
      "start": 348.04,
      "end": 348.74,
      "text": "들려주세요"
    },
    {
      "start": 348.74,
      "end": 352.0,
      "text": "she says she still loves you"
