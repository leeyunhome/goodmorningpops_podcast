    {
      "start": 468.5,
      "end": 470.04,
      "text": "아니면 레몬 이런 것도"
    },
    {
      "start": 470.04,
      "end": 471.7,
      "text": "오, 너무 좋아요"
    },
    {
      "start": 471.7,
      "end": 472.0,
      "text": "오, 너무 좋아요"
