    },
    {
      "start": 520.32,
      "end": 522.46,
      "text": "오, 순회복 어필하셨고요"
    },
    {
      "start": 522.46,
      "end": 524.76,
      "text": "The biggest ladies man"
    },
    {
      "start": 524.76,
      "end": 527.18,
      "text": "이제 잘 추측을 하셨을 텐데요"
