      "start": 669.21,
      "end": 669.77,
      "text": "그렇죠"
    },
    {
      "start": 669.77,
      "end": 670.61,
      "text": "그랜마"
    },
    {
      "start": 670.61,
      "end": 671.33,
      "text": "Nonna"
    },
    {
      "start": 671.33,
      "end": 672.33,
      "text": "미안, 랭귀지로"
    },
    {
      "start": 672.33,
      "end": 673.67,
      "text": "할머니라는 의미로"
