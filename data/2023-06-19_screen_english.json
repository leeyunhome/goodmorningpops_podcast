    {
      "start": 653.3,
      "end": 655.02,
      "text": "as if it were the last"
    },
    {
      "start": 655.02,
      "end": 655.96,
      "text": "그 다음에"
    },
    {
      "start": 655.96,
      "end": 655.98,
      "text": "그 다음에"
    },
    {
      "start": 655.98,
      "end": 658.08,
      "text": "사랑을 담아서"
    },
    {
      "start": 658.08,
      "end": 659.46,
      "text": "squeeze the love"
