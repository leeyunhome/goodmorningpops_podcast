    {
      "start": 704.6,
      "end": 706.15,
      "text": "Missing him?"
    },
    {
      "start": 706.59,
      "end": 707.59,
      "text": "What was he like?"
    },
    {
      "start": 708.03,
      "end": 709.27,
      "text": "그러니까 니키가"
    },
    {
      "start": 709.27,
      "end": 711.49,
      "text": "그리우세요, 할아버지가?"
