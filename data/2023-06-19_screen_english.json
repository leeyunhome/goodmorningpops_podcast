    {
      "start": 727.69,
      "end": 728.49,
      "text": "That's adorable"
    },
    {
      "start": 728.49,
      "end": 729.61,
      "text": "But she's a widow"
    },
    {
      "start": 729.61,
      "end": 730.61,
      "text": "He passed away"
    },
    {
      "start": 730.61,
      "end": 733.29,
      "text": "But she's still in total love with him"
    },
    {
      "start": 733.29,
      "end": 735.11,
      "text": "And she's bragging about him"
    },
    {
      "start": 735.11,
      "end": 736.63,
      "text": "Being a ladies man"
    },
    {
      "start": 736.63,
      "end": 738.43,
      "text": "My wife would not brag about that"
    },
    {
      "start": 738.43,
      "end": 741.77,
      "text": "자, 프랑카 할머니가 뭐라고"
    },
    {
      "start": 741.77,
      "end": 744.19,
      "text": "돌아가신 할아버지에 대해서 설명을 했냐면"
