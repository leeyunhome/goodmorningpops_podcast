      "text": "그럼요"
    },
    {
      "start": 573.56,
      "end": 573.8,
      "text": "보통?"
    },
    {
      "start": 574.14,
      "end": 574.78,
      "text": "그럼요"
    },
    {
      "start": 574.78,
      "end": 576.78,
