{
  "id": "2024-05-28_screen_english",
  "date": "2024-05-28",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "더 파더 (The Father)",
  "duration_sec": 998.59,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2024-05-28_screen_english.mp3",
  "script": [
    {
      "start": 0.0,
      "end": 12.79,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 12.79,
      "end": 26.13,
      "text": "I live my life day by day and that's how I continue to live it."
    },
    {
      "start": 26.65,
      "end": 30.65,
      "text": "하루하루 살아가는 게 내가 인생을 지속해 나가는 방법이다."
    },
    {
      "start": 31.35,
      "end": 33.23,
      "text": "모델 나오미 캠벨이 한 말입니다."
    },
    {
      "start": 33.95,
      "end": 37.57,
      "text": "Live day by day, 지나버린 과거에 얽매이지 않고"
    },
    {
      "start": 37.57,
      "end": 40.73,
      "text": "아직 오지 않은 미래를 너무 걱정하지 않고"
    },
    {
      "start": 40.73,
      "end": 44.15,
      "text": "주어진 하루하루를 충실히 살아간다는 뜻이죠."
    },
    {
      "start": 44.15,
      "end": 47.63,
      "text": "근데 이게 생각보다 쉽지는 않은데요."
    },
    {
      "start": 47.63,
      "end": 51.51,
      "text": "방법은 바로 don't think about what ifs."
    },
    {
      "start": 51.99,
      "end": 55.39,
      "text": "만일 내가 그때 다른 선택을 했다면 어땠을까?"
    },
    {
      "start": 56.07,
      "end": 58.43,
      "text": "나중에 안 좋은 일이라도 생기면 어쩌지?"
    },
    {
      "start": 59.03,
      "end": 61.67,
      "text": "머릿속에서 이런 쓸데없는 생각만 지워버려도"
    },
    {
      "start": 61.67,
      "end": 64.69,
      "text": "오늘 하루에 온전히 집중할 수 있다는 겁니다."
    },
    {
      "start": 65.51,
      "end": 68.61,
      "text": "영어 공부를 계속해 나가는 방법도 비슷하지 않을까요?"
    },
    {
      "start": 68.61,
      "end": 73.45,
      "text": "I live my life day by day and that's how I'll continue to live it."
    },
    {
      "start": 80.15,
      "end": 81.43,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 81.43,
      "end": 84.61,
      "text": "첫 곡은 Robbie Williams의 Mr. Bojangles"
    },
    {
      "start": 84.61,
      "end": 89.65,
      "text": "화요일 아침 첫 곡으로 Robbie Williams의 Mr. Bojangles 듣고 왔습니다."
    },
    {
      "start": 91.19,
      "end": 91.79,
      "text": "8583님"
    },
    {
      "start": 91.79,
      "end": 93.31,
      "text": "안녕하세요 정현쌤"
    },
    {
      "start": 93.31,
      "end": 97.17,
      "text": "직장을 옮기고 나서 새벽부터 출근을 하고 있어요."
    },
    {
      "start": 97.79,
      "end": 99.63,
      "text": "새벽 출근이라 많이 피곤했는데"
    },
    {
      "start": 99.63,
      "end": 101.81,
      "text": "우연히 듣게 된 굿모닝 팝스"
    },
    {
      "start": 101.81,
      "end": 104.85,
      "text": "통통 튀는 샘의 목소리가 졸음을 깨워주더라고요."
    },
    {
      "start": 105.63,
      "end": 106.77,
      "text": "오랜만에 다시 듣는데"
    },
    {
      "start": 106.77,
      "end": 110.43,
      "text": "그동안 제가 영어를 너무 손 놓고 있었다는 걸 느꼈어요."
    },
    {
      "start": 110.93,
      "end": 114.97,
      "text": "매일 아침 출근하며 신나는 영어, 재미있는 영어 들려주셔서 감사합니다."
    },
    {
      "start": 115.81,
      "end": 117.09,
      "text": "오늘도 굿모닝입니다."
    },
    {
      "start": 118.81,
      "end": 120.87,
      "text": "활기찬 에너지가 느껴집니다."
    },
    {
      "start": 120.87,
      "end": 122.97,
      "text": "우리 8583님"
    },
    {
      "start": 122.97,
      "end": 125.89,
      "text": "제가 졸음을 깨워드리는데"
    },
    {
      "start": 125.89,
      "end": 128.71,
      "text": "이렇게 조금이나마 도움이 되어드리는 것 같아서"
    },
    {
      "start": 128.71,
      "end": 130.09,
      "text": "저도 너무 기뻐요."
    },
    {
      "start": 130.09,
      "end": 132.21,
      "text": "그리고 화요일에는"
    },
    {
      "start": 132.21,
      "end": 136.89,
      "text": "좀 더 화목하게 보내시기를 바라는 마음을 담아봅니다."
    },
    {
      "start": 137.71,
      "end": 139.83,
      "text": "오늘 더욱더 신나고 행복한 일"
    },
    {
      "start": 139.83,
      "end": 141.23,
      "text": "많으시길 바랄게요."
    },
    {
      "start": 142.09,
      "end": 143.17,
      "text": "8583님께"
    },
    {
      "start": 143.17,
      "end": 145.43,
      "text": "아메리카노 모바일 쿠폰 보내드릴게요."
    },
    {
      "start": 145.43,
      "end": 149.17,
      "text": "GMP를 위한 에너지 팡팡 터지는 이벤트"
    },
    {
      "start": 149.17,
      "end": 150.85,
      "text": "GMP로 영어 실력 업!"
    },
    {
      "start": 151.13,
      "end": 152.07,
      "text": "에너지도 업!"
    },
    {
      "start": 152.63,
      "end": 155.55,
      "text": "오늘은 달콤한 아이스 초코 한 잔 어떠세요?"
    },
    {
      "start": 156.05,
      "end": 158.95,
      "text": "메시지 보내주신 분들 중에 총 5분 뽑아서"
    },
    {
      "start": 158.95,
      "end": 161.83,
      "text": "아이스 초코 모바일 쿠폰 선물로 보내드릴게요."
    },
    {
      "start": 162.49,
      "end": 166.37,
      "text": "다문 50원과 장문 100원에 추가 요금이 부과되는 문자 샵 8910"
    },
    {
      "start": 166.37,
      "end": 168.17,
      "text": "아니면 샵 1061"
    },
    {
      "start": 168.17,
      "end": 171.77,
      "text": "혹은 무료인 콩 또는 KBS 플러스로 참여해주세요."
    },
    {
      "start": 171.77,
      "end": 197.47,
      "text": "임여섯시 조정현의 굿모닝파"
    },
    {
      "start": 197.47,
      "end": 212.83,
      "text": "English"
    },
    {
      "start": 212.83,
      "end": 232.15,
      "text": "음악 감상과 영어 공부를 동시에"
    },
    {
      "start": 232.15,
      "end": 234.21,
      "text": "killing many birds with one stone"
    },
    {
      "start": 234.21,
      "end": 235.77,
      "text": "screen english time"
    },
    {
      "start": 235.77,
      "end": 238.79,
      "text": "5월 영화는 앤터니 헉킨스 쥐안의"
    },
    {
      "start": 238.79,
      "end": 239.87,
      "text": "The Father"
    },
    {
      "start": 239.87,
      "end": 243.09,
      "text": "와우 이미 심장하게 외쳐주셨습니다."
    },
    {
      "start": 243.49,
      "end": 245.01,
      "text": "Yeah, I think of Darth Vader."
    },
    {
      "start": 245.01,
      "end": 249.45,
      "text": "아, 멋진 Darth Vader 연기를 하신 거죠?"
    },
    {
      "start": 250.05,
      "end": 251.67,
      "text": "네, Darth Vader 멋지지 않고요."
    },
    {
      "start": 251.79,
      "end": 252.95,
      "text": "연기는 멋졌으면"
    },
    {
      "start": 252.95,
      "end": 253.51,
      "text": "아, 목소리만"
    },
    {
      "start": 253.51,
      "end": 254.09,
      "text": "멋졌네요."
    },
    {
      "start": 254.75,
      "end": 255.51,
      "text": "I'm your father."
    },
    {
      "start": 255.69,
      "end": 256.35,
      "text": "오, 네."
    },
    {
      "start": 256.69,
      "end": 259.11,
      "text": "The Father 제목과 함께 우리 크스에 모셨어요."
    },
    {
      "start": 259.65,
      "end": 263.33,
      "text": "양지영 님께서 정연쌤, 크리스쌤 오늘도 반갑습니다."
    },
    {
      "start": 263.91,
      "end": 266.19,
      "text": "알람 소리 못 듣고 늦잠 잘 뻔했는데"
    },
    {
      "start": 266.19,
      "end": 268.59,
      "text": "이 시간 되니 번쩍 눈이 떠지네요."
    },
    {
      "start": 268.99,
      "end": 269.43,
      "text": "오늘도 화이팅!"
    },
    {
      "start": 270.39,
      "end": 270.93,
      "text": "와우!"
    },
    {
      "start": 270.99,
      "end": 271.75,
      "text": "니우니우니우니!"
    },
    {
      "start": 271.75,
      "end": 274.37,
      "text": "아, 오늘은 화요일이니까 화요팅?"
    },
    {
      "start": 274.87,
      "end": 276.65,
      "text": "이렇게 신조어도 한번 만들어보고"
    },
    {
      "start": 276.65,
      "end": 278.43,
      "text": "지요팅, 뭐 목요팅"
    },
    {
      "start": 278.43,
      "end": 279.69,
      "text": "다 있겠네요."
    },
    {
      "start": 279.79,
      "end": 280.29,
      "text": "그럼요."
    },
    {
      "start": 280.35,
      "end": 280.75,
      "text": "고고!"
    },
    {
      "start": 280.75,
      "end": 282.35,
      "text": "내일에 우리가 힘을 내야 되겠습니다."
    },
    {
      "start": 282.67,
      "end": 283.67,
      "text": "Monday through Friday"
    },
    {
      "start": 283.67,
      "end": 285.07,
      "text": "We can do it!"
    },
    {
      "start": 285.77,
      "end": 289.17,
      "text": "우리가 개운하게 화요일도 본격적으로 시작을 할 시간인데요."
    },
    {
      "start": 289.77,
      "end": 296.89,
      "text": "이 영화가 플로리안 젤러 이 감독분의 그 극본 플레이로부터 시작이 된 영화잖아요."
    },
    {
      "start": 296.89,
      "end": 302.51,
      "text": "근데 게다가 아카데미 각색상을 받았다라는 이야기도 우리가 이미 했습니다."
    },
    {
      "start": 302.95,
      "end": 304.97,
      "text": "Yeah, best adapted screenplay."
    },
    {
      "start": 305.09,
      "end": 307.27,
      "text": "It won the Academy Award."
    },
    {
      "start": 307.79,
      "end": 308.19,
      "text": "그래요."
    },
    {
      "start": 308.31,
      "end": 311.57,
      "text": "이렇게 연극이 영화로 만들어지는 경우는 종종 있잖아요."
    },
    {
      "start": 312.15,
      "end": 315.17,
      "text": "그런데 이게 좀 드문 경우로"
    },
    {
      "start": 315.17,
      "end": 317.01,
      "text": "To get an Academy Award?"
    },
    {
      "start": 317.51,
      "end": 318.57,
      "text": "이거는 쉽지 않죠?"
    },
    {
      "start": 318.57,
      "end": 320.29,
      "text": "쉽지 않겠죠."
    },
    {
      "start": 320.71,
      "end": 326.25,
      "text": "Because original, 원래 원작이 훨씬 보통 좋은 경우가 많아요."
    },
    {
      "start": 326.35,
      "end": 326.91,
      "text": "영화보다."
    },
    {
      "start": 327.17,
      "end": 329.61,
      "text": "Like the book is always better than the movie."
    },
    {
      "start": 329.73,
      "end": 330.23,
      "text": "Makes sense."
    },
    {
      "start": 330.33,
      "end": 332.41,
      "text": "The play is always better than the movie."
    },
    {
      "start": 332.53,
      "end": 333.43,
      "text": "The musical."
    },
    {
      "start": 334.45,
      "end": 337.25,
      "text": "But Mama Mia, I think Mama Mia the movie was good."
    },
    {
      "start": 337.57,
      "end": 338.67,
      "text": "You know, but usually."
    },
    {
      "start": 339.03,
      "end": 341.31,
      "text": "But in this case, it's very rare."
    },
    {
      "start": 341.49,
      "end": 341.67,
      "text": "Yeah."
    },
    {
      "start": 341.99,
      "end": 343.41,
      "text": "A best adapted screenplay."
    },
    {
      "start": 343.41,
      "end": 347.25,
      "text": "So the last film to win best adapted screenplay"
    },
    {
      "start": 347.25,
      "end": 349.17,
      "text": "That was also a play"
    },
    {
      "start": 349.17,
      "end": 351.47,
      "text": "Was Driving Miss Daisy."
    },
    {
      "start": 351.79,
      "end": 353.75,
      "text": "Have you heard of Driving Miss Daisy?"
    },
    {
      "start": 354.19,
      "end": 356.65,
      "text": "이게 제가 지금 좀 찾아봤더니"
    },
    {
      "start": 356.65,
      "end": 359.41,
      "text": "되게 흥미로운 영화 같다 보여요."
    },
    {
      "start": 360.27,
      "end": 360.63,
      "text": "아, yes."
    },
    {
      "start": 360.69,
      "end": 361.35,
      "text": "아주 흥미로워요."
    },
    {
      "start": 361.61,
      "end": 362.37,
      "text": "1989"
    },
    {
      "start": 362.37,
      "end": 364.65,
      "text": "It was based on a play"
    },
    {
      "start": 364.65,
      "end": 366.07,
      "text": "Of the same name"
    },
    {
      "start": 366.07,
      "end": 367.27,
      "text": "1987"
    },
    {
      "start": 367.27,
      "end": 369.19,
      "text": "나랑 친구 동간네지"
    },
    {
      "start": 369.19,
      "end": 370.21,
      "text": "It was a play"
    },
    {
      "start": 370.21,
      "end": 372.21,
      "text": "Starring the legendary"
    },
    {
      "start": 372.21,
      "end": 373.59,
      "text": "Morgan Freeman"
    },
    {
      "start": 373.59,
      "end": 374.37,
      "text": "그러니까요."
    },
    {
      "start": 374.41,
      "end": 375.83,
      "text": "제가 그 정보를 찾았잖아요."
    },
    {
      "start": 376.07,
      "end": 377.03,
      "text": "He was the driver"
    },
    {
      "start": 377.03,
      "end": 380.11,
      "text": "And he drove around this southern lady"
    },
    {
      "start": 380.11,
      "end": 381.27,
      "text": "Jewish lady"
    },
    {
      "start": 381.27,
      "end": 384.13,
      "text": "Who's kind of funny, complicated"
    },
    {
      "start": 384.13,
      "end": 386.51,
      "text": "And their chemistry"
    },
    {
      "start": 386.51,
      "end": 388.63,
      "text": "Makes the movie entertaining"
    },
    {
      "start": 388.63,
      "end": 393.81,
      "text": "사실 그 당시에 시대적인 반영을 많이 했겠죠."
    },
    {
      "start": 394.03,
      "end": 396.11,
      "text": "훨씬 이전에, 고전시대에"
    },
    {
      "start": 396.11,
      "end": 398.97,
      "text": "So reflected the era of racism"
    },
    {
      "start": 398.97,
      "end": 400.05,
      "text": "In the south."
    },
    {
      "start": 400.45,
      "end": 402.37,
      "text": "Racism was very prevalent"
    },
    {
      "start": 402.37,
      "end": 404.91,
      "text": "In the south, especially back then."
    },
    {
      "start": 405.53,
      "end": 409.89,
      "text": "And they made this into a kind of comedy slash drama."
    },
    {
      "start": 410.41,
      "end": 412.07,
      "text": "It won Best Picture, too."
    },
    {
      "start": 412.19,
      "end": 413.73,
      "text": "It won a lot of Academy Awards."
    },
    {
      "start": 414.05,
      "end": 415.17,
      "text": "It's a great movie"
    },
    {
      "start": 415.17,
      "end": 417.61,
      "text": "And I heard it was released in Korea, too."
    },
    {
      "start": 417.89,
      "end": 420.11,
      "text": "Way back, before Jo Sam was born."
    },
    {
      "start": 420.59,
      "end": 421.41,
      "text": "한참 전에"
    },
    {
      "start": 421.41,
      "end": 423.09,
      "text": "거의 호랑이 시절에"
    },
    {
      "start": 423.09,
      "end": 423.59,
      "text": "어머나"
    },
    {
      "start": 423.59,
      "end": 424.63,
      "text": "담배 피우는 시절에"
    },
    {
      "start": 424.63,
      "end": 425.97,
      "text": "아, 노코멘트 하겠습니다."
    },
    {
      "start": 427.19,
      "end": 429.01,
      "text": "이렇게 연극을 배경으로 해서"
    },
    {
      "start": 429.01,
      "end": 430.83,
      "text": "영화로도 아주 성공적으로"
    },
    {
      "start": 430.83,
      "end": 433.29,
      "text": "자리매김한 경우에 대해서 알아봤네요."
    },
    {
      "start": 433.93,
      "end": 435.73,
      "text": "그러면 기분 좋게 오늘 장면도"
    },
    {
      "start": 435.73,
      "end": 436.87,
      "text": "한번 기대를 해보겠습니다."
    },
    {
      "start": 438.56,
      "end": 439.54,
      "text": "It's very nice."
    },
    {
      "start": 440.93,
      "end": 442.95,
      "text": "It's a bit like being in a hotel, don't you think?"
    },
    {
      "start": 443.69,
      "end": 444.71,
      "text": "All the residents say so."
    },
    {
      "start": 444.71,
      "end": 450.84,
      "text": "I think you'd be better off here."
    },
    {
      "start": 451.93,
      "end": 452.25,
      "text": "Where?"
    },
    {
      "start": 453.05,
      "end": 453.41,
      "text": "Here."
    },
    {
      "start": 454.89,
      "end": 457.79,
      "text": "I think it'd be more reassuring and nicer for you"
    },
    {
      "start": 457.79,
      "end": 461.35,
      "text": "if we came to a joint decision about you living here."
    },
    {
      "start": 462.15,
      "end": 462.73,
      "text": "What do you think?"
    },
    {
      "start": 463.57,
      "end": 464.43,
      "text": "What about you?"
    },
    {
      "start": 465.43,
      "end": 466.19,
      "text": "What would you do?"
    },
    {
      "start": 466.77,
      "end": 468.61,
      "text": "And where would you sleep?"
    },
    {
      "start": 468.89,
      "end": 469.53,
      "text": "Which room?"
    },
    {
      "start": 471.69,
      "end": 473.65,
      "text": "기분이 좋은 내용은 아니었어요."
    },
    {
      "start": 474.01,
      "end": 474.39,
      "text": "Yeah."
    },
    {
      "start": 474.89,
      "end": 475.89,
      "text": "So 기분 좋지 않죠."
    },
    {
      "start": 475.89,
      "end": 478.53,
      "text": "그리고 it wasn't a hotel."
    },
    {
      "start": 478.97,
      "end": 479.23,
      "text": "No."
    },
    {
      "start": 480.15,
      "end": 482.27,
      "text": "It reminds me of where my grandma's staying."
    },
    {
      "start": 482.63,
      "end": 484.01,
      "text": "It looks like a hotel."
    },
    {
      "start": 484.35,
      "end": 485.07,
      "text": "It's very luxurious."
    },
    {
      "start": 485.43,
      "end": 486.77,
      "text": "But it's not a hotel."
    },
    {
      "start": 487.53,
      "end": 488.71,
      "text": "And she is disappointed."
    },
    {
      "start": 489.03,
      "end": 489.29,
      "text": "그렇죠."
    },
    {
      "start": 489.59,
      "end": 492.99,
      "text": "이게 요양병원의 한 입원실이었던 걸로"
    },
    {
      "start": 492.99,
      "end": 494.77,
      "text": "제 장면을 기억을 하는데요."
    },
    {
      "start": 494.87,
      "end": 495.07,
      "text": "Yeah."
    },
    {
      "start": 495.07,
      "end": 495.69,
      "text": "He's not happy."
    },
    {
      "start": 495.69,
      "end": 499.99,
      "text": "그리고 이렇게 이동을 할 수밖에 없었던 상황이긴 했어요."
    },
    {
      "start": 499.99,
      "end": 502.89,
      "text": "It's because it's getting worse and worse."
    },
    {
      "start": 503.29,
      "end": 503.55,
      "text": "Yeah."
    },
    {
      "start": 503.73,
      "end": 504.61,
      "text": "Day by day."
    },
    {
      "start": 504.71,
      "end": 508.91,
      "text": "His memory and condition is just going downhill."
    },
    {
      "start": 509.11,
      "end": 509.45,
      "text": "맞아요."
    },
    {
      "start": 509.63,
      "end": 510.53,
      "text": "Way steep downhill."
    },
    {
      "start": 511.03,
      "end": 514.85,
      "text": "자, 들으신 표현들 중에서 어떤 거 미리 알아볼까요?"
    },
    {
      "start": 515.71,
      "end": 517.73,
      "text": "All the residents say so."
    },
    {
      "start": 517.95,
      "end": 520.09,
      "text": "All the residents say so."
    },
    {
      "start": 520.47,
      "end": 526.05,
      "text": "여기서의 residents라는 것은 요양시설에 입소해 있는 입소자분들을 이야기하는 거죠."
    },
    {
      "start": 526.27,
      "end": 526.73,
      "text": "그렇죠."
    },
    {
      "start": 527.11,
      "end": 528.95,
      "text": "주민들도 그런 뜻으로"
    },
    {
      "start": 528.95,
      "end": 532.41,
      "text": "All the apartment residents got together for a meeting."
    },
    {
      "start": 532.41,
      "end": 533.73,
      "text": "And they were complaining."
    },
    {
      "start": 534.73,
      "end": 536.73,
      "text": "아, 그런 경우가 좀 많긴 해요."
    },
    {
      "start": 536.93,
      "end": 537.43,
      "text": "가끔이에요."
    },
    {
      "start": 537.47,
      "end": 537.63,
      "text": "네."
    },
    {
      "start": 537.73,
      "end": 541.39,
      "text": "주민분들이 모이면 고성이 오고 가는 경우가 되게 많더라고요."
    },
    {
      "start": 541.65,
      "end": 542.83,
      "text": "아, 반성회."
    },
    {
      "start": 542.97,
      "end": 543.45,
      "text": "뭐라고 하죠?"
    },
    {
      "start": 543.65,
      "end": 544.15,
      "text": "반성회."
    },
    {
      "start": 544.15,
      "end": 547.79,
      "text": "아, 반성회도 있고 동회의도 있고 그렇습니다."
    },
    {
      "start": 547.83,
      "end": 550.51,
      "text": "저는 최근에 참석하지 못한 걸 죄송합니다."
    },
    {
      "start": 550.51,
      "end": 552.27,
      "text": "그럼 평소에는 자주 참석하세요?"
    },
    {
      "start": 552.51,
      "end": 553.03,
      "text": "No, no."
    },
    {
      "start": 554.25,
      "end": 555.11,
      "text": "No way."
    },
    {
      "start": 555.31,
      "end": 557.77,
      "text": "아, 왠지 크쌤이 등장하면 유쾌할 것 같아가지고."
    },
    {
      "start": 557.95,
      "end": 560.87,
      "text": "아, 초대 뭐 하자면 제가 갑니다. 무조건 끼니까."
    },
    {
      "start": 561.01,
      "end": 561.33,
      "text": "아, 그래요?"
    },
    {
      "start": 561.33,
      "end": 564.41,
      "text": "본인이 살지 않는 아파트에도 초대를 하면 가시나요?"
    },
    {
      "start": 564.83,
      "end": 569.03,
      "text": "뭐, 가끔 이렇게 간식이나 약과 같은 거 나오면."
    },
    {
      "start": 569.11,
      "end": 569.83,
      "text": "약과."
    },
    {
      "start": 570.51,
      "end": 571.15,
      "text": "참고하겠습니다."
    },
    {
      "start": 571.45,
      "end": 572.05,
      "text": "생각할 수 있죠."
    },
    {
      "start": 572.21,
      "end": 572.33,
      "text": "네."
    },
    {
      "start": 572.81,
      "end": 574.33,
      "text": "자, 그러면 첫 번째 표현으로"
    },
    {
      "start": 574.33,
      "end": 576.39,
      "text": "All the residents say so."
    },
    {
      "start": 576.53,
      "end": 576.89,
      "text": "Say so."
    },
    {
      "start": 577.01,
      "end": 577.15,
      "text": "네."
    },
    {
      "start": 577.35,
      "end": 578.31,
      "text": "Say so. 말해서는 말이죠."
    },
    {
      "start": 578.31,
      "end": 579.75,
      "text": "그렇게 말한다."
    },
    {
      "start": 580.15,
      "end": 580.61,
      "text": "라는 뜻이죠."
    },
    {
      "start": 580.97,
      "end": 581.65,
      "text": "They all say so."
    },
    {
      "start": 581.83,
      "end": 582.75,
      "text": "그렇게 말한다."
    },
    {
      "start": 583.11,
      "end": 583.81,
      "text": "그냥 여러 사람이."
    },
    {
      "start": 584.29,
      "end": 585.55,
      "text": "2, 9, same 소리."
    },
    {
      "start": 586.45,
      "end": 587.17,
      "text": "이구동성으로."
    },
    {
      "start": 587.29,
      "end": 588.33,
      "text": "They all say so."
    },
    {
      "start": 588.33,
      "end": 592.39,
      "text": "그러면 모든 주민분들이, 모든 입소자분들이 그렇게 말하세요."
    },
    {
      "start": 592.83,
      "end": 594.17,
      "text": "They all say so."
    },
    {
      "start": 595.5,
      "end": 597.64,
      "text": "You'd be better off here."
    },
    {
      "start": 598.02,
      "end": 601.6,
      "text": "여기에 계시는 게 낫겠네요. 라는 문장이네요."
    },
    {
      "start": 602.02,
      "end": 602.38,
      "text": "맞아요."
    },
    {
      "start": 602.82,
      "end": 605.92,
      "text": "You'd be better off going to lunch with me."
    },
    {
      "start": 606.12,
      "end": 607.18,
      "text": "Not him."
    },
    {
      "start": 607.44,
      "end": 608.1,
      "text": "Come with me."
    },
    {
      "start": 608.1,
      "end": 613.16,
      "text": "그런데 여기서 off라는 것은 굳이 해석을 할 필요가 전혀 없는 거죠?"
    },
    {
      "start": 613.3,
      "end": 613.68,
      "text": "없어요."
    },
    {
      "start": 614.14,
      "end": 615.46,
      "text": "그냥 그 표현이 있다."
    },
    {
      "start": 616.1,
      "end": 616.66,
      "text": "외우세요."
    },
    {
      "start": 617.1,
      "end": 617.7,
      "text": "구수어네요."
    },
    {
      "start": 617.94,
      "end": 618.06,
      "text": "네."
    },
    {
      "start": 618.3,
      "end": 619.58,
      "text": "그냥 외우세요."
    },
    {
      "start": 619.68,
      "end": 621.1,
      "text": "1,000번 반복하시면 외웁니다."
    },
    {
      "start": 621.82,
      "end": 622.94,
      "text": "단 조건이 붙습니다."
    },
    {
      "start": 623.12,
      "end": 623.64,
      "text": "1,000번."
    },
    {
      "start": 624.26,
      "end": 624.94,
      "text": "알겠어요."
    },
    {
      "start": 625.06,
      "end": 627.36,
      "text": "사람마다 다르겠지만 그냥 외워야 돼요."
    },
    {
      "start": 627.4,
      "end": 627.82,
      "text": "알겠습니다."
    },
    {
      "start": 627.88,
      "end": 628.74,
      "text": "You'd be better off."
    },
    {
      "start": 628.88,
      "end": 629.7,
      "text": "많이 있으니까."
    },
    {
      "start": 629.86,
      "end": 630.84,
      "text": "여기 있는 게 낫겠다."
    },
    {
      "start": 631.3,
      "end": 632.6,
      "text": "A very, very useful."
    },
    {
      "start": 632.6,
      "end": 636.52,
      "text": "It would be more reassuring."
    },
    {
      "start": 637.76,
      "end": 640.16,
      "text": "Reassuring이라는 표현임에 마지막에 틀렸어요."
    },
    {
      "start": 640.34,
      "end": 643.6,
      "text": "그러니까 안심이 되는 이라는 의미이므로"
    },
    {
      "start": 643.6,
      "end": 645.68,
      "text": "It would be more reassuring."
    },
    {
      "start": 645.8,
      "end": 648.84,
      "text": "그게 더 안심이 될 거다라고 해석하면 되겠네요."
    },
    {
      "start": 648.98,
      "end": 649.16,
      "text": "Yeah."
    },
    {
      "start": 649.24,
      "end": 652.3,
      "text": "If they could agree on moving to this nursing home,"
    },
    {
      "start": 652.46,
      "end": 656.3,
      "text": "it would be so much more reassuring from the daughter's perspective."
    },
    {
      "start": 656.54,
      "end": 657.14,
      "text": "그러네요."
    },
    {
      "start": 657.32,
      "end": 659.4,
      "text": "Because she wants her dad to be happy."
    },
    {
      "start": 659.4,
      "end": 662.96,
      "text": "She doesn't want to force him to live in a nursing home."
    },
    {
      "start": 663.98,
      "end": 665.74,
      "text": "그러면 내용 다시 한번 들어볼게요."
    },
    {
      "start": 666.43,
      "end": 667.71,
      "text": "It's very nice."
    },
    {
      "start": 669.1,
      "end": 671.12,
      "text": "It's a bit like being in a hotel, don't you think?"
    },
    {
      "start": 671.84,
      "end": 672.88,
      "text": "All the residents say so."
    },
    {
      "start": 674.93,
      "end": 678.99,
      "text": "I think you'd be better off here."
    },
    {
      "start": 680.11,
      "end": 680.41,
      "text": "Where?"
    },
    {
      "start": 681.21,
      "end": 681.55,
      "text": "Here."
    },
    {
      "start": 683.01,
      "end": 685.95,
      "text": "I think it'd be more reassuring and nicer for you"
    },
    {
      "start": 685.95,
      "end": 689.53,
      "text": "if we came to a joint decision about you living here."
    },
    {
      "start": 690.31,
      "end": 690.89,
      "text": "What do you think?"
    },
    {
      "start": 690.89,
      "end": 692.57,
      "text": "What about you?"
    },
    {
      "start": 693.63,
      "end": 694.37,
      "text": "What would you do?"
    },
    {
      "start": 695.65,
      "end": 696.79,
      "text": "Where would you sleep?"
    },
    {
      "start": 697.07,
      "end": 697.69,
      "text": "Which room?"
    },
    {
      "start": 699.26,
      "end": 700.88,
      "text": "중간중간에 here."
    },
    {
      "start": 701.44,
      "end": 701.88,
      "text": "What?"
    },
    {
      "start": 702.12,
      "end": 702.44,
      "text": "Where."
    },
    {
      "start": 703.44,
      "end": 704.42,
      "text": "Where, here?"
    },
    {
      "start": 705.24,
      "end": 705.82,
      "text": "Here."
    },
    {
      "start": 706.12,
      "end": 706.3,
      "text": "네."
    },
    {
      "start": 706.66,
      "end": 707.04,
      "text": "Here."
    },
    {
      "start": 707.12,
      "end": 709.64,
      "text": "아주 인상적인 발음도 들어봤습니다."
    },
    {
      "start": 709.66,
      "end": 710.96,
      "text": "바람 소리 한 90%예요."
    },
    {
      "start": 711.08,
      "end": 711.36,
      "text": "네."
    },
    {
      "start": 711.72,
      "end": 712.04,
      "text": "Here."
    },
    {
      "start": 712.32,
      "end": 712.58,
      "text": "Here."
    },
    {
      "start": 712.86,
      "end": 713.18,
      "text": "Here."
    },
    {
      "start": 713.46,
      "end": 714.32,
      "text": "아, care."
    },
    {
      "start": 714.32,
      "end": 714.62,
      "text": "라."
    },
    {
      "start": 716.2,
      "end": 717.7,
      "text": "복습도 한번 해보고요."
    },
    {
      "start": 717.84,
      "end": 718.1,
      "text": "네."
    },
    {
      "start": 718.42,
      "end": 720.3,
      "text": "자, 앤이 먼저 이야기를 시작하죠."
    },
    {
      "start": 720.3,
      "end": 721.8,
      "text": "It's very nice."
    },
    {
      "start": 721.8,
      "end": 723.42,
      "text": "아, 여기 아주 좋네요."
    },
    {
      "start": 724.02,
      "end": 727.16,
      "text": "It's a bit like being in a hotel, don't you think?"
    },
    {
      "start": 727.34,
      "end": 730.5,
      "text": "여기 약간 호텔방에 있는 것 같기도 하고요."
    },
    {
      "start": 730.62,
      "end": 731.12,
      "text": "Don't you think?"
    },
    {
      "start": 731.44,
      "end": 731.86,
      "text": "안 그래요?"
    },
    {
      "start": 733.08,
      "end": 734.82,
      "text": "All the residents say so."
    },
    {
      "start": 734.96,
      "end": 738.58,
      "text": "음, 그랬더니 이 방에 또 다른 여성분이 대답을 했습니다."
    },
    {
      "start": 739.14,
      "end": 740.8,
      "text": "All the residents say so."
    },
    {
      "start": 741.16,
      "end": 745.12,
      "text": "모든 주민분들, 모든 입소자분들이 다 그렇게 이야기하세요."
    },
    {
      "start": 745.12,
      "end": 746.34,
      "text": "아, 설득 작업이네요."
    },
    {
      "start": 746.4,
      "end": 746.58,
      "text": "네."
    },
    {
      "start": 746.74,
      "end": 748.2,
      "text": "They're trying to convince him."
    },
    {
      "start": 748.24,
      "end": 749.48,
      "text": "다들 그렇게 이야기하세요."
    },
    {
      "start": 749.76,
      "end": 750.74,
      "text": "Come on, move in."
    },
    {
      "start": 750.8,
      "end": 751.88,
      "text": "It's beautiful."
    },
    {
      "start": 751.96,
      "end": 752.66,
      "text": "호텔 같죠?"
    },
    {
      "start": 752.84,
      "end": 753.58,
      "text": "Five-star hotel."
    },
    {
      "start": 753.82,
      "end": 754.0,
      "text": "네."
    },
    {
      "start": 755.42,
      "end": 758.84,
      "text": "Um, I think you'd be better off here."
    },
    {
      "start": 758.94,
      "end": 761.44,
      "text": "아, 천번 연습해야 되는 문장이 한 번 더 들렸습니다."
    },
    {
      "start": 762.02,
      "end": 762.44,
      "text": "어려워요."
    },
    {
      "start": 762.44,
      "end": 766.16,
      "text": "음, I think you'd be better off here."
    },
    {
      "start": 766.66,
      "end": 770.02,
      "text": "여기에서 지내시는 게 훨씬 좋을 것 같아요."
    },
    {
      "start": 770.94,
      "end": 771.44,
      "text": "Where?"
    },
    {
      "start": 771.68,
      "end": 772.7,
      "text": "그랬더니, where?"
    },
    {
      "start": 773.24,
      "end": 773.84,
      "text": "어디?"
    },
    {
      "start": 774.32,
      "end": 774.86,
      "text": "Where."
    },
    {
      "start": 775.0,
      "end": 776.22,
      "text": "영국 그 발음."
    },
    {
      "start": 776.28,
      "end": 776.44,
      "text": "그렇죠."
    },
    {
      "start": 776.56,
      "end": 777.24,
      "text": "읽지 않았군요."
    },
    {
      "start": 777.28,
      "end": 777.44,
      "text": "네."
    },
    {
      "start": 777.6,
      "end": 777.92,
      "text": "Where?"
    },
    {
      "start": 777.92,
      "end": 780.17,
      "text": "Here."
    },
    {
      "start": 780.51,
      "end": 780.69,
      "text": "네."
    },
    {
      "start": 781.19,
      "end": 781.67,
      "text": "Here."
    },
    {
      "start": 781.91,
      "end": 782.21,
      "text": "Here."
    },
    {
      "start": 782.83,
      "end": 790.19,
      "text": "I think it would be more reassuring and nicer for you if we came to a joint decision."
    },
    {
      "start": 791.2,
      "end": 791.4,
      "text": "네."
    },
    {
      "start": 792.02,
      "end": 793.32,
      "text": "뒤에도 한 번 이야기해 주시면 안 돼요?"
    },
    {
      "start": 793.56,
      "end": 795.9,
      "text": "아, 그 완벽한 문장인데 더 길게 하네요."
    },
    {
      "start": 795.9,
      "end": 796.18,
      "text": "네."
    },
    {
      "start": 796.48,
      "end": 797.8,
      "text": "About you living here."
    },
    {
      "start": 797.86,
      "end": 800.02,
      "text": "아, 여기까지 부탁을 드려봤습니다."
    },
    {
      "start": 800.84,
      "end": 802.12,
      "text": "특히, here."
    },
    {
      "start": 802.48,
      "end": 806.76,
      "text": "이렇게 발음 연습을 하실 때마다 목을 이렇게 거북이처럼 빼시는 것 같아요."
    },
    {
      "start": 806.88,
      "end": 807.14,
      "text": "Here."
    },
    {
      "start": 807.34,
      "end": 807.5,
      "text": "네."
    },
    {
      "start": 807.5,
      "end": 808.12,
      "text": "더 잘 되죠?"
    },
    {
      "start": 808.12,
      "end": 808.44,
      "text": "네."
    },
    {
      "start": 809.1,
      "end": 809.82,
      "text": "역시, 가보기."
    },
    {
      "start": 809.98,
      "end": 810.58,
      "text": "가보기."
    },
    {
      "start": 810.78,
      "end": 811.02,
      "text": "네."
    },
    {
      "start": 811.14,
      "end": 811.66,
      "text": "좋습니다."
    },
    {
      "start": 812.3,
      "end": 813.04,
      "text": "아, 여기예요."
    },
    {
      "start": 813.38,
      "end": 815.66,
      "text": "I think he would be more reassuring."
    },
    {
      "start": 815.86,
      "end": 817.58,
      "text": "이게 더 안심이 될 것 같고."
    },
    {
      "start": 817.9,
      "end": 819.6,
      "text": "And nicer for you."
    },
    {
      "start": 819.98,
      "end": 821.74,
      "text": "아빠에게 훨씬 더 좋을 것 같아요."
    },
    {
      "start": 822.32,
      "end": 825.14,
      "text": "If we came to a joint decision."
    },
    {
      "start": 825.14,
      "end": 830.4,
      "text": "여기서 joint decision이라는 표현이 들렸는데, 공동의 결정."
    },
    {
      "start": 830.5,
      "end": 830.9,
      "text": "Oh, yes."
    },
    {
      "start": 831.28,
      "end": 835.02,
      "text": "We came to a joint decision about our kids' allowance."
    },
    {
      "start": 835.26,
      "end": 836.92,
      "text": "One dollar per year."
    },
    {
      "start": 836.92,
      "end": 837.96,
      "text": "Per year?"
    },
    {
      "start": 837.96,
      "end": 837.98,
      "text": "Per year?"
    },
    {
      "start": 838.08,
      "end": 838.48,
      "text": "Per year."
    },
    {
      "start": 838.48,
      "end": 839.22,
      "text": "One dollar?"
    },
    {
      "start": 839.22,
      "end": 841.8,
      "text": "They need to work for their money."
    },
    {
      "start": 841.82,
      "end": 842.28,
      "text": "It's too harsh."
    },
    {
      "start": 842.56,
      "end": 843.36,
      "text": "아, 너무한 거 아니에요?"
    },
    {
      "start": 843.5,
      "end": 844.98,
      "text": "돈 벌어서 핸드폰 사요."
    },
    {
      "start": 845.18,
      "end": 847.76,
      "text": "어떻게 1년에 1달러는 너무 심하셨다."
    },
    {
      "start": 847.84,
      "end": 848.62,
      "text": "Two dollars."
    },
    {
      "start": 849.62,
      "end": 850.76,
      "text": "싸달라 갈게요."
    },
    {
      "start": 850.76,
      "end": 852.5,
      "text": "네, 선심을 써주셨네요."
    },
    {
      "start": 852.5,
      "end": 870.22,
      "text": "If we came to a joint decision, 우리가 공동의 결정에 이른다면, about you living here, 이곳에서 지내시는 것에 대해서 우리가 공동의 결정을 내린다면, 그러니까 아빠와 저와 같은 생각이라면, 아빠에게 더 좋을 것 같아요, 라는 문장이었어요."
    },
    {
      "start": 870.22,
      "end": 872.15,
      "text": "What do you think?"
    },
    {
      "start": 872.31,
      "end": 873.43,
      "text": "Oh, what do you think?"
    },
    {
      "start": 873.69,
      "end": 874.55,
      "text": "어떨 것 같으세요?"
    },
    {
      "start": 875.65,
      "end": 877.65,
      "text": "Well, what about you?"
    },
    {
      "start": 877.85,
      "end": 879.97,
      "text": "그랬더니 앤포니가 하는 말이었어요."
    },
    {
      "start": 880.31,
      "end": 881.59,
      "text": "Well, what about you?"
    },
    {
      "start": 881.71,
      "end": 882.25,
      "text": "그럼 너는?"
    },
    {
      "start": 882.61,
      "end": 884.27,
      "text": "What would you do?"
    },
    {
      "start": 884.27,
      "end": 886.13,
      "text": "너는 뭐 어떻게 하려고?"
    },
    {
      "start": 886.97,
      "end": 888.21,
      "text": "Where would you sleep?"
    },
    {
      "start": 888.77,
      "end": 889.63,
      "text": "어디서 잘 건데?"
    },
    {
      "start": 889.83,
      "end": 890.63,
      "text": "Which room?"
    },
    {
      "start": 891.11,
      "end": 891.85,
      "text": "무슨 방에서?"
    },
    {
      "start": 892.17,
      "end": 892.77,
      "text": "어떤 방에서?"
    },
    {
      "start": 893.03,
      "end": 894.11,
      "text": "질문이 많네요."
    },
    {
      "start": 894.11,
      "end": 896.61,
      "text": "He's worried, really worried."
    },
    {
      "start": 896.77,
      "end": 899.85,
      "text": "혹시 자신만 두고 딸이 떠날까봐."
    },
    {
      "start": 900.89,
      "end": 901.83,
      "text": "여기 뭐 방이 있어?"
    },
    {
      "start": 902.13,
      "end": 902.91,
      "text": "어디서 잘 건데?"
    },
    {
      "start": 903.05,
      "end": 903.55,
      "text": "Oh, no."
    },
    {
      "start": 903.59,
      "end": 904.33,
      "text": "너는 어떻게 하려고?"
    },
    {
      "start": 904.53,
      "end": 905.35,
      "text": "어떻게 해?"
    },
    {
      "start": 905.43,
      "end": 907.07,
      "text": "My heart goes out to him."
    },
    {
      "start": 907.07,
      "end": 912.35,
      "text": "네, 아무튼 점점 어떻게 상황이 진행이 되는지 살펴봐야 되겠습니다."
    },
    {
      "start": 913.17,
      "end": 915.03,
      "text": "그럼 마지막으로 한 번 더 확인해 볼게요."
    },
    {
      "start": 915.95,
      "end": 916.95,
      "text": "It's very nice."
    },
    {
      "start": 918.33,
      "end": 920.35,
      "text": "It's a bit like being in a hotel, don't you think?"
    },
    {
      "start": 921.07,
      "end": 922.11,
      "text": "All the residents say so."
    },
    {
      "start": 922.11,
      "end": 928.24,
      "text": "Um, I think you'd be better off here."
    },
    {
      "start": 929.19,
      "end": 929.65,
      "text": "Where?"
    },
    {
      "start": 930.45,
      "end": 930.79,
      "text": "Here."
    },
    {
      "start": 932.27,
      "end": 938.77,
      "text": "I think it'd be more reassuring and nicer for you if we came to a joint decision about you living here."
    },
    {
      "start": 939.54,
      "end": 940.12,
      "text": "What do you think?"
    },
    {
      "start": 940.93,
      "end": 941.83,
      "text": "What about you?"
    },
    {
      "start": 942.83,
      "end": 943.61,
      "text": "What would you do?"
    },
    {
      "start": 944.19,
      "end": 946.02,
      "text": "And where would you sleep?"
    },
    {
      "start": 946.3,
      "end": 946.92,
      "text": "Which room?"
    },
    {
      "start": 946.92,
      "end": 953.99,
      "text": "아마도 이 딸의 입장에서는 must have felt uneasy and uncomfortable."
    },
    {
      "start": 954.55,
      "end": 954.83,
      "text": "Sure."
    },
    {
      "start": 955.31,
      "end": 955.87,
      "text": "Heartbroken."
    },
    {
      "start": 956.05,
      "end": 956.37,
      "text": "맞아요."
    },
    {
      "start": 956.55,
      "end": 960.59,
      "text": "Just she can't, she probably hates to see her dad like this."
    },
    {
      "start": 960.69,
      "end": 960.93,
      "text": "맞아요."
    },
    {
      "start": 961.43,
      "end": 963.93,
      "text": "점점 마음이 무거워지는 것 같은 느낌이 듭니다."
    },
    {
      "start": 964.79,
      "end": 966.47,
      "text": "안정예 님께서요."
    },
    {
      "start": 966.83,
      "end": 969.93,
      "text": "크쌤이랑 정연쌤이랑 케미가 너무 좋은 것 같아요."
    },
    {
      "start": 970.79,
      "end": 971.31,
      "text": "재미나고요."
    },
    {
      "start": 971.81,
      "end": 973.23,
      "text": "매일매일 잘 듣고 있어요."
    },
    {
      "start": 973.43,
      "end": 973.91,
      "text": "하셨습니다."
    },
    {
      "start": 973.91,
      "end": 976.35,
      "text": "Here's to Joker 케미."
    },
    {
      "start": 976.67,
      "end": 977.89,
      "text": "Here, not here."
    },
    {
      "start": 978.29,
      "end": 979.39,
      "text": "Here's to Joker 케미."
    },
    {
      "start": 979.67,
      "end": 984.11,
      "text": "네, 미쿡식으로 마무리를 하면서 마무리를 해보도록 하겠습니다."
    },
    {
      "start": 984.23,
      "end": 984.71,
      "text": "Joker 케미?"
    },
    {
      "start": 984.87,
      "end": 985.27,
      "text": "위하여!"
    },
    {
      "start": 985.43,
      "end": 985.95,
      "text": "위하여!"
    },
    {
      "start": 986.01,
      "end": 987.91,
      "text": "이거 잘할 때도 건배사."
    },
    {
      "start": 988.17,
      "end": 989.09,
      "text": "Here's to."
    },
    {
      "start": 989.31,
      "end": 991.21,
      "text": "영국으로 here's to 하나."
    },
    {
      "start": 992.35,
      "end": 992.99,
      "text": "그렇군요."
    },
    {
      "start": 993.21,
      "end": 994.01,
      "text": "잘 모르겠고요."
    },
    {
      "start": 994.19,
      "end": 995.79,
      "text": "거기 빈트 형한테 물어봐요."
    },
    {
      "start": 995.83,
      "end": 996.37,
      "text": "알겠습니다."
    },
    {
      "start": 996.77,
      "end": 997.87,
      "text": "그럼 우리 내일 만나요."
    },
    {
      "start": 998.11,
      "end": 998.59,
      "text": "Bye-bye."
    }
  ]
}