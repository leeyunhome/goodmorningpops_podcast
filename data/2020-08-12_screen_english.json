      "start": 544.57,
      "end": 545.67,
      "text": "그런 문장이었는데"
    },
    {
      "start": 545.67,
      "end": 547.87,
      "text": "남들이 어떻게 생각하는 건"
    },
    {
      "start": 547.87,
      "end": 549.33,
      "text": "상관이 없어, Faye"
    },
    {
      "start": 549.33,
      "end": 550.43,
      "text": "라는 거예요"
    },
    {
      "start": 550.43,
      "end": 552.43,
      "text": "You have to know yourself"
    },
    {
      "start": 552.43,
      "end": 554.39,
      "text": "How special you are"
    },
    {
      "start": 554.39,
      "end": 555.91,
      "text": "You have to know yourself"
    },
    {
      "start": 555.91,
      "end": 557.31,
      "text": "How special you are"
    },
    {
      "start": 557.31,
      "end": 558.73,
      "text": "너는 네가"
    },
    {
      "start": 558.73,
      "end": 560.47,
      "text": "아주 특별하다는 걸"
    },
    {
      "start": 560.47,
      "end": 561.35,
      "text": "알아야 해"
    },
    {
      "start": 561.35,
      "end": 561.91,
      "text": "라는 겁니다"
    },
    {
      "start": 561.91,
      "end": 562.89,
      "text": "You don't need"
    },
    {
      "start": 562.89,
      "end": 564.49,
      "text": "other people to tell you"
    },
    {
      "start": 564.49,
      "end": 566.07,
      "text": "You don't need other people"
    },
    {
      "start": 566.07,
      "end": 567.35,
      "text": "다른 사람이 필요 없대요"
    },
    {
      "start": 567.35,
      "end": 568.23,
      "text": "To tell you"
    },
    {
      "start": 568.23,
      "end": 570.15,
      "text": "너에게 말해줄 필요가 없다는 거죠"
    },
    {
      "start": 570.15,
      "end": 571.29,
      "text": "다른 사람이 너에게"
    },
    {
      "start": 571.29,
      "end": 572.35,
      "text": "말해줄 필요가 없다"
    },
    {
      "start": 572.35,
      "end": 574.17,
      "text": "아, 그런 생각입니다"
    },
    {
      "start": 574.17,
      "end": 575.39,
      "text": "I need people to tell me"
    },
    {
      "start": 575.39,
      "end": 576.77,
      "text": "Come on, you're special"
    },
    {
      "start": 576.77,
      "end": 577.45,
      "text": "You're special"
    },
    {
      "start": 577.45,
      "end": 578.61,
      "text": "말 들어요"
    },
    {
      "start": 578.61,
      "end": 579.15,
      "text": "그럼요"
    },
    {
      "start": 579.15,
      "end": 579.85,
      "text": "기분도 좋아요"
    },
    {
      "start": 579.85,
      "end": 581.67,
      "text": "우리 청취자 여러분들께서"
    },
    {
      "start": 581.67,
      "end": 582.37,
      "text": "크리스 씨에게"
    },
    {
      "start": 582.37,
      "end": 583.19,
      "text": "응원의 메시지를"
    },
    {
      "start": 583.19,
      "end": 584.13,
      "text": "남겨주시는 것처럼"
    },
    {
      "start": 584.13,
      "end": 586.29,
      "text": "그런 긍정적인 이야기는"
    },
    {
      "start": 586.29,
      "end": 587.25,
      "text": "들을수록 좋지만"
    },
    {
      "start": 587.25,
      "end": 589.09,
      "text": "안 좋은 이야기를 들은"
    },
    {
      "start": 589.09,
      "end": 589.71,
      "text": "Faye에게는"
    },
    {
      "start": 589.71,
      "end": 590.25,
      "text": "엄마가 이렇게"
    },
    {
      "start": 590.25,
      "end": 591.57,
      "text": "조언을 해줄 수밖에 없죠"
    },
    {
      "start": 591.57,
      "end": 592.99,
      "text": "엄마 해주니까"
    },
    {
      "start": 592.99,
      "end": 593.81,
      "text": "괜찮아요"
    },
    {
      "start": 593.81,
      "end": 595.75,
      "text": "If her mom didn't say this"
    },
    {
      "start": 595.75,
      "end": 597.41,
      "text": "things would not be so good"
    },
    {
      "start": 597.41,
      "end": 597.91,
      "text": "맞아요"
    },
    {
      "start": 597.91,
      "end": 598.83,
      "text": "자, 이 내용"
    },
    {
      "start": 598.83,
      "end": 600.29,
      "text": "마지막으로 한 번 더 들어볼게요"
    },
    {
      "start": 600.29,
      "end": 603.65,
      "text": "Faye, we will find the witch"
    },
    {
      "start": 603.65,
      "end": 604.41,
      "text": "I promise"
    },
    {
      "start": 604.41,
      "end": 606.13,
      "text": "It's not just that"
    },
    {
      "start": 606.13,
      "end": 607.73,
      "text": "Finally a boy thought"
    },
    {
      "start": 607.73,
      "end": 608.41,
      "text": "I was pretty"
    },
    {
      "start": 608.41,
      "end": 610.51,
      "text": "and now he can't even"
    },
    {
      "start": 610.51,
      "end": 611.13,
      "text": "look at me"
    },
    {
      "start": 611.13,
      "end": 612.93,
      "text": "Beauty doesn't last"
    },
    {
      "start": 612.93,
      "end": 614.49,
      "text": "It doesn't matter"
    },
    {
      "start": 614.49,
      "end": 615.97,
      "text": "what anyone else thinks, Faye"
    },
    {
      "start": 615.97,
      "end": 618.47,
      "text": "You have to know yourself"
    },
    {
      "start": 618.47,
      "end": 619.95,
      "text": "how special you are"
    },
    {
      "start": 619.95,
      "end": 621.63,
      "text": "You don't need other people"
    },
    {
      "start": 621.63,
      "end": 622.29,
      "text": "to tell you"
    },
    {
      "start": 622.29,
      "end": 625.08,
      "text": "Emma's teaching us"
    },
    {
      "start": 625.08,
      "end": 625.92,
      "text": "that the inside"
    },
    {
      "start": 625.92,
      "end": 627.04,
      "text": "is more important"
    },
    {
      "start": 627.04,
      "end": 628.14,
      "text": "That's a valuable"
    },
    {
      "start": 628.14,
      "end": 629.02,
      "text": "life lesson"
    },
    {
      "start": 629.02,
      "end": 629.32,
      "text": "Yeah"
    },
    {
      "start": 629.32,
      "end": 630.06,
      "text": "How do you teach"
    },
    {
      "start": 630.06,
      "end": 630.72,
      "text": "your kids that?"
    },
    {
      "start": 631.06,
      "end": 632.92,
      "text": "It's what's on inside"
    },
    {
      "start": 632.92,
      "end": 633.8,
      "text": "that matters"
    },
    {
      "start": 633.8,
      "end": 635.0,
      "text": "not what's on"
    },
    {
      "start": 635.0,
      "end": 635.96,
      "text": "the outside"
    },
    {
      "start": 635.96,
      "end": 636.44,
      "text": "맞아요"
    },
    {
      "start": 636.44,
      "end": 638.12,
      "text": "내면이 아름다워야 한다"
    },
    {
      "start": 638.12,
      "end": 639.3,
      "text": "라는 교훈을"
    },
    {
      "start": 639.3,
      "end": 640.44,
      "text": "또 알게 해줍니다"
    },
    {
      "start": 640.44,
      "end": 642.16,
      "text": "계속 얘기해줘야 되겠다"
    },
    {
      "start": 642.16,
      "end": 642.7,
      "text": "그럼요"
    },
    {
      "start": 642.7,
      "end": 643.46,
      "text": "You need to hear this"
    },
    {
      "start": 643.46,
      "end": 644.36,
      "text": "over and over and over"
    },
    {
      "start": 644.36,
      "end": 645.64,
      "text": "중요합니다"
    },
    {
      "start": 645.64,
      "end": 647.0,
      "text": "자, 오늘 이렇게"
    },
    {
      "start": 647.0,
      "end": 648.0,
      "text": "가슴이 따뜻해지는"
    },
    {
      "start": 648.0,
      "end": 648.88,
      "text": "Screen English는"
    },
    {
      "start": 648.88,
      "end": 649.92,
      "text": "여기에서 마무리하였고요"
    }
  ]
}