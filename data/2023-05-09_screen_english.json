{
  "id": "2023-05-09_screen_english",
  "date": "2023-05-09",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "치어리딩 클럽 (Poms)",
  "duration_sec": 869.3,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2023-05-09_screen_english.mp3",
  "script": [
    {
      "start": 0.0,
      "end": 1.96,
      "text": "매일매일 굿모닝 팝스 듣고 있어요."
    },
    {
      "start": 1.96,
      "end": 6.14,
      "text": "글 쓰는 건 느리지만 한 단어 한 단어 외우면서"
    },
    {
      "start": 6.14,
      "end": 9.34,
      "text": "아이와 대화할 때마다 한 번씩 사용하니"
    },
    {
      "start": 9.34,
      "end": 12.5,
      "text": "아이도 놀라고 저도 우아하네요."
    },
    {
      "start": 13.12,
      "end": 15.42,
      "text": "영어 실력이 늘어가는 게 너무 신기해요."
    },
    {
      "start": 16.4,
      "end": 17.26,
      "text": "와, 그렇죠."
    },
    {
      "start": 17.4,
      "end": 19.86,
      "text": "이렇게 새로운 단어들을 외우시고 나서"
    },
    {
      "start": 19.86,
      "end": 25.2,
      "text": "그 단어들을 아이한테 한두 번씩 직접 이야기해 주시면"
    },
    {
      "start": 25.2,
      "end": 27.44,
      "text": "더 기억하기 쉬우실 거예요."
    },
    {
      "start": 28.28,
      "end": 30.02,
      "text": "그리고 아이의 입장에서는"
    },
    {
      "start": 30.02,
      "end": 34.54,
      "text": "우리 엄마가 영어를 이렇게 열심히 공부하시는구나"
    },
    {
      "start": 34.54,
      "end": 36.68,
      "text": "그리고 좋아하시는구나"
    },
    {
      "start": 36.68,
      "end": 38.54,
      "text": "이렇게 느낄 겁니다."
    },
    {
      "start": 39.08,
      "end": 41.38,
      "text": "그리고 자연스럽게 영어에 대해서"
    },
    {
      "start": 41.38,
      "end": 43.4,
      "text": "점점 더 마음을 열게 될 거예요."
    },
    {
      "start": 43.58,
      "end": 44.6,
      "text": "좋아하게 될 거고요."
    },
    {
      "start": 45.38,
      "end": 46.42,
      "text": "우리 장유희님."
    },
    {
      "start": 46.54,
      "end": 47.82,
      "text": "앞으로도 제가 응원할게요."
    },
    {
      "start": 47.82,
      "end": 49.97,
      "text": "김모정님."
    },
    {
      "start": 50.51,
      "end": 50.91,
      "text": "안녕하세요."
    },
    {
      "start": 51.55,
      "end": 53.55,
      "text": "요즘 다시 듣기로 듣고 있었는데"
    },
    {
      "start": 53.55,
      "end": 56.41,
      "text": "노래는 함께 들을 수 없어 아쉬웠어요."
    },
    {
      "start": 57.05,
      "end": 60.01,
      "text": "오늘 초등 1학년 쌍둥이들 소풍 준비로"
    },
    {
      "start": 60.01,
      "end": 61.71,
      "text": "평소보다 일찍 일어나서"
    },
    {
      "start": 61.71,
      "end": 63.31,
      "text": "굿모닝 팝스를 듣고 있으니"
    },
    {
      "start": 63.31,
      "end": 65.03,
      "text": "제 자신이 뿌듯하네요."
    },
    {
      "start": 65.45,
      "end": 67.95,
      "text": "다음 주도 본방 4주 도전해 보려 합니다."
    },
    {
      "start": 68.95,
      "end": 69.21,
      "text": "그렇죠."
    },
    {
      "start": 69.61,
      "end": 71.69,
      "text": "굿모닝 팝스는 이름처럼 역시"
    },
    {
      "start": 71.69,
      "end": 74.81,
      "text": "우리 팝스와 함께 하셔야 제맛인데요."
    },
    {
      "start": 74.81,
      "end": 78.81,
      "text": "우리 쌍둥이들 소풍 준비하시느라"
    },
    {
      "start": 79.45,
      "end": 81.49,
      "text": "굉장히 바쁘셨을 것 같은데"
    },
    {
      "start": 81.49,
      "end": 84.05,
      "text": "그럼에도 잊지 않으시고"
    },
    {
      "start": 84.05,
      "end": 86.83,
      "text": "본방을 사수해 주시는 이 센스"
    },
    {
      "start": 86.83,
      "end": 88.85,
      "text": "너무 감동입니다."
    },
    {
      "start": 89.17,
      "end": 89.89,
      "text": "감사드립니다."
    },
    {
      "start": 90.07,
      "end": 90.95,
      "text": "김모정님."
    },
    {
      "start": 91.79,
      "end": 92.81,
      "text": "본방 사수하시면서"
    },
    {
      "start": 93.37,
      "end": 96.03,
      "text": "이렇게 좋은 음악들 들어보시고"
    },
    {
      "start": 96.03,
      "end": 97.85,
      "text": "나만의 힐링 시간"
    },
    {
      "start": 97.85,
      "end": 99.53,
      "text": "마음껏 즐기시길 바랄게요."
    },
    {
      "start": 100.39,
      "end": 101.99,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 101.99,
      "end": 104.71,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 105.61,
      "end": 107.23,
      "text": "GMP를 위해 준비한"
    },
    {
      "start": 107.23,
      "end": 110.29,
      "text": "소소하지만 확실한 행복 이벤트"
    },
    {
      "start": 110.29,
      "end": 112.03,
      "text": "GMP로 영어실력 업"
    },
    {
      "start": 112.03,
      "end": 113.21,
      "text": "에너지도 업"
    },
    {
      "start": 113.21,
      "end": 115.84,
      "text": "오늘은 아이스 아메리카노 두 잔"
    },
    {
      "start": 115.84,
      "end": 117.62,
      "text": "모바일 굿본 준비했습니다."
    },
    {
      "start": 118.3,
      "end": 120.18,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 120.18,
      "end": 123.24,
      "text": "행운의 주인공 총 5분 뽑아서 보내드릴게요."
    },
    {
      "start": 123.98,
      "end": 126.88,
      "text": "단문 50원과 장문 100원의 추가요금이 부과되는"
    },
    {
      "start": 126.88,
      "end": 131.26,
      "text": "문자 샵 8910 아니면 샵 1061로 신청하시거나"
    },
    {
      "start": 131.26,
      "end": 133.88,
      "text": "무료인 콩 또는 마이케이로 참여해 주세요."
    },
    {
      "start": 133.88,
      "end": 165.53,
      "text": "영어 공부를 동시에 스크린 잉글리시 타임"
    },
    {
      "start": 165.53,
      "end": 167.63,
      "text": "5월에 함께하고 있는 영화는"
    },
    {
      "start": 167.63,
      "end": 169.43,
      "text": "자라 헤이즈 감독의"
    },
    {
      "start": 169.43,
      "end": 171.15,
      "text": "팜스 치어리딩 클럽"
    },
    {
      "start": 171.15,
      "end": 173.57,
      "text": "You're never too old to bring it"
    },
    {
      "start": 173.57,
      "end": 177.68,
      "text": "너무 감동적이에요. 이렇게 훅 들어오셨네요."
    },
    {
      "start": 178.4,
      "end": 182.34,
      "text": "약간 words of encouragement 이렇게 표현할 수 있을 것 같아요."
    },
    {
      "start": 182.54,
      "end": 183.64,
      "text": "감동시키고 싶었어요."
    },
    {
      "start": 183.74,
      "end": 184.9,
      "text": "네. 아주 힘이 납니다."
    },
    {
      "start": 185.24,
      "end": 187.34,
      "text": "You're never too old to bring it."
    },
    {
      "start": 187.34,
      "end": 187.98,
      "text": "Let's bring it."
    },
    {
      "start": 188.24,
      "end": 191.62,
      "text": "그래요. 이 영화의 아주 큰 메시지이기도 합니다. 그렇죠?"
    },
    {
      "start": 191.62,
      "end": 193.98,
      "text": "Yeah. It's never too late."
    },
    {
      "start": 195.54,
      "end": 200.08,
      "text": "4925님께서 크리스쌤 어서 오세요. 기다리고 있었어요. 하셨습니다."
    },
    {
      "start": 200.34,
      "end": 201.14,
      "text": "Thanks for waiting."
    },
    {
      "start": 201.48,
      "end": 207.38,
      "text": "왠지 우리를 두 팔 벌려 환영하고 계시는 우리 청취자분들을 보는 것 같아요."
    },
    {
      "start": 207.42,
      "end": 208.08,
      "text": "Welcome, welcome."
    },
    {
      "start": 208.4,
      "end": 211.32,
      "text": "And remember it's never too late to tune in."
    },
    {
      "start": 211.32,
      "end": 212.44,
      "text": "Oh, 맞습니다."
    },
    {
      "start": 212.74,
      "end": 213.34,
      "text": "본방사수."
    },
    {
      "start": 213.46,
      "end": 213.98,
      "text": "Go down."
    },
    {
      "start": 214.06,
      "end": 214.72,
      "text": "Never too late."
    },
    {
      "start": 215.16,
      "end": 216.28,
      "text": "중간에 치고 들어와도"
    },
    {
      "start": 216.28,
      "end": 217.4,
      "text": "No problem."
    },
    {
      "start": 217.52,
      "end": 218.74,
      "text": "그럼요. Stay tuned."
    },
    {
      "start": 218.96,
      "end": 220.94,
      "text": "이것도 같이 기억해 주시면 좋겠고요."
    },
    {
      "start": 221.76,
      "end": 222.82,
      "text": "제가 소개해드린 것처럼"
    },
    {
      "start": 222.82,
      "end": 224.06,
      "text": "이 감독의 이름은"
    },
    {
      "start": 224.06,
      "end": 226.56,
      "text": "자라 헤이즈라는 사람인데요."
    },
    {
      "start": 227.3,
      "end": 229.96,
      "text": "I heard there was a special reason"
    },
    {
      "start": 229.96,
      "end": 230.96,
      "text": "she made this movie."
    },
    {
      "start": 231.48,
      "end": 232.28,
      "text": "There was."
    },
    {
      "start": 232.54,
      "end": 234.5,
      "text": "Actually, when you think of cheerleading"
    },
    {
      "start": 234.5,
      "end": 236.5,
      "text": "which country do you think of?"
    },
    {
      "start": 236.58,
      "end": 237.7,
      "text": "Of course. America."
    },
    {
      "start": 238.18,
      "end": 239.56,
      "text": "Yes. USA."
    },
    {
      "start": 239.56,
      "end": 242.44,
      "text": "But Zara Hayes is not from the USA."
    },
    {
      "start": 242.74,
      "end": 243.06,
      "text": "그래요?"
    },
    {
      "start": 243.24,
      "end": 244.18,
      "text": "She's from the U."
    },
    {
      "start": 244.36,
      "end": 245.1,
      "text": "It starts with the U."
    },
    {
      "start": 245.32,
      "end": 246.3,
      "text": "It's the other U."
    },
    {
      "start": 246.36,
      "end": 246.68,
      "text": "UK."
    },
    {
      "start": 247.12,
      "end": 248.52,
      "text": "아, 반전인데요?"
    },
    {
      "start": 248.78,
      "end": 249.56,
      "text": "Yes, 반전이죠."
    },
    {
      "start": 249.86,
      "end": 253.4,
      "text": "So she was in her house in London."
    },
    {
      "start": 253.64,
      "end": 254.16,
      "text": "Wow."
    },
    {
      "start": 254.4,
      "end": 255.42,
      "text": "Just laying on the sofa."
    },
    {
      "start": 255.84,
      "end": 258.18,
      "text": "And she was looking at the Sunday paper."
    },
    {
      "start": 258.36,
      "end": 259.16,
      "text": "The newspaper."
    },
    {
      "start": 259.6,
      "end": 259.84,
      "text": "Yeah."
    },
    {
      "start": 260.16,
      "end": 262.08,
      "text": "And apparently there were pictures"
    },
    {
      "start": 262.08,
      "end": 264.94,
      "text": "of this American cheerleading squad."
    },
    {
      "start": 265.2,
      "end": 266.96,
      "text": "I mentioned them before."
    },
    {
      "start": 267.06,
      "end": 268.68,
      "text": "The Sun City Palms."
    },
    {
      "start": 268.68,
      "end": 271.56,
      "text": "The Senior Citizen Cheerleading Squad."
    },
    {
      "start": 271.56,
      "end": 272.04,
      "text": "Wow."
    },
    {
      "start": 272.04,
      "end": 273.06,
      "text": "How influential."
    },
    {
      "start": 273.86,
      "end": 274.04,
      "text": "Yeah."
    },
    {
      "start": 274.18,
      "end": 276.24,
      "text": "So she was very intrigued"
    },
    {
      "start": 276.24,
      "end": 277.5,
      "text": "by these pictures."
    },
    {
      "start": 277.78,
      "end": 278.0,
      "text": "Wow."
    },
    {
      "start": 278.12,
      "end": 278.64,
      "text": "And she's like,"
    },
    {
      "start": 278.7,
      "end": 280.84,
      "text": "I want to find out more about them."
    },
    {
      "start": 280.96,
      "end": 281.32,
      "text": "Wow."
    },
    {
      "start": 281.56,
      "end": 283.06,
      "text": "And she was already a television,"
    },
    {
      "start": 283.32,
      "end": 285.24,
      "text": "a popular television director."
    },
    {
      "start": 285.74,
      "end": 288.56,
      "text": "So she decided to learn more about them"
    },
    {
      "start": 288.56,
      "end": 289.66,
      "text": "and make this movie."
    },
    {
      "start": 289.9,
      "end": 290.46,
      "text": "Wow."
    },
    {
      "start": 290.82,
      "end": 292.56,
      "text": "정말 들으면 들을수록 놀랍네요."
    },
    {
      "start": 292.56,
      "end": 294.78,
      "text": "이 영화를 만들게 된 계기 중에"
    },
    {
      "start": 294.78,
      "end": 297.96,
      "text": "특히 이 감독이 영국 출신이었는데"
    },
    {
      "start": 297.96,
      "end": 299.84,
      "text": "어느 날 소파에 앉아서"
    },
    {
      "start": 299.84,
      "end": 301.4,
      "text": "뉴스페이퍼를 보다가"
    },
    {
      "start": 301.4,
      "end": 305.12,
      "text": "미쿡의 이런 소식을 보게 된 거라는 것."
    },
    {
      "start": 305.38,
      "end": 308.64,
      "text": "그러니까 그 작년들, 노년들의"
    },
    {
      "start": 308.64,
      "end": 312.3,
      "text": "이 팜팜 이슈가 얼마나 화제가 되었는지"
    },
    {
      "start": 312.3,
      "end": 315.54,
      "text": "영국의 신문에까지 실릴 정도였다는 거죠."
    },
    {
      "start": 315.54,
      "end": 317.26,
      "text": "아, 미쿡 문화."
    },
    {
      "start": 317.7,
      "end": 318.6,
      "text": "이 파급력."
    },
    {
      "start": 319.16,
      "end": 319.92,
      "text": "자랑스럽네요."
    },
    {
      "start": 320.1,
      "end": 323.58,
      "text": "영쿡까지 파급력을 보여주고 있었습니다."
    },
    {
      "start": 323.72,
      "end": 326.34,
      "text": "Yeah, but I don't know if she likes cheerleading herself."
    },
    {
      "start": 326.58,
      "end": 331.02,
      "text": "She said it's kind of a bizarre and fascinating activity."
    },
    {
      "start": 331.26,
      "end": 332.88,
      "text": "이거 비웃는 건가?"
    },
    {
      "start": 333.52,
      "end": 334.74,
      "text": "존경하는 건가?"
    },
    {
      "start": 335.06,
      "end": 335.74,
      "text": "좀 애매하다."
    },
    {
      "start": 336.12,
      "end": 336.64,
      "text": "그렇군요."
    },
    {
      "start": 336.66,
      "end": 337.62,
      "text": "한번 얘기해봐야겠어요."
    },
    {
      "start": 337.78,
      "end": 340.24,
      "text": "호기심에 시작을 하게 된 것 같은데"
    },
    {
      "start": 340.24,
      "end": 343.38,
      "text": "아무래도 만들면서 점점 더 매료가 되었겠죠."
    },
    {
      "start": 343.38,
      "end": 345.84,
      "text": "영화에서 느껴지는 그런 분위기가 있었잖아요."
    },
    {
      "start": 345.9,
      "end": 346.44,
      "text": "아예 없어."
    },
    {
      "start": 346.7,
      "end": 349.08,
      "text": "그 bizarre, 이 어감 조금 별로다."
    },
    {
      "start": 349.2,
      "end": 349.72,
      "text": "그렇긴 하네요."
    },
    {
      "start": 349.74,
      "end": 350.26,
      "text": "bizarre."
    },
    {
      "start": 351.06,
      "end": 352.86,
