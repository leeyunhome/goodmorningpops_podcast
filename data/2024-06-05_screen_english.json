    },
    {
      "start": 547.73,
      "end": 548.89,
      "text": "존재에 대해서"
    },
    {
      "start": 548.89,
      "end": 549.85,
      "text": "믿었어요"
    },
    {
      "start": 549.85,
      "end": 550.85,
      "text": "More than anything"
    },
    {
      "start": 550.85,
      "end": 552.31,
      "text": "그 어떤 것보다도"
    },
    {
      "start": 552.31,
      "end": 553.15,
      "text": "굳게 믿었어요"
    },
    {
      "start": 553.15,
      "end": 554.45,
      "text": "Oh do you believe in ghosts?"
    },
    {
      "start": 554.83,
      "end": 555.19,
      "text": "저요?"
    },
    {
      "start": 555.97,
      "end": 556.41,
      "text": "예"
    },
    {
      "start": 556.41,
      "end": 556.95,
      "text": "저한테요"
    },
    {
      "start": 556.95,
      "end": 557.49,
      "text": "왜 그렇게"
    },
    {
      "start": 557.49,
      "end": 558.37,
      "text": "째려보세요?"
    },
    {
      "start": 558.85,
      "end": 559.77,
      "text": "아니 이게 어떻게"
    },
    {
      "start": 559.77,
      "end": 560.65,
      "text": "째려보는 눈이에요"
    },
    {
      "start": 560.65,
      "end": 562.11,
      "text": "사랑을 담은 눈이지"
    },
    {
      "start": 562.11,
      "end": 562.49,
      "text": "아"
    },
    {
      "start": 562.49,
      "end": 563.31,
      "text": "사랑스럽네요"
    },
    {
      "start": 563.31,
      "end": 565.75,
      "text": "유령의 존재"
    },
    {
      "start": 565.75,
      "end": 566.07,
      "text": "그렇죠"
    },
    {
      "start": 566.07,
      "end": 567.31,
      "text": "신적인 존재"
    },
    {
      "start": 567.31,
      "end": 568.65,
      "text": "분명히 있다고 생각합니다"
    },
    {
      "start": 568.65,
      "end": 569.11,
      "text": "아하"
    },
    {
      "start": 569.11,
      "end": 569.81,
      "text": "오케이"
    },
    {
      "start": 569.81,
      "end": 570.61,
      "text": "thank you"
    },
    {
      "start": 570.61,
      "end": 572.75,
      "text": "When you live alone"
    },
    {
      "start": 572.75,
      "end": 574.35,
      "text": "on a remote island"
    },
    {
      "start": 574.35,
      "end": 575.35,
      "text": "you know"
    },
    {
      "start": 575.35,
      "end": 575.77,
      "text": "아"
    },
    {
      "start": 575.77,
      "end": 577.27,
      "text": "왜 딴 곳에서"
    },
    {
      "start": 577.27,
      "end": 578.03,
      "text": "혼자서"
    },
    {
      "start": 578.03,
      "end": 578.81,
      "text": "살았으니까"
    },
    {
      "start": 578.81,
      "end": 579.55,
      "text": "뭐"
    },
    {
      "start": 579.55,
      "end": 580.23,
      "text": "어떻겠어요"
    },
    {
      "start": 580.23,
      "end": 582.39,
      "text": "He felt"
    },
    {
      "start": 582.39,
      "end": 583.55,
      "text": "Ingrid's presence"
    },
    {
      "start": 583.55,
      "end": 584.47,
      "text": "in the house"
    },
    {
      "start": 584.47,
      "end": 585.13,
      "text": "그는"
    },
    {
      "start": 585.13,
      "end": 586.23,
      "text": "그 집에서"
    },
    {
      "start": 586.23,
      "end": 587.51,
      "text": "Ingrid의"
    },
    {
      "start": 587.51,
      "end": 588.35,
      "text": "영혼을"
    },
    {
      "start": 588.35,
      "end": 589.13,
      "text": "느꼈대요"
    },
    {
      "start": 589.13,
      "end": 589.63,
      "text": "Oh creepy"
    },
    {
      "start": 589.63,
      "end": 590.81,
      "text": "scary"
    },
    {
      "start": 590.81,
      "end": 592.19,
      "text": "오싹하죠"
    },
    {
      "start": 592.19,
      "end": 593.49,
      "text": "여기에서 언급이"
    },
    {
      "start": 593.49,
      "end": 593.99,
      "text": "되고 있는"
    },
    {
      "start": 593.99,
      "end": 595.15,
      "text": "Ingrid라는 것은"
    },
    {
      "start": 595.15,
      "end": 596.37,
      "text": "one of his wives"
    },
    {
      "start": 596.37,
      "end": 597.15,
      "text": "가 되겠죠"
    },
    {
      "start": 597.15,
      "end": 597.93,
      "text": "Maybe"
    },
    {
      "start": 597.93,
      "end": 599.09,
      "text": "He did have"
    },
    {
      "start": 599.09,
      "end": 599.93,
      "text": "many wives"
    },
    {
      "start": 599.93,
      "end": 600.81,
      "text": "about four"
    },
    {
      "start": 600.81,
      "end": 601.91,
      "text": "and one of them"
    },
    {
      "start": 601.91,
      "end": 602.95,
      "text": "his last wife"
    },
    {
      "start": 602.95,
      "end": 603.79,
      "text": "was named"
    },
    {
      "start": 603.79,
      "end": 604.47,
      "text": "Ingrid"
    },
    {
      "start": 604.47,
      "end": 604.85,
      "text": "Yeah"
    },
    {
      "start": 604.85,
      "end": 606.35,
      "text": "Her presence"
    },
    {
      "start": 606.35,
      "end": 607.43,
      "text": "Oh my gosh"
    },
    {
      "start": 607.43,
      "end": 608.05,
      "text": "it's a ghost"
    },
    {
      "start": 608.05,
      "end": 609.33,
      "text": "그녀의 영혼이"
    },
    {
      "start": 609.33,
      "end": 610.19,
      "text": "죽은 이후에도"
    },
    {
      "start": 610.19,
      "end": 610.99,
      "text": "그 집에 머물러"
    },
    {
      "start": 610.99,
      "end": 612.11,
      "text": "있다고 생각했나봐요"
    },
    {
      "start": 612.11,
      "end": 612.83,
      "text": "Yeah"
    },
    {
      "start": 612.83,
      "end": 615.13,
      "text": "He said she was there"
    },
    {
      "start": 615.13,
      "end": 616.05,
      "text": "그는 말했어요"
    },
    {
      "start": 616.05,
      "end": 616.81,
      "text": "그녀가"
    },
    {
      "start": 616.81,
      "end": 617.59,
      "text": "거기 있다고"
    },
    {
      "start": 617.59,
      "end": 619.06,
      "text": "He was absolutely"
    },
    {
      "start": 619.06,
      "end": 620.38,
      "text": "convinced of it"
    },
    {
      "start": 620.38,
      "end": 621.28,
      "text": "그는"
    },
    {
      "start": 621.28,
      "end": 623.68,
      "text": "완전히 확신했죠"
    },
    {
      "start": 623.68,
      "end": 624.76,
      "text": "Well wait"
    },
    {
      "start": 624.76,
      "end": 626.1,
      "text": "So they're staying in that house"
    },
    {
      "start": 626.1,
      "end": 627.42,
      "text": "and now they're learning"
    },
    {
      "start": 627.42,
      "end": 628.3,
      "text": "about this ghost"
    },
    {
      "start": 628.3,
      "end": 629.62,
      "text": "who's in the house"
    },
    {
      "start": 629.62,
      "end": 631.0,
      "text": "and she's already"
    },
    {
      "start": 631.0,
      "end": 632.06,
      "text": "like a little scared"
    },
    {
      "start": 632.06,
      "end": 632.42,
      "text": "Yeah"
    },
    {
      "start": 632.42,
      "end": 633.86,
      "text": "So this is not good"
    },
    {
      "start": 633.86,
      "end": 635.8,
      "text": "아 불면증이 생길 것 같은데요"
    },
    {
      "start": 635.8,
      "end": 637.22,
      "text": "I don't think she's gonna sleep tonight"
    },
    {
      "start": 637.22,
      "end": 638.82,
      "text": "자 이내야"
    },
    {
      "start": 638.82,
      "end": 639.36,
      "text": "이 내용"
    },
    {
      "start": 639.36,
      "end": 639.86,
      "text": "다시 한번"
    },
    {
      "start": 639.86,
      "end": 640.44,
      "text": "들어볼게요"
    },
    {
      "start": 640.44,
      "end": 643.39,
      "text": "Did he believe in God?"
    },
    {
      "start": 643.51,
      "end": 643.83,
      "text": "I mean"
    },
    {
      "start": 643.83,
      "end": 645.43,
      "text": "It was complicated"
    },
    {
      "start": 645.43,
      "end": 645.91,
      "text": "I'm sure"
    },
    {
      "start": 645.91,
      "end": 647.29,
      "text": "But did he ever talk about it?"
    },
    {
      "start": 647.87,
      "end": 648.71,
      "text": "He always said that"
    },
    {
      "start": 648.71,
      "end": 650.55,
      "text": "death was just a light going out"
    },
    {
      "start": 650.55,
      "end": 651.69,
      "text": "That changed after"
    },
    {
      "start": 651.69,
      "end": 652.49,
      "text": "Ingrid died"
    },
    {
      "start": 652.49,
      "end": 654.41,
      "text": "The old man believed in ghosts"
    },
    {
      "start": 654.41,
      "end": 655.65,
      "text": "more than anything"
    },
    {
      "start": 655.65,
      "end": 657.43,
      "text": "When you live alone"
    },
    {
      "start": 657.43,
      "end": 658.21,
      "text": "on a remote island"
    },
    {
      "start": 658.21,
      "end": 659.33,
      "text": "He felt"
    },
    {
      "start": 659.33,
      "end": 660.35,
      "text": "Ingrid's presence"
    },
    {
      "start": 660.35,
      "end": 660.97,
      "text": "in the house"
    },
    {
      "start": 660.97,
      "end": 662.09,
      "text": "He said she was there"
    },
    {
      "start": 662.09,
      "end": 663.39,
      "text": "He was absolutely"
    },
    {
      "start": 663.39,
      "end": 664.49,
      "text": "convinced of it"
    },
    {
      "start": 664.49,
      "end": 666.39,
      "text": "Oh"
    },
    {
      "start": 666.39,
      "end": 667.73,
      "text": "올리비아님께서요"
    },
    {
      "start": 667.73,
      "end": 669.05,
      "text": "크쌤과 정연쌤"
    },
    {
      "start": 669.05,
      "end": 670.27,
      "text": "케미 짱이에요"
    },
    {
      "start": 670.27,
      "end": 671.69,
      "text": "하셨습니다"
    },
    {
      "start": 671.69,
      "end": 672.29,
      "text": "Oh"
    },
    {
      "start": 672.29,
      "end": 673.01,
      "text": "감사해요"
    },
    {
      "start": 673.01,
      "end": 673.77,
      "text": "그러니까요"
    },
    {
      "start": 673.77,
      "end": 674.15,
      "text": "이렇게"
    },
    {
      "start": 674.15,
      "end": 675.37,
      "text": "다정한 눈으로"
    },
    {
      "start": 675.37,
      "end": 676.65,
      "text": "제가 바라보는 이유가"
    },
    {
      "start": 676.65,
      "end": 677.15,
      "text": "다 있죠"
    },
    {
      "start": 677.15,
      "end": 677.83,
      "text": "Yeah"
    },
    {
      "start": 677.83,
      "end": 678.99,
      "text": "조크 케미"
    },
    {
      "start": 678.99,
      "end": 679.71,
      "text": "I love the"
    },
    {
      "start": 679.71,
      "end": 680.41,
      "text": "They're beautiful"
    },
    {
      "start": 680.41,
      "end": 680.81,
      "text": "째려보는 거 아니에요"
    },
    {
      "start": 680.81,
      "end": 681.65,
      "text": "Beautiful eyes"
    },
    {
      "start": 681.65,
      "end": 682.71,
      "text": "No 째려본"
    },
    {
      "start": 682.71,
      "end": 684.19,
      "text": "Very 사랑스러움"
    },
    {
      "start": 684.19,
      "end": 685.61,
      "text": "그럼 내일도"
    },
    {
      "start": 685.61,
      "end": 686.53,
      "text": "우리 또 만나요"
    },
    {
      "start": 686.53,
      "end": 687.57,
      "text": "See you tomorrow"
    },
    {
      "start": 687.57,
      "end": 688.37,
      "text": "Bye Bye"
    }
  ]
}