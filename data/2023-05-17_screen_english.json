  "script": [
    {
      "start": 0.0,
      "end": 0.9,
      "text": "Good morning"
    },
    {
      "start": 0.9,
      "end": 1.94,
      "text": "Good morning everyone"
    },
    {
      "start": 1.94,
      "end": 3.82,
      "text": "네 아시다시피"
    },
    {
      "start": 3.82,
      "end": 5.76,
      "text": "다이언 키튼이라는 배우가"
    },
    {
      "start": 5.76,
      "end": 6.9,
      "text": "플레이트 마르사 힐"
    },
    {
      "start": 6.9,
      "end": 10.78,
      "text": "그런데 and the actual model of the character"
    },
    {
      "start": 10.78,
      "end": 14.02,
      "text": "Marthor라는 그 실제 캐릭터"
    },
    {
      "start": 14.02,
      "end": 15.26,
      "text": "아니 실제 인물"
    },
    {
      "start": 15.26,
      "end": 17.68,
      "text": "아 뭐 찌찌뽕"
    },
    {
      "start": 17.68,
      "end": 19.36,
      "text": "똑같아 했네"
    },
    {
      "start": 19.36,
      "end": 19.94,
      "text": "네네"
    },
    {
      "start": 19.94,
      "end": 23.48,
      "text": "그 사람이 바로 Patricia Maria Weber"
    },
    {
      "start": 23.48,
      "end": 24.88,
      "text": "이라는 사람이라고 해요"
    },
    {
      "start": 24.88,
      "end": 25.72,
      "text": "Patricia"
    },
    {
      "start": 25.72,
      "end": 26.76,
      "text": "Patricia"
    },
    {
      "start": 26.76,
      "end": 28.5,
      "text": "Very nice"
    },
    {
      "start": 28.5,
      "end": 30.0,
      "text": "Patricia가 맞나요?"
    },
    {
      "start": 30.08,
      "end": 31.56,
      "text": "Patricia가 맞나요?"
    },
    {
      "start": 31.78,
      "end": 32.86,
      "text": "그때그때"
    },
    {
      "start": 32.86,
      "end": 33.92,
      "text": "그때그때 다 알아요"
    },
    {
      "start": 33.92,
      "end": 34.38,
      "text": "Patricia"
    },
    {
      "start": 34.38,
      "end": 35.28,
      "text": "Patricia"
    },
    {
      "start": 35.28,
      "end": 35.82,
      "text": "Patricia"
    },
    {
      "start": 35.82,
      "end": 37.02,
      "text": "Hi Patricia"
    },
    {
      "start": 37.02,
      "end": 38.16,
      "text": "오 좋습니다"
    },
    {
      "start": 38.16,
      "end": 40.96,
      "text": "Anyway her name is Patricia Marie"
    },
    {
      "start": 40.96,
      "end": 43.44,
      "text": "And she was a real life person"
    },
    {
      "start": 43.44,
      "end": 45.56,
      "text": "And also a long time member"
    },
    {
      "start": 45.56,
      "end": 47.6,
      "text": "Of that famous cheerleading squad"
    },
    {
      "start": 47.6,
      "end": 49.78,
      "text": "Senior citizen cheerleading squad"
    },
    {
      "start": 49.78,
      "end": 51.36,
      "text": "Called the Sun City Palms"
    },
    {
      "start": 51.36,
      "end": 54.9,
      "text": "So this character is loosely based on"
    },
    {
      "start": 54.9,
      "end": 56.08,
      "text": "This person"
    },
    {
      "start": 56.08,
      "end": 58.44,
      "text": "She was a baton twirler"
    },
    {
      "start": 58.44,
      "end": 59.76,
      "text": "In high school"
    },
    {
      "start": 59.76,
      "end": 61.9,
      "text": "You know the girl who holds the baton"
    },
    {
      "start": 61.9,
      "end": 63.6,
      "text": "Spins it super fast"
    },
    {
      "start": 63.6,
      "end": 64.9,
      "text": "Throws it in the air"
    },
    {
      "start": 64.9,
      "end": 65.54,
      "text": "And catches it"
    },
    {
      "start": 65.54,
      "end": 66.52,
      "text": "Like a circus act"
    },
    {
      "start": 66.52,
      "end": 67.36,
      "text": "So cool"
    },
    {
      "start": 67.36,
      "end": 67.7,
      "text": "Yeah"
    },
    {
      "start": 67.7,
      "end": 68.34,
      "text": "Wow"
    },
    {
      "start": 68.34,
      "end": 70.76,
      "text": "그 지휘봉을 어떻게 그렇게 빨리 돌리는지"
    },
    {
      "start": 70.76,
      "end": 71.94,
      "text": "Hand eye coordination"
    },
    {
      "start": 71.94,
      "end": 72.46,
      "text": "Yeah"
    },
    {
      "start": 72.46,
      "end": 73.96,
      "text": "Maybe a lot of video games"
    },
    {
      "start": 73.96,
      "end": 75.22,
      "text": "Good practice"
    },
    {
      "start": 75.22,
      "end": 76.82,
      "text": "I can't do it"
    },
    {
      "start": 76.82,
      "end": 77.66,
      "text": "저도 못해요"
    },
    {
      "start": 77.66,
      "end": 78.98,
      "text": "Terrible coordination"
    },
    {
      "start": 78.98,
      "end": 79.74,
      "text": "저도 이게"
    },
    {
      "start": 79.74,
      "end": 80.74,
      "text": "Bad coordination"
    },
    {
      "start": 80.74,
      "end": 84.42,
      "text": "뭐 하나 돌려보려고 해도 손가락이 안 돌아가던데요"
    },
    {
      "start": 84.42,
      "end": 85.74,
      "text": "아 근데 돌리는 봤어요?"
    },
    {
      "start": 85.86,
      "end": 87.24,
      "text": "네 노력은 해봤어요"
    },
    {
      "start": 87.24,
      "end": 88.06,
      "text": "돌리는 봤는데"
    },
    {
      "start": 88.06,
      "end": 95.04,
      "text": "I can do three and four but only in two hands"
    },
    {
      "start": 95.04,
      "end": 96.04,
      "text": "따로따로"
    },
    {
      "start": 96.04,
      "end": 97.64,
      "text": "5은 절대 안 되더라고요"
    },
    {
      "start": 97.64,
      "end": 97.66,
      "text": "5은 절대 안 되더라고요"
    },
    {
      "start": 97.66,
      "end": 101.54,
      "text": "근데 뭐 연습을 만약에 포기하지 않고 계속했더라면"
    },
    {
      "start": 101.54,
      "end": 103.5,
      "text": "우리가 할 수도 있었을 거예요"
    },
    {
      "start": 103.5,
      "end": 104.16,
      "text": "Sure"
    },
    {
      "start": 104.16,
      "end": 105.88,
      "text": "Practice makes perfect"
    },
    {
      "start": 105.88,
      "end": 106.36,
      "text": "그럼요"
    },
    {
      "start": 106.36,
      "end": 107.74,
      "text": "Anybody can do it with practice"
    },
    {
      "start": 107.74,
      "end": 108.24,
      "text": "Yeah"
    },
    {
      "start": 108.24,
      "end": 110.9,
      "text": "Anyway this actual person"
    },
    {
      "start": 110.9,
      "end": 111.7,
      "text": "Patricia"
    },
    {
      "start": 111.7,
      "end": 114.28,
      "text": "She was diagnosed with breast cancer"
    },
    {
      "start": 114.28,
      "end": 117.58,
      "text": "And she passed away at the age of 88"
    },
    {
      "start": 117.58,
      "end": 119.04,
      "text": "In 2019"
    },
    {
      "start": 119.04,
      "end": 122.24,
      "text": "And Martha's character also has cancer"
    },
    {
      "start": 122.24,
      "end": 124.6,
      "text": "And she's leading this cheerleading squad"
    },
    {
      "start": 124.6,
      "end": 127.96,
      "text": "So very similar to this actual person"
    },
    {
      "start": 127.96,
      "end": 128.46,
      "text": "Yeah"
    },
    {
      "start": 128.46,
      "end": 132.68,
      "text": "이렇게 실제 인물에서 어느 정도 영감을 받아가지고"
    },
    {
      "start": 132.68,
      "end": 136.62,
      "text": "이처럼 Martha라는 캐릭터가 탄생을 한 거라고 하니까"
    },
    {
      "start": 136.62,
      "end": 139.92,
      "text": "아무래도 I'm getting more into it 하게 되는 것 같습니다"
    },
    {
      "start": 139.92,
      "end": 142.38,
      "text": "그럼 준비된 장면 듣고 오시죠"
    },
    {
      "start": 142.38,
      "end": 143.86,
      "text": "So um"
    },
    {
      "start": 143.86,
      "end": 144.46,
      "text": "Alice"
    },
    {
      "start": 144.46,
      "end": 148.8,
      "text": "We noticed you signed up for the cheerleading tryouts"
    },
    {
      "start": 148.8,
      "end": 149.7,
      "text": "Oh yes"
    },
    {
      "start": 149.7,
      "end": 151.14,
      "text": "I saw your flyer"
    },
    {
      "start": 151.14,
      "end": 152.52,
      "text": "It sounded fun"
    },
    {
      "start": 152.52,
      "end": 154.22,
      "text": "Why didn't you come?"
    },
    {
      "start": 154.64,
      "end": 154.9,
      "text": "Well"
    },
    {
      "start": 154.9,
      "end": 156.3,
      "text": "I wanted to"
    },
    {
      "start": 156.3,
      "end": 156.86,
      "text": "But"
    },
    {
      "start": 156.86,
      "end": 160.6,
      "text": "My husband doesn't like me out too much on my own"
    },
    {
      "start": 160.6,
      "end": 163.24,
      "text": "I took a sewing class last year"
    },
    {
      "start": 163.24,
      "end": 166.56,
      "text": "And he had to make his own dinners on Wednesday nights"
    },
    {
      "start": 166.56,
      "end": 168.98,
      "text": "Well that sounds traumatic of course"
    },
    {
      "start": 168.98,
      "end": 171.84,
      "text": "What if we practiced in the morning"
    },
    {
      "start": 171.84,
      "end": 174.3,
      "text": "And then you could get home in time for dinner"
    },
    {
      "start": 174.3,
      "end": 175.75,
      "text": "Oh"
    },
    {
      "start": 175.75,
      "end": 179.89,
      "text": "자 그래도 뭐 한 명 한 명 회원이 들어가고 있어요"
    },
    {
      "start": 179.89,
      "end": 181.25,
      "text": "Well they need"
    },
    {
      "start": 181.25,
      "end": 182.25,
      "text": "How many do they need?"
    },
    {
      "start": 182.37,
      "end": 182.89,
      "text": "사실"
    },
    {
      "start": 182.89,
      "end": 184.79,
      "text": "There should be eight members"
    },
    {
      "start": 184.79,
      "end": 186.71,
      "text": "They only have five so far"
    },
    {
      "start": 186.71,
      "end": 188.79,
      "text": "Five came to try out"
    },
    {
      "start": 188.79,
      "end": 189.77,
      "text": "Audition"
    },
    {
      "start": 189.77,
      "end": 191.41,
      "text": "오디션도 열었죠"
    },
    {
      "start": 191.41,
      "end": 191.71,
      "text": "맞아요"
    },
    {
      "start": 191.71,
      "end": 193.81,
      "text": "그 오디션 장면이 굉장히 재밌었습니다"
    },
    {
      "start": 193.81,
      "end": 194.81,
      "text": "생각보다"
    },
    {
      "start": 194.81,
      "end": 197.63,
      "text": "They were good at dancing and moving their bodies"
    },
    {
      "start": 197.63,
      "end": 198.35,
      "text": "They were hilarious"
    },
    {
      "start": 198.35,
      "end": 199.91,
      "text": "It was so fun"
    },
    {
      "start": 199.91,
      "end": 202.23,
      "text": "그리고 특히 그 요가하던 분"
    },
    {
      "start": 202.23,
      "end": 203.91,
      "text": "너무 인상적이었어요"
    },
    {
      "start": 203.91,
      "end": 205.17,
      "text": "Oh what did she do?"
    },
    {
      "start": 205.23,
      "end": 207.09,
      "text": "저보다 훨씬 더 flexible"
    },
    {
      "start": 207.09,
      "end": 207.87,
      "text": "아"
    },
    {
      "start": 207.87,
      "end": 209.53,
      "text": "Wasn't she like meditating?"
    },
    {
      "start": 209.81,
      "end": 210.13,
      "text": "Yeah"
    },
    {
      "start": 210.13,
      "end": 211.41,
      "text": "명성했어요"
    },
    {
      "start": 211.41,
      "end": 213.13,
      "text": "진짜 대단하시더라고요"
    },
    {
      "start": 213.13,
      "end": 213.87,
      "text": "아 네"
    },
    {
      "start": 213.87,
      "end": 218.55,
      "text": "그리고 지금은 이 Alice라는 사람의 목소리를 주로 들어보셨는데"
    },
    {
      "start": 218.55,
      "end": 220.89,
      "text": "She already signed up for the club"
    },
    {
      "start": 220.89,
      "end": 222.63,
      "text": "그럼에도 불구하고"
    },
    {
      "start": 222.63,
      "end": 223.31,
      "text": "어두웠어요"
    },
    {
      "start": 223.31,
      "end": 226.55,
      "text": "오디션 현장 모임에 나타나지 않으니까"
    },
    {
      "start": 226.55,
      "end": 227.25,
      "text": "A no-show"
    },
    {
      "start": 227.25,
      "end": 228.09,
      "text": "She did a no-show"
    },
    {
      "start": 228.09,
      "end": 228.55,
      "text": "맞아요"
    },
    {
      "start": 228.55,
      "end": 229.29,
      "text": "And 알고 보니"
    },
    {
      "start": 229.29,
      "end": 230.29,
      "text": "They went to her house"
    },
    {
      "start": 230.29,
      "end": 230.65,
      "text": "Yeah"
    },
    {
      "start": 230.65,
      "end": 232.87,
      "text": "Because they need at least six people"
    },
    {
      "start": 232.87,
      "end": 235.41,
      "text": "And they found out the reason"
    },
    {
      "start": 235.41,
      "end": 237.33,
      "text": "Why she didn't show up"
    },
    {
      "start": 237.33,
      "end": 238.11,
      "text": "그러니까요"
    },
    {
      "start": 238.11,
      "end": 240.01,
      "text": "그래서 지금 집에 방문해가지고"
    },
    {
      "start": 240.01,
      "end": 241.69,
      "text": "Martha와 Cheryl하고"
    },
    {
      "start": 241.69,
      "end": 243.29,
      "text": "또 Alice까지"
    },
    {
      "start": 243.29,
      "end": 245.37,
      "text": "대화를 나누고 있는 장면입니다"
    },
    {
      "start": 245.37,
      "end": 245.79,
      "text": "Yeah"
    },
    {
      "start": 245.79,
      "end": 247.01,
      "text": "이 장면 끝나고"
    },
    {
      "start": 247.01,
      "end": 248.11,
      "text": "진짜 대박 반전"
    },
    {
      "start": 248.11,
      "end": 248.51,
      "text": "맞아요"
    },
    {
      "start": 248.51,
      "end": 249.23,
      "text": "있었죠"
    },
    {
      "start": 249.23,
      "end": 249.77,
      "text": "너무"
    },
    {
      "start": 249.77,
      "end": 251.81,
      "text": "I found it very funny"
    },
    {
      "start": 251.81,
      "end": 252.47,
      "text": "Oh yeah"
    },
    {
      "start": 252.47,
      "end": 253.57,
      "text": "그게 빵빵 터졌어요"
    },
    {
      "start": 253.57,
      "end": 254.77,
      "text": "약간 funny면서"
    },
    {
      "start": 254.77,
      "end": 255.95,
      "text": "amazing 하면서"
    },
    {
      "start": 255.95,
      "end": 257.87,
      "text": "약간 scary 하기도 했어요"
    },
    {
      "start": 257.87,
      "end": 258.75,
      "text": "scary"
    },
    {
      "start": 258.75,
      "end": 259.87,
      "text": "What happened?"
    },
    {
      "start": 260.19,
      "end": 260.59,
      "text": "그러니까요"
    },
    {
      "start": 260.59,
      "end": 261.91,
      "text": "What did she do to him?"
    },
    {
      "start": 261.97,
      "end": 263.83,
      "text": "굉장히 미스테리한 그런"
    },
    {
      "start": 263.83,
      "end": 266.65,
      "text": "장례식 장면이었습니다"
    },
    {
      "start": 266.65,
      "end": 266.91,
      "text": "네"
    },
    {
      "start": 266.91,
      "end": 269.01,
      "text": "아무튼 그 남편의 반대"
    },
    {
      "start": 269.01,
      "end": 269.99,
      "text": "반대 때문에"
    },
    {
      "start": 269.99,
      "end": 272.19,
      "text": "지금 칠 일인 활동 못하는 상황"
    },
    {
      "start": 272.19,
      "end": 272.87,
      "text": "아니 근데"
    },
    {
      "start": 272.87,
      "end": 275.27,
      "text": "She's probably over 60 or 70"
    },
    {
      "start": 275.27,
      "end": 275.95,
      "text": "Yes"
    },
    {
      "start": 275.95,
      "end": 277.03,
      "text": "그럼에도 불구하고"
    },
    {
      "start": 277.03,
      "end": 279.45,
      "text": "She's still under her husband's control"
    },
    {
      "start": 279.45,
      "end": 280.81,
      "text": "와우"
    },
    {
      "start": 280.81,
      "end": 281.41,
      "text": "그러니까요"
    },
    {
      "start": 281.41,
      "end": 282.31,
      "text": "되게 놀라웠어요"
    },
    {
      "start": 282.31,
      "end": 283.13,
      "text": "저랑 정반대예요"
    },
    {
      "start": 283.13,
      "end": 284.99,
      "text": "여기 남편한테 잡혀 살고"
