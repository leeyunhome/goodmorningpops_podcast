    },
    {
      "start": 511.08,
      "end": 512.14,
      "text": "get home in time"
    },
    {
      "start": 512.14,
      "end": 512.76,
      "text": "for dinner"
    },
    {
      "start": 512.76,
      "end": 514.48,
      "text": "그럼 저녁 시간에"
    },
    {
      "start": 514.48,
      "end": 515.84,
      "text": "맞춰서 집에 올 수"
    },
    {
      "start": 515.84,
      "end": 516.4,
      "text": "있잖아요"
    },
    {
      "start": 516.4,
      "end": 518.46,
      "text": "라고 제안을 했어요"
    },
    {
      "start": 518.46,
      "end": 519.8,
      "text": "That's a good idea"
    },
    {
      "start": 519.8,
      "end": 520.26,
      "text": "maybe"
    },
    {
      "start": 520.26,
      "end": 521.92,
      "text": "but then"
    },
    {
      "start": 521.92,
      "end": 522.48,
      "text": "suddenly"
    },
    {
      "start": 522.48,
      "end": 523.96,
      "text": "Oh she goes"
    },
    {
      "start": 523.96,
      "end": 525.4,
      "text": "She goes to ask"
    },
    {
      "start": 525.4,
      "end": 525.98,
      "text": "for permission"
    },
    {
      "start": 525.98,
      "end": 527.02,
      "text": "one more time"
    },
    {
      "start": 527.02,
      "end": 527.36,
      "text": "맞아요"
    },
    {
      "start": 527.36,
      "end": 528.48,
      "text": "She tried to persuade"
    },
    {
      "start": 528.48,
      "end": 530.44,
      "text": "her husband"
    },
    {
      "start": 530.44,
      "end": 531.14,
      "text": "once"
    },
    {
      "start": 531.14,
      "end": 532.14,
      "text": "제발"
    },
    {
      "start": 532.14,
      "end": 533.28,
      "text": "허락해줘 여보"
    },
    {
      "start": 533.28,
      "end": 533.92,
      "text": "그런데"
    },
    {
      "start": 533.92,
      "end": 535.34,
      "text": "her husband"
    },
    {
      "start": 535.34,
      "end": 536.06,
      "text": "even said"
    },
    {
      "start": 536.06,
      "end": 537.68,
      "text": "Over my dead body"
    },
    {
      "start": 537.68,
      "end": 539.14,
      "text": "Over my dead body"
    },
    {
      "start": 539.14,
      "end": 539.82,
      "text": "Wow"
    },
    {
      "start": 539.82,
      "end": 541.22,
      "text": "어디 어디"
    },
    {
      "start": 541.22,
      "end": 542.62,
      "text": "어디 먼지 들어갈 때까지"
    },
    {
      "start": 542.62,
      "end": 542.92,
      "text": "거기"
    },
    {
      "start": 542.92,
      "end": 544.06,
      "text": "막 나오더라고"
    },
    {
      "start": 544.06,
      "end": 544.88,
      "text": "맞아요 맞아요"
    },
    {
      "start": 544.88,
      "end": 545.68,
      "text": "눈에 먼지가"
    },
    {
      "start": 545.68,
      "end": 547.02,
      "text": "내 눈에 흙이 들어가기"
    },
    {
      "start": 547.02,
      "end": 547.72,
      "text": "전까지는 안돼"
    },
    {
      "start": 547.72,
      "end": 547.98,
      "text": "흙이죠"
    },
    {
      "start": 547.98,
      "end": 549.68,
      "text": "Over my dead body"
    },
    {
      "start": 549.68,
      "end": 551.04,
      "text": "그 다음 장면은"
    },
    {
      "start": 551.04,
      "end": 551.98,
      "text": "장례식이죠"
    },
    {
      "start": 551.98,
      "end": 552.84,
      "text": "funeral"
    },
    {
      "start": 552.84,
      "end": 555.52,
      "text": "어떻게 죽었을까"
    },
    {
      "start": 555.52,
      "end": 556.14,
      "text": "앨리스가"
    },
    {
      "start": 556.14,
      "end": 558.4,
      "text": "그 장례식 이후에"
    },
    {
      "start": 558.4,
      "end": 560.1,
      "text": "아주 미소를 지으면서"
    },
    {
      "start": 560.1,
      "end": 562.06,
      "text": "그럼 클럽에서 만나요"
    },
    {
      "start": 562.06,
      "end": 562.86,
      "text": "이러면서"
    },
    {
      "start": 562.86,
      "end": 563.76,
      "text": "지나가면서"
    },
    {
      "start": 563.76,
      "end": 564.64,
      "text": "인사를 했던 게"
    },
    {
      "start": 564.64,
      "end": 565.64,
      "text": "생각이 나면서"
    },
    {
      "start": 565.64,
      "end": 566.56,
      "text": "오싹 하면서"
    },
    {
      "start": 566.56,
      "end": 568.94,
      "text": "웃픈 현실이었습니다"
    },
    {
      "start": 568.94,
      "end": 572.9,
      "text": "정말 궁금한데요"
    },
    {
      "start": 572.9,
      "end": 575.04,
      "text": "한 번 더 확인해 보시죠"
    },
    {
      "start": 575.04,
      "end": 576.18,
      "text": "So Alice"
    },
    {
      "start": 576.18,
      "end": 580.52,
      "text": "we noticed you signed up for the cheerleading tryouts"
    },
    {
      "start": 580.52,
      "end": 581.42,
      "text": "Oh yes"
    },
    {
      "start": 581.42,
      "end": 582.86,
      "text": "I saw your flyer"
    },
    {
      "start": 582.86,
      "end": 584.22,
      "text": "It sounded fun"
    },
    {
      "start": 584.22,
      "end": 585.92,
      "text": "Why didn't you come?"
    },
    {
      "start": 586.38,
      "end": 586.64,
      "text": "Well"
    },
    {
      "start": 586.64,
      "end": 588.04,
      "text": "I wanted to"
    },
    {
      "start": 588.04,
      "end": 588.58,
      "text": "but"
    },
    {
      "start": 588.58,
      "end": 592.32,
      "text": "my husband doesn't like me out too much on my own"
    },
    {
      "start": 592.32,
      "end": 594.98,
      "text": "I took a sewing class last year"
    },
    {
      "start": 594.98,
      "end": 598.3,
      "text": "and he had to make his own dinners on Wednesday nights"
    },
    {
      "start": 598.3,
      "end": 600.7,
      "text": "Well that sounds traumatic of course"
    },
    {
      "start": 600.7,
      "end": 603.56,
      "text": "What if we practiced in the morning"
    },
    {
      "start": 603.56,
      "end": 606.0,
      "text": "and then you could get home in time for dinner"
    },
    {
      "start": 606.0,
      "end": 608.9,
      "text": "강지영님께서"
    },
    {
      "start": 608.9,
      "end": 610.1,
      "text": "크쌤"
    },
    {
      "start": 610.1,
      "end": 612.18,
      "text": "재미있는 크쌤 덕에"
    },
    {
      "start": 612.18,
      "end": 613.94,
      "text": "방송이 더 재밌어요"
    },
    {
      "start": 613.94,
      "end": 615.3,
      "text": "Wow thank you"
    },
    {
      "start": 615.3,
      "end": 616.0,
      "text": "Glad to hear"
    },
    {
      "start": 616.0,
      "end": 616.2,
      "text": "맞습니다"
    },
    {
      "start": 616.2,
      "end": 618.04,
      "text": "우리 크쌤 덕분에"
    },
    {
      "start": 618.04,
      "end": 619.56,
      "text": "이 시간이 너무너무 행복해요"
    },
    {
      "start": 619.56,
      "end": 620.64,
      "text": "저도 행복합니다"
    },
    {
      "start": 620.64,
      "end": 621.5,
      "text": "여러분 덕분에"
    },
    {
      "start": 621.5,
      "end": 621.86,
      "text": "Thank you very much"
    },
    {
      "start": 621.86,
      "end": 624.74,
      "text": "우리는 그럼 내일 다시 만나겠습니다"
    }
  ]
}