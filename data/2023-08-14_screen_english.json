    },
    {
      "start": 664.27,
      "end": 666.55,
      "text": "되게 재밌는 표현이었죠."
    },
    {
      "start": 666.95,
      "end": 668.73,
      "text": "그냥 no 라고 해도 되는데"
    },
    {
      "start": 668.73,
      "end": 670.29,
