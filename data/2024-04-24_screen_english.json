      "text": "아, 그럼요."
    },
    {
      "start": 456.78,
      "end": 457.42,
      "text": "확실합니다."
    },
    {
      "start": 457.58,
      "end": 458.14,
      "text": "That's for sure."
    },
    {
      "start": 458.24,
      "end": 458.42,
      "text": "Yeah."
    },
    {
      "start": 458.56,
      "end": 459.06,
      "text": "That's for sure."
    },
    {
      "start": 459.14,
      "end": 460.6,
      "text": "이렇게 대답도 가능합니다."
    },
    {
      "start": 460.6,
      "end": 461.48,
      "text": "That's for sure."
    },
    {
      "start": 461.48,
