    },
    {
      "start": 191.63,
      "end": 191.81,
      "text": "네."
    },
    {
      "start": 191.97,
      "end": 192.27,
      "text": "감사합니다."
    },
    {
      "start": 192.89,
      "end": 193.61,
      "text": "이름 카페야죠."
    },
    {
      "start": 193.73,
      "end": 194.27,
      "text": "아 그럼요."
    },
    {
      "start": 194.51,
      "end": 195.99,
      "text": "이렇게 사람뿐만 아니라"
    },
    {
      "start": 195.99,
      "end": 197.29,
