    {
      "start": 170.87,
      "end": 171.25,
      "text": "와"
    },
    {
      "start": 171.25,
      "end": 174.11,
      "text": "그래서 KBS에"
    },
    {
      "start": 174.11,
      "end": 175.03,
      "text": "왔나?"
    },
    {
      "start": 175.35,
      "end": 176.43,
      "text": "어진 방송국에"
    },
    {
      "start": 176.43,
      "end": 177.77,
      "text": "이렇게 심어놨어요."
    },
    {
      "start": 177.79,
      "end": 178.13,
      "text": "어진 방송국."
    },
    {
      "start": 178.49,
      "end": 178.79,
      "text": "그렇죠."
    },
    {
      "start": 178.95,
      "end": 179.45,
      "text": "I'm jealous."
    },
    {
      "start": 179.57,
      "end": 181.15,
      "text": "You have a really beautiful meaning"
    },
    {
      "start": 181.15,
      "end": 182.17,
