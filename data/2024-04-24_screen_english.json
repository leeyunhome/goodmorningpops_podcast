    },
    {
      "start": 646.48,
      "end": 647.28,
      "text": "풀어야겠다."
    },
    {
      "start": 647.7,
      "end": 648.84,
      "text": "Please blow your nose."
    },
    {
      "start": 649.18,
      "end": 649.88,
      "text": "Here's a Kleenex."
    },
    {
      "start": 649.92,
      "end": 651.56,
      "text": "이미 코가 흐르고 있었어요."
    },
    {
      "start": 652.7,
      "end": 653.42,
      "text": "그렇군요."
    },
    {
      "start": 654.08,
      "end": 656.18,
      "text": "목적지에 거의 다 왔어."
    },
