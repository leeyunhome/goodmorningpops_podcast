    {
      "start": 239.99,
      "end": 248.67,
      "text": "Oh, 비슷합니다."
    },
    {
      "start": 248.67,
      "end": 250.19,
      "text": "They're in the dolphin family."
    },
    {
      "start": 250.91,
      "end": 252.39,
      "text": "And this actually means"
    },
    {
