    },
    {
      "start": 440.72,
      "end": 441.64,
      "text": "끼워 맞춰야죠."
    },
    {
      "start": 441.64,
      "end": 442.8,
      "text": "그죠."
    },
    {
      "start": 443.16,
      "end": 444.02,
      "text": "안 되면 되게 알아."
    },
    {
      "start": 444.88,
      "end": 446.04,
      "text": "아주 좋습니다."
    },
    {
      "start": 446.2,
      "end": 446.7,
      "text": "아, 좋습니다."
    },
    {
      "start": 446.82,
      "end": 447.86,
      "text": "회장님 말씀 따라야죠."
