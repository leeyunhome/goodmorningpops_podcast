    },
    {
      "start": 310.12,
      "end": 311.82,
      "text": "and that whole range"
    },
    {
      "start": 311.82,
      "end": 312.9,
      "text": "the wide range."
    },
    {
      "start": 313.5,
      "end": 313.82,
      "text": "So 가끔"
