    {
      "start": 285.75,
      "end": 288.03,
      "text": "in Russian."
    },
    {
      "start": 288.21,
      "end": 288.41,
      "text": "Yeah."
    },
    {
      "start": 289.41,
      "end": 289.85,
      "text": "이렇게"
    },
    {
      "start": 289.85,
      "end": 291.69,
      "text": "러시아어에서부터"
    },
    {
      "start": 291.69,
      "end": 293.33,
      "text": "차용이 되었다는 것까지"
