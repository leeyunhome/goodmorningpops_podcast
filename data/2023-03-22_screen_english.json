      "start": 153.89,
      "end": 154.35,
      "text": "네"
    },
    {
      "start": 154.35,
      "end": 155.99,
      "text": "점점 정들고 있어요"
    },
    {
      "start": 155.99,
      "end": 156.39,
      "text": "Yeah"
    },
    {
      "start": 156.39,
      "end": 156.63,
      "text": "you"
    },
    {
      "start": 156.63,
      "end": 157.51,
      "text": "I mean"
    },
    {
      "start": 157.51,
      "end": 158.13,
      "text": "I am too"
    },
    {
      "start": 158.13,
      "end": 159.15,
      "text": "Everybody is"
    },
    {
      "start": 159.15,
      "end": 160.23,
      "text": "He's a sweetheart"
    },
    {
      "start": 160.23,
      "end": 160.89,
      "text": "맞아요"
    },
    {
      "start": 160.89,
      "end": 161.53,
      "text": "and a hero"
    },
    {
      "start": 161.53,
      "end": 162.85,
      "text": "그런데"
    },
    {
      "start": 162.85,
      "end": 163.65,
      "text": "이게"
    },
    {
      "start": 163.65,
      "end": 166.13,
      "text": "다른 강아지 종류도 아니고"
    },
    {
      "start": 166.13,
      "end": 167.69,
      "text": "새잖아요"
    },
    {
      "start": 167.69,
      "end": 168.47,
      "text": "A bird"
    },
    {
      "start": 168.47,
      "end": 169.21,
      "text": "네"
    },
    {
      "start": 169.21,
      "end": 170.57,
      "text": "그럼 새라는 것은"
    },
    {
      "start": 170.57,
      "end": 170.97,
      "text": "곧"
    },
    {
      "start": 170.97,
      "end": 171.95,
      "text": "can fly"
    },
    {
      "start": 171.95,
      "end": 173.09,
      "text": "할 수 있다는 거잖아요"
    },
    {
      "start": 173.09,
      "end": 174.23,
      "text": "Most birds"
    },
    {
      "start": 174.23,
      "end": 175.17,
      "text": "except like"
    },
    {
      "start": 175.17,
      "end": 176.09,
      "text": "ostriches"
    },
    {
      "start": 176.09,
      "end": 176.35,
      "text": "어"
    },
    {
      "start": 176.35,
      "end": 176.63,
      "text": "그죠"
    },
    {
      "start": 176.63,
      "end": 177.59,
      "text": "타조 빼고는"
    },
    {
      "start": 177.59,
      "end": 178.65,
      "text": "펭귄"
    },
    {
      "start": 178.65,
      "end": 179.55,
      "text": "몇 개 빼고는"
    },
    {
      "start": 179.55,
      "end": 180.03,
      "text": "펭귄"
    },
    {
      "start": 180.03,
