    {
      "start": 190.94,
      "end": 191.5,
      "text": "No, I'm kidding."
    },
    {
      "start": 191.58,
      "end": 192.34,
      "text": "I can't do anything."
    },
    {
      "start": 192.72,
      "end": 197.36,
      "text": "Like someone in, like my dad, my friend's dad, he could fix the toilet."
    },
