    },
    {
      "start": 164.9,
      "end": 166.64,
      "text": "네, 그 겨레 왕국 봤으면."
    },
    {
      "start": 166.76,
      "end": 168.18,
      "text": "네, 봤는데 기억이 안 나요."
    },
    {
      "start": 168.24,
      "end": 168.64,
      "text": "미안해요."
    },
    {
      "start": 168.72,
      "end": 169.46,
      "text": "노래 들었으면."
    },
    {
      "start": 169.96,
      "end": 173.68,
      "text": "네, 근데 다재다능한 사람한테 칭할 수 있는 또 다른 표현으로"
    },
    {
      "start": 173.68,
      "end": 174.44,
      "text": "막 그런 거 있잖아요."
    },
    {
      "start": 174.8,
      "end": 176.6,
      "text": "It's the jack of all trades."
    },
    {
      "start": 176.82,
      "end": 177.54,
      "text": "That's good."
    },
    {
      "start": 178.18,
      "end": 179.1,
      "text": "Jack of all trades."
    },
    {
      "start": 179.6,
      "end": 180.72,
      "text": "A renaissance man."
    },
    {
      "start": 180.8,
      "end": 182.32,
      "text": "Oh, a renaissance man."
    },
    {
