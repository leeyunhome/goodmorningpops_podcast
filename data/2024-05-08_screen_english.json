    },
    {
      "start": 184.66,
      "end": 185.88,
      "text": "와, 되게 고급지다."
    },
    {
      "start": 186.16,
      "end": 186.76,
      "text": "Oh, thank you."
    },
    {
      "start": 186.84,
      "end": 187.84,
      "text": "I'm a very 고급진 남자."
    },
    {
      "start": 188.02,
      "end": 188.26,
      "text": "Yeah."
    },
    {
      "start": 188.54,
      "end": 189.54,
      "text": "I'm a renaissance man."
    },
    {
      "start": 189.6,
      "end": 190.52,
      "text": "아, 스스로?"
