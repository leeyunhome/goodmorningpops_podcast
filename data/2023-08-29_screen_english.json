    {
      "start": 848.88,
      "end": 850.58,
      "text": "틈에 사이에"
    },
    {
      "start": 850.58,
      "end": 853.12,
      "text": "You will forget where you came from"
    },
    {
      "start": 853.12,
      "end": 855.46,
      "text": "너는 네가 어디에서 왔는지도"
    },
    {
      "start": 855.46,
      "end": 856.46,
      "text": "잊게 될 거야"
    },
    {
      "start": 856.46,
      "end": 858.6,
      "text": "I can totally identify with that"
    },
    {
      "start": 858.6,
      "end": 860.02,
      "text": "When you go to a new world"
    },
    {
      "start": 860.02,
      "end": 862.04,
      "text": "You just forget where you came from"
    },
    {
      "start": 862.04,
      "end": 863.78,
      "text": "And you just dive into it"
    },
    {
      "start": 863.78,
      "end": 864.98,
      "text": "You plunge into it"
    },
    {
      "start": 864.98,
      "end": 866.9,
      "text": "And absorb new things"
    },
    {
      "start": 866.9,
      "end": 868.26,
      "text": "That's so beautiful"
    },
    {
      "start": 868.26,
      "end": 868.9,
      "text": "I like that"
    },
    {
      "start": 868.9,
      "end": 869.46,
      "text": "맞아요"
    },
    {
      "start": 869.46,
      "end": 871.3,
      "text": "어떤 새로운 문화나"
    },
    {
      "start": 871.3,
      "end": 874.46,
      "text": "새로운 특정한 장소에"
    },
    {
      "start": 874.46,
      "end": 875.58,
      "text": "놓여지게 되면"
    },
    {
      "start": 875.58,
      "end": 877.3,
      "text": "그곳에 우리가 완벽하게"
    },
    {
      "start": 877.3,
      "end": 878.12,
      "text": "몰입을 한다면"
    },
    {
      "start": 878.12,
      "end": 879.82,
      "text": "내가 어디에서 왔는지"
    },
    {
      "start": 879.82,
      "end": 881.46,
      "text": "시간 가는지"
    },
    {
      "start": 881.46,
      "end": 882.06,
      "text": "그렇죠"
    },
    {
      "start": 882.06,
      "end": 883.0,
      "text": "뭐 몰라요"
    },
    {
      "start": 883.0,
      "end": 883.96,
      "text": "일도 몰라요"
    },
    {
      "start": 883.96,
      "end": 884.36,
      "text": "맞아요"
    },
    {
      "start": 884.36,
      "end": 885.6,
      "text": "그냥 가는 거예요"
    },
    {
      "start": 885.6,
      "end": 886.96,
      "text": "세월 흐리는 거죠"
    },
    {
      "start": 886.96,
      "end": 887.84,
      "text": "가는 거예요"
    },
    {
      "start": 887.84,
      "end": 889.68,
      "text": "강가듯이"
    },
    {
      "start": 889.68,
      "end": 891.52,
      "text": "네 명언입니다"
    },
    {
      "start": 891.52,
      "end": 892.42,
      "text": "그러면 이 장면"
    },
    {
      "start": 892.42,
      "end": 893.46,
      "text": "한 번 더 들어볼게요"
    },
    {
      "start": 893.46,
      "end": 896.46,
      "text": "You will see so many living things"
    },
    {
      "start": 896.46,
      "end": 898.37,
      "text": "Plants and animals"
    },
    {
      "start": 898.37,
      "end": 899.35,
      "text": "beyond imagining"
    },
    {
      "start": 899.35,
      "end": 902.26,
      "text": "Here it is always the same"
    },
    {
      "start": 902.26,
      "end": 903.64,
      "text": "But there"
    },
    {
      "start": 903.64,
      "end": 905.04,
      "text": "everything is in motion"
    },
    {
      "start": 905.04,
      "end": 906.04,
      "text": "Everything"
    },
    {
      "start": 906.04,
      "end": 908.22,
      "text": "is always changing"
    },
    {
      "start": 908.22,
      "end": 911.17,
      "text": "Be plunged into"
    },
    {
      "start": 911.17,
      "end": 912.43,
      "text": "Earth's river of time"
    },
    {
      "start": 912.43,
      "end": 915.35,
      "text": "There will be so much"
    },
    {
      "start": 915.35,
      "end": 915.99,
      "text": "for you to learn"
    },
    {
      "start": 915.99,
      "end": 919.46,
      "text": "And so much for you to feel"
    },
    {
      "start": 919.46,
      "end": 921.0,
      "text": "Pleasure"
    },
    {
      "start": 921.0,
      "end": 922.02,
      "text": "and fear"
    },
    {
      "start": 922.02,
      "end": 924.18,
      "text": "Joy"
    },
    {
      "start": 924.18,
      "end": 925.34,
      "text": "and disappointment"
    },
    {
      "start": 925.34,
      "end": 926.97,
      "text": "Sadness"
    },
    {
      "start": 926.97,
      "end": 928.37,
      "text": "and wonder"
    },
    {
      "start": 928.37,
      "end": 933.0,
      "text": "In your confusion"
    },
    {
      "start": 933.0,
      "end": 933.6,
      "text": "and delight"
    },
    {
      "start": 933.6,
      "end": 935.12,
      "text": "You will forget"
    },
    {
      "start": 935.12,
      "end": 936.46,
      "text": "where you came from"
    },
    {
      "start": 936.46,
      "end": 938.88,
      "text": "It would be so great"
    },
    {
      "start": 938.88,
      "end": 939.9,
      "text": "to give advice"
    },
    {
      "start": 939.9,
      "end": 941.68,
      "text": "to children like this"
    },
    {
      "start": 941.68,
      "end": 942.3,
      "text": "진짜"
    },
    {
      "start": 942.3,
      "end": 942.66,
      "text": "Yeah"
    },
    {
      "start": 942.66,
      "end": 943.66,
      "text": "I want to get this book"
    },
    {
      "start": 943.66,
      "end": 944.42,
      "text": "for my kids"
    },
    {
      "start": 944.42,
      "end": 945.98,
      "text": "Great bedtime story"
    },
    {
      "start": 945.98,
      "end": 946.78,
      "text": "Good idea"
    },
    {
      "start": 946.78,
      "end": 946.82,
      "text": "Good idea"
    },
    {
      "start": 946.82,
      "end": 947.28,
      "text": "Good idea"
    },
    {
      "start": 947.28,
      "end": 949.34,
      "text": "많은 경우에는"
    },
    {
      "start": 949.34,
      "end": 949.96,
      "text": "아이들한테"
    },
    {
      "start": 949.96,
      "end": 951.18,
      "text": "공부해라"
    },
    {
      "start": 951.18,
      "end": 952.14,
      "text": "숙제했니?"
    },
    {
      "start": 952.34,
      "end": 953.52,
      "text": "이런 이야기로"
    },
    {
      "start": 953.52,
      "end": 955.02,
      "text": "자기 전에 마무리를"
    },
    {
      "start": 955.02,
      "end": 956.3,
      "text": "하게 되는 경우가 있을 텐데"
    },
    {
      "start": 956.3,
      "end": 956.96,
      "text": "그렇죠"
    },
    {
      "start": 956.96,
      "end": 958.12,
      "text": "학습지 했냐"
    },
    {
      "start": 958.12,
      "end": 959.08,
      "text": "빨리 해"
    },
    {
      "start": 959.08,
      "end": 961.44,
      "text": "경험담 같으신데요"
    },
    {
      "start": 961.44,
      "end": 962.08,
      "text": "가끔"
    },
    {
      "start": 962.08,
      "end": 963.3,
      "text": "가끔"
    },
    {
      "start": 963.3,
      "end": 965.12,
      "text": "이제는 오늘은"
    },
    {
      "start": 965.12,
      "end": 966.96,
      "text": "이제 조니 삼촌의"
    },
    {
      "start": 966.96,
      "end": 968.12,
      "text": "이 장면을 통해서"
    },
    {
      "start": 968.12,
      "end": 969.9,
      "text": "좀 더 추상적이면서"
    },
    {
      "start": 969.9,
      "end": 971.62,
      "text": "인생이란 무엇인지"
    },
    {
      "start": 971.62,
      "end": 973.86,
      "text": "좀 깊은 이야기를 하면서"
    },
    {
      "start": 973.86,
      "end": 975.84,
      "text": "아이들이 잠을 쏠쏠"
    },
    {
      "start": 975.84,
      "end": 977.16,
      "text": "이룰 수 있지 않을까"
    },
    {
      "start": 977.16,
      "end": 977.94,
      "text": "예상합니다"
    },
    {
      "start": 977.94,
      "end": 979.34,
      "text": "Beautiful"
    },
    {
      "start": 979.34,
      "end": 980.56,
      "text": "I hope they have a deep sleep"
    },
    {
      "start": 980.56,
      "end": 981.48,
      "text": "Sleep tight"
    },
    {
      "start": 981.48,
      "end": 982.56,
      "text": "Don't let the bed bugs bite"
    },
    {
      "start": 982.56,
      "end": 984.92,
      "text": "이 도경님께서"
    },
    {
      "start": 984.92,
      "end": 985.78,
      "text": "크리스쌤"
    },
    {
      "start": 985.78,
      "end": 986.64,
      "text": "바이바이"
    },
    {
      "start": 986.64,
      "end": 987.22,
      "text": "하셨어요"
    },
    {
      "start": 987.22,
      "end": 988.04,
      "text": "바이바이"
    },
    {
      "start": 988.04,
      "end": 988.46,
      "text": "네"
    },
    {
      "start": 988.46,
      "end": 989.82,
      "text": "우린 내일 이어갈게요"
    },
    {
      "start": 989.82,
      "end": 990.56,
      "text": "I'll see you then"
    }
  ]
}