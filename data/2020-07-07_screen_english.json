    },
    {
      "start": 738.33,
      "end": 741.89,
      "text": "이라고 하면서 주방으로 이렇게 딱 가는 그런 장면이 생각이 나요."
    },
    {
      "start": 742.55,
      "end": 744.09,
      "text": "저는 저녁 차릴게요."
    },
    {
      "start": 744.43,
      "end": 744.83,
      "text": "라고 합니다."
    },
    {
      "start": 745.01,
      "end": 746.51,
      "text": "Very good timing, Gareth."
    },
    {
      "start": 746.51,
      "end": 749.07,
      "text": "That's how to escape this kind of situation."
    },
    {
      "start": 749.29,
      "end": 750.41,
      "text": "Yeah, very sweet and wise."
    },
    {
      "start": 750.81,
      "end": 753.29,
      "text": "I can definitely identify with Mr. Gareth."
    },
    {
      "start": 753.39,
