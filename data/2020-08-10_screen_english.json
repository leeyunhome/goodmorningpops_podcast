    {
      "start": 466.14,
      "end": 467.72,
      "text": "Very, very strange"
    },
    {
      "start": 467.72,
      "end": 468.32,
      "text": "맞아요"
    },
    {
      "start": 468.32,
      "end": 470.78,
      "text": "아무튼 되게 재밌게 표현이 된 것 같은데요"
    },
    {
      "start": 470.78,
      "end": 472.1,
      "text": "내용을 한번 알아볼까요?"
