    {
      "start": 744.25,
      "end": 744.81,
      "text": "Exactly."
    },
    {
      "start": 746.09,
      "end": 746.95,
      "text": "I don't know."
    },
    {
      "start": 747.15,
      "end": 748.31,
      "text": "그랬더니 I don't know."
    },
    {
      "start": 748.61,
      "end": 751.33,
      "text": "되게 또 쿨하게, 시크하게 대답합니다."
    },
    {
      "start": 751.41,
      "end": 751.89,
      "text": "I don't know."
    },
    {
      "start": 752.03,
      "end": 752.51,
      "text": "I don't know."
    },
    {
      "start": 752.67,
      "end": 753.23,
      "text": "We'll see."
    },
    {
      "start": 753.47,
      "end": 753.75,
      "text": "Yeah."
    },
    {
      "start": 753.97,
      "end": 755.01,
      "text": "한번 봐야 되겠네요."
    },
    {
      "start": 755.01,
      "end": 756.73,
      "text": "이 장면 한 번 더 들어보시죠."
    },
    {
      "start": 756.73,
      "end": 760.47,
      "text": "Most people who are terrified of singing don't sign up for choir."
    },
    {
      "start": 760.95,
      "end": 762.31,
      "text": "Other kids make me nervous."
    },
    {
      "start": 762.91,
      "end": 763.83,
      "text": "I used to get me fun of."
    },
    {
      "start": 764.33,
      "end": 768.15,
      "text": "I talked funny when I first started school."
    },
    {
      "start": 768.83,
      "end": 770.95,
      "text": "You're the girl with the depth family?"
    },
    {
      "start": 771.51,
      "end": 772.29,
      "text": "Everyone but you?"
    },
    {
      "start": 772.85,
      "end": 773.09,
      "text": "Yeah."
    },
    {
      "start": 773.73,
      "end": 774.41,
      "text": "And you sing."
    },
    {
      "start": 775.13,
      "end": 775.57,
      "text": "Interesting."
    },
    {
      "start": 776.25,
      "end": 776.89,
      "text": "Are you any good?"
    },
    {
      "start": 777.39,
      "end": 777.85,
      "text": "I don't know."
    },
    {
      "start": 777.85,
      "end": 785.9,
      "text": "정민정 님께서 서울에서 크서방은 못 찾겠지만 매일매일 방송으로 챙겨드릴게요."
    },
    {
      "start": 786.4,
      "end": 790.4,
      "text": "정연쌤, 크리스쌤 항상 재밌게 설명해 주셔서 감사해요."
    },
    {
      "start": 790.62,
      "end": 791.04,
      "text": "웃음 웃음."
    },
    {
      "start": 791.1,
      "end": 791.78,
      "text": "I love you."
    }
  ]
}