    {
      "start": 440.1,
      "end": 441.42,
      "text": "막 오바에서 얘기하는"
    },
    {
      "start": 441.42,
      "end": 441.56,
      "text": "Yeah"
    },
    {
      "start": 441.56,
      "end": 444.9,
      "text": "So how was your first winter in Korea?"
    },
    {
      "start": 445.28,
