    {
      "start": 389.17,
      "end": 389.79,
      "text": "on a trip"
    },
    {
      "start": 389.79,
      "end": 391.29,
      "text": "But not too attached"
    },
    {
      "start": 391.29,
      "end": 392.25,
      "text": "Just a weekend"
    },
    {
      "start": 392.25,
      "end": 393.35,
      "text": "Saturday, Sunday"
    },
    {
      "start": 393.35,
      "end": 394.47,
      "text": "주말이면 충분한가요?"
    },
    {
      "start": 394.63,
      "end": 395.51,
