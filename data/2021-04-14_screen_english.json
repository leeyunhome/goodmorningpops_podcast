    {
      "start": 379.47,
      "end": 380.43,
      "text": "적당히만"
    },
    {
      "start": 380.43,
      "end": 383.11,
      "text": "I wish someone grew a little bit attached"
    },
    {
      "start": 383.11,
      "end": 384.13,
      "text": "to my kids"
    },
    {
      "start": 384.13,
      "end": 386.81,
