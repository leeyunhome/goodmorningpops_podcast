    },
    {
      "start": 671.57,
      "end": 673.35,
      "text": "재미 진짜 완전 들어가졌어요"
    },
    {
      "start": 673.35,
      "end": 673.99,
      "text": "개판"
    },
    {
      "start": 673.99,
      "end": 676.95,
      "text": "한 번 더 확인해 볼게요"
    },
    {
      "start": 676.95,
      "end": 678.45,
      "text": "So pick me up off the street"
    },
    {
      "start": 678.45,
      "end": 679.43,
      "text": "I had no choice"
    },
    {
      "start": 679.43,
      "end": 681.15,
      "text": "Yeah, well, don't get too attached"
    },
    {
      "start": 681.15,
      "end": 683.05,
      "text": "humans will kick you out the door"
    },
    {
      "start": 683.05,
      "end": 684.27,
      "text": "any chance they get"
    },
    {
      "start": 684.27,
      "end": 687.05,
      "text": "do not trust them for a second"
    },
    {
      "start": 687.05,
      "end": 687.67,
      "text": "What?"
    },
    {
      "start": 688.09,
      "end": 689.87,
      "text": "No human would ever treat me badly"
    },
    {
      "start": 689.87,
      "end": 692.39,
      "text": "Then how come you're standing in the dark"
    },
    {
      "start": 692.39,
      "end": 693.79,
      "text": "in the freezing cold"
    },
    {
      "start": 693.79,
      "end": 696.21,
      "text": "next to a pile of garbage cans"
    },
    {
      "start": 696.21,
      "end": 699.43,
      "text": "네, 안현희 님께서요"
    },
    {
      "start": 699.43,
      "end": 701.39,
      "text": "로라쌤, 크리스쌤"
    },
    {
      "start": 701.39,
      "end": 703.09,
      "text": "두 분 연기도 good"
    },
    {
      "start": 703.09,
      "end": 705.43,
      "text": "귀여운 수다쟁이 크리스님"
    },
    {
      "start": 705.43,
      "end": 706.27,
      "text": "고마워요"
    },
    {
      "start": 706.27,
      "end": 707.97,
      "text": "한국 사람 다 됐어요"
    },
    {
      "start": 707.97,
      "end": 709.69,
      "text": "Have an amazing day"
    },
    {
      "start": 709.69,
      "end": 711.39,
      "text": "You too, thank you"
    },
    {
      "start": 711.39,
      "end": 713.61,
      "text": "귀여운 수다쟁이 크리스님"
    },
    {
      "start": 713.61,
      "end": 715.57,
      "text": "이거 딱 어울리는 표현인 것 같아요"
    },
    {
      "start": 715.57,
      "end": 716.25,
      "text": "아주 좋아요"
    },
    {
      "start": 716.25,
      "end": 716.59,
      "text": "네"
    },
    {
      "start": 716.59,
      "end": 718.99,
      "text": "우리 또 연기들이 좀"
    },
    {
      "start": 718.99,
      "end": 719.21,
      "text": "왜?"
    },
    {
      "start": 719.47,
      "end": 721.71,
      "text": "좀 일부러라도 해보는 게 좋을 것 같아요"
    },
    {
      "start": 721.71,
      "end": 722.19,
      "text": "그러니까요"
    },
    {
      "start": 722.19,
      "end": 723.87,
      "text": "우리 연기하고 있었던 거 아니었어요?"
    },
    {
      "start": 723.87,
      "end": 726.25,
      "text": "뭐 하다 말도 하다 말도 하는데"
    },
    {
      "start": 726.25,
      "end": 726.87,
      "text": "맞네"
    },
    {
      "start": 726.87,
      "end": 728.33,
      "text": "한번 제대로 해야 되겠네"
    },
    {
      "start": 728.33,
      "end": 729.99,
      "text": "성내모사, 개인 성내모사"
    },
    {
      "start": 729.99,
      "end": 730.37,
      "text": "좋았고"
    },
    {
      "start": 730.37,
      "end": 731.01,
      "text": "네, 어저께 했던"
    },
    {
      "start": 731.01,
      "end": 732.87,
      "text": "열심히 하겠습니다"
    },
    {
      "start": 732.87,
      "end": 735.39,
      "text": "네, 같이 좀 이렇게 호흡 좀 맞춰봐요"
    },
    {
      "start": 735.39,
      "end": 736.25,
      "text": "네, 알겠어요"
    },
    {
      "start": 736.25,
      "end": 738.53,
      "text": "자, 스크린 잉글리시 오늘 여기까지입니다"
    }
  ]
}