      "text": "Yeah."
    },
    {
      "start": 558.32,
      "end": 560.76,
      "text": "And he stayed in the mansion to get some rest."
    },
    {
      "start": 561.08,
      "end": 562.52,
      "text": "He's always resting."
    },
