  "script": [
    {
      "start": 0.0,
      "end": 1.86,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 1.86,
      "end": 20.23,
      "text": "나의 집이란 장소가 아니라 사람들이다"
    },
    {
      "start": 20.23,
      "end": 25.51,
      "text": "공상과학 소설가 루이스 맥마스터 무조울이 한 말입니다"
    },
    {
      "start": 25.51,
      "end": 31.46,
      "text": "화려하고 멋진 집에 내가 싫어하는 사람들과 함께 있다면"
    },
    {
      "start": 31.46,
      "end": 35.1,
      "text": "과연 그 집에 오래 머물고 싶을까요?"
    },
    {
      "start": 35.1,
      "end": 42.05,
      "text": "반대로 집은 좀 초라해도 서로 아껴주는 사람들과 함께 있다면"
    },
    {
      "start": 42.05,
      "end": 45.73,
      "text": "시간 가는 줄 모르고 웃음꽃을 피우지 않을까요?"
    },
    {
      "start": 47.15,
      "end": 50.97,
      "text": "우린 항상 더 크고 더 멋진 집을 꿈꾸지만"
    },
    {
      "start": 50.97,
      "end": 58.06,
      "text": "누구와 함께 그 공간과 시간을 채워나가는지가 훨씬 더 중요한 거겠죠"
    },
    {
      "start": 58.06,
      "end": 62.25,
      "text": "My home is not a place, it is people"
    },
    {
      "start": 62.25,
      "end": 68.17,
      "text": "여러분에게 또 하나의 home이 되고 싶은 조정현의 굿모닝 팝스"
    },
    {
      "start": 68.17,
      "end": 68.99,
      "text": "시작하겠습니다"
    },
    {
      "start": 68.99,
      "end": 75.64,
      "text": "네, 일요일 첫 곡으로 에릭 클랩턴의 Tears in Heaven 이었습니다"
    },
    {
      "start": 75.64,
      "end": 81.69,
      "text": "편안하고 또 마음에 따뜻한 채움이 있는"
    },
    {
      "start": 81.69,
      "end": 86.91,
      "text": "그런 스윗 홈 그런 존재가 되고 싶네요"
    },
    {
      "start": 86.91,
      "end": 89.65,
      "text": "5195님"
    },
    {
      "start": 89.65,
      "end": 93.61,
      "text": "강릉으로 휴가 가는 중인데 굿모닝 팝스 듣고 있습니다"
    },
    {
      "start": 93.61,
      "end": 97.77,
      "text": "남편과 좋은 팝송 들으며 기분 좋게 갑니다"
    },
    {
      "start": 97.77,
      "end": 99.89,
      "text": "늘 감사합니다 하트"
    },
    {
      "start": 99.89,
      "end": 104.57,
      "text": "와 열심히 일한 후에 떠나는 휴가라면"
    },
    {
      "start": 104.57,
      "end": 110.71,
      "text": "이렇게 시작부터 발걸음도 가볍고 더 즐거울 수밖에 없는 거죠"
    },
    {
      "start": 110.71,
      "end": 117.5,
      "text": "평소에도 그렇고 지금도 심지어 휴가 기간인데도 불구하고"
    },
    {
      "start": 117.5,
      "end": 120.78,
      "text": "애청해 주셔서요 정말 감사드립니다"
    },
    {
      "start": 120.78,
      "end": 123.2,
      "text": "강릉 어디로 가시나요?"
    },
    {
      "start": 124.22,
      "end": 126.64,
      "text": "왠지 수목원도 괜찮을 것 같고요"
    },
    {
      "start": 126.64,
      "end": 130.6,
      "text": "아무튼 우리 5195님"
    },
    {
      "start": 130.6,
      "end": 135.46,
      "text": "남편분과 안전하고 즐거운 휴가 잘 보내시고 오세요"
    },
    {
      "start": 135.46,
      "end": 137.72,
      "text": "신금수님"
    },
    {
      "start": 137.72,
      "end": 142.84,
      "text": "아주 오래전 20대일 때 출근할 때마다 들었던 굿모닝 팝스"
    },
    {
      "start": 142.84,
      "end": 144.38,
      "text": "오랜만에 들어도 좋네요"
    },
    {
      "start": 144.38,
      "end": 148.58,
      "text": "활력 있는 목소리를 아침마다 들려주셔서 감사합니다"
    },
    {
      "start": 148.58,
      "end": 150.82,
      "text": "늘 건강 유의하세요"
    },
    {
      "start": 150.82,
      "end": 154.64,
      "text": "와 반갑습니다 신금수님"
    },
    {
      "start": 154.64,
      "end": 157.6,
      "text": "20대를 회상해 보시면서"
    },
    {
      "start": 157.6,
      "end": 161.68,
      "text": "지금도 여전히 그런 젊은 에너지"
    },
    {
      "start": 161.68,
      "end": 165.68,
      "text": "건강한 에너지로 애청해 주실 거라고 믿습니다"
    },
    {
      "start": 165.68,
      "end": 168.84,
      "text": "그리고 이제 가끔이 아니고"
    },
    {
      "start": 168.84,
      "end": 172.52,
      "text": "매일 매일 들어주시기를 기대할게요"
    },
    {
      "start": 172.52,
      "end": 176.24,
      "text": "신금수님께서도요 건강 잘 챙기시고요"
    },
    {
      "start": 176.24,
      "end": 178.52,
      "text": "사연 소개되신 두 분께는"
    },
    {
      "start": 178.52,
      "end": 181.24,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴게요"
    },
    {
      "start": 181.24,
      "end": 184.44,
      "text": "이렇게 굿모닝 팝스에 사연 보내고 싶으신 분들은"
    },
    {
      "start": 184.44,
      "end": 187.04,
      "text": "홈페이지 청취자 게시판에 남겨주세요"
    },
    {
      "start": 187.04,
      "end": 189.18,
      "text": "실시간으로 듣고 계신 분들은"
    },
    {
      "start": 189.18,
      "end": 190.98,
      "text": "지금 바로 참여하실 수 있는데요"
    },
    {
      "start": 190.98,
      "end": 194.36,
      "text": "다문 50원과 장문 100원에 추가요금이 부과되는"
    },
    {
      "start": 194.36,
      "end": 196.6,
      "text": "KBS 콜 FM 문자샵 8910"
    },
    {
      "start": 196.6,
      "end": 200.66,
      "text": "아니면 KBS e라디오 문자샵 1061로 보내주시거나"
    },
    {
      "start": 200.66,
      "end": 204.32,
      "text": "무료 KBS 애플리케이션 콩 또는 마이K로 참여해 주세요"
    },
    {
      "start": 204.32,
      "end": 217.4,
      "text": "일아침 6시 조정현의 굿모닝 팝스"
    },
    {
      "start": 217.4,
      "end": 230.81,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 230.81,
      "end": 245.85,
      "text": "Part 1 Screen English"
    },
    {
      "start": 245.85,
      "end": 268.28,
      "text": "Big Trip 아기팬더 배달대의 모험의 마지막 장면과"
    },
    {
      "start": 268.28,
      "end": 272.34,
      "text": "8월의 새로운 영화 Come on Come on의 표현들도"
    },
    {
      "start": 272.34,
      "end": 274.84,
      "text": "차근차근 복습을 해볼 겁니다"
    },
    {
      "start": 274.84,
      "end": 279.38,
      "text": "먼저 7월 31일 월요일에 함께했던 7월의 영화"
    },
    {
      "start": 279.38,
      "end": 282.0,
      "text": "Big Trip 마지막 장면입니다"
    },
    {
      "start": 282.0,
      "end": 285.64,
      "text": "긴 여정을 마치고 마침내 집으로 돌아온"
    },
    {
      "start": 285.64,
      "end": 288.64,
      "text": "밍밍과 오스카는 진짜 친구가 됩니다"
    },
    {
      "start": 288.64,
      "end": 293.69,
      "text": "There's no doubt about it"
    },
    {
      "start": 293.69,
      "end": 295.99,
      "text": "There's no doubt about it"
    },
    {
      "start": 295.99,
      "end": 299.07,
      "text": "네, 특히 이 말이 들리기 바로 전에"
    },
    {
      "start": 299.07,
      "end": 300.85,
      "text": "제 기억으로는 오스카가"
    },
    {
      "start": 300.85,
      "end": 302.35,
      "text": "We are friends?"
    },
    {
      "start": 302.73,
      "end": 304.03,
      "text": "Are you sure?"
    },
    {
      "start": 304.57,
      "end": 307.23,
      "text": "이렇게 밍밍이한테 질문을 했던 게 기억이 나요"
    },
    {
      "start": 307.23,
      "end": 310.19,
      "text": "그랬을 때 밍밍이가 대답을 한 거죠"
    },
    {
      "start": 310.19,
      "end": 312.23,
      "text": "There's no doubt about it"
    },
    {
      "start": 312.23,
      "end": 313.97,
      "text": "두 말 하면 잔소리지"
    },
    {
      "start": 313.97,
      "end": 316.45,
      "text": "의심할 여지가 없지라는 말입니다"
    },
    {
      "start": 316.45,
      "end": 319.65,
      "text": "이것보다도 더 간단하게 이야기할 수도 있어요"
    },
    {
      "start": 319.65,
      "end": 322.95,
      "text": "중간에 들으셨던 no doubt 이거 있잖아요"
    },
    {
      "start": 322.95,
      "end": 326.15,
      "text": "이거 자체로도 의심하지 마"
    },
    {
      "start": 326.15,
      "end": 328.21,
      "text": "이건 두 말 하면 잔소리지"
    },
    {
      "start": 328.21,
      "end": 331.15,
      "text": "당연하지 라는 의미로 쓰일 수가 있습니다"
    },
    {
      "start": 331.15,
      "end": 334.35,
      "text": "그럼 The Big Trip 마지막 장면 들어보시죠"
    },
    {
      "start": 334.35,
      "end": 338.37,
      "text": "Home sweet home"
    },
    {
      "start": 338.37,
      "end": 343.24,
      "text": "That was one big trip"
    },
    {
      "start": 343.24,
      "end": 348.83,
      "text": "Well, guess I'll be going then"
    },
    {
      "start": 348.83,
      "end": 351.05,
      "text": "It was nice traveling with you, Mick Mick"
    },
    {
      "start": 351.05,
      "end": 353.97,
      "text": "Hey, Oscar"
    },
    {
      "start": 353.97,
      "end": 354.67,
      "text": "Yeah?"
    },
    {
      "start": 355.88,
      "end": 356.26,
      "text": "What?"
    },
    {
      "start": 356.8,
      "end": 358.79,
      "text": "Stay at my place for the night"
    },
    {
      "start": 358.79,
      "end": 361.13,
      "text": "And we'll start building you a new house tomorrow"
    },
    {
      "start": 361.13,
      "end": 363.9,
      "text": "No kidding?"
    },
    {
      "start": 364.34,
      "end": 365.38,
      "text": "Well, of course"
    },
    {
      "start": 365.38,
      "end": 366.9,
      "text": "What are friends for?"
    },
    {
      "start": 367.85,
      "end": 368.81,
      "text": "We're friends"
    },
    {
      "start": 368.81,
      "end": 370.03,
      "text": "Are you sure?"
    },
    {
      "start": 370.03,
      "end": 372.99,
      "text": "There's no doubt about it"
    },
    {
      "start": 372.99,
      "end": 377.75,
      "text": "What is it?"
    },
    {
      "start": 382.71,
      "end": 384.27,
      "text": "이번엔 8월의 영화"
    },
    {
      "start": 384.27,
      "end": 387.25,
      "text": "Come on, come on의 복습 시작이 되는데요"
    },
    {
      "start": 387.25,
      "end": 390.75,
      "text": "8월 1일 화요일에 함께한 장면입니다"
    },
    {
      "start": 390.75,
      "end": 393.97,
      "text": "어린이의 삶과 미래에 대해 인터뷰하는"
    },
    {
      "start": 393.97,
      "end": 396.03,
      "text": "라디오 저널리스트인 조니는"
    },
    {
      "start": 396.03,
      "end": 397.81,
      "text": "어머니의 죽음 이후"
    },
    {
      "start": 397.81,
      "end": 400.01,
      "text": "한동안 연락을 끊고 지냈던"
    },
    {
      "start": 400.01,
      "end": 402.61,
      "text": "여동생 위브와 통화를 하게 됩니다"
    },
    {
      "start": 402.61,
      "end": 408.46,
      "text": "I didn't know what to do with myself today"
    },
    {
      "start": 408.46,
      "end": 412.44,
      "text": "I didn't know what to do with myself today"
    },
    {
      "start": 412.44,
      "end": 417.52,
      "text": "오늘은 나 스스로가 뭘 해야 할지도 모르겠더라"
    },
    {
      "start": 417.52,
      "end": 418.9,
      "text": "라는 말이었습니다"
    },
    {
      "start": 418.9,
      "end": 421.6,
      "text": "근데 이거하고 비슷한 구조로요"
    },
    {
      "start": 421.6,
      "end": 423.94,
      "text": "I don't know what to do"
    },
    {
      "start": 423.94,
      "end": 425.74,
      "text": "이런 말도 우리가 많이 하잖아요"
    },
    {
      "start": 425.74,
      "end": 428.14,
      "text": "내가 뭘 해야 될지 모르겠어"
    },
    {
      "start": 428.14,
      "end": 429.38,
      "text": "라는 문장입니다"
    },
    {
      "start": 429.38,
      "end": 432.0,
      "text": "함께 기억해 보시면 좋을 것 같아요"
    },
    {
      "start": 432.0,
      "end": 434.66,
      "text": "그럼 남매의 통화 내용 들어보시죠"
    },
    {
      "start": 434.66,
      "end": 437.35,
      "text": "It doesn't feel like it's been a year to me"
    },
    {
      "start": 437.35,
      "end": 439.42,
      "text": "Does it to you?"
    },
    {
      "start": 441.15,
      "end": 443.13,
      "text": "No, it's weird"
    },
    {
      "start": 443.13,
      "end": 448.31,
      "text": "I didn't know what to do with myself today"
    },
    {
      "start": 448.31,
      "end": 450.39,
      "text": "Yeah, I know"
    },
    {
      "start": 450.39,
      "end": 453.39,
      "text": "If I just work"
    },
    {
      "start": 453.39,
      "end": 456.49,
      "text": "then I feel like I'm not mourning in the right way or whatever"
    },
    {
      "start": 456.49,
      "end": 462.36,
      "text": "If I sit in this depressing hotel room"
    },
    {
      "start": 462.36,
      "end": 464.16,
      "text": "and just think about mom"
    },
    {
      "start": 464.16,
      "end": 466.4,
      "text": "then it's just pretty brutal"
    },
    {
      "start": 466.4,
      "end": 469.05,
      "text": "So, yeah, I called you"
    },
    {
      "start": 469.05,
      "end": 473.92,
      "text": "이제 리뷰타임 수요일 장면은 노래 듣고 이어갈게요"
    },
    {
      "start": 473.92,
      "end": 476.6,
      "text": "Share, I got you, babe"
    },
    {
      "start": 476.6,
      "end": 479.2,
      "text": "여러분은 지금 KBS 라디오 조정현의"
    },
    {
      "start": 479.2,
      "end": 480.8,
      "text": "굿모닝 팝스 함께하고 계십니다"
    },
    {
      "start": 481.38,
      "end": 484.8,
      "text": "이제 8월 2일 수요일에 만나본 장면인데요"
    },
    {
      "start": 484.8,
      "end": 488.94,
      "text": "조니는 8살 조카 제시를 돌보기 위해서"
    },
    {
      "start": 488.94,
      "end": 491.76,
      "text": "여동생 비브의 집에 도착하는데요"
    },
    {
      "start": 491.76,
      "end": 495.8,
      "text": "비브는 조니에게 제시의 특별한 역할놀이에 대해서"
    },
    {
      "start": 495.8,
      "end": 497.8,
      "text": "설명해 주면서 이렇게 말합니다"
    },
    {
      "start": 497.8,
      "end": 501.47,
      "text": "Brace yourself"
    },
    {
      "start": 501.47,
      "end": 503.59,
      "text": "Brace yourself"
    },
    {
      "start": 503.59,
      "end": 504.73,
      "text": "잘 들리시죠?"
    },
    {
      "start": 505.39,
      "end": 508.11,
      "text": "일단 brace 라고 하면 가장 먼저"
    },
    {
      "start": 508.11,
      "end": 509.93,
      "text": "버팀 때라든지"
    },
    {
      "start": 509.93,
      "end": 513.01,
      "text": "쨈쇠 아니면 교정기"
    },
    {
      "start": 513.01,
      "end": 516.11,
      "text": "이런 단어들일 거라고 생각이 나는데요"
    },
    {
      "start": 516.11,
      "end": 519.53,
      "text": "이 뒤에 yourself가 붙어졌잖아요"
    },
    {
      "start": 519.53,
      "end": 523.55,
      "text": "그러면 마음을 단단히 먹다"
    },
    {
      "start": 523.55,
      "end": 527.71,
      "text": "각오하다 라는 의미가 자연스럽게 형성이 되는 거겠죠"
    },
    {
      "start": 527.71,
      "end": 529.27,
      "text": "Brace yourself"
    },
    {
      "start": 529.27,
      "end": 533.97,
      "text": "마음 단단히 먹어 각오해 라는 뜻이라는 거 기억해 보시고요"
    },
    {
      "start": 533.97,
      "end": 535.51,
      "text": "다시 한번 들어보시죠"
    },
    {
      "start": 535.51,
      "end": 572.57,
      "text": "계속해서 8월 3일 목요일에 함께한 장면입니다"
    },
    {
      "start": 572.57,
      "end": 575.85,
      "text": "여동생인 비브는 남편을 돕기 위해"
    },
    {
      "start": 575.85,
      "end": 577.49,
      "text": "오클랜드로 떠나고"
    },
    {
      "start": 577.49,
      "end": 581.39,
      "text": "조니는 조카인 제시와 단둘이 지내게 되는데요"
    },
    {
      "start": 581.39,
      "end": 582.97,
      "text": "목욕을 하던 제시는"
    },
    {
      "start": 582.97,
      "end": 586.23,
      "text": "자신의 엄마와 조니에 대해서 물어보면서"
    },
    {
      "start": 586.23,
      "end": 587.25,
      "text": "이렇게 말합니다"
    },
    {
      "start": 587.25,
      "end": 591.93,
      "text": "Did you used to talk a lot?"
    },
    {
      "start": 591.93,
      "end": 595.28,
      "text": "Did you used to talk a lot?"
    },
    {
      "start": 596.06,
      "end": 601.06,
      "text": "네 여기에서 used to 동사원형 이 구가 활용이 된 거잖아요"
    },
    {
      "start": 601.06,
      "end": 605.48,
      "text": "그렇기 때문에 의미는 뭐뭐 하곤 했다라고 해석을 하는 겁니다"
    },
    {
      "start": 605.48,
      "end": 610.32,
      "text": "과거에 습관적으로 했던 동작을 나타내는 표현이었던 거죠"
    },
    {
      "start": 610.32,
      "end": 613.14,
      "text": "그래서 질문의 문장을 만들려고 하고"
    },
    {
      "start": 613.14,
      "end": 615.6,
      "text": "과거의 일을 묻는 것이니까"
    },
    {
      "start": 615.6,
      "end": 617.84,
      "text": "Did you 이렇게 시작이 된 겁니다"
    },
    {
      "start": 617.84,
      "end": 620.2,
      "text": "Did you used to talk a lot?"
    },
    {
      "start": 620.74,
      "end": 623.52,
      "text": "예전에는 그러면 이야기를 많이 하곤 했나요?"
    },
    {
      "start": 623.94,
      "end": 625.28,
      "text": "라는 질문이었어요"
    },
    {
      "start": 625.28,
      "end": 627.96,
      "text": "그럼 이 장면 한 번 더 확인해 보시죠"
    },
    {
      "start": 627.96,
      "end": 629.68,
      "text": "How sounds amazing you hear"
    },
    {
      "start": 629.68,
      "end": 632.2,
      "text": "My dad would love this"
    },
    {
      "start": 632.2,
      "end": 633.78,
      "text": "조니"
    },
    {
      "start": 633.78,
      "end": 634.82,
      "text": "You son?"
    },
    {
      "start": 635.3,
      "end": 638.69,
      "text": "Your mom tells me stories"
    },
    {
      "start": 638.69,
      "end": 640.93,
      "text": "It can be fiction or non-fiction"
    },
    {
      "start": 640.93,
      "end": 645.23,
      "text": "Boy I don't know any stories"
    },
    {
      "start": 645.23,
      "end": 648.57,
      "text": "We just talk"
    },
    {
      "start": 648.57,
      "end": 650.69,
      "text": "Get to know each other"
    },
    {
      "start": 650.69,
      "end": 653.52,
      "text": "Why did you stop talking to you?"
    },
    {
      "start": 655.67,
      "end": 658.19,
      "text": "We talk"
    },
    {
      "start": 658.19,
      "end": 659.39,
      "text": "No I don't"
    },
    {
      "start": 659.39,
      "end": 665.08,
      "text": "Did you used to talk a lot?"
    },
    {
      "start": 665.08,
      "end": 673.17,
      "text": "오늘로 7월의 영화 빅트립 아기팬더 배달 대모험을 마무리하고요"
    },
    {
      "start": 673.17,
      "end": 678.23,
      "text": "8월의 영화 Come on Come on의 초반 내용을 복습을 해봤습니다"
    },
    {
      "start": 678.23,
      "end": 682.59,
      "text": "내일 곧바로 다음 이야기 알아볼 예정이니까요 기대해 주세요"
    },
    {
      "start": 682.59,
      "end": 684.67,
      "text": "이제 노래 한 곡 들어보겠습니다"
    },
    {
      "start": 684.67,
      "end": 688.25,
      "text": "Stevie Wonder의 I just called to say I love you"
    },
    {
      "start": 688.25,
      "end": 700.05,
      "text": "조정현의 굿모닝 팝스에서 준비한 선물입니다"
    },
    {
      "start": 700.05,
      "end": 705.27,
      "text": "한국 방송 출판에서 월간 굿모닝 팝스 책 3개월 구독권을 드립니다"
    },
    {
      "start": 705.27,
      "end": 715.03,
      "text": "미연님"
    },
    {
      "start": 715.03,
      "end": 716.93,
      "text": "굿모닝 정현쌤"
    },
    {
      "start": 716.93,
      "end": 721.31,
      "text": "손주 때문에 영어 단어책을 한 권 사서 복습해 가면서"
    },
    {
      "start": 721.31,
      "end": 724.43,
      "text": "노트에 열심히 단어를 옮겨 쓰고 있답니다"
    },
    {
      "start": 724.43,
      "end": 728.59,
      "text": "아침에는 굿모닝 팝스 들으며 정현쌤 덕분에 열공하네요"
    },
    {
      "start": 728.59,
      "end": 730.65,
      "text": "고맙습니다 하트"
    },
    {
      "start": 730.65,
      "end": 735.31,
      "text": "손주 사랑 엄청 느껴집니다"
    },
    {
      "start": 735.31,
      "end": 737.69,
      "text": "그 사랑의 마음이 워낙 크시니까"
    },
    {
      "start": 737.69,
      "end": 742.63,
      "text": "이렇게 영어 단어책도 구매하시고 직접 일일이 쓰시면서"
    },
    {
      "start": 742.63,
      "end": 745.25,
      "text": "지금 열공을 하고 계시는 모습이네요"
    },
    {
      "start": 745.25,
      "end": 751.97,
      "text": "공부하는 할머니의 모습 특히 그 모습을 뒤에서 봤을 때"
    },
    {
      "start": 751.97,
      "end": 757.25,
      "text": "그 할머니의 공부하는 등 뒷모습을 봤을 때 얼마나 멋질까요"
    },
    {
      "start": 757.25,
      "end": 759.41,
      "text": "저도 응원할게요"
    },
    {
      "start": 759.41,
      "end": 761.07,
      "text": "이은정님"
    },
    {
      "start": 761.07,
      "end": 762.47,
      "text": "굿모닝"
    },
    {
      "start": 762.47,
      "end": 765.71,
      "text": "어떤 영어 공부를 해야 할까 고민하던 중에"
    },
    {
      "start": 765.71,
      "end": 769.29,
      "text": "굿모닝 팝스를 들으며 책으로도 재밌게 공부 중입니다"
    },
    {
      "start": 769.29,
      "end": 772.31,
      "text": "아침마다 늘 빠짐없이 듣고 있답니다"
    },
    {
      "start": 772.31,
      "end": 773.63,
      "text": "덕분에 감사합니다"
    },
    {
      "start": 773.63,
      "end": 779.97,
      "text": "와 신중한 고민에 고민을 하신 끝에"
    },
    {
      "start": 779.97,
      "end": 783.93,
      "text": "결국 이렇게 굿모닝 팝스를 선택을 해주신 거네요"
    },
    {
      "start": 783.93,
      "end": 786.65,
      "text": "너무 감사해요 은정님"
    },
    {
      "start": 786.65,
      "end": 789.13,
      "text": "교재도 준비하시고"
    },
    {
      "start": 789.13,
      "end": 792.67,
      "text": "무엇보다도 재미있게 공부 중이라고 하시니까"
    },
    {
      "start": 792.67,
      "end": 793.75,
      "text": "진짜 좋네요"
    },
    {
      "start": 793.75,
      "end": 799.01,
      "text": "앞으로 영어와 더 가까워지시길 바라겠습니다"
    },
    {
      "start": 799.01,
      "end": 803.85,
      "text": "사연 소개되신 두 분께는 월간 굿모닝 팝 3개월 구독권 보내드릴게요"
    },
    {
      "start": 803.85,
      "end": 806.15,
      "text": "이제 노래 한 곡 들어보겠습니다"
    },
    {
      "start": 806.15,
      "end": 809.75,
      "text": "마이클 볼튼의 Love is a Wonderful Thing"
    },
    {
      "start": 809.75,
      "end": 824.0,
      "text": "리뷰타임 Part 2"
    },
    {
      "start": 824.0,
      "end": 825.56,
      "text": "스마트 리뷰디 잉글리쉬"
    },
    {
      "start": 825.56,
      "end": 839.14,
      "text": "문장 속에서 유용하게 활용할 수 있는 표현을"
    },
    {
      "start": 839.14,
      "end": 841.3,
      "text": "문장 속에 넣어서 연습해보는 시간"
    },
    {
      "start": 841.3,
      "end": 842.8,
      "text": "스마트 리뷰디 잉글리쉬"
    },
    {
      "start": 842.8,
      "end": 845.3,
      "text": "이제 한 주간 연습했던 표현들"
    },
    {
      "start": 845.3,
      "end": 847.42,
      "text": "다시 꼼꼼하게 복습을 해볼게요"
    },
    {
      "start": 847.42,
      "end": 851.08,
      "text": "먼저 7월 31일 월요일에 만난 표현입니다"
    },
    {
      "start": 851.08,
      "end": 854.95,
      "text": "Say it to one's face"
    },
    {
      "start": 854.95,
      "end": 856.89,
      "text": "생생하게 기억이 나시죠?"
    },
    {
      "start": 857.79,
      "end": 860.15,
      "text": "직역을 해도 어떤 의미인지"
    },
    {
      "start": 860.15,
      "end": 862.45,
      "text": "금방 떠올리실 수 있을 거예요"
    },
    {
      "start": 862.45,
      "end": 866.95,
      "text": "누군가의 얼굴에다가 대놓고 말하는 거잖아요"
    },
    {
      "start": 866.95,
      "end": 868.73,
      "text": "그래서 대놓고 말하다"
    },
    {
      "start": 868.73,
      "end": 870.33,
      "text": "Say it to one's face"
    },
    {
      "start": 870.33,
      "end": 871.33,
      "text": "라는 거"
    },
    {
      "start": 871.33,
      "end": 873.41,
      "text": "첫 번째로"
    },
    {
      "start": 873.41,
      "end": 876.95,
      "text": "그녀에게 떳떳하게 대놓고 말하는 게 어때?"
    },
    {
      "start": 876.95,
      "end": 879.95,
      "text": "라는 문장을 말씀을 해보시죠"
    },
    {
      "start": 879.95,
      "end": 882.41,
      "text": "Why don't you"
    },
    {
      "start": 882.41,
      "end": 883.41,
      "text": "그렇죠"
    },
    {
      "start": 883.41,
      "end": 884.85,
      "text": "Why don't you say it?"
    },
    {
      "start": 885.21,
      "end": 886.53,
      "text": "그녀의 얼굴이라고 했으니까"
    },
    {
      "start": 886.53,
      "end": 888.23,
      "text": "To her face"
    },
    {
      "start": 888.23,
      "end": 891.09,
      "text": "이렇게 완성을 시키시면 되겠습니다"
    },
    {
      "start": 891.09,
      "end": 892.68,
      "text": "할 말 있으면"
    },
    {
      "start": 892.68,
      "end": 894.14,
      "text": "내 앞에서 말해"
    },
    {
      "start": 894.14,
      "end": 896.32,
      "text": "말할 게 무언가 있다면"
    },
    {
      "start": 896.32,
      "end": 898.64,
      "text": "내 얼굴 앞에서 말해"
    },
    {
      "start": 898.64,
      "end": 900.44,
      "text": "이렇게 한번 전달을 해보세요"
    },
    {
      "start": 900.44,
      "end": 904.44,
      "text": "If you have something to say"
    },
    {
      "start": 904.44,
      "end": 907.4,
      "text": "Say it to my face"
    },
    {
      "start": 907.4,
      "end": 910.67,
      "text": "또박또박 잘 표현을 해봤습니다"
    },
    {
      "start": 910.67,
      "end": 913.75,
      "text": "이번엔 8월 1일 화요일 표현입니다"
    },
    {
      "start": 913.75,
      "end": 918.09,
      "text": "Think something through"
    },
    {
      "start": 918.09,
      "end": 919.31,
      "text": "기억나시죠?"
    },
    {
      "start": 920.09,
      "end": 923.35,
      "text": "Think 이것만 보면 생각하다 이건데"
    },
    {
      "start": 923.35,
      "end": 924.59,
      "text": "Something을"
    },
    {
      "start": 924.59,
      "end": 928.79,
      "text": "뭔가 통과하는 과정을 거쳐가지고"
    },
    {
      "start": 928.79,
      "end": 931.05,
      "text": "아하 심사숙고하다"
    },
    {
      "start": 931.05,
      "end": 932.79,
      "text": "라는 의미가 완성이 된 거죠"
    },
    {
      "start": 932.79,
      "end": 934.31,
      "text": "만약에"
    },
    {
      "start": 934.31,
      "end": 935.99,
      "text": "Think something through"
    },
    {
      "start": 935.99,
      "end": 936.59,
      "text": "라는 것을"
    },
    {
      "start": 936.59,
      "end": 938.71,
      "text": "그냥 한 단어로 나타내고 싶다"
    },
    {
      "start": 938.71,
      "end": 939.05,
      "text": "그러면"
    },
    {
      "start": 939.05,
      "end": 940.93,
      "text": "Contemplate"
    },
    {
      "start": 940.93,
      "end": 942.11,
      "text": "이런 단어"
    },
    {
      "start": 942.11,
      "end": 943.79,
      "text": "충분히 가능할 것 같고요"
    },
    {
      "start": 943.79,
      "end": 944.59,
      "text": "아니면"
    },
    {
      "start": 944.59,
      "end": 946.69,
      "text": "Think something over"
    },
    {
      "start": 946.69,
      "end": 949.05,
      "text": "이렇게 좀 더 쉬운 표현으로도"
    },
    {
      "start": 949.05,
      "end": 950.79,
      "text": "추가 설명을 해드립니다"
    },
    {
      "start": 950.79,
      "end": 952.39,
      "text": "Think something over"
    },
    {
      "start": 952.39,
      "end": 953.05,
      "text": "도 괜찮고"
    },
    {
      "start": 953.05,
      "end": 954.67,
      "text": "Think something through"
    },
    {
      "start": 954.67,
      "end": 955.43,
      "text": "도 괜찮고"
    },
    {
      "start": 955.43,
      "end": 956.45,
      "text": "한 단어로는"
    },
    {
      "start": 956.45,
      "end": 957.33,
      "text": "Contemplate"
    },
    {
      "start": 957.33,
      "end": 958.47,
      "text": "이 단어까지"
    },
    {
      "start": 958.47,
      "end": 960.37,
      "text": "기억을 해보시면 좋을 것 같고요"
    },
    {
      "start": 960.37,
      "end": 962.67,
      "text": "심사숙고 합시다"
    },
    {
      "start": 962.67,
      "end": 963.67,
      "text": "해볼까요?"
    },
    {
      "start": 964.47,
      "end": 966.75,
      "text": "Let's think it through"
    },
    {
      "start": 966.75,
      "end": 967.61,
      "text": "좋아요"
    },
    {
      "start": 967.61,
      "end": 968.49,
      "text": "그러면"
    },
    {
