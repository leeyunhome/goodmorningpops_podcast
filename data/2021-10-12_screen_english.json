      "start": 700.61,
      "end": 702.19,
      "text": "제가 한 살 때까지는"
    },
    {
      "start": 702.19,
      "end": 704.45,
      "text": "저하고 아빠만 있었어요"
    },
    {
      "start": 704.45,
      "end": 706.09,
      "text": "라는 부연 설명까지 해줍니다"
    },
    {
      "start": 706.09,
      "end": 707.35,
      "text": "Wow"
    },
    {
      "start": 707.35,
      "end": 709.35,
      "text": "아니 이때 이사벨하고"
    },
    {
      "start": 709.35,
      "end": 711.61,
      "text": "테리사의 남편인 오스카하고"
    },
    {
      "start": 711.61,
      "end": 712.83,
      "text": "서로 눈이 마주칩니다"
    },
    {
      "start": 712.83,
      "end": 714.17,
      "text": "They look at each other"
    },
    {
      "start": 714.17,
      "end": 716.73,
      "text": "And what does that feel like?"
    },
    {
      "start": 716.83,
      "end": 719.29,
      "text": "아 오스카는 거의 동공지진 수준이었어요"
    },
    {
      "start": 719.29,
      "end": 720.61,
      "text": "Yeah he wants to run away"
    },
    {
      "start": 720.61,
      "end": 722.27,
      "text": "And she wants to chase him"
    },
    {
      "start": 722.27,
      "end": 723.47,
      "text": "And talk to him"
    },
    {
      "start": 723.47,
      "end": 723.71,
      "text": "Yeah"
    },
    {
      "start": 723.71,
      "end": 725.07,
      "text": "What happened?"
    },
    {
      "start": 725.31,
      "end": 726.55,
      "text": "맞습니다"
    },
    {
      "start": 726.55,
      "end": 728.07,
      "text": "네 마지막으로 이 장면"
    },
    {
      "start": 728.07,
      "end": 728.87,
      "text": "한 번 더 들어볼게요"
    },
    {
      "start": 728.87,
      "end": 730.31,
      "text": "Mom"
    },
    {
      "start": 730.31,
      "end": 733.55,
      "text": "You've made this night so special"
    },
    {
      "start": 733.55,
      "end": 737.57,
      "text": "You are the most caring"
    },
    {
      "start": 737.57,
      "end": 738.81,
      "text": "Loving"
    },
    {
      "start": 738.81,
      "end": 741.2,
      "text": "Best example of a woman"
    },
    {
      "start": 741.2,
      "end": 742.64,
      "text": "I could have ever asked for"
    },
    {
      "start": 742.64,
      "end": 743.46,
      "text": "In a mother"
    },
    {
      "start": 743.46,
      "end": 748.09,
      "text": "And for those of you"
    },
    {
      "start": 748.09,
      "end": 748.77,
      "text": "who don't know"
    },
    {
      "start": 748.77,
      "end": 750.79,
      "text": "I had the rare experience"
    },
    {
      "start": 750.79,
      "end": 751.63,
      "text": "of getting to choose"
    },
    {
      "start": 751.63,
      "end": 752.19,
      "text": "my own mother"
    },
    {
      "start": 752.19,
      "end": 753.93,
      "text": "It was just me and my dad"
    },
    {
      "start": 753.93,
      "end": 755.53,
      "text": "for the first year of my life"
    },
    {
      "start": 755.53,
      "end": 758.48,
      "text": "김정민님께서"
    },
    {
      "start": 758.48,
      "end": 761.44,
      "text": "스크린 잉글리시가 조금씩 들리는 것 같아요"
    },
    {
      "start": 761.44,
      "end": 764.34,
      "text": "이렇게 희소식을 전달을 해주셨네요"
    },
    {
      "start": 764.34,
      "end": 765.28,
      "text": "Good for you"
    },
    {
      "start": 765.28,
      "end": 766.96,
      "text": "이제 시작입니다"
    },
    {
      "start": 766.96,
      "end": 768.84,
      "text": "조금씩 조금씩 들리면서"
    },
    {
      "start": 768.84,
      "end": 770.98,
      "text": "자신감도 막 차오르잖아요"
    },
    {
      "start": 770.98,
      "end": 773.6,
      "text": "그때 더욱더 박차를 가하시면 되겠습니다"
    },
    {
      "start": 773.6,
      "end": 774.2,
      "text": "Yes"
    },
    {
      "start": 774.2,
      "end": 775.34,
      "text": "You can do it"
    },
    {
      "start": 775.34,
      "end": 775.86,
      "text": "Go for it"
    },
    {
      "start": 775.86,
      "end": 777.06,
      "text": "It always feels really good"
    },
    {
      "start": 777.06,
      "end": 778.08,
      "text": "The first time"
    },
    {
      "start": 778.08,
      "end": 779.16,
      "text": "you understand"
    },
    {
      "start": 779.16,
      "end": 780.94,
      "text": "like a long sentence"
    },
    {
      "start": 780.94,
      "end": 782.7,
      "text": "or some long conversation"
    },
    {
      "start": 782.7,
      "end": 784.34,
      "text": "I remember that time"
    },
    {
      "start": 784.34,
      "end": 785.76,
      "text": "When I first came to Korea"
    },
    {
      "start": 785.76,
      "end": 787.58,
      "text": "It feels amazing"
    },
    {
      "start": 787.58,
      "end": 788.16,
      "text": "Wow"
    },
    {
      "start": 788.16,
      "end": 790.08,
      "text": "It's like you entered another world"
    },
    {
      "start": 790.08,
      "end": 791.16,
      "text": "와우"
    },
    {
      "start": 791.16,
      "end": 791.58,
      "text": "그러니까"
    },
    {
      "start": 791.58,
      "end": 793.74,
      "text": "지금 김정민님과"
    },
    {
      "start": 793.74,
      "end": 795.24,
      "text": "비슷한 그런 경험을"
    },
    {
      "start": 795.24,
      "end": 796.78,
      "text": "이미 해보신 분으로서"
    },
    {
      "start": 796.78,
      "end": 797.64,
      "text": "우리 크쌤이"
    },
    {
      "start": 797.64,
      "end": 799.32,
      "text": "확신을 주시네요"
    },
    {
      "start": 799.32,
      "end": 799.64,
      "text": "그렇죠"
    },
    {
      "start": 799.64,
      "end": 800.24,
      "text": "네"
    },
    {
      "start": 800.24,
      "end": 801.24,
      "text": "오늘 스크린 잉글리시는"
    },
    {
      "start": 801.24,
      "end": 802.24,
      "text": "여기까지입니다"
    }
  ]
}