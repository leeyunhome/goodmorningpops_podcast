    },
    {
      "start": 1233.35,
      "end": 1234.95,
      "text": "이라는 단어였어요."
    },
    {
      "start": 1235.69,
      "end": 1235.99,
      "text": "그래서"
    },
    {
      "start": 1235.99,
      "end": 1238.81,
      "text": "you are a trendsetter in fashion"
    },
    {
      "start": 1238.81,
