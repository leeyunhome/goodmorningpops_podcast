      "start": 103.71,
      "end": 104.61,
      "text": "Stop eating that."
    },
    {
      "start": 104.75,
      "end": 105.57,
      "text": "아유 진짜요 맛있는데."
    },
    {
      "start": 105.85,
      "end": 106.33,
      "text": "그러게."
    },
    {
      "start": 106.51,
      "end": 107.35,
      "text": "이게 볶음밥."
    },
    {
      "start": 107.49,
      "end": 108.53,
      "text": "살짝 타기 직전."
    },
    {
      "start": 108.61,
      "end": 108.99,
      "text": "어머 어머."
    },
    {
      "start": 109.11,
      "end": 109.71,
      "text": "눌려서."
    },
    {
      "start": 110.01,
      "end": 110.67,
