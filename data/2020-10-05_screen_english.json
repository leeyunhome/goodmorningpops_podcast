    {
      "start": 46.89,
      "end": 47.39,
      "text": "아!"
    },
    {
      "start": 47.47,
      "end": 48.85,
      "text": "이름이 너무 어려워요."
    },
    {
      "start": 49.03,
      "end": 50.63,
      "text": "I like your attitude."
    },
    {
      "start": 50.89,
      "end": 52.33,
      "text": "진짜 열심히 하고 있어요."
    },
    {
      "start": 52.43,
      "end": 52.63,
      "text": "그죠?"
    },
    {
      "start": 52.73,
      "end": 53.91,
      "text": "You did it with a smile."
    },
    {
      "start": 54.07,
      "end": 54.51,
      "text": "아!"
    },
    {
      "start": 54.67,
      "end": 55.21,
      "text": "보셨어요?"
