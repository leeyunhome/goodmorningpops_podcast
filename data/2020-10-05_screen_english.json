      "end": 133.03,
      "text": "It's hard to pronounce her name."
    },
    {
      "start": 133.13,
      "end": 133.53,
      "text": "Dixie."
    },
    {
      "start": 133.63,
      "end": 134.33,
      "text": "That's a nice name."
    },
    {
      "start": 134.71,
      "end": 135.91,
      "text": "Dixie Egericks."
    },
    {
      "start": 136.01,
