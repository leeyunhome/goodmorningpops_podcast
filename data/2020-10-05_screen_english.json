      "text": "그죠?"
    },
    {
      "start": 282.29,
      "end": 283.95,
      "text": "오늘 장면 듣고 올게요."
    },
    {
      "start": 285.1,
      "end": 289.52,
      "text": "First things first, we are fully electric."
    },
