    {
      "start": 81.59,
      "end": 81.89,
      "text": "Yeah."
    },
    {
      "start": 82.11,
      "end": 82.75,
      "text": "Hanging out."
    },
    {
      "start": 82.89,
      "end": 84.61,
      "text": "Making some chuseok food."
    },
    {
      "start": 84.77,
      "end": 86.17,
      "text": "Like 동태jeon."
    },
    {
      "start": 86.51,
      "end": 87.75,
      "text": "Sounds so yummy."
    },
    {
      "start": 87.85,
      "end": 89.77,
      "text": "It was not that great."
    },
    {
      "start": 89.87,
      "end": 92.01,
      "text": "It kind of burnt it a little bit."
    },
    {
      "start": 92.11,
      "end": 92.57,
      "text": "Oh really?"
    },
    {
      "start": 92.99,
      "end": 93.49,
      "text": "But yeah."
    },
    {
      "start": 93.49,
      "end": 94.55,
      "text": "살짝 탄 게 맛있어요."
    },
