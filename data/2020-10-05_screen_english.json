    {
      "start": 55.33,
      "end": 55.67,
      "text": "Yes."
    },
    {
      "start": 55.75,
      "end": 57.29,
      "text": "아유 참 감사합니다."
    },
    {
      "start": 57.31,
      "end": 59.07,
      "text": "웃으면서 보기 좋았어요."
    },
    {
      "start": 59.23,
      "end": 59.87,
      "text": "아 진짜요?"
    },
    {
      "start": 59.87,
      "end": 62.13,
      "text": "아 이게 이름이 너무 어렵다 보니까"
    },
    {
      "start": 62.13,
      "end": 63.71,
      "text": "웃음이 저절로 나오더라고요."
    },
    {
      "start": 64.13,
      "end": 64.93,
      "text": "Good morning everyone!"
    },
    {
      "start": 65.09,
      "end": 65.49,
      "text": "Yeah!"
    },
    {
      "start": 65.73,
      "end": 66.65,
      "text": "Good morning입니다!"
    },
    {
      "start": 66.89,
      "end": 69.21,
      "text": "우리 10월 둘째 주가 시작이 되었는데요."
    },
    {
      "start": 69.37,
      "end": 69.61,
      "text": "Yeah."
    },
    {
      "start": 69.85,
      "end": 70.19,
      "text": "Oh!"
    },
    {
      "start": 70.27,
      "end": 71.39,
      "text": "Did you have a good holiday?"
    },
    {
      "start": 71.87,
      "end": 73.69,
      "text": "I had a lovely holiday."
    },
    {
      "start": 73.95,
      "end": 74.71,
      "text": "Chuseok."
    },
    {
      "start": 74.85,
      "end": 76.31,
      "text": "It was amazing."
    },
    {
      "start": 76.59,
      "end": 78.47,
      "text": "It was quiet at first."
    },
    {
      "start": 78.55,
      "end": 79.07,
      "text": "Oh really?"
    },
    {
      "start": 79.19,
      "end": 81.47,
      "text": "I was at home with just my family."
