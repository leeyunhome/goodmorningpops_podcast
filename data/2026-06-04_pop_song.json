    {
      "start": 392.37,
      "end": 393.93,
      "text": "Just can't stay away."
    },
    {
      "start": 394.37,
      "end": 396.59,
      "text": "나는 멀어질 수가 없네요."
    },
    {
      "start": 397.43,
      "end": 399.01,
      "text": "Dance through the crowd."
    },
    {
      "start": 399.53,
      "end": 401.77,
      "text": "사람들 사이를 해치면서 춤춘대요."
