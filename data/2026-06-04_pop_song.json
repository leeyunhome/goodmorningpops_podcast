    },
    {
      "start": 508.37,
      "end": 512.37,
      "text": "I've been on my own for so long."
    },
    {
      "start": 512.87,
      "end": 514.83,
      "text": "차근차근 기억해내시죠."
    },
    {
      "start": 515.37,
      "end": 517.45,
      "text": "I've been on my own for so long."
    },
    {
      "start": 517.91,
      "end": 518.87,
      "text": "이 문장이었습니다."
    },
    {
      "start": 519.63,
      "end": 522.83,
      "text": "I've been by myself for a long time."
    },
    {
      "start": 523.25,
      "end": 524.97,
      "text": "이것과도 같은 문장이겠죠."
