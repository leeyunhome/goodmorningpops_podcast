    {
      "start": 994.14,
      "end": 998.0,
      "text": "고생 많으셨습니다"
    },
    {
      "start": 998.0,
      "end": 999.32,
      "text": "라는 인삿말입니다."
    },
    {
      "start": 1000.3,
      "end": 1001.52,
      "text": "조정연의 굿모닝 팝스"
    },
    {
      "start": 1001.52,
      "end": 1003.14,
      "text": "이제 마무리할 시간이네요."
    },
    {
      "start": 1004.18,
      "end": 1006.62,
      "text": "정말 이런 날이 많네요."
    },
    {
      "start": 1006.94,
      "end": 1007.82,
      "text": "안 올 것 같았는데"
    },
    {
      "start": 1007.82,
      "end": 1010.0,
      "text": "정말 이런 날이 오긴 왔습니다."
    },
    {
      "start": 1010.2,
      "end": 1013.02,
      "text": "2020년 1월 6일부터"
    },
    {
      "start": 1013.02,
      "end": 1015.98,
      "text": "2024년 6월 30일"
    },
    {
      "start": 1015.98,
      "end": 1016.7,
      "text": "오늘까지"
    },
    {
      "start": 1016.7,
      "end": 1018.98,
      "text": "4년 반 동안"
    },
    {
      "start": 1018.98,
      "end": 1021.24,
      "text": "이렇게 조정연의 굿모닝 팝스라는"
    },
    {
      "start": 1021.24,
      "end": 1023.48,
      "text": "프로그램을 사랑해 주신"
    },
    {
      "start": 1023.48,
      "end": 1024.88,
      "text": "청취자 여러분들께"
    },
    {
      "start": 1024.88,
      "end": 1026.32,
      "text": "진심으로 감사드립니다."
    },
    {
      "start": 1027.54,
      "end": 1029.26,
      "text": "처음에는 아마 그러셨을 거예요."
    },
    {
      "start": 1029.4,
      "end": 1030.46,
      "text": "생소한 이름이고"
    },
    {
      "start": 1030.46,
      "end": 1032.2,
      "text": "또 얼굴도 생소하고"
    },
    {
      "start": 1032.2,
      "end": 1034.24,
      "text": "처음 듣는 목소리이고"
    },
    {
      "start": 1034.24,
      "end": 1035.8,
      "text": "그래서 서먹하셨을 수도"
    },
    {
      "start": 1035.8,
      "end": 1037.48,
      "text": "있으셨을 텐데"
    },
    {
      "start": 1037.48,
      "end": 1040.18,
      "text": "그래도 이렇게 마음의 문을 열어주시고"
    },
    {
      "start": 1040.18,
      "end": 1041.0,
      "text": "믿어주시고"
    },
    {
      "start": 1041.0,
      "end": 1042.7,
      "text": "믿어주시고 응원해 주시고"
    },
    {
      "start": 1042.7,
      "end": 1045.18,
      "text": "또 이렇게 사랑이 담긴"
    },
    {
      "start": 1045.18,
      "end": 1046.6,
      "text": "따뜻한 메시지들로"
    },
    {
      "start": 1046.6,
      "end": 1049.06,
      "text": "채워주신 우리 청취자 여러분들"
    },
    {
      "start": 1049.06,
      "end": 1051.86,
      "text": "덕분에 또 나아갈 힘을 얻는 것 같아요."
    },
    {
      "start": 1053.3,
      "end": 1055.16,
      "text": "정말 우리가 함께 사연을 나누면서"
    },
    {
      "start": 1055.16,
      "end": 1058.0,
      "text": "삶의 정말 조각조각 일부분들을 나눴잖아요."
    },
    {
      "start": 1058.0,
      "end": 1060.18,
      "text": "그렇게 웃으면서"
    },
    {
      "start": 1060.18,
      "end": 1061.68,
      "text": "또 감동도 하고"
    },
    {
      "start": 1061.68,
      "end": 1063.42,
      "text": "그 순간순간들을"
    },
    {
      "start": 1063.42,
      "end": 1065.72,
      "text": "저는 평생 잊지 못할 거라고 생각합니다."
    },
    {
      "start": 1066.82,
      "end": 1068.38,
      "text": "컨디션이 안 좋은 날에도"
    },
    {
      "start": 1068.38,
      "end": 1069.98,
      "text": "힘을 낼 수 있었던"
    },
    {
      "start": 1069.98,
      "end": 1073.1,
      "text": "정말 큰 이유이기도 했습니다."
    },
    {
      "start": 1074.2,
      "end": 1076.08,
      "text": "낯가림이 아주 심한 편인데"
    },
    {
      "start": 1076.08,
      "end": 1078.22,
      "text": "저의 경계심을 쫙 풀어주신"
    },
    {
      "start": 1078.22,
      "end": 1080.7,
      "text": "우리 크리스 존슨 씨, 피터 빈트 씨,"
    },
    {
      "start": 1080.7,
      "end": 1083.92,
      "text": "월터 리 씨, 벤 에이커스 씨께도"
    },
    {
      "start": 1083.92,
      "end": 1084.84,
      "text": "감사를 드리고"
    },
    {
      "start": 1084.84,
      "end": 1087.84,
      "text": "또 심지어 두의 꽃 준비할 때마다"
    },
    {
      "start": 1087.84,
      "end": 1089.6,
      "text": "수고해 주신 엔지니어분들"
    },
    {
      "start": 1089.6,
      "end": 1091.02,
      "text": "얼굴도 막 떠올라요."
    },
    {
      "start": 1091.78,
      "end": 1095.04,
      "text": "또 초반에 제가 너무나도 많은 긴장을 하고"
    },
    {
      "start": 1095.04,
      "end": 1096.7,
      "text": "동공지진이 났어서"
    },
    {
      "start": 1096.7,
      "end": 1100.1,
      "text": "저에게 DJ란 무엇인지"
    },
    {
      "start": 1100.1,
      "end": 1102.48,
      "text": "살뜰하게 챙겨주신"
    },
    {
      "start": 1102.48,
      "end": 1104.48,
      "text": "많은 PD님들이 계셨어요."
    },
    {
      "start": 1104.68,
      "end": 1106.7,
      "text": "임병석 PD님, 이혁희 PD님"
    },
    {
      "start": 1106.7,
      "end": 1109.22,
      "text": "그리고 꽤 오랜 시간 동안 함께하면서"
    },
    {
      "start": 1109.22,
      "end": 1111.66,
      "text": "정말 조언도 정성스럽게 해주시고"
    },
    {
      "start": 1111.66,
      "end": 1113.4,
      "text": "편안하게 만들어주셨던"
    },
    {
      "start": 1113.4,
      "end": 1114.76,
      "text": "최재성 PD님과"
    },
    {
      "start": 1114.76,
      "end": 1117.26,
      "text": "하석필 PD님, 김우영 PD님,"
    },
    {
      "start": 1117.34,
      "end": 1119.28,
      "text": "송윤성 PD님, 권예지 PD님"
    },
    {
      "start": 1119.28,
      "end": 1122.8,
      "text": "그리고 이렇게 프로그램 마무리 순간까지"
    },
    {
      "start": 1122.8,
      "end": 1124.16,
      "text": "함께해 주신"
    },
    {
      "start": 1124.16,
      "end": 1128.22,
      "text": "따뜻하고 섬세한 감성으로"
    },
    {
      "start": 1128.22,
      "end": 1132.74,
      "text": "저에게 힐링 시간을 만들어주신"
    },
    {
      "start": 1132.74,
      "end": 1133.98,
      "text": "이동호 PD님께"
    },
    {
      "start": 1133.98,
      "end": 1136.25,
      "text": "진심으로 감사드립니다."
    },
    {
      "start": 1136.25,
      "end": 1139.07,
      "text": "정말 너무 좋은 PD님들을"
    },
    {
      "start": 1139.07,
      "end": 1141.15,
      "text": "이곳에서 많이 만난 것 같고"
    },
    {
      "start": 1141.15,
      "end": 1144.76,
      "text": "든든했고 많이 의지했고"
    },
    {
      "start": 1144.76,
      "end": 1146.59,
      "text": "정말 행복했습니다."
    },
    {
      "start": 1147.47,
      "end": 1148.75,
      "text": "또 오랜 시간"
    },
    {
      "start": 1148.75,
      "end": 1152.77,
      "text": "정말 묵묵히 좋은 원고를 쓰기 위해서"
    },
    {
      "start": 1152.77,
      "end": 1156.93,
      "text": "정말 정성을 눌러 담아 써주신"
    },
    {
      "start": 1156.93,
      "end": 1158.49,
      "text": "최환 작가님과"
    },
    {
      "start": 1158.49,
      "end": 1160.63,
      "text": "정민선 작가님 두 분께도"
    },
    {
      "start": 1160.63,
      "end": 1162.07,
      "text": "정말 감사드립니다."
    },
    {
      "start": 1162.07,
      "end": 1164.88,
      "text": "저는 내일부터"
    },
    {
      "start": 1164.88,
      "end": 1167.02,
      "text": "또 상쾌한 아침의 코너로"
    },
    {
      "start": 1167.54,
      "end": 1170.38,
      "text": "굿모닝 팝스에서 다시 인사를 드릴 건데요."
    },
    {
      "start": 1171.02,
      "end": 1174.06,
      "text": "무엇보다도 저는 우리 청취자분들의 사연으로"
    },
    {
      "start": 1174.06,
      "end": 1176.82,
      "text": "매일 이렇게 마음을 나누던 시간이"
    },
    {
      "start": 1176.82,
      "end": 1178.3,
      "text": "정말 그리울 것 같습니다."
    },
    {
      "start": 1178.3,
      "end": 1182.41,
      "text": "계속 응원하는 사이 되어주실 거라고 믿고 있고요."
    },
    {
      "start": 1182.85,
      "end": 1185.21,
      "text": "우리 또 힘차게 만나야죠."
    },
    {
      "start": 1185.41,
      "end": 1188.05,
      "text": "트렌디한 모습으로 만나 뵙도록 하겠습니다."
    },
    {
      "start": 1189.05,
      "end": 1190.99,
      "text": "이제 마지막 곡 들려드리도록 할게요."
    },
    {
      "start": 1191.51,
      "end": 1193.25,
      "text": "아바의 Thank you for the music"
    }
  ]
}