{
  "id": "2023-03-27_screen_english",
  "date": "2023-03-27",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "I can_t keep teaching you",
  "movie": "",
  "duration_sec": 765.48,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2023-03-27_screen_english.mp3",
  "script": [
    {
      "start": 0.0,
      "end": 4.85,
      "text": "과거보다는 미래를 바라보며 살고 있는지 등등"
    },
    {
      "start": 4.85,
      "end": 8.41,
      "text": "이런 것들로 젊음의 나이를 측정할 수 있죠."
    },
    {
      "start": 9.99,
      "end": 13.61,
      "text": "이렇게 기준은 각기 다르지만 공통점이 있다면"
    },
    {
      "start": 13.61,
      "end": 17.36,
      "text": "신체 나이와는 전혀 상관이 없다는 거예요."
    },
    {
      "start": 18.55,
      "end": 20.85,
      "text": "우리에게 주어진 모든 상황을"
    },
    {
      "start": 20.85,
      "end": 23.21,
      "text": "얼마나 긍정적으로 해석하고"
    },
    {
      "start": 23.21,
      "end": 25.43,
      "text": "적극적으로 활용하는지에 따라"
    },
    {
      "start": 25.43,
      "end": 28.41,
      "text": "젊고 늙음이 결정될 뿐이죠."
    },
    {
      "start": 29.72,
      "end": 31.94,
      "text": "여러분의 진짜 나이는 몇 살인가요?"
    },
    {
      "start": 33.18,
      "end": 36.12,
      "text": "older people sit down and ask, what is it?"
    },
    {
      "start": 36.56,
      "end": 39.02,
      "text": "but the boy asks, what can I do with it?"
    },
    {
      "start": 39.62,
      "end": 41.62,
      "text": "조장연의 굿모닝 팝스 시작하겠습니다."
    },
    {
      "start": 43.01,
      "end": 45.85,
      "text": "네, 경쾌한 월요일 시작해봤습니다."
    },
    {
      "start": 46.05,
      "end": 48.81,
      "text": "첫 곡으로 KT턴스터의 Hold On 이었고요."
    },
    {
      "start": 48.81,
      "end": 54.21,
      "text": "7701님, 휴직 후에 다시 복직하게 되었는데"
    },
    {
      "start": 54.21,
      "end": 58.53,
      "text": "출근 시간이 빨라져서 굿모닝 팝스를 실시간으로 듣고 있어요."
    },
    {
      "start": 59.19,
      "end": 61.73,
      "text": "귀도 깨우고 머리도 깨우고 좋네요."
    },
    {
      "start": 62.19,
      "end": 63.79,
      "text": "유익하게 잘 듣고 있습니다."
    },
    {
      "start": 64.03,
      "end": 64.51,
      "text": "하트!"
    },
    {
      "start": 64.51,
      "end": 70.91,
      "text": "아, 7701님, 복직하신 소감이 좀 어떠신가요?"
    },
    {
      "start": 71.91,
      "end": 74.33,
      "text": "장단점이 뭐든 다 있죠."
    },
    {
      "start": 75.49,
      "end": 79.87,
      "text": "그럼 우리는 그냥 장점에 집중해 보기로 할까요?"
    },
    {
      "start": 79.87,
      "end": 83.45,
      "text": "네, 그리고 이미 잘 적응하고 계신 것 같아요."
    },
    {
      "start": 83.85,
      "end": 90.83,
      "text": "7701님, 귀가 열리고 분명 뇌 건강에도 많은 도움이 될 겁니다."
    },
    {
      "start": 91.59,
      "end": 94.89,
      "text": "오늘도 힘차게 출근길 저랑 함께 해주세요."
    },
    {
      "start": 96.0,
      "end": 99.75,
      "text": "백경화님, 출근할 때는 운전하느라 바빠서"
    },
    {
      "start": 99.75,
      "end": 103.39,
      "text": "오후에 다시 듣기로 굿모닝 팝스 공부하고 있어요."
    },
    {
      "start": 104.19,
      "end": 105.95,
      "text": "작년에 힘든 일이 있을 때는"
    },
    {
      "start": 105.95,
      "end": 109.97,
      "text": "그냥 평범한 방송 내용만 들어도 울컥했었거든요."
    },
    {
      "start": 110.97,
      "end": 113.57,
      "text": "그런데 좋은 날도 안 좋은 날도"
    },
    {
      "start": 113.57,
      "end": 115.95,
      "text": "굿모닝 팝스와 함께여서 좋았어요."
    },
    {
      "start": 116.73,
      "end": 120.05,
      "text": "앞으로 더 열심히 굿모닝 팝스와 함께 공부할게요."
    },
    {
      "start": 120.05,
      "end": 120.85,
      "text": "감사합니다."
    },
    {
      "start": 122.51,
      "end": 127.77,
      "text": "우리 백경화님, 좋은 날이든 안 좋은 날이든"
    },
    {
      "start": 127.77,
      "end": 129.31,
      "text": "이렇게 늘 함께 하시고"
    },
    {
      "start": 129.31,
      "end": 134.97,
      "text": "그 안에서 정말 조금이나마 위로를 얻으셨으면 좋겠어요."
    },
    {
      "start": 136.18,
      "end": 137.38,
      "text": "사실 저도 그래요."
    },
    {
      "start": 137.6,
      "end": 141.12,
      "text": "우리가 인간인지라 매일매일이 불완전하잖아요."
    },
    {
      "start": 141.92,
      "end": 143.62,
      "text": "마음이 상하는 날도 있고"
    },
    {
      "start": 143.62,
      "end": 145.44,
      "text": "기쁜 날도 있고"
    },
    {
      "start": 145.44,
      "end": 147.76,
      "text": "컨디션이 좀 저저한 날도 있고"
    },
    {
      "start": 147.76,
      "end": 150.22,
      "text": "에너지가 마구마구 샘솟는 날도 있고"
    },
    {
      "start": 150.22,
      "end": 154.32,
      "text": "그런데 저도 이렇게 방송을 하면서"
    },
    {
      "start": 154.32,
      "end": 156.52,
      "text": "청취자분들의 사연을 접하고"
    },
    {
      "start": 156.52,
      "end": 160.16,
      "text": "또 늘 응원해 주시는 그 인사말 하나하나에"
    },
    {
      "start": 160.16,
      "end": 162.64,
      "text": "다시 힘을 얻고 하는 거잖아요."
    },
    {
      "start": 164.14,
      "end": 167.12,
      "text": "진심을 담아서 우리 이번 한 주도"
    },
    {
      "start": 167.12,
      "end": 168.78,
      "text": "꼭 함께해 주세요."
    },
    {
      "start": 169.08,
      "end": 169.92,
      "text": "백경화님"
    },
    {
      "start": 169.92,
      "end": 172.65,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 172.65,
      "end": 175.55,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 175.55,
      "end": 178.79,
      "text": "에너지 가득한 아침을 위한 이벤트"
    },
    {
      "start": 178.79,
      "end": 180.07,
      "text": "GMP로 영어실력"
    },
    {
      "start": 180.07,
      "end": 181.49,
      "text": "업! 에너지도 업!"
    },
    {
      "start": 182.14,
      "end": 183.68,
      "text": "이번 주에는 편의점에서"
    },
    {
      "start": 183.68,
      "end": 185.18,
      "text": "유용하게 사용하실 수 있는"
    },
    {
      "start": 185.18,
      "end": 187.08,
      "text": "편의점 모바일 쿠폰 준비했어요."
    },
    {
      "start": 187.78,
      "end": 189.68,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 189.68,
      "end": 191.68,
      "text": "총 5분 뽑아서 보내드릴게요."
    },
    {
      "start": 192.38,
      "end": 193.9,
      "text": "단문 50원과 장문 100원에"
    },
    {
      "start": 193.9,
      "end": 195.04,
      "text": "추가 요금이 부과되는"
    },
    {
      "start": 195.04,
      "end": 197.24,
      "text": "KBS 쿨 FM 문자샵 8910"
    },
    {
      "start": 197.24,
      "end": 201.22,
      "text": "아니면 KBS 이라디오 문자샵 1061로 신청하시거나"
    },
    {
      "start": 201.22,
      "end": 203.24,
      "text": "무료 KBS 애플리케이션 콩"
    },
    {
      "start": 203.24,
      "end": 204.9,
      "text": "분은 마이케이로 참여해 주세요."
    },
    {
      "start": 214.02,
      "end": 214.5,
      "text": "English"
    },
    {
      "start": 214.5,
      "end": 235.32,
      "text": "Green English Time"
    },
    {
      "start": 235.32,
      "end": 237.48,
      "text": "3월에 함께하고 있는 영화는"
    },
    {
      "start": 237.48,
      "end": 238.62,
      "text": "Storm Boy"
    },
    {
      "start": 238.62,
      "end": 241.3,
      "text": "It's about a young boy who lives with his father"
    },
    {
      "start": 241.3,
      "end": 244.36,
      "text": "among the dunes in South Australia's"
    },
    {
      "start": 244.36,
      "end": 245.74,
      "text": "Kronk coast."
    },
    {
      "start": 245.98,
      "end": 247.46,
      "text": "Oh, good morning입니다."
    },
    {
      "start": 247.62,
      "end": 248.5,
      "text": "우리 크쌤."
    },
    {
      "start": 248.56,
      "end": 249.02,
      "text": "Good morning."
    },
    {
      "start": 249.88,
      "end": 251.26,
      "text": "지정숙님께서도요."
    },
    {
      "start": 251.58,
      "end": 252.76,
      "text": "Hello, 크리스쌤."
    },
    {
      "start": 252.8,
      "end": 253.24,
      "text": "하트."
    },
    {
      "start": 253.42,
      "end": 254.24,
      "text": "Happy Monday."
    },
    {
      "start": 254.58,
      "end": 255.06,
      "text": "해 주셨어요."
    },
    {
      "start": 255.36,
      "end": 255.84,
      "text": "Thank you."
    },
    {
      "start": 255.9,
      "end": 256.44,
      "text": "Happy Monday."
    },
    {
      "start": 256.56,
      "end": 258.5,
      "text": "Let's start it off nicely."
    },
    {
      "start": 258.72,
      "end": 259.2,
      "text": "Okay."
    },
    {
      "start": 259.2,
      "end": 260.38,
      "text": "On a good note."
    },
    {
      "start": 261.7,
      "end": 264.08,
      "text": "Anyway, did you have a nice weekend?"
    },
    {
      "start": 264.66,
      "end": 265.56,
      "text": "Sure, yeah."
    },
    {
      "start": 265.72,
      "end": 267.12,
      "text": "I had a great weekend."
    },
    {
      "start": 267.32,
      "end": 272.42,
      "text": "네, 이렇게 힘차게 우리 월요일 영화 내용도 시작을 해봐야 되겠습니다."
    },
    {
      "start": 272.86,
      "end": 273.72,
      "text": "How was your weekend?"
    },
    {
      "start": 273.94,
      "end": 274.48,
      "text": "아, 저요?"
    },
    {
      "start": 274.52,
      "end": 275.56,
      "text": "좀 스몰톡 좀 하고."
    },
    {
      "start": 275.76,
      "end": 277.16,
      "text": "아, 그냥 넘어가려고 했는데"
    },
    {
      "start": 277.16,
      "end": 280.44,
      "text": "저는 그냥 주말이 과로로 인해서"
    },
    {
      "start": 280.44,
      "end": 283.26,
      "text": "굉장히 고된 주말을 보내서"
    },
    {
      "start": 283.26,
      "end": 288.08,
      "text": "저는 우리 크쌤이 행복하게 보내셨다는 소식에 대리만족을 하면서"
    },
    {
      "start": 288.08,
      "end": 290.48,
      "text": "슬슬쩍 지나가려고 했습니다."
    },
    {
      "start": 290.82,
      "end": 292.02,
      "text": "Take it easy."
    },
    {
      "start": 292.16,
      "end": 292.34,
      "text": "네."
    },
    {
      "start": 292.9,
      "end": 294.16,
      "text": "저는 대리 오늘이 더 행복해요."
    },
    {
      "start": 294.44,
      "end": 294.82,
      "text": "Okay."
    },
    {
      "start": 294.92,
      "end": 295.88,
      "text": "Oh, happy Monday."
    },
    {
      "start": 296.38,
      "end": 297.7,
      "text": "You're working and you're happy."
    },
    {
      "start": 298.42,
      "end": 298.76,
      "text": "좋아요."
    },
    {
      "start": 298.76,
      "end": 299.7,
      "text": "아, 네."
    },
    {
      "start": 300.14,
      "end": 302.26,
      "text": "아무튼 시작을 해보도록 하겠습니다."
    },
    {
      "start": 303.58,
      "end": 309.78,
      "text": "Colin Tilly라는 호주 작가가 wrote this novel in, 아, novel은 아니죠."
    },
    {
      "start": 310.1,
      "end": 311.46,
      "text": "Fairy tale이었죠."
    },
    {
      "start": 311.66,
      "end": 312.42,
      "text": "Fairy tale?"
    },
    {
      "start": 312.54,
      "end": 312.92,
      "text": "Right."
    },
    {
      "start": 313.18,
      "end": 315.62,
      "text": "And in 1964."
    },
    {
      "start": 316.06,
      "end": 317.48,
      "text": "I thought it was a novel."
    },
    {
      "start": 317.58,
      "end": 318.44,
      "text": "아, novel인가요?"
    },
    {
      "start": 318.54,
      "end": 321.44,
      "text": "Fairy tale is like Peter Pan, Cinderella."
    },
    {
      "start": 321.44,
      "end": 325.24,
      "text": "그러니까 어린이용으로 동화부터 시작을 했었으니까."
    },
    {
      "start": 325.52,
      "end": 325.82,
      "text": "아."
    },
    {
      "start": 326.02,
      "end": 327.52,
      "text": "네, 그런 의미로다가"
    },
    {
      "start": 327.52,
      "end": 331.34,
      "text": "어쨌든 이 책을 1964년에 썼는데"
    },
    {
      "start": 331.34,
      "end": 335.14,
      "text": "근데 이게 단순한 것이라기보다는"
    },
    {
      "start": 335.14,
      "end": 337.02,
      "text": "Is that autobiographical?"
    },
    {
      "start": 337.84,
      "end": 339.22,
      "text": "Not exactly."
    },
    {
      "start": 339.44,
      "end": 341.86,
      "text": "But some people think it might be"
    },
    {
      "start": 341.86,
      "end": 344.78,
      "text": "at least based on his personal experiences."
    },
    {
      "start": 345.14,
      "end": 346.22,
      "text": "I see."
    },
    {
      "start": 346.22,
      "end": 346.82,
      "text": "그래요."
    },
    {
      "start": 346.82,
      "end": 352.72,
      "text": "자전적인 내용을 그래도 조금씩 담은 게 아닐까라고 예상을 한다고 합니다."
    },
    {
      "start": 353.02,
      "end": 359.44,
      "text": "He was born in Australia, but to a German immigrant family in southern Australia,"
    },
    {
      "start": 359.7,
      "end": 361.54,
      "text": "which is famous for wine."
    },
    {
      "start": 361.76,
      "end": 363.32,
      "text": "Have you heard of Barossa?"
    },
    {
      "start": 363.66,
      "end": 364.82,
      "text": "The Barossa region?"
    },
    {
      "start": 365.08,
      "end": 365.72,
      "text": "와우."
    },
    {
      "start": 365.98,
      "end": 367.66,
      "text": "시라즈, 거기 굉장히 마시고요."
    },
    {
      "start": 367.84,
      "end": 368.16,
      "text": "아, 네."
    },
    {
      "start": 368.28,
      "end": 369.14,
      "text": "와인 전문가."
    },
    {
      "start": 369.54,
      "end": 370.98,
      "text": "Very fruity, very delicious."
    },
    {
      "start": 371.3,
      "end": 375.72,
      "text": "Anyway, he was born there, but his parents spoke only German at home."
    },
    {
      "start": 375.72,
      "end": 376.2,
      "text": "Yeah."
    },
    {
      "start": 376.36,
      "end": 378.72,
      "text": "So he didn't speak any English at all."
    },
    {
      "start": 378.88,
      "end": 380.02,
      "text": "너무 힘들었겠는데요."
    },
    {
      "start": 380.24,
      "end": 383.24,
      "text": "And he went to school speaking zero English."
    },
    {
      "start": 383.36,
      "end": 383.8,
      "text": "Uh-oh."
    },
    {
      "start": 383.9,
      "end": 384.62,
      "text": "Only German."
    },
    {
      "start": 384.8,
      "end": 385.26,
      "text": "Uh-oh."
    },
    {
      "start": 385.28,
      "end": 387.36,
      "text": "So he felt like a total outsider."
    },
    {
      "start": 387.66,
      "end": 388.16,
      "text": "Uh-huh."
    },
    {
      "start": 388.34,
      "end": 390.78,
      "text": "And he had some troubles adjusting."
    },
    {
      "start": 391.1,
      "end": 391.46,
      "text": "Yeah."
    },
    {
      "start": 391.74,
      "end": 393.14,
      "text": "And then look at Storm Boy."
    },
    {
      "start": 393.34,
      "end": 393.7,
      "text": "Um."
    },
    {
      "start": 393.92,
      "end": 395.98,
      "text": "Storm Boy also is about outsiders."
    },
    {
      "start": 396.3,
      "end": 396.8,
      "text": "맞네요."
    },
    {
      "start": 397.38,
      "end": 400.1,
      "text": "The main characters all feel like outsiders."
    },
    {
      "start": 400.4,
      "end": 400.7,
      "text": "Yeah."
    },
    {
      "start": 400.7,
      "end": 403.66,
      "text": "They live on the outskirts of society."
    },
    {
      "start": 404.04,
      "end": 404.34,
      "text": "Right."
    },
    {
      "start": 404.34,
      "end": 409.34,
      "text": "Hideaway Tom, Fingerbone Bill, Mike, Storm Boy, even the three pelicans."
    },
    {
      "start": 409.98,
      "end": 413.96,
      "text": "They grow up with no parents, with people, no pelicans."
    },
    {
      "start": 413.96,
      "end": 441.0,
      "text": "그러니까 이 작가가 경험한 것을 실질적으로 100% 일치하는 내용으로는 아니지만 상징적으로 이렇게 자기가 아웃사이더였으니까 지금 이 Storm Boy로 역할을 하고 있는 그 마이클, 그리고 three pelicans, 그리고 아버지인 Tom, 그리고 원주민 아저씨 Fingerbone Bill, 이 아저씨까지 캐릭터들이 딱딱 들어맞는 느낌이 들기는 합니다."
    },
    {
      "start": 441.0,
      "end": 444.16,
      "text": "어, 배경 지식이 나날이 쌓아지는 것 같아요."
    },
    {
      "start": 444.6,
      "end": 446.0,
      "text": "그럼 오늘 준비된 내용 먼저 들어볼게요."
    },
    {
      "start": 446.0,
      "end": 448.1,
      "text": "I'm not going."
    },
    {
      "start": 448.34,
      "end": 449.96,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 450.48,
      "end": 451.76,
      "text": "I don't want an opportunity."
    },
    {
      "start": 451.94,
      "end": 452.88,
      "text": "I want to stay here."
    },
    {
      "start": 452.92,
      "end": 454.46,
      "text": "But I can't keep teaching you."
    },
    {
      "start": 454.86,
      "end": 456.32,
      "text": "Yeah, not the way you should be."
    },
    {
      "start": 456.38,
      "end": 458.0,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 458.36,
      "end": 460.42,
      "text": "Look, it's a big world, and there's a lot to do out there."
    },
    {
      "start": 460.44,
      "end": 460.92,
      "text": "I don't care."
    },
    {
      "start": 460.92,
      "end": 472.3,
      "text": "아니, 지난주에 the villagers said they would send him to 아주 좋은 boarding school에 보내고 싶다라고 이야기했었잖아요."
    },
    {
      "start": 472.58,
      "end": 473.5,
      "text": "Saint something."
    },
    {
      "start": 473.76,
      "end": 474.08,
      "text": "맞아요."
    },
    {
      "start": 474.08,
      "end": 476.14,
      "text": "Saint Andrews, a fancy school."
    },
    {
      "start": 476.3,
      "end": 479.56,
      "text": "네, 그러면서 he needs a proper education."
    },
    {
      "start": 479.82,
      "end": 481.34,
      "text": "이런 이야기도 했었단 말이죠."
    },
    {
      "start": 481.52,
      "end": 484.3,
      "text": "That's what many people think, but he does not agree."
    },
    {
      "start": 484.3,
      "end": 492.3,
      "text": "네, 지금 마이클의 목소리를 들으면서 예상을 하신 것처럼 아주 격하게 되게 반대되는 반응을 하고 있습니다."
    },
    {
      "start": 492.3,
      "end": 495.8,
      "text": "He wants to stay with his pelican friend, Percival."
    },
    {
      "start": 496.04,
      "end": 497.24,
      "text": "He's a brother."
    },
    {
      "start": 497.6,
      "end": 500.62,
      "text": "How can he separate from his brother, pelican brother?"
    },
    {
      "start": 500.8,
      "end": 501.44,
      "text": "그러게 말이에요."
    },
    {
      "start": 501.58,
      "end": 505.0,
      "text": "이 헤어짐이라는 것이 결코 쉬운 일이 아닐 겁니다."
    },
    {
      "start": 505.62,
      "end": 506.58,
      "text": "Yeah, but it must be done."
    },
    {
      "start": 507.54,
      "end": 507.88,
      "text": "그렇죠."
    },
    {
      "start": 507.88,
      "end": 513.56,
      "text": "자, 오늘 들은 내용 중에서 주요 표현을 점검을 해보겠습니다."
    },
    {
      "start": 513.82,
      "end": 514.76,
      "text": "아, 네, 감상 약간."
    },
    {
      "start": 514.86,
      "end": 516.18,
      "text": "Sorry."
    },
    {
      "start": 516.52,
      "end": 516.8,
      "text": "Sorry."
    },
    {
      "start": 517.94,
      "end": 518.98,
      "text": "양해 부탁드리고요."
    },
    {
      "start": 519.48,
      "end": 520.24,
      "text": "Opportunity."
    },
    {
      "start": 520.7,
      "end": 524.24,
      "text": "네, Opportunity라고 하면 기회라는 뜻입니다."
    },
    {
      "start": 525.0,
      "end": 526.54,
      "text": "I can't keep teaching you."
    },
    {
      "start": 526.64,
      "end": 529.24,
      "text": "I can't keep teaching you."
    },
    {
      "start": 529.44,
      "end": 530.26,
      "text": "이게 무슨 의미일까요?"
    },
    {
      "start": 530.26,
      "end": 534.26,
      "text": "내가 너를 계속해서 가르칠 수는 없어 라는 의미입니다."
    },
    {
      "start": 535.24,
      "end": 536.7,
      "text": "Look, it's a big world."
    },
    {
      "start": 536.7,
      "end": 538.78,
      "text": "Look, it's a big world."
    },
    {
      "start": 539.26,
      "end": 541.3,
      "text": "봐봐, 세상은 넓어."
    },
    {
      "start": 541.94,
      "end": 543.94,
      "text": "과연 누구에게 이야기를 하는 걸까요?"
    },
    {
      "start": 544.28,
      "end": 544.9,
      "text": "궁금하시죠?"
    },
    {
      "start": 545.28,
      "end": 546.5,
      "text": "다시 한번 들어보시죠."
    },
    {
      "start": 546.5,
      "end": 547.86,
      "text": "I'm not going."
    },
    {
      "start": 548.1,
      "end": 549.7,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 550.24,
      "end": 551.5,
      "text": "I don't want an opportunity."
    },
    {
      "start": 551.7,
      "end": 552.62,
      "text": "I want to stay here."
    },
    {
      "start": 552.68,
      "end": 554.22,
      "text": "I can't keep teaching you."
    },
    {
      "start": 554.62,
      "end": 556.08,
      "text": "Not the way you should be."
    },
    {
      "start": 556.14,
      "end": 557.78,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 558.12,
      "end": 560.08,
      "text": "Look, it's a big world and there's a lot to do out there."
    },
    {
      "start": 560.1,
      "end": 560.68,
      "text": "I don't care."
    },
    {
      "start": 560.8,
      "end": 562.33,
      "text": "I'm not going."
    },
    {
      "start": 562.95,
      "end": 566.55,
      "text": "바로바로 아들과 아버지의 대화였습니다."
    },
    {
      "start": 566.55,
      "end": 569.99,
      "text": "네, 처음으로 이제 마이클이 하는 말을 들어볼게요."
    },
    {
      "start": 570.31,
      "end": 571.21,
      "text": "I'm not going."
    },
    {
      "start": 571.41,
      "end": 573.37,
      "text": "네, 아주 큰 소리로 외쳤습니다."
    },
    {
      "start": 573.61,
      "end": 574.63,
      "text": "I'm not going."
    },
    {
      "start": 575.11,
      "end": 575.69,
      "text": "안 가요."
    },
    {
      "start": 575.81,
      "end": 576.49,
      "text": "안 갈 거예요."
    },
    {
      "start": 576.97,
      "end": 577.79,
      "text": "No way."
    },
    {
      "start": 579.15,
      "end": 581.59,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 581.59,
      "end": 584.27,
      "text": "아빠의 이야기였는데요."
    },
    {
      "start": 584.45,
      "end": 587.11,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 587.75,
      "end": 590.71,
      "text": "너는 그걸 기회로 간주해야 돼, 마이클."
    },
    {
      "start": 591.23,
      "end": 592.49,
      "text": "I don't want an opportunity."
    },
    {
      "start": 592.77,
      "end": 593.83,
      "text": "I want to stay here."
    },
    {
      "start": 594.71,
      "end": 596.95,
      "text": "저는 그런 기회 따위인 필요 없어요."
    },
    {
      "start": 597.23,
      "end": 598.49,
      "text": "I don't want an opportunity."
    },
    {
      "start": 599.07,
      "end": 599.85,
      "text": "그 다음에 하는 말이"
    },
    {
      "start": 599.85,
      "end": 601.19,
      "text": "I want to stay here."
    },
    {
      "start": 601.59,
      "end": 602.89,
      "text": "저는 여기에서 살 거예요."
    },
    {
      "start": 603.65,
      "end": 606.23,
      "text": "Yeah, but I can't keep teaching you."
    },
    {
      "start": 606.23,
      "end": 607.45,
      "text": "음, 그래."
    },
    {
      "start": 607.73,
      "end": 610.99,
      "text": "하지만, but I can't keep teaching you."
    },
    {
      "start": 611.39,
      "end": 614.07,
      "text": "아빠가 너를 계속해서 가르칠 수는 없어."
    },
    {
      "start": 614.59,
      "end": 617.15,
      "text": "Not the way you should be taught."
    },
    {
      "start": 617.33,
      "end": 618.59,
      "text": "다 생략이 됐군요."
    },
    {
      "start": 618.67,
      "end": 619.11,
      "text": "아하."
    },
    {
      "start": 619.45,
      "end": 621.63,
      "text": "네, taught가 생략이 되었다라는 것까지"
    },
    {
      "start": 621.63,
      "end": 623.21,
      "text": "아주 친절한 설명 감사드립니다."
    },
    {
      "start": 623.97,
      "end": 626.31,
      "text": "네가 교육을 받아야 할 방식이 아니야."
    },
    {
      "start": 626.89,
      "end": 630.51,
      "text": "그러니까 내가 너를 제대로 계속해서 가르칠 수 없어"
    },
    {
      "start": 630.51,
      "end": 632.17,
      "text": "라는 부연 설명이 되겠죠."
    },
    {
      "start": 632.17,
      "end": 634.73,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 635.27,
      "end": 635.71,
      "text": "싫어요."
    },
    {
      "start": 636.13,
      "end": 637.57,
      "text": "I'm staying here with you."
    },
    {
      "start": 638.03,
      "end": 640.01,
      "text": "아빠랑 여기에서 지낼 거예요."
    },
    {
      "start": 640.67,
      "end": 642.17,
      "text": "Look, it's a big world"
    },
    {
      "start": 642.17,
      "end": 644.63,
      "text": "and there's a lot to do out there."
    },
    {
      "start": 644.87,
      "end": 645.85,
      "text": "네, 그러면서"
    },
    {
      "start": 645.85,
      "end": 648.11,
      "text": "자, it's a big world."
    },
    {
      "start": 648.53,
      "end": 649.77,
      "text": "세상은 넓고"
    },
    {
      "start": 649.77,
      "end": 652.39,
      "text": "and there's a lot to do out there."
    },
    {
      "start": 652.77,
      "end": 655.55,
      "text": "저 세상에 할 일은 아주 많단다."
    },
    {
      "start": 655.67,
      "end": 656.19,
      "text": "라고 한 거예요."
    },
    {
      "start": 656.37,
      "end": 657.35,
      "text": "Yeah, for us too."
    },
    {
      "start": 657.51,
      "end": 658.67,
      "text": "We need to get out."
    },
    {
      "start": 658.79,
      "end": 659.07,
      "text": "Yeah."
    },
    {
      "start": 659.35,
      "end": 659.91,
      "text": "Explore."
    },
    {
      "start": 660.07,
      "end": 660.53,
      "text": "그럼요."
    },
    {
      "start": 660.53,
      "end": 662.59,
      "text": "네, 탐험 정신, 도전 정신"
    },
    {
      "start": 662.59,
      "end": 663.75,
      "text": "네, 필요하죠."
    },
    {
      "start": 663.85,
      "end": 664.71,
      "text": "우리도 실천합시다."
    },
    {
      "start": 664.83,
      "end": 664.99,
      "text": "네."
    },
    {
      "start": 665.13,
      "end": 665.63,
      "text": "조셈이랑."
    },
    {
      "start": 665.83,
      "end": 666.47,
      "text": "알겠습니다."
    },
    {
      "start": 666.63,
      "end": 667.17,
      "text": "어디로 갈까요?"
    },
    {
      "start": 667.75,
      "end": 668.75,
      "text": "음, 집으로."
    },
    {
      "start": 670.05,
      "end": 672.29,
      "text": "아, 거기가 세상이 넓고 할 일이 많은 곳이에요."
    },
    {
      "start": 672.65,
      "end": 674.29,
      "text": "할 일이 정말 산더미죠."
    },
    {
      "start": 674.75,
      "end": 674.83,
      "text": "아."
    },
    {
      "start": 675.03,
      "end": 676.21,
      "text": "The house chores."
    },
    {
      "start": 676.57,
      "end": 676.87,
      "text": "아하."
    },
    {
      "start": 677.03,
      "end": 677.31,
      "text": "Yeah."
    },
    {
      "start": 677.77,
      "end": 679.19,
      "text": "정말 피곤하네요, 생각만 해도."
    },
    {
      "start": 679.25,
      "end": 679.89,
      "text": "네, 가지 맙시다."
    },
    {
      "start": 680.03,
      "end": 681.27,
      "text": "일하는 게 가장 행복한 걸로."
    },
    {
      "start": 681.41,
      "end": 681.69,
      "text": "아, yeah."
    },
    {
      "start": 682.27,
      "end": 683.37,
      "text": "Work is happiness."
    },
    {
      "start": 683.61,
      "end": 683.77,
      "text": "Yeah."
    },
    {
      "start": 683.87,
      "end": 684.77,
      "text": "Work is a blessing."
    },
    {
      "start": 684.99,
      "end": 686.17,
      "text": "네, 오늘의 명언이고요."
    },
    {
      "start": 686.97,
      "end": 687.57,
      "text": "I don't care."
    },
    {
      "start": 687.63,
      "end": 688.37,
      "text": "I'm not going."
    },
    {
      "start": 688.37,
      "end": 690.93,
      "text": "네, 이제 아들이 이야기한 말입니다."
    },
    {
      "start": 691.09,
      "end": 691.87,
      "text": "I don't care."
    },
    {
      "start": 692.27,
      "end": 693.11,
      "text": "상관없어요."
    },
    {
      "start": 693.51,
      "end": 694.59,
      "text": "I'm not going."
    },
    {
      "start": 694.83,
      "end": 695.91,
      "text": "안 간다고요."
    },
    {
      "start": 696.21,
      "end": 699.19,
      "text": "네, 이렇게 계속해서 안 간다고 부정을 하고 있습니다."
    },
    {
      "start": 700.27,
      "end": 702.87,
      "text": "그래도 이제 아버지의 입장에서는"
    },
    {
      "start": 702.87,
      "end": 707.91,
      "text": "he knew he had to educate his son in a proper way."
    },
    {
      "start": 707.91,
      "end": 710.97,
      "text": "그럼 당연히 보내야 되는 상황이긴 하겠죠."
    },
    {
      "start": 711.17,
      "end": 711.37,
      "text": "Yeah."
    },
    {
      "start": 711.47,
      "end": 712.91,
      "text": "Especially without his mother."
    },
    {
      "start": 713.07,
      "end": 716.91,
      "text": "He feels like that's his responsibility, his duty as a dad."
    },
    {
      "start": 716.97,
      "end": 719.93,
      "text": "To give his kid a proper education."
    },
    {
      "start": 720.17,
      "end": 720.51,
      "text": "Right."
    },
    {
      "start": 720.51,
      "end": 721.11,
      "text": "I understand."
    },
    {
      "start": 721.37,
      "end": 721.57,
      "text": "네."
    },
    {
      "start": 722.09,
      "end": 724.27,
      "text": "앞으로 어떻게 될지 점점 기대가 됩니다."
    },
    {
      "start": 724.97,
      "end": 726.27,
      "text": "그럼 한 번 더 들어보시죠."
    },
    {
      "start": 726.91,
      "end": 727.75,
      "text": "I'm not going."
    },
    {
      "start": 727.97,
      "end": 729.65,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 730.13,
      "end": 731.39,
      "text": "I don't want an opportunity."
    },
    {
      "start": 731.57,
      "end": 732.51,
      "text": "I want to stay here."
    },
    {
      "start": 732.55,
      "end": 734.11,
      "text": "But I can't keep teaching you."
    },
    {
      "start": 734.51,
      "end": 735.97,
      "text": "Not the way you should be."
    },
    {
      "start": 735.97,
      "end": 737.67,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 738.01,
      "end": 739.97,
      "text": "Look, it's a big world and there's a lot to do out there."
    },
    {
      "start": 739.99,
      "end": 740.59,
      "text": "I don't care."
    },
    {
      "start": 742.9,
      "end": 744.22,
      "text": "잘 들어보셨죠?"
    },
    {
      "start": 744.44,
      "end": 745.58,
      "text": "이해라 님께서"
    },
    {
      "start": 745.58,
      "end": 747.2,
      "text": "크쌤 감사합니다."
    },
    {
      "start": 747.6,
      "end": 748.32,
      "text": "하트 세 개."
    },
    {
      "start": 748.98,
      "end": 749.78,
      "text": "Oh, thank you."
    },
    {
      "start": 749.88,
      "end": 750.06,
      "text": "네."
    },
    {
      "start": 750.38,
      "end": 751.92,
      "text": "하트 백 개."
    },
    {
      "start": 752.02,
      "end": 752.62,
      "text": "백 개."
    },
    {
      "start": 752.78,
      "end": 754.68,
      "text": "와, 엄청나게 증가했네요."
    },
    {
      "start": 754.84,
      "end": 756.34,
      "text": "I'm feeling generous this morning."
    },
    {
      "start": 756.42,
      "end": 756.72,
      "text": "와."
    },
    {
      "start": 756.9,
      "end": 758.06,
      "text": "I'm feeling like, yeah."
    },
    {
      "start": 758.2,
      "end": 758.52,
      "text": "Yeah."
    },
    {
      "start": 758.7,
      "end": 759.2,
      "text": "Giving a lot."
    },
    {
      "start": 759.4,
      "end": 759.6,
      "text": "Yeah."
    },
    {
      "start": 759.6,
      "end": 761.4,
      "text": "Generous Monday morning입니다."
    },
    {
      "start": 762.0,
      "end": 763.52,
      "text": "Fabulous한 날 보내시고요."
    },
    {
      "start": 763.68,
      "end": 764.44,
      "text": "Have a great day."
    },
    {
      "start": 764.54,
      "end": 764.82,
      "text": "Yeah."
    },
    {
      "start": 764.94,
      "end": 765.48,
      "text": "See you tomorrow."
    }
