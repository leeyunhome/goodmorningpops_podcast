{
  "id": "2023-03-27_screen_english",
  "date": "2023-03-27",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "스톰 보이 (Storm Boy)",
  "duration_sec": 815.77,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2023-03-27_screen_english.mp3",
  "artwork_generated_url": "",
  "script": [
    {
      "start": 0.0,
      "end": 1.94,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 1.94,
      "end": 15.57,
      "text": "애플 창업자 스티브 잡스가 이런 말을 했습니다."
    },
    {
      "start": 16.89,
      "end": 20.27,
      "text": "older people sit down and ask, what is it?"
    },
    {
      "start": 21.08,
      "end": 24.06,
      "text": "but the boy asks, what can I do with it?"
    },
    {
      "start": 25.35,
      "end": 29.83,
      "text": "나이 든 사람들은 앉아서 이게 뭐지? 라고 묻지만"
    },
    {
      "start": 29.83,
      "end": 35.45,
      "text": "젊은 사람들은 이걸로 내가 뭘 할 수 있지? 라고 묻는다."
    },
    {
      "start": 35.45,
      "end": 41.86,
      "text": "젊은이와 나이 든 사람을 구별하는 기준이 이것 말고도 여러가지가 있죠."
    },
    {
      "start": 43.24,
      "end": 46.14,
      "text": "호기심이나 상상력이 얼마나 풍부한지"
    },
    {
      "start": 46.14,
      "end": 49.81,
      "text": "꿈을 이루고 싶은 열정이 얼마나 뜨거운지"
    },
    {
      "start": 49.81,
      "end": 54.66,
      "text": "과거보다는 미래를 바라보며 살고 있는지 등등"
    },
    {
      "start": 54.66,
      "end": 58.22,
      "text": "이런 것들로 젊음의 나이를 측정할 수 있죠."
    },
    {
      "start": 59.8,
      "end": 63.42,
      "text": "이렇게 기준은 각기 다르지만 공통점이 있다면"
    },
    {
      "start": 63.42,
      "end": 67.17,
      "text": "신체 나이와는 전혀 상관이 없다는 거예요."
    },
    {
      "start": 68.36,
      "end": 70.66,
      "text": "우리에게 주어진 모든 상황을"
    },
    {
      "start": 70.66,
      "end": 73.02,
      "text": "얼마나 긍정적으로 해석하고"
    },
    {
      "start": 73.02,
      "end": 75.24,
      "text": "적극적으로 활용하는지에 따라"
    },
    {
      "start": 75.24,
      "end": 78.22,
      "text": "젊고 늙음이 결정될 뿐이죠."
    },
    {
      "start": 79.53,
      "end": 81.75,
      "text": "여러분의 진짜 나이는 몇 살인가요?"
    },
    {
      "start": 82.99,
      "end": 85.93,
      "text": "older people sit down and ask, what is it?"
    },
    {
      "start": 86.37,
      "end": 88.83,
      "text": "but the boy asks, what can I do with it?"
    },
    {
      "start": 89.43,
      "end": 91.43,
      "text": "조장연의 굿모닝 팝스 시작하겠습니다."
    },
    {
      "start": 92.82,
      "end": 95.66,
      "text": "네, 경쾌한 월요일 시작해봤습니다."
    },
    {
      "start": 95.86,
      "end": 98.62,
      "text": "첫 곡으로 KT턴스터의 Hold On 이었고요."
    },
    {
      "start": 98.62,
      "end": 104.02,
      "text": "7701님, 휴직 후에 다시 복직하게 되었는데"
    },
    {
      "start": 104.02,
      "end": 108.34,
      "text": "출근 시간이 빨라져서 굿모닝 팝스를 실시간으로 듣고 있어요."
    },
    {
      "start": 109.0,
      "end": 111.54,
      "text": "귀도 깨우고 머리도 깨우고 좋네요."
    },
    {
      "start": 112.0,
      "end": 113.6,
      "text": "유익하게 잘 듣고 있습니다."
    },
    {
      "start": 113.84,
      "end": 114.32,
      "text": "하트!"
    },
    {
      "start": 114.32,
      "end": 120.72,
      "text": "아, 7701님, 복직하신 소감이 좀 어떠신가요?"
    },
    {
      "start": 121.72,
      "end": 124.14,
      "text": "장단점이 뭐든 다 있죠."
    },
    {
      "start": 125.3,
      "end": 129.68,
      "text": "그럼 우리는 그냥 장점에 집중해 보기로 할까요?"
    },
    {
      "start": 129.68,
      "end": 133.26,
      "text": "네, 그리고 이미 잘 적응하고 계신 것 같아요."
    },
    {
      "start": 133.66,
      "end": 140.64,
      "text": "7701님, 귀가 열리고 분명 뇌 건강에도 많은 도움이 될 겁니다."
    },
    {
      "start": 141.4,
      "end": 144.7,
      "text": "오늘도 힘차게 출근길 저랑 함께 해주세요."
    },
    {
      "start": 145.81,
      "end": 149.56,
      "text": "백경화님, 출근할 때는 운전하느라 바빠서"
    },
    {
      "start": 149.56,
      "end": 153.2,
      "text": "오후에 다시 듣기로 굿모닝 팝스 공부하고 있어요."
    },
    {
      "start": 154.0,
      "end": 155.76,
      "text": "작년에 힘든 일이 있을 때는"
    },
    {
      "start": 155.76,
      "end": 159.78,
      "text": "그냥 평범한 방송 내용만 들어도 울컥했었거든요."
    },
    {
      "start": 160.78,
      "end": 163.38,
      "text": "그런데 좋은 날도 안 좋은 날도"
    },
    {
      "start": 163.38,
      "end": 165.76,
      "text": "굿모닝 팝스와 함께여서 좋았어요."
    },
    {
      "start": 166.54,
      "end": 169.86,
      "text": "앞으로 더 열심히 굿모닝 팝스와 함께 공부할게요."
    },
    {
      "start": 169.86,
      "end": 170.66,
      "text": "감사합니다."
    },
    {
      "start": 172.32,
      "end": 177.58,
      "text": "우리 백경화님, 좋은 날이든 안 좋은 날이든"
    },
    {
      "start": 177.58,
      "end": 179.12,
      "text": "이렇게 늘 함께 하시고"
    },
    {
      "start": 179.12,
      "end": 184.78,
      "text": "그 안에서 정말 조금이나마 위로를 얻으셨으면 좋겠어요."
    },
    {
      "start": 185.99,
      "end": 187.19,
      "text": "사실 저도 그래요."
    },
    {
      "start": 187.41,
      "end": 190.93,
      "text": "우리가 인간인지라 매일매일이 불완전하잖아요."
    },
    {
      "start": 191.73,
      "end": 193.43,
      "text": "마음이 상하는 날도 있고"
    },
    {
      "start": 193.43,
      "end": 195.25,
      "text": "기쁜 날도 있고"
    },
    {
      "start": 195.25,
      "end": 197.57,
      "text": "컨디션이 좀 저저한 날도 있고"
    },
    {
      "start": 197.57,
      "end": 200.03,
      "text": "에너지가 마구마구 샘솟는 날도 있고"
    },
    {
      "start": 200.03,
      "end": 204.13,
      "text": "그런데 저도 이렇게 방송을 하면서"
    },
    {
      "start": 204.13,
      "end": 206.33,
      "text": "청취자분들의 사연을 접하고"
    },
    {
      "start": 206.33,
      "end": 209.97,
      "text": "또 늘 응원해 주시는 그 인사말 하나하나에"
    },
    {
      "start": 209.97,
      "end": 212.45,
      "text": "다시 힘을 얻고 하는 거잖아요."
    },
    {
      "start": 213.95,
      "end": 216.93,
      "text": "진심을 담아서 우리 이번 한 주도"
    },
    {
      "start": 216.93,
      "end": 218.59,
      "text": "꼭 함께해 주세요."
    },
    {
      "start": 218.89,
      "end": 219.73,
      "text": "백경화님"
    },
    {
      "start": 219.73,
      "end": 222.46,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 222.46,
      "end": 225.36,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 225.36,
      "end": 228.6,
      "text": "에너지 가득한 아침을 위한 이벤트"
    },
    {
      "start": 228.6,
      "end": 229.88,
      "text": "GMP로 영어실력"
    },
    {
      "start": 229.88,
      "end": 231.3,
      "text": "업! 에너지도 업!"
    },
    {
      "start": 231.95,
      "end": 233.49,
      "text": "이번 주에는 편의점에서"
    },
    {
      "start": 233.49,
      "end": 234.99,
      "text": "유용하게 사용하실 수 있는"
    },
    {
      "start": 234.99,
      "end": 236.89,
      "text": "편의점 모바일 쿠폰 준비했어요."
    },
    {
      "start": 237.59,
      "end": 239.49,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 239.49,
      "end": 241.49,
      "text": "총 5분 뽑아서 보내드릴게요."
    },
    {
      "start": 242.19,
      "end": 243.71,
      "text": "단문 50원과 장문 100원에"
    },
    {
      "start": 243.71,
      "end": 244.85,
      "text": "추가 요금이 부과되는"
    },
    {
      "start": 244.85,
      "end": 247.05,
      "text": "KBS 쿨 FM 문자샵 8910"
    },
    {
      "start": 247.05,
      "end": 251.03,
      "text": "아니면 KBS 이라디오 문자샵 1061로 신청하시거나"
    },
    {
      "start": 251.03,
      "end": 253.05,
      "text": "무료 KBS 애플리케이션 콩"
    },
    {
      "start": 253.05,
      "end": 254.71,
      "text": "분은 마이케이로 참여해 주세요."
    },
    {
      "start": 263.83,
      "end": 264.31,
      "text": "English"
    },
    {
      "start": 264.31,
      "end": 285.13,
      "text": "Green English Time"
    },
    {
      "start": 285.13,
      "end": 287.29,
      "text": "3월에 함께하고 있는 영화는"
    },
    {
      "start": 287.29,
      "end": 288.43,
      "text": "Storm Boy"
    },
    {
      "start": 288.43,
      "end": 291.11,
      "text": "It's about a young boy who lives with his father"
    },
    {
      "start": 291.11,
      "end": 294.17,
      "text": "among the dunes in South Australia's"
    },
    {
      "start": 294.17,
      "end": 295.55,
      "text": "Kronk coast."
    },
    {
      "start": 295.79,
      "end": 297.27,
      "text": "Oh, good morning입니다."
    },
    {
      "start": 297.43,
      "end": 298.31,
      "text": "우리 크쌤."
    },
    {
      "start": 298.37,
      "end": 298.83,
      "text": "Good morning."
    },
    {
      "start": 299.69,
      "end": 301.07,
      "text": "지정숙님께서도요."
    },
    {
      "start": 301.39,
      "end": 302.57,
      "text": "Hello, 크리스쌤."
    },
    {
      "start": 302.61,
      "end": 303.05,
      "text": "하트."
    },
    {
      "start": 303.23,
      "end": 304.05,
      "text": "Happy Monday."
    },
    {
      "start": 304.39,
      "end": 304.87,
      "text": "해 주셨어요."
    },
    {
      "start": 305.17,
      "end": 305.65,
      "text": "Thank you."
    },
    {
      "start": 305.71,
      "end": 306.25,
      "text": "Happy Monday."
    },
    {
      "start": 306.37,
      "end": 308.31,
      "text": "Let's start it off nicely."
    },
    {
      "start": 308.53,
      "end": 309.01,
      "text": "Okay."
    },
    {
      "start": 309.01,
      "end": 310.19,
      "text": "On a good note."
    },
    {
      "start": 311.51,
      "end": 313.89,
      "text": "Anyway, did you have a nice weekend?"
    },
    {
      "start": 314.47,
      "end": 315.37,
      "text": "Sure, yeah."
    },
    {
      "start": 315.53,
      "end": 316.93,
      "text": "I had a great weekend."
    },
    {
      "start": 317.13,
      "end": 322.23,
      "text": "네, 이렇게 힘차게 우리 월요일 영화 내용도 시작을 해봐야 되겠습니다."
    },
    {
      "start": 322.67,
      "end": 323.53,
      "text": "How was your weekend?"
    },
    {
      "start": 323.75,
      "end": 324.29,
      "text": "아, 저요?"
    },
    {
      "start": 324.33,
      "end": 325.37,
      "text": "좀 스몰톡 좀 하고."
    },
    {
      "start": 325.57,
      "end": 326.97,
      "text": "아, 그냥 넘어가려고 했는데"
    },
    {
      "start": 326.97,
      "end": 330.25,
      "text": "저는 그냥 주말이 과로로 인해서"
    },
    {
      "start": 330.25,
      "end": 333.07,
      "text": "굉장히 고된 주말을 보내서"
    },
    {
      "start": 333.07,
      "end": 337.89,
      "text": "저는 우리 크쌤이 행복하게 보내셨다는 소식에 대리만족을 하면서"
    },
    {
      "start": 337.89,
      "end": 340.29,
      "text": "슬슬쩍 지나가려고 했습니다."
    },
    {
      "start": 340.63,
      "end": 341.83,
      "text": "Take it easy."
    },
    {
      "start": 341.97,
      "end": 342.15,
      "text": "네."
    },
    {
      "start": 342.71,
      "end": 343.97,
      "text": "저는 대리 오늘이 더 행복해요."
    },
    {
      "start": 344.25,
      "end": 344.63,
      "text": "Okay."
    },
    {
      "start": 344.73,
      "end": 345.69,
      "text": "Oh, happy Monday."
    },
    {
      "start": 346.19,
      "end": 347.51,
      "text": "You're working and you're happy."
    },
    {
      "start": 348.23,
      "end": 348.57,
      "text": "좋아요."
    },
    {
      "start": 348.57,
      "end": 349.51,
      "text": "아, 네."
    },
    {
      "start": 349.95,
      "end": 352.07,
      "text": "아무튼 시작을 해보도록 하겠습니다."
    },
    {
      "start": 353.39,
      "end": 359.59,
      "text": "Colin Tilly라는 호주 작가가 wrote this novel in, 아, novel은 아니죠."
    },
    {
      "start": 359.91,
      "end": 361.27,
      "text": "Fairy tale이었죠."
    },
    {
      "start": 361.47,
      "end": 362.23,
      "text": "Fairy tale?"
    },
    {
      "start": 362.35,
      "end": 362.73,
      "text": "Right."
    },
    {
      "start": 362.99,
      "end": 365.43,
      "text": "And in 1964."
    },
    {
      "start": 365.87,
      "end": 367.29,
      "text": "I thought it was a novel."
    },
    {
      "start": 367.39,
      "end": 368.25,
      "text": "아, novel인가요?"
    },
    {
      "start": 368.35,
      "end": 371.25,
      "text": "Fairy tale is like Peter Pan, Cinderella."
    },
    {
      "start": 371.25,
      "end": 375.05,
      "text": "그러니까 어린이용으로 동화부터 시작을 했었으니까."
    },
    {
      "start": 375.33,
      "end": 375.63,
      "text": "아."
    },
    {
      "start": 375.83,
      "end": 377.33,
      "text": "네, 그런 의미로다가"
    },
    {
      "start": 377.33,
      "end": 381.15,
      "text": "어쨌든 이 책을 1964년에 썼는데"
    },
    {
      "start": 381.15,
      "end": 384.95,
      "text": "근데 이게 단순한 것이라기보다는"
    },
    {
      "start": 384.95,
      "end": 386.83,
      "text": "Is that autobiographical?"
    },
    {
      "start": 387.65,
      "end": 389.03,
      "text": "Not exactly."
    },
    {
      "start": 389.25,
      "end": 391.67,
      "text": "But some people think it might be"
    },
    {
      "start": 391.67,
      "end": 394.59,
      "text": "at least based on his personal experiences."
    },
    {
      "start": 394.95,
      "end": 396.03,
      "text": "I see."
    },
    {
      "start": 396.03,
      "end": 396.63,
      "text": "그래요."
    },
    {
      "start": 396.63,
      "end": 402.53,
      "text": "자전적인 내용을 그래도 조금씩 담은 게 아닐까라고 예상을 한다고 합니다."
    },
    {
      "start": 402.83,
      "end": 409.25,
      "text": "He was born in Australia, but to a German immigrant family in southern Australia,"
    },
    {
      "start": 409.51,
      "end": 411.35,
      "text": "which is famous for wine."
    },
    {
      "start": 411.57,
      "end": 413.13,
      "text": "Have you heard of Barossa?"
    },
    {
      "start": 413.47,
      "end": 414.63,
      "text": "The Barossa region?"
    },
    {
      "start": 414.89,
      "end": 415.53,
      "text": "와우."
    },
    {
      "start": 415.79,
      "end": 417.47,
      "text": "시라즈, 거기 굉장히 마시고요."
    },
    {
      "start": 417.65,
      "end": 417.97,
      "text": "아, 네."
    },
    {
      "start": 418.09,
      "end": 418.95,
      "text": "와인 전문가."
    },
    {
      "start": 419.35,
      "end": 420.79,
      "text": "Very fruity, very delicious."
    },
    {
      "start": 421.11,
      "end": 425.53,
      "text": "Anyway, he was born there, but his parents spoke only German at home."
    },
    {
      "start": 425.53,
      "end": 426.01,
      "text": "Yeah."
    },
    {
      "start": 426.17,
      "end": 428.53,
      "text": "So he didn't speak any English at all."
    },
    {
      "start": 428.69,
      "end": 429.83,
      "text": "너무 힘들었겠는데요."
    },
    {
      "start": 430.05,
      "end": 433.05,
      "text": "And he went to school speaking zero English."
    },
    {
      "start": 433.17,
      "end": 433.61,
      "text": "Uh-oh."
    },
    {
      "start": 433.71,
      "end": 434.43,
      "text": "Only German."
    },
    {
      "start": 434.61,
      "end": 435.07,
      "text": "Uh-oh."
    },
    {
      "start": 435.09,
      "end": 437.17,
      "text": "So he felt like a total outsider."
    },
    {
      "start": 437.47,
      "end": 437.97,
      "text": "Uh-huh."
    },
    {
      "start": 438.15,
      "end": 440.59,
      "text": "And he had some troubles adjusting."
    },
    {
      "start": 440.91,
      "end": 441.27,
      "text": "Yeah."
    },
    {
      "start": 441.55,
      "end": 442.95,
      "text": "And then look at Storm Boy."
    },
    {
      "start": 443.15,
      "end": 443.51,
      "text": "Um."
    },
    {
      "start": 443.73,
      "end": 445.79,
      "text": "Storm Boy also is about outsiders."
    },
    {
      "start": 446.11,
      "end": 446.61,
      "text": "맞네요."
    },
    {
      "start": 447.19,
      "end": 449.91,
      "text": "The main characters all feel like outsiders."
    },
    {
      "start": 450.21,
      "end": 450.51,
      "text": "Yeah."
    },
    {
      "start": 450.51,
      "end": 453.47,
      "text": "They live on the outskirts of society."
    },
    {
      "start": 453.85,
      "end": 454.15,
      "text": "Right."
    },
    {
      "start": 454.15,
      "end": 459.15,
      "text": "Hideaway Tom, Fingerbone Bill, Mike, Storm Boy, even the three pelicans."
    },
    {
      "start": 459.79,
      "end": 463.77,
      "text": "They grow up with no parents, with people, no pelicans."
    },
    {
      "start": 463.77,
      "end": 490.81,
      "text": "그러니까 이 작가가 경험한 것을 실질적으로 100% 일치하는 내용으로는 아니지만 상징적으로 이렇게 자기가 아웃사이더였으니까 지금 이 Storm Boy로 역할을 하고 있는 그 마이클, 그리고 three pelicans, 그리고 아버지인 Tom, 그리고 원주민 아저씨 Fingerbone Bill, 이 아저씨까지 캐릭터들이 딱딱 들어맞는 느낌이 들기는 합니다."
    },
    {
      "start": 490.81,
      "end": 493.97,
      "text": "어, 배경 지식이 나날이 쌓아지는 것 같아요."
    },
    {
      "start": 494.41,
      "end": 495.81,
      "text": "그럼 오늘 준비된 내용 먼저 들어볼게요."
    },
    {
      "start": 495.81,
      "end": 497.91,
      "text": "I'm not going."
    },
    {
      "start": 498.15,
      "end": 499.77,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 500.29,
      "end": 501.57,
      "text": "I don't want an opportunity."
    },
    {
      "start": 501.75,
      "end": 502.69,
      "text": "I want to stay here."
    },
    {
      "start": 502.73,
      "end": 504.27,
      "text": "But I can't keep teaching you."
    },
    {
      "start": 504.67,
      "end": 506.13,
      "text": "Yeah, not the way you should be."
    },
    {
      "start": 506.19,
      "end": 507.81,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 508.17,
      "end": 510.23,
      "text": "Look, it's a big world, and there's a lot to do out there."
    },
    {
      "start": 510.25,
      "end": 510.73,
      "text": "I don't care."
    },
    {
      "start": 510.73,
      "end": 522.11,
      "text": "아니, 지난주에 the villagers said they would send him to 아주 좋은 boarding school에 보내고 싶다라고 이야기했었잖아요."
    },
    {
      "start": 522.39,
      "end": 523.31,
      "text": "Saint something."
    },
    {
      "start": 523.57,
      "end": 523.89,
      "text": "맞아요."
    },
    {
      "start": 523.89,
      "end": 525.95,
      "text": "Saint Andrews, a fancy school."
    },
    {
      "start": 526.11,
      "end": 529.37,
      "text": "네, 그러면서 he needs a proper education."
    },
    {
      "start": 529.63,
      "end": 531.15,
      "text": "이런 이야기도 했었단 말이죠."
    },
    {
      "start": 531.33,
      "end": 534.11,
      "text": "That's what many people think, but he does not agree."
    },
    {
      "start": 534.11,
      "end": 542.11,
      "text": "네, 지금 마이클의 목소리를 들으면서 예상을 하신 것처럼 아주 격하게 되게 반대되는 반응을 하고 있습니다."
    },
    {
      "start": 542.11,
      "end": 545.61,
      "text": "He wants to stay with his pelican friend, Percival."
    },
    {
      "start": 545.85,
      "end": 547.05,
      "text": "He's a brother."
    },
    {
      "start": 547.41,
      "end": 550.43,
      "text": "How can he separate from his brother, pelican brother?"
    },
    {
      "start": 550.61,
      "end": 551.25,
      "text": "그러게 말이에요."
    },
    {
      "start": 551.39,
      "end": 554.81,
      "text": "이 헤어짐이라는 것이 결코 쉬운 일이 아닐 겁니다."
    },
    {
      "start": 555.43,
      "end": 556.39,
      "text": "Yeah, but it must be done."
    },
    {
      "start": 557.35,
      "end": 557.69,
      "text": "그렇죠."
    },
    {
      "start": 557.69,
      "end": 563.37,
      "text": "자, 오늘 들은 내용 중에서 주요 표현을 점검을 해보겠습니다."
    },
    {
      "start": 563.63,
      "end": 564.57,
      "text": "아, 네, 감상 약간."
    },
    {
      "start": 564.67,
      "end": 565.99,
      "text": "Sorry."
    },
    {
      "start": 566.33,
      "end": 566.61,
      "text": "Sorry."
    },
    {
      "start": 567.75,
      "end": 568.79,
      "text": "양해 부탁드리고요."
    },
    {
      "start": 569.29,
      "end": 570.05,
      "text": "Opportunity."
    },
    {
      "start": 570.51,
      "end": 574.05,
      "text": "네, Opportunity라고 하면 기회라는 뜻입니다."
    },
    {
      "start": 574.81,
      "end": 576.35,
      "text": "I can't keep teaching you."
    },
    {
      "start": 576.45,
      "end": 579.05,
      "text": "I can't keep teaching you."
    },
    {
      "start": 579.25,
      "end": 580.07,
      "text": "이게 무슨 의미일까요?"
    },
    {
      "start": 580.07,
      "end": 584.07,
      "text": "내가 너를 계속해서 가르칠 수는 없어 라는 의미입니다."
    },
    {
      "start": 585.05,
      "end": 586.51,
      "text": "Look, it's a big world."
    },
    {
      "start": 586.51,
      "end": 588.59,
      "text": "Look, it's a big world."
    },
    {
      "start": 589.07,
      "end": 591.11,
      "text": "봐봐, 세상은 넓어."
    },
    {
      "start": 591.75,
      "end": 593.75,
      "text": "과연 누구에게 이야기를 하는 걸까요?"
    },
    {
      "start": 594.09,
      "end": 594.71,
      "text": "궁금하시죠?"
    },
    {
      "start": 595.09,
      "end": 596.31,
      "text": "다시 한번 들어보시죠."
    },
    {
      "start": 596.31,
      "end": 597.67,
      "text": "I'm not going."
    },
    {
      "start": 597.91,
      "end": 599.51,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 600.05,
      "end": 601.31,
      "text": "I don't want an opportunity."
    },
    {
      "start": 601.51,
      "end": 602.43,
      "text": "I want to stay here."
    },
    {
      "start": 602.49,
      "end": 604.03,
      "text": "I can't keep teaching you."
    },
    {
      "start": 604.43,
      "end": 605.89,
      "text": "Not the way you should be."
    },
    {
      "start": 605.95,
      "end": 607.59,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 607.93,
      "end": 609.89,
      "text": "Look, it's a big world and there's a lot to do out there."
    },
    {
      "start": 609.91,
      "end": 610.49,
      "text": "I don't care."
    },
    {
      "start": 610.61,
      "end": 612.14,
      "text": "I'm not going."
    },
    {
      "start": 612.76,
      "end": 616.36,
      "text": "바로바로 아들과 아버지의 대화였습니다."
    },
    {
      "start": 616.36,
      "end": 619.8,
      "text": "네, 처음으로 이제 마이클이 하는 말을 들어볼게요."
    },
    {
      "start": 620.12,
      "end": 621.02,
      "text": "I'm not going."
    },
    {
      "start": 621.22,
      "end": 623.18,
      "text": "네, 아주 큰 소리로 외쳤습니다."
    },
    {
      "start": 623.42,
      "end": 624.44,
      "text": "I'm not going."
    },
    {
      "start": 624.92,
      "end": 625.5,
      "text": "안 가요."
    },
    {
      "start": 625.62,
      "end": 626.3,
      "text": "안 갈 거예요."
    },
    {
      "start": 626.78,
      "end": 627.6,
      "text": "No way."
    },
    {
      "start": 628.96,
      "end": 631.4,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 631.4,
      "end": 634.08,
      "text": "아빠의 이야기였는데요."
    },
    {
      "start": 634.26,
      "end": 636.92,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 637.56,
      "end": 640.52,
      "text": "너는 그걸 기회로 간주해야 돼, 마이클."
    },
    {
      "start": 641.04,
      "end": 642.3,
      "text": "I don't want an opportunity."
    },
    {
      "start": 642.58,
      "end": 643.64,
      "text": "I want to stay here."
    },
    {
      "start": 644.52,
      "end": 646.76,
      "text": "저는 그런 기회 따위인 필요 없어요."
    },
    {
      "start": 647.04,
      "end": 648.3,
      "text": "I don't want an opportunity."
    },
    {
      "start": 648.88,
      "end": 649.66,
      "text": "그 다음에 하는 말이"
    },
    {
      "start": 649.66,
      "end": 651.0,
      "text": "I want to stay here."
    },
    {
      "start": 651.4,
      "end": 652.7,
      "text": "저는 여기에서 살 거예요."
    },
    {
      "start": 653.46,
      "end": 656.04,
      "text": "Yeah, but I can't keep teaching you."
    },
    {
      "start": 656.04,
      "end": 657.26,
      "text": "음, 그래."
    },
    {
      "start": 657.54,
      "end": 660.8,
      "text": "하지만, but I can't keep teaching you."
    },
    {
      "start": 661.2,
      "end": 663.88,
      "text": "아빠가 너를 계속해서 가르칠 수는 없어."
    },
    {
      "start": 664.4,
      "end": 666.96,
      "text": "Not the way you should be taught."
    },
    {
      "start": 667.14,
      "end": 668.4,
      "text": "다 생략이 됐군요."
    },
    {
      "start": 668.48,
      "end": 668.92,
      "text": "아하."
    },
    {
      "start": 669.26,
      "end": 671.44,
      "text": "네, taught가 생략이 되었다라는 것까지"
    },
    {
      "start": 671.44,
      "end": 673.02,
      "text": "아주 친절한 설명 감사드립니다."
    },
    {
      "start": 673.78,
      "end": 676.12,
      "text": "네가 교육을 받아야 할 방식이 아니야."
    },
    {
      "start": 676.7,
      "end": 680.32,
      "text": "그러니까 내가 너를 제대로 계속해서 가르칠 수 없어"
    },
    {
      "start": 680.32,
      "end": 681.98,
      "text": "라는 부연 설명이 되겠죠."
    },
    {
      "start": 681.98,
      "end": 684.54,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 685.08,
      "end": 685.52,
      "text": "싫어요."
    },
    {
      "start": 685.94,
      "end": 687.38,
      "text": "I'm staying here with you."
    },
    {
      "start": 687.84,
      "end": 689.82,
      "text": "아빠랑 여기에서 지낼 거예요."
    },
    {
      "start": 690.48,
      "end": 691.98,
      "text": "Look, it's a big world"
    },
    {
      "start": 691.98,
      "end": 694.44,
      "text": "and there's a lot to do out there."
    },
    {
      "start": 694.68,
      "end": 695.66,
      "text": "네, 그러면서"
    },
    {
      "start": 695.66,
      "end": 697.92,
      "text": "자, it's a big world."
    },
    {
      "start": 698.34,
      "end": 699.58,
      "text": "세상은 넓고"
    },
    {
      "start": 699.58,
      "end": 702.2,
      "text": "and there's a lot to do out there."
    },
    {
      "start": 702.58,
      "end": 705.36,
      "text": "저 세상에 할 일은 아주 많단다."
    },
    {
      "start": 705.48,
      "end": 706.0,
      "text": "라고 한 거예요."
    },
    {
      "start": 706.18,
      "end": 707.16,
      "text": "Yeah, for us too."
    },
    {
      "start": 707.32,
      "end": 708.48,
      "text": "We need to get out."
    },
    {
      "start": 708.6,
      "end": 708.88,
      "text": "Yeah."
    },
    {
      "start": 709.16,
      "end": 709.72,
      "text": "Explore."
    },
    {
      "start": 709.88,
      "end": 710.34,
      "text": "그럼요."
    },
    {
      "start": 710.34,
      "end": 712.4,
      "text": "네, 탐험 정신, 도전 정신"
    },
    {
      "start": 712.4,
      "end": 713.56,
      "text": "네, 필요하죠."
    },
    {
      "start": 713.66,
      "end": 714.52,
      "text": "우리도 실천합시다."
    },
    {
      "start": 714.64,
      "end": 714.8,
      "text": "네."
    },
    {
      "start": 714.94,
      "end": 715.44,
      "text": "조셈이랑."
    },
    {
      "start": 715.64,
      "end": 716.28,
      "text": "알겠습니다."
    },
    {
      "start": 716.44,
      "end": 716.98,
      "text": "어디로 갈까요?"
    },
    {
      "start": 717.56,
      "end": 718.56,
      "text": "음, 집으로."
    },
    {
      "start": 719.86,
      "end": 722.1,
      "text": "아, 거기가 세상이 넓고 할 일이 많은 곳이에요."
    },
    {
      "start": 722.46,
      "end": 724.1,
      "text": "할 일이 정말 산더미죠."
    },
    {
      "start": 724.56,
      "end": 724.64,
      "text": "아."
    },
    {
      "start": 724.84,
      "end": 726.02,
      "text": "The house chores."
    },
    {
      "start": 726.38,
      "end": 726.68,
      "text": "아하."
    },
    {
      "start": 726.84,
      "end": 727.12,
      "text": "Yeah."
    },
    {
      "start": 727.58,
      "end": 729.0,
      "text": "정말 피곤하네요, 생각만 해도."
    },
    {
      "start": 729.06,
      "end": 729.7,
      "text": "네, 가지 맙시다."
    },
    {
      "start": 729.84,
      "end": 731.08,
      "text": "일하는 게 가장 행복한 걸로."
    },
    {
      "start": 731.22,
      "end": 731.5,
      "text": "아, yeah."
    },
    {
      "start": 732.08,
      "end": 733.18,
      "text": "Work is happiness."
    },
    {
      "start": 733.42,
      "end": 733.58,
      "text": "Yeah."
    },
    {
      "start": 733.68,
      "end": 734.58,
      "text": "Work is a blessing."
    },
    {
      "start": 734.8,
      "end": 735.98,
      "text": "네, 오늘의 명언이고요."
    },
    {
      "start": 736.78,
      "end": 737.38,
      "text": "I don't care."
    },
    {
      "start": 737.44,
      "end": 738.18,
      "text": "I'm not going."
    },
    {
      "start": 738.18,
      "end": 740.74,
      "text": "네, 이제 아들이 이야기한 말입니다."
    },
    {
      "start": 740.9,
      "end": 741.68,
      "text": "I don't care."
    },
    {
      "start": 742.08,
      "end": 742.92,
      "text": "상관없어요."
    },
    {
      "start": 743.32,
      "end": 744.4,
      "text": "I'm not going."
    },
    {
      "start": 744.64,
      "end": 745.72,
      "text": "안 간다고요."
    },
    {
      "start": 746.02,
      "end": 749.0,
      "text": "네, 이렇게 계속해서 안 간다고 부정을 하고 있습니다."
    },
    {
      "start": 750.08,
      "end": 752.68,
      "text": "그래도 이제 아버지의 입장에서는"
    },
    {
      "start": 752.68,
      "end": 757.72,
      "text": "he knew he had to educate his son in a proper way."
    },
    {
      "start": 757.72,
      "end": 760.78,
      "text": "그럼 당연히 보내야 되는 상황이긴 하겠죠."
    },
    {
      "start": 760.98,
      "end": 761.18,
      "text": "Yeah."
    },
    {
      "start": 761.28,
      "end": 762.72,
      "text": "Especially without his mother."
    },
    {
      "start": 762.88,
      "end": 766.72,
      "text": "He feels like that's his responsibility, his duty as a dad."
    },
    {
      "start": 766.78,
      "end": 769.74,
      "text": "To give his kid a proper education."
    },
    {
      "start": 769.98,
      "end": 770.32,
      "text": "Right."
    },
    {
      "start": 770.32,
      "end": 770.92,
      "text": "I understand."
    },
    {
      "start": 771.18,
      "end": 771.38,
      "text": "네."
    },
    {
      "start": 771.9,
      "end": 774.08,
      "text": "앞으로 어떻게 될지 점점 기대가 됩니다."
    },
    {
      "start": 774.78,
      "end": 776.08,
      "text": "그럼 한 번 더 들어보시죠."
    },
    {
      "start": 776.72,
      "end": 777.56,
      "text": "I'm not going."
    },
    {
      "start": 777.78,
      "end": 779.46,
      "text": "You need to think of it as an opportunity."
    },
    {
      "start": 779.94,
      "end": 781.2,
      "text": "I don't want an opportunity."
    },
    {
      "start": 781.38,
      "end": 782.32,
      "text": "I want to stay here."
    },
    {
      "start": 782.36,
      "end": 783.92,
      "text": "But I can't keep teaching you."
    },
    {
      "start": 784.32,
      "end": 785.78,
      "text": "Not the way you should be."
    },
    {
      "start": 785.78,
      "end": 787.48,
      "text": "No, I'm staying here with you."
    },
    {
      "start": 787.82,
      "end": 789.78,
      "text": "Look, it's a big world and there's a lot to do out there."
    },
    {
      "start": 789.8,
      "end": 790.4,
      "text": "I don't care."
    },
    {
      "start": 792.71,
      "end": 794.03,
      "text": "잘 들어보셨죠?"
    },
    {
      "start": 794.25,
      "end": 795.39,
      "text": "이해라 님께서"
    },
    {
      "start": 795.39,
      "end": 797.01,
      "text": "크쌤 감사합니다."
    },
    {
      "start": 797.41,
      "end": 798.13,
      "text": "하트 세 개."
    },
    {
      "start": 798.79,
      "end": 799.59,
      "text": "Oh, thank you."
    },
    {
      "start": 799.69,
      "end": 799.87,
      "text": "네."
    },
    {
      "start": 800.19,
      "end": 801.73,
      "text": "하트 백 개."
    },
    {
      "start": 801.83,
      "end": 802.43,
      "text": "백 개."
    },
    {
      "start": 802.59,
      "end": 804.49,
      "text": "와, 엄청나게 증가했네요."
    },
    {
      "start": 804.65,
      "end": 806.15,
      "text": "I'm feeling generous this morning."
    },
    {
      "start": 806.23,
      "end": 806.53,
      "text": "와."
    },
    {
      "start": 806.71,
      "end": 807.87,
      "text": "I'm feeling like, yeah."
    },
    {
      "start": 808.01,
      "end": 808.33,
      "text": "Yeah."
    },
    {
      "start": 808.51,
      "end": 809.01,
      "text": "Giving a lot."
    },
    {
      "start": 809.21,
      "end": 809.41,
      "text": "Yeah."
    },
    {
      "start": 809.41,
      "end": 811.21,
      "text": "Generous Monday morning입니다."
    },
    {
      "start": 811.81,
      "end": 813.33,
      "text": "Fabulous한 날 보내시고요."
    },
    {
      "start": 813.49,
      "end": 814.25,
      "text": "Have a great day."
    },
    {
      "start": 814.35,
      "end": 814.63,
      "text": "Yeah."
    },
    {
      "start": 814.75,
      "end": 815.29,
      "text": "See you tomorrow."
    },
    {
      "start": 815.53,
      "end": 815.77,
      "text": "Bye."
    }
  ]
}