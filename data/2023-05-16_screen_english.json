      "start": 777.9,
      "end": 778.68,
      "text": "잘해 주실 거예요."
    },
    {
      "start": 778.82,
      "end": 781.62,
      "text": "간식도 챙겨주는 좋은 누님이니까요."
    },
    {
      "start": 781.86,
      "end": 783.36,
      "text": "슬브텡 누님 잘 만났어요."
    },
    {
      "start": 783.72,
      "end": 785.92,
      "text": "네, 그럼 우리는 내일 또 이어갈게요."
    },
    {
      "start": 786.24,
      "end": 787.1,
      "text": "All right, see you then."
    },
    {
      "start": 787.24,
      "end": 787.7,
      "text": "Bye-bye."
    },
    {
      "start": 787.8,
      "end": 788.02,
      "text": "Bye."
    }
  ]
}