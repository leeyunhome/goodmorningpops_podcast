    },
    {
      "start": 411.15,
      "end": 412.33,
      "text": "usage"
    },
    {
      "start": 412.33,
      "end": 413.49,
      "text": "or any time"
    },
    {
      "start": 413.49,
      "end": 414.21,
      "text": "to use this"
    },
    {
      "start": 414.21,
      "end": 415.51,
      "text": "있으면 안 될 것 같아요"
    },
    {
      "start": 415.51,
      "end": 415.85,
      "text": "Yeah"
    },
    {
      "start": 415.85,
      "end": 417.31,
      "text": "이거 듣는 사람들은"
    },
    {
      "start": 417.31,
      "end": 418.47,
      "text": "굉장히 마상"
    },
    {
      "start": 418.47,
      "end": 418.81,
      "text": "그죠?"
    },
    {
      "start": 418.89,
      "end": 419.73,
      "text": "마음의 상처"
    },
    {
      "start": 419.73,
      "end": 420.65,
      "text": "될 것 같습니다"
    },
    {
      "start": 420.65,
      "end": 421.05,
      "text": "Yeah"
    },
    {
      "start": 421.05,
      "end": 421.67,
      "text": "You're a plain"
