    },
    {
      "start": 425.27,
      "end": 426.45,
      "text": "알아들이면 돼요"
    },
    {
      "start": 426.45,
      "end": 426.79,
      "text": "그래요"
    },
    {
      "start": 426.79,
      "end": 428.01,
      "text": "이 문장은"
    },
    {
      "start": 428.01,
      "end": 430.29,
      "text": "메들록이라고 불려지는"
    },
    {
      "start": 430.29,
      "end": 431.43,
