      "text": "이것도 좀 이용하지 않나요?"
    },
    {
      "start": 320.02,
      "end": 320.54,
      "text": "Does it matter?"
    },
    {
      "start": 320.68,
      "end": 321.18,
      "text": "Very good"
    },
    {
      "start": 321.18,
      "end": 323.8,
      "text": "This is the most useful expression of the three"
