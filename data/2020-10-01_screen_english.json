    {
      "start": 494.37,
      "end": 495.71,
      "text": "이 소녀가"
    },
    {
      "start": 495.71,
      "end": 496.91,
      "text": "이제 머물게 돼"
    },
    {
      "start": 496.91,
      "end": 497.87,
      "text": "The uncle's house"
