      "start": 516.71,
      "end": 517.63,
      "text": "in the war"
    },
    {
      "start": 517.63,
      "end": 519.29,
      "text": "이 Miss Selthwaite"
    },
    {
      "start": 519.29,
      "end": 520.05,
      "text": "라는 곳에"
    },
    {
      "start": 520.05,
      "end": 520.83,
      "text": "얽힌 그런"
    },
    {
      "start": 520.83,
      "end": 521.43,
      "text": "히스토리를"
    },
    {
      "start": 521.43,
      "end": 522.33,
      "text": "이야기해줍니다"
    },
    {
      "start": 522.33,
      "end": 524.23,
      "text": "Those army savages"
    },
    {
      "start": 524.23,
      "end": 525.63,
      "text": "used it"
    },
    {
      "start": 525.63,
      "end": 526.37,
      "text": "저"
