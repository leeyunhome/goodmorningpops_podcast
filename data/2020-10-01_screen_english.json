    {
      "start": 497.87,
      "end": 498.59,
      "text": "Yeah uncle's house"
    },
    {
      "start": 498.59,
      "end": 499.65,
      "text": "의 이름이 되는 거죠"
    },
    {
      "start": 499.65,
      "end": 501.33,
      "text": "It's a huge mansion"
