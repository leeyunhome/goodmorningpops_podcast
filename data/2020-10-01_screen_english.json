    },
    {
      "start": 399.56,
      "end": 401.25,
      "text": "한번 들어볼까요?"
    },
    {
      "start": 401.27,
      "end": 402.61,
      "text": "You are a plain"
    },
    {
      "start": 402.61,
      "end": 404.21,
      "text": "little piece of goods"
    },
    {
      "start": 404.21,
      "end": 405.11,
      "text": "aren't you?"
    },
    {
      "start": 405.25,
      "end": 405.85,
      "text": "이거"
    },
    {
      "start": 405.85,
      "end": 406.75,
      "text": "크리스 씨가"
    },
    {
      "start": 406.75,
      "end": 407.63,
      "text": "이거 이야기하면"
    },
    {
      "start": 407.63,
      "end": 408.27,
      "text": "안 된다라고"
    },
    {
      "start": 408.27,
      "end": 409.17,
      "text": "설명을 드렸는데"
    },
    {
      "start": 409.17,
      "end": 409.55,
      "text": "Yeah"
    },
    {
      "start": 409.55,
      "end": 411.15,
