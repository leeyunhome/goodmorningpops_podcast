    {
      "start": 481.01,
      "end": 482.85,
      "text": "장소 이름이니까"
    },
    {
      "start": 482.85,
      "end": 483.87,
      "text": "어렵다 이거"
    },
    {
      "start": 483.87,
      "end": 484.81,
      "text": "맞아요 고유명사니까"
