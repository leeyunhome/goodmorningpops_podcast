    },
    {
      "start": 188.02,
      "end": 190.76,
      "text": "And she had servants taking care of her"
    },
    {
      "start": 190.76,
      "end": 193.0,
      "text": "But they all ran away"
    },
    {
      "start": 193.0,
      "end": 197.04,
      "text": "And she's left all alone in this house in British India"
    },
    {
      "start": 197.04,
      "end": 202.92,
      "text": "So, the British forces, military, they find her in this home"
    },
    {
      "start": 202.92,
      "end": 204.5,
      "text": "And they send her away"
    },
    {
      "start": 204.5,
      "end": 206.38,
      "text": "And they send her away to her uncle's house"
