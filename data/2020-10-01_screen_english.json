    {
      "start": 295.14,
      "end": 297.46,
      "text": "Army savages"
    },
    {
      "start": 297.46,
      "end": 299.52,
      "text": "Army 하면 군대인데"
    },
    {
      "start": 299.52,
      "end": 301.16,
      "text": "savages라고 했으니까"
    },
    {
      "start": 301.16,
      "end": 303.24,
      "text": "S-A-V-A-G-E-S"
    },
    {
      "start": 303.24,
      "end": 303.5,
      "text": "그렇죠?"
    },
    {
      "start": 303.96,
      "end": 305.5,
      "text": "야만인들이라는 거거든요"
    },
    {
      "start": 305.5,
      "end": 308.38,
      "text": "그래서 야만스러운 군인들"
    },
    {
      "start": 308.38,
      "end": 309.96,
      "text": "이렇게 해석하셔도 좋을 것 같아요"
    },
    {
      "start": 309.96,
      "end": 311.02,
      "text": "Not a nice name"
    },
