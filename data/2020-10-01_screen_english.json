    {
      "start": 454.53,
      "end": 455.41,
      "text": "자존감을 너무"
    },
    {
      "start": 455.41,
      "end": 456.73,
      "text": "밟아버리네요"
    },
    {
      "start": 456.73,
      "end": 459.61,
      "text": "Don't expect luxury"
    },
    {
      "start": 459.61,
      "end": 461.57,
      "text": "또 이렇게 연달아 이야기합니다"
    },
    {
      "start": 461.57,
      "end": 463.33,
      "text": "Don't expect luxury"
    },
    {
      "start": 463.33,
      "end": 464.65,
      "text": "럭셔리한 거"
    },
    {
      "start": 464.65,
      "end": 465.41,
