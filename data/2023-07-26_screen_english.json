    {
      "start": 643.12,
      "end": 643.46,
      "text": "뭐라고?"
    },
    {
      "start": 644.14,
      "end": 648.8,
      "text": "뭔가 자신에 대한 무용담을 쓸 준비를 하는 것 같습니다"
    },
    {
      "start": 648.8,
      "end": 653.3,
      "text": "자, 이렇게 다행히 아기를 구하고 있는 그런 상황입니다"
    },
    {
      "start": 653.3,
      "end": 655.12,
      "text": "그럼 한 번 더 들어보시죠"
    },
    {
      "start": 655.12,
      "end": 656.72,
      "text": "Thank you, Oscar"
    },
    {
      "start": 656.72,
      "end": 658.36,
      "text": "You saved my life"
    },
    {
      "start": 658.36,
      "end": 660.33,
      "text": "Ah, come on"
    },
    {
      "start": 660.33,
      "end": 661.75,
      "text": "What are you talking about?"
    },
    {
      "start": 662.11,
      "end": 663.19,
      "text": "Without all of you?"
    },
    {
      "start": 664.98,
      "end": 666.8,
      "text": "I'm a worthless half-plaint"
    },
    {
      "start": 666.8,
      "end": 668.86,
      "text": "We're all winners"
    },
    {
      "start": 668.86,
      "end": 672.38,
      "text": "We won today because we worked together"
    },
    {
      "start": 672.38,
      "end": 674.66,
      "text": "And it was the best day"
    },
    {
      "start": 674.66,
      "end": 675.78,
      "text": "Do you guys remember?"
    },
    {
      "start": 675.78,
      "end": 675.84,
      "text": "Do you guys remember?"
    },
    {
      "start": 676.08,
      "end": 677.58,
      "text": "Hey, remember how"
    },
    {
      "start": 677.58,
      "end": 678.2,
      "text": "I thought"
    },
    {
      "start": 678.2,
      "end": 679.12,
      "text": "Yeah, I see"
    },
    {
      "start": 679.12,
      "end": 679.94,
      "text": "I didn't have to"
    },
    {
      "start": 679.94,
      "end": 680.54,
      "text": "I thought"
    },
    {
      "start": 680.54,
      "end": 681.54,
      "text": "I came out of the blue"
    },
    {
      "start": 681.54,
      "end": 685.77,
      "text": "Yeah, Duke"
    },
    {
      "start": 685.77,
      "end": 686.81,
      "text": "Duke는 아무래도"
    },
    {
      "start": 686.81,
      "end": 688.05,
      "text": "제가 예상하건데"
    },
    {
      "start": 688.05,
      "end": 689.89,
      "text": "He's gonna talk about himself"
    },
    {
      "start": 689.89,
      "end": 691.61,
      "text": "More and more"
    },
    {
      "start": 691.61,
      "end": 692.69,
      "text": "He likes to brag"
    },
    {
      "start": 692.69,
      "end": 693.23,
      "text": "Wow"
    },
    {
      "start": 693.23,
      "end": 694.51,
      "text": "그러면서 아마도"
    },
    {
      "start": 694.51,
      "end": 695.93,
      "text": "나머지 친구들은"
    },
    {
      "start": 695.93,
      "end": 697.49,
      "text": "Are getting sick and tired of"
    },
    {
      "start": 697.49,
      "end": 699.17,
      "text": "The stories"
    },
    {
      "start": 699.17,
      "end": 700.71,
      "text": "We've had enough"
    },
    {
      "start": 700.71,
      "end": 701.29,
      "text": "That's right"
    },
    {
      "start": 701.29,
      "end": 701.97,
      "text": "Enough"
    },
    {
      "start": 701.97,
      "end": 704.83,
      "text": "이 말을 아마 달고 살지 않을까 예상합니다"
    },
    {
      "start": 704.83,
      "end": 707.01,
      "text": "여름비님께서요"
    },
    {
      "start": 707.01,
      "end": 709.19,
      "text": "오늘도 유쾌한 크쌤"
    },
    {
      "start": 709.19,
      "end": 710.95,
      "text": "내일 또 만나요 하셨어요"
    },
    {
      "start": 710.95,
      "end": 712.51,
      "text": "I'll see you tomorrow"
    },
    {
      "start": 712.51,
      "end": 713.69,
      "text": "Have a lovely day"
    },
    {
      "start": 713.69,
      "end": 714.81,
      "text": "Bye bye"
    }
  ]
}