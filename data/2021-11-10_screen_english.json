    {
      "start": 89.56,
      "end": 90.24,
      "text": "예, 알겠습니다."
    },
    {
      "start": 90.54,
      "end": 91.28,
      "text": "부끄러우신가 봐요."
    },
    {
      "start": 92.06,
      "end": 93.1,
      "text": "아우, 어글어글."
