      "start": 733.56,
      "end": 733.98,
      "text": "Youth."
    },
    {
      "start": 734.64,
      "end": 735.56,
      "text": "It's a filthy habit."
    },
    {
      "start": 737.58,
      "end": 738.48,
      "text": "What's wrong?"
    },
    {
      "start": 738.82,
      "end": 739.74,
      "text": "What's wrong, my child?"
    },
    {
      "start": 740.46,
      "end": 742.36,
      "text": "Nobody knows how much I'm suffering."
    },
    {
      "start": 747.28,
      "end": 749.04,
      "text": "The spell's cast by this lake."
    },
    {
      "start": 749.54,
      "end": 750.72,
      "text": "But what can I do, my child?"
    },
    {
      "start": 751.42,
      "end": 752.26,
      "text": "What?"
    },
    {
      "start": 754.56,
      "end": 759.04,
      "text": "박명근님께서 크리스, 정현쌤, 토크 정말 재밌네요."
    },
    {
      "start": 759.84,
      "end": 760.34,
      "text": "토크?"
    },
    {
      "start": 760.54,
      "end": 760.66,
      "text": "네."
    },
    {
      "start": 760.9,
      "end": 761.66,
      "text": "Thank you."
    },
    {
      "start": 761.94,
      "end": 763.36,
      "text": "정말 크리스쌤 덕분입니다."
    },
    {
      "start": 763.62,
      "end": 764.54,
      "text": "토크 재밌어요."
    },
    {
      "start": 764.56,
      "end": 766.52,
      "text": "우리 티키타카가 너무 잘 통하는 것 같아요."
    },
    {
      "start": 766.8,
      "end": 768.08,
      "text": "계속 티키타카 좀 합시다."
    },
    {
      "start": 768.34,
      "end": 768.36,
      "text": "네."
    },
    {
      "start": 768.82,
      "end": 770.66,
      "text": "우리 내일 이어가도록 하겠습니다."
    },
    {
      "start": 770.94,
      "end": 771.66,
      "text": "I'll see you tomorrow."
    }
  ]
}