    {
      "start": 37.8,
      "end": 41.04,
      "text": "And he went on to launch a great playwriting career."
    },
    {
      "start": 41.3,
      "end": 42.26,
      "text": "Wow, that was a good twist."
    },
    {
      "start": 42.42,
      "end": 43.7,
      "text": "It was a great twist."
    },
    {
      "start": 43.94,
