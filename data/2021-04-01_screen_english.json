      "text": "A huge mansion."
    },
    {
      "start": 257.47,
      "end": 260.73,
      "text": "거의 진짜 looked magnificent."
    },
    {
      "start": 261.05,
      "end": 262.67,
      "text": "이런 형용사가 어울릴 것 같은."
    },
    {
      "start": 262.93,
      "end": 263.25,
      "text": "Sure."
    },
    {
      "start": 263.41,
      "end": 263.55,
      "text": "Yeah."
    },
    {
      "start": 263.55,
      "end": 265.61,
      "text": "Brilliant, magnificent, splendid."
    },
    {
      "start": 265.93,
      "end": 266.19,
      "text": "Yeah."
    },
    {
      "start": 266.19,
      "end": 269.91,
      "text": "And the dog of the mansion has his own bed."
    },
    {
      "start": 270.07,
      "end": 270.55,
      "text": "맞아요."
    },
    {
      "start": 270.95,
      "end": 271.95,
      "text": "깜짝 놀랐어요."
    },
    {
      "start": 272.01,
      "end": 273.69,
      "text": "He's pampered, spoiled dog."
    },
    {
      "start": 273.97,
      "end": 274.93,
      "text": "He gets massages."
    },
    {
      "start": 275.63,
      "end": 276.65,
      "text": "He's so spoiled."
