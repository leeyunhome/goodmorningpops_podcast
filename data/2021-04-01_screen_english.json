    },
    {
      "start": 188.8,
      "end": 193.16,
      "text": "아무튼 되게 fabulous한 액터일 것 같은 느낌이 듭니다."
    },
    {
      "start": 193.26,
      "end": 194.66,
      "text": "Their voices, how were their voices?"
    },
    {
      "start": 195.16,
      "end": 196.74,
      "text": "It was so great."
    },
    {
      "start": 196.86,
      "end": 197.58,
      "text": "Very vibrant."
    },
    {
      "start": 197.72,
      "end": 198.1,
      "text": "Yeah, yeah, yeah."
    },
    {
      "start": 198.1,
