    {
      "start": 1070.88,
      "end": 1071.18,
      "text": "Yeah."
    },
    {
      "start": 1071.48,
      "end": 1072.84,
      "text": "I think she likes languages."
    },
    {
      "start": 1073.02,
      "end": 1073.2,
      "text": "Yeah."
    },
    {
      "start": 1073.38,
      "end": 1074.22,
      "text": "So she's always,"
    },
    {
      "start": 1074.22,
      "end": 1075.62,
      "text": "she carries this pen around"
    },
    {
      "start": 1075.62,
      "end": 1077.16,
      "text": "that speaks English to her."
    },
    {
      "start": 1077.3,
      "end": 1077.74,
      "text": "Wow."
    },
    {
      "start": 1077.9,
      "end": 1078.7,
      "text": "That's good news."
    },
    {
      "start": 1078.72,
      "end": 1079.8,
      "text": "And she brags to dad."
    },
    {
      "start": 1079.86,
      "end": 1080.5,
      "text": "Daddy, daddy."
    },
    {
      "start": 1080.7,
      "end": 1081.64,
      "text": "I can read this."
    },
    {
      "start": 1081.7,
      "end": 1083.22,
      "text": "정말 adorable 한 것 같아요."
    },
    {
      "start": 1083.34,
      "end": 1084.0,
      "text": "They're getting better."
    },
    {
      "start": 1084.22,
      "end": 1086.26,
      "text": "특히 이 4월의 영화가"
    },
    {
      "start": 1086.26,
      "end": 1087.5,
      "text": "애니메이션이잖아요."
    },
    {
      "start": 1087.6,
      "end": 1089.28,
      "text": "귀여운 댕댕이 영화이니까"
    },
    {
      "start": 1089.28,
      "end": 1091.38,
      "text": "우리 어린 친구들이"
    },
    {
      "start": 1091.38,
      "end": 1092.14,
      "text": "함께 들어도"
    },
    {
      "start": 1092.14,
      "end": 1093.14,
      "text": "정말 재미있게"
    },
    {
      "start": 1093.14,
      "end": 1094.28,
      "text": "잘 들을 수 있을 것 같아요."
    },
    {
      "start": 1094.4,
      "end": 1094.62,
      "text": "Yeah."
    },
    {
      "start": 1094.72,
      "end": 1095.84,
      "text": "I watched this with my daughters."
    },
    {
      "start": 1096.1,
      "end": 1097.38,
      "text": "They liked it a lot."
    },
    {
      "start": 1097.52,
      "end": 1097.86,
      "text": "Yeah."
    },
    {
      "start": 1098.06,
      "end": 1099.84,
      "text": "Very enjoyable for the whole family."
    },
    {
      "start": 1100.04,
      "end": 1100.26,
      "text": "네."
    },
    {
      "start": 1100.5,
      "end": 1101.58,
      "text": "아주 기쁜 소식입니다."
    },
    {
      "start": 1102.08,
      "end": 1103.2,
      "text": "우린 다음 주에"
    },
    {
      "start": 1103.2,
      "end": 1103.84,
      "text": "이어갈게요."
    },
    {
      "start": 1104.12,
      "end": 1104.9,
      "text": "I'll see you next week."
    },
    {
      "start": 1104.96,
      "end": 1105.36,
      "text": "Bye."
    }
  ]
}