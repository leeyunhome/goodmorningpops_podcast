    },
    {
      "start": 630.33,
      "end": 631.05,
      "text": "If she talks"
    },
    {
      "start": 631.05,
      "end": 631.83,
      "text": "to the wrong people"
    },
    {
      "start": 631.83,
      "end": 633.35,
      "text": "she may disappear."
    },
    {
      "start": 633.55,
      "end": 634.35,
      "text": "She may not"
    },
    {
      "start": 634.35,
      "end": 635.09,
      "text": "ever be able"
    },
    {
      "start": 635.09,
      "end": 636.05,
      "text": "to go back home."
    },
    {
      "start": 636.61,
      "end": 637.39,
      "text": "And she knows that."
    },
    {
      "start": 637.39,
      "end": 639.65,
      "text": "Maybe home"
    },
    {
      "start": 639.65,
      "end": 640.39,
      "text": "will be different"
    },
    {
      "start": 640.39,
      "end": 641.11,
      "text": "if you're"
    },
    {
      "start": 641.11,
      "end": 641.81,
      "text": "Miss World."
    },
    {
      "start": 642.31,
      "end": 642.59,
      "text": "그랬더니"
    },
    {
      "start": 642.59,
      "end": 643.09,
      "text": "Jennifer"
    },
    {
      "start": 643.09,
      "end": 644.19,
      "text": "Miss Granada가"
    },
    {
      "start": 644.19,
      "end": 645.41,
      "text": "Maybe home"
    },
    {
      "start": 645.41,
      "end": 646.53,
      "text": "will be different"
    },
    {
      "start": 646.53,
      "end": 647.13,
      "text": "if you're"
    },
    {
      "start": 647.13,
      "end": 647.93,
      "text": "Miss World."
    },
    {
      "start": 648.45,
      "end": 649.29,
      "text": "어쩌면"
    },
    {
      "start": 649.29,
      "end": 650.01,
      "text": "그 집이"
    },
    {
      "start": 650.01,
      "end": 651.03,
      "text": "달라질 거야."
    },
    {
      "start": 651.41,
      "end": 652.07,
      "text": "If you're"
    },
    {
      "start": 652.07,
      "end": 653.03,
      "text": "Miss World."
    },
    {
      "start": 653.41,
      "end": 654.07,
      "text": "네가 만약에"
    },
    {
      "start": 654.07,
      "end": 655.25,
      "text": "Miss World가 된다면"
    },
    {
      "start": 655.25,
      "end": 656.21,
      "text": "이라는 거거든요."
    },
    {
      "start": 656.37,
      "end": 657.57,
      "text": "굉장히 희망을 가지고"
    },
    {
      "start": 657.57,
      "end": 658.97,
      "text": "이렇게 이야기를 해줬는데."
    },
    {
      "start": 659.19,
      "end": 659.95,
      "text": "If you win"
    },
    {
      "start": 659.95,
      "end": 661.73,
      "text": "it's a life-changing event."
    },
    {
      "start": 661.73,
      "end": 662.51,
      "text": "Yeah."
    },
    {
      "start": 663.51,
      "end": 664.39,
      "text": "But Pearl"
    },
    {
      "start": 664.39,
      "end": 665.27,
      "text": "does not think so."
    },
    {
      "start": 666.39,
      "end": 667.07,
      "text": "We're not"
    },
    {
      "start": 667.07,
      "end": 667.97,
      "text": "going to be"
    },
    {
      "start": 667.97,
      "end": 668.55,
      "text": "Miss World."
    },
    {
      "start": 668.95,
      "end": 670.07,
      "text": "Feel so sorry."
    },
    {
      "start": 670.15,
      "end": 670.47,
      "text": "She says"
    },
    {
      "start": 670.47,
      "end": 671.07,
      "text": "we are."
    },
    {
      "start": 671.31,
      "end": 672.41,
      "text": "You and"
    },
    {
      "start": 672.41,
      "end": 672.95,
      "text": "myself."
    },
    {
      "start": 673.07,
      "end": 673.85,
      "text": "We're never"
    },
    {
      "start": 673.85,
      "end": 674.43,
      "text": "going to win"
    },
    {
      "start": 674.43,
      "end": 675.17,
      "text": "this contest."
    },
    {
      "start": 675.47,
      "end": 675.91,
      "text": "Wow."
    },
    {
      "start": 676.05,
      "end": 676.43,
      "text": "She didn't"
    },
    {
      "start": 676.43,
      "end": 677.41,
      "text": "deny the reality."
    },
    {
      "start": 678.41,
      "end": 679.59,
      "text": "지금 현실을"
    },
    {
      "start": 679.59,
      "end": 680.61,
      "text": "정말 부정도"
    },
    {
      "start": 680.61,
      "end": 681.19,
      "text": "하지 않는"
    },
    {
      "start": 681.19,
      "end": 681.99,
      "text": "그런 문장이"
    },
    {
      "start": 681.99,
      "end": 682.69,
      "text": "들렸습니다."
    },
    {
      "start": 683.07,
      "end": 683.55,
      "text": "We are not"
    },
    {
      "start": 683.55,
      "end": 684.23,
      "text": "going to be"
    },
    {
      "start": 684.23,
      "end": 684.99,
      "text": "Miss World"
    },
    {
      "start": 684.99,
      "end": 686.13,
      "text": "들으셨죠."
    },
    {
      "start": 686.13,
      "end": 686.81,
      "text": "우리는"
    },
    {
      "start": 686.81,
      "end": 687.79,
      "text": "Miss World가"
    },
    {
      "start": 687.79,
      "end": 688.91,
      "text": "될 수 없어."
    },
    {
      "start": 689.27,
      "end": 689.99,
      "text": "되지 않을 거야."
    },
    {
      "start": 690.43,
      "end": 690.67,
      "text": "라고"
    },
    {
      "start": 690.67,
      "end": 691.85,
      "text": "포기를 하고 있는"
    },
    {
      "start": 691.85,
      "end": 692.73,
      "text": "그런 내용도"
    },
    {
      "start": 692.73,
      "end": 693.45,
      "text": "들렸어요."
    },
    {
      "start": 694.29,
      "end": 694.71,
      "text": "그 당시에"
    },
    {
      "start": 694.71,
      "end": 695.47,
      "text": "이 남아공의"
    },
    {
      "start": 695.47,
      "end": 696.05,
      "text": "인종차별이"
    },
    {
      "start": 696.05,
      "end": 697.15,
      "text": "얼마나 심각했으면"
    },
    {
      "start": 697.15,
      "end": 698.03,
      "text": "이렇게"
    },
    {
      "start": 698.03,
      "end": 698.77,
      "text": "Pearl이"
    },
    {
      "start": 698.77,
      "end": 699.67,
      "text": "자포자기하는"
    },
    {
      "start": 699.67,
      "end": 700.17,
      "text": "심정으로"
    },
    {
      "start": 700.17,
      "end": 700.99,
      "text": "이야기를 했을까"
    },
    {
      "start": 700.99,
      "end": 702.01,
      "text": "짐작하게 합니다."
    },
    {
      "start": 702.39,
      "end": 702.51,
      "text": "Yeah."
    },
    {
      "start": 702.61,
      "end": 703.45,
      "text": "Very sad"
    },
    {
      "start": 703.45,
      "end": 704.49,
      "text": "and also ironic"
    },
    {
      "start": 704.49,
      "end": 706.29,
      "text": "that they ended up winning"
    },
    {
      "start": 706.29,
      "end": 708.67,
      "text": "and changing the contest."
    },
    {
      "start": 708.89,
      "end": 709.05,
      "text": "그래요."
    },
    {
      "start": 709.29,
      "end": 709.95,
      "text": "인생은 정말"
    },
    {
      "start": 709.95,
      "end": 710.85,
      "text": "아무도 모르는 거예요."
    },
    {
      "start": 711.41,
      "end": 711.53,
      "text": "자,"
    },
    {
      "start": 711.59,
      "end": 712.01,
      "text": "마지막으로"
    },
    {
      "start": 712.01,
      "end": 712.41,
      "text": "한 번 더"
    },
    {
      "start": 712.41,
      "end": 712.91,
      "text": "들어보겠습니다."
    },
    {
      "start": 714.23,
      "end": 715.49,
      "text": "Before I got on the plane"
    },
    {
      "start": 715.49,
      "end": 716.53,
      "text": "they showed me"
    },
    {
      "start": 716.53,
      "end": 717.61,
      "text": "all these photographs"
    },
    {
      "start": 717.61,
      "end": 718.83,
      "text": "of people"
    },
    {
      "start": 718.83,
      "end": 719.41,
      "text": "I'm supposed to"
    },
    {
      "start": 719.41,
      "end": 719.85,
      "text": "have nothing"
    },
    {
      "start": 719.85,
      "end": 720.43,
      "text": "to do with."
    },
    {
      "start": 721.13,
      "end": 722.53,
      "text": "What kind of people?"
    },
    {
      "start": 722.87,
      "end": 723.81,
      "text": "Certain journalists."
    },
    {
      "start": 724.65,
      "end": 725.11,
      "text": "A man"
    },
    {
      "start": 725.11,
      "end": 726.43,
      "text": "called Peter Hain."
    },
    {
      "start": 727.29,
      "end": 727.73,
      "text": "Political"
    },
    {
      "start": 727.73,
      "end": 728.33,
      "text": "people."
    },
    {
      "start": 729.54,
      "end": 730.26,
      "text": "Home is home."
    },
    {
      "start": 730.9,
      "end": 731.44,
      "text": "I want to see"
    },
    {
      "start": 731.44,
      "end": 732.34,
      "text": "my parents again."
    },
    {
      "start": 733.08,
      "end": 733.4,
      "text": "Sorry."
    },
    {
      "start": 734.65,
      "end": 735.67,
      "text": "Maybe home"
    },
    {
      "start": 735.67,
      "end": 736.57,
      "text": "would be different"
    },
    {
      "start": 736.57,
      "end": 737.87,
      "text": "if you're Miss World."
    },
    {
      "start": 738.31,
      "end": 739.03,
      "text": "We're not going"
    },
    {
      "start": 739.03,
      "end": 740.29,
      "text": "to be Miss World."
    },
    {
      "start": 741.7,
      "end": 742.68,
      "text": "One of our"
    },
    {
      "start": 742.68,
      "end": 743.24,
      "text": "listeners"
    },
    {
      "start": 743.24,
      "end": 744.44,
      "text": "lives in"
    },
    {
      "start": 744.44,
      "end": 745.08,
      "text": "somewhere in"
    },
    {
      "start": 745.08,
      "end": 746.02,
      "text": "Africa as far as"
    },
    {
      "start": 746.02,
      "end": 746.38,
      "text": "I don't know"
    },
    {
      "start": 746.38,
      "end": 746.92,
      "text": "Oh!"
    },
    {
      "start": 746.92,
      "end": 747.98,
      "text": "Which country?"
    },
    {
      "start": 748.5,
      "end": 749.24,
      "text": "Africa에"
    },
    {
      "start": 749.24,
      "end": 750.24,
      "text": "어느 부분에서"
    },
    {
      "start": 750.24,
      "end": 750.94,
      "text": "살고 계시는"
    },
    {
      "start": 750.94,
      "end": 752.04,
      "text": "우리 청취자분"
    },
    {
      "start": 752.04,
      "end": 752.7,
      "text": "중에 한 분이"
    },
    {
      "start": 752.7,
      "end": 753.2,
      "text": "계셔요."
    },
    {
      "start": 753.24,
      "end": 754.0,
      "text": "Do they send in"
    },
    {
      "start": 754.0,
      "end": 754.38,
      "text": "messages?"
    },
    {
      "start": 754.62,
      "end": 755.0,
      "text": "예전에"
    },
    {
      "start": 755.0,
      "end": 756.04,
      "text": "보내주셨었는데"
    },
    {
      "start": 756.04,
      "end": 758.48,
      "text": "대놓고"
    },
    {
      "start": 758.48,
      "end": 759.38,
      "text": "차별은 없을 것"
    },
    {
      "start": 759.38,
      "end": 760.08,
      "text": "같긴 한데"
    },
    {
      "start": 760.08,
      "end": 761.36,
      "text": "남아공 상황은"
    },
    {
      "start": 761.36,
      "end": 762.24,
      "text": "요즘 어떤지"
    },
    {
      "start": 762.24,
      "end": 763.32,
      "text": "조금 궁금해지기도"
    },
    {
      "start": 763.32,
      "end": 763.82,
      "text": "하네요."
    },
    {
      "start": 764.02,
      "end": 764.76,
      "text": "Well,"
    },
    {
      "start": 764.94,
      "end": 765.24,
      "text": "we know"
    },
    {
      "start": 765.24,
      "end": 766.0,
      "text": "the apartheid"
    },
    {
      "start": 766.0,
      "end": 767.2,
      "text": "regime is over"
    },
    {
      "start": 767.2,
      "end": 768.4,
      "text": "and"
    },
    {
      "start": 768.4,
      "end": 769.68,
      "text": "Nelson Mandela"
    },
    {
      "start": 769.68,
      "end": 770.56,
      "text": "is the"
    },
    {
      "start": 770.56,
      "end": 771.52,
      "text": "liberation hero."
    },
    {
      "start": 771.7,
      "end": 772.48,
      "text": "진짜"
    },
    {
      "start": 772.48,
      "end": 773.52,
      "text": "그분이 없었으면"
    },
    {
      "start": 773.52,
      "end": 774.34,
      "text": "더 힘든"
    },
    {
      "start": 774.34,
      "end": 775.22,
      "text": "상황이었을 것"
    },
    {
      "start": 775.22,
      "end": 775.82,
      "text": "같은데요."
    },
    {
      "start": 775.82,
      "end": 776.42,
      "text": "자,"
    },
    {
      "start": 776.58,
      "end": 776.88,
      "text": "일단"
    },
    {
      "start": 776.88,
      "end": 777.7,
      "text": "Screen English는"
    },
    {
      "start": 777.7,
      "end": 778.18,
      "text": "오늘 여기서"
    },
    {
      "start": 778.18,
      "end": 778.92,
      "text": "마무리할게요."
    }
  ]
}