    },
    {
      "start": 240.38,
      "end": 240.58,
      "text": "Yeah."
    },
    {
      "start": 240.82,
      "end": 241.9,
      "text": "A fabulous cook."
    },
    {
      "start": 242.0,
      "end": 243.4,
