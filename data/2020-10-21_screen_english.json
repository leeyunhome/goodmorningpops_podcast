    },
    {
      "start": 642.37,
      "end": 643.45,
      "text": "다 포함이 되어 있는"
    },
    {
      "start": 643.45,
      "end": 644.53,
      "text": "문장 들어보셨습니다"
    },
    {
      "start": 644.53,
      "end": 645.31,
      "text": "British style"
    },
    {
      "start": 645.31,
      "end": 645.79,
      "text": "Yeah"
    },
    {
      "start": 645.79,
      "end": 646.49,
      "text": "마지막으로"
    },
    {
      "start": 646.49,
      "end": 647.45,
      "text": "한 번 더 들어볼게요"
    },
    {
      "start": 647.45,
      "end": 649.46,
      "text": "They can't you in here"
    },
    {
      "start": 649.46,
      "end": 650.34,
      "text": "They'll have you whipped"
    },
    {
      "start": 650.34,
      "end": 651.64,
      "text": "It's worth the risk"
    },
    {
      "start": 651.64,
      "end": 653.14,
      "text": "You risk being sent to school"
    },
    {
      "start": 653.14,
      "end": 654.64,
      "text": "We risk far more"
    },
    {
      "start": 654.64,
      "end": 655.9,
      "text": "Don't worry yourself"
    },
    {
      "start": 655.9,
      "end": 656.48,
      "text": "Mrs. Medlock"
    },
    {
      "start": 656.48,
      "end": 657.36,
      "text": "I'll deal with him"
    },
    {
      "start": 657.36,
      "end": 658.4,
      "text": "Never normally"
    },
    {
      "start": 658.4,
      "end": 659.04,
      "text": "causes bother"
    },
    {
      "start": 659.04,
      "end": 659.68,
      "text": "at this hour"
    },
    {
      "start": 659.68,
      "end": 660.94,
      "text": "네"
    },
    {
      "start": 660.94,
      "end": 661.94,
      "text": "우리 마르사의"
    },
    {
      "start": 661.94,
      "end": 663.7,
      "text": "도움이 정말 컸어요"
    },
    {
      "start": 663.7,
      "end": 665.54,
      "text": "감사할 뿐입니다"
    },
    {
      "start": 665.54,
      "end": 666.64,
      "text": "우리 마르사에게"
    },
    {
      "start": 666.64,
      "end": 667.52,
      "text": "Thank you, 마르사"
    },
    {
      "start": 667.52,
      "end": 669.0,
      "text": "더 잘할게요"
    },
    {
      "start": 669.0,
      "end": 669.36,
      "text": "네"
    },
    {
      "start": 669.36,
      "end": 670.36,
      "text": "말 드릴게요"
    },
    {
      "start": 670.36,
      "end": 671.26,
      "text": "아, 네"
    },
    {
      "start": 671.26,
      "end": 672.12,
      "text": "새담 새담"
    },
    {
      "start": 672.12,
      "end": 673.12,
      "text": "That's what Mary has to say"
    },
    {
      "start": 673.12,
      "end": 674.12,
      "text": "네, 맞아요"
    },
    {
      "start": 674.12,
      "end": 675.64,
      "text": "오늘 Screen English는"
    },
    {
      "start": 675.64,
      "end": 676.84,
      "text": "여기에서 마무리하겠습니다"
    }
  ]
}