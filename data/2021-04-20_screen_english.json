  "script": [
    {
      "start": 0.0,
      "end": 3.68,
      "text": "아, 제과점에서도 굿모닝 팝스 많이 듣고 계시죠?"
    },
    {
      "start": 4.56,
      "end": 7.46,
      "text": "이른 시간에 미리미리 준비를 하셔야 되니까."
    },
    {
      "start": 7.46,
      "end": 11.92,
      "text": "아, 또 부지런히 지금 피자빵 만들고 계시다고요?"
    },
    {
      "start": 11.92,
      "end": 17.04,
      "text": "제 눈앞에 지금 피자빵이 아주 김이 모락모락하면서 아른거리고 있습니다."
    },
    {
      "start": 18.66,
      "end": 22.86,
      "text": "6251님과 호중형님이랑 진수 이모님,"
    },
    {
      "start": 23.3,
      "end": 27.64,
      "text": "다들 함께 들으시면서 세상 맛있는 빵 많이 많이 만들어주세요."
    },
    {
      "start": 28.18,
      "end": 30.64,
      "text": "또 좋은 일이 많아지시길 응원합니다."
    },
    {
      "start": 30.64,
      "end": 33.66,
      "text": "6251님, 백인희님."
    },
    {
      "start": 34.2,
      "end": 37.34,
      "text": "10살 딸이 아파트 단지에서 만 원을 주었습니다."
    },
    {
      "start": 38.16,
      "end": 41.02,
      "text": "그걸로 맛있는 거 사먹고 싶은 욕도 컸을 텐데"
    },
    {
      "start": 41.02,
      "end": 44.62,
      "text": "관리사무소에 주인 찾아달라고 주고 왔대요."
    },
    {
      "start": 45.1,
      "end": 46.44,
      "text": "너무 기특한 것 같아요."
    },
    {
      "start": 47.14,
      "end": 48.66,
      "text": "어머, 백인희님."
    },
    {
      "start": 49.18,
      "end": 50.78,
      "text": "따님이 너무 기특한데요?"
    },
    {
      "start": 51.04,
      "end": 54.26,
      "text": "와, 무한 칭찬을 해줘도 좋을 것 같습니다."
    },
    {
      "start": 54.26,
      "end": 60.08,
      "text": "관리사무소 직원분들도 마음이 되게 따뜻해지셨을 것 같아요."
    },
    {
      "start": 60.96,
      "end": 65.96,
      "text": "순수한 어린아이가 이렇게 바른 마음과 행동을 보여주면"
    },
    {
      "start": 65.96,
      "end": 70.12,
      "text": "그걸 보고 어른들도 참 마음이 정화가 되고 힘이 되잖아요."
    },
    {
      "start": 70.52,
      "end": 71.48,
      "text": "기특합니다."
    },
    {
      "start": 71.84,
      "end": 73.28,
      "text": "전망이 아주 밝아요."
    },
    {
      "start": 74.06,
      "end": 75.66,
      "text": "오늘 사연 소개되신 분들 모두"
    },
    {
      "start": 75.66,
      "end": 78.68,
      "text": "월간 굿모닝팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 79.44,
      "end": 81.38,
      "text": "굿모닝팝스에 사연 보내고 싶은 분들"
    },
    {
      "start": 81.38,
      "end": 83.44,
      "text": "홈페이지 청취자 게시판에 남겨주세요."
    },
    {
      "start": 83.44,
      "end": 87.3,
      "text": "꼬르륵, 꼬르륵, 어, 꼬르륵"
    },
    {
      "start": 87.3,
      "end": 88.54,
      "text": "저도 지금 이러고 있는데"
    },
    {
      "start": 88.54,
      "end": 89.44,
      "text": "배고프신 분들"
    },
    {
      "start": 89.44,
      "end": 92.54,
      "text": "GMP로 영어 실력 업, 에너지도 업!"
    },
    {
      "start": 93.04,
      "end": 95.58,
      "text": "너무 배고프면 집중력이 흐트러지잖아요."
    },
    {
      "start": 96.22,
      "end": 97.82,
      "text": "저는 손도 떨리더라고요."
    },
    {
      "start": 98.36,
      "end": 99.9,
      "text": "식사 꼭 챙겨 드시고"
    },
    {
      "start": 99.9,
      "end": 103.54,
      "text": "에너지 충전하시기를 바라는 마음으로 준비했지요."
    },
    {
      "start": 104.02,
      "end": 107.06,
      "text": "쇠고기 야채죽 모바일 쿠폰 준비되어 있습니다."
    },
    {
      "start": 107.82,
      "end": 110.12,
      "text": "신청해 주신 분들 중에 다섯 분 뽑아서"
    },
    {
      "start": 110.12,
      "end": 113.02,
      "text": "오늘 바로 드실 수 있게 쿠폰 싸드릴게요."
    },
    {
      "start": 113.44,
      "end": 116.42,
      "text": "단문 50원과 장문 100원의 추가 요금이 부과되는"
