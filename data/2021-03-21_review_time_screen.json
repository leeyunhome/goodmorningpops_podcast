      "end": 895.56,
      "text": "쉑쉑"
    },
    {
      "start": 895.56,
      "end": 896.36,
      "text": "소리나다"
    },
    {
      "start": 896.36,
      "end": 899.52,
      "text": "약간 바람 빠지는 느낌이 들었잖아요."
