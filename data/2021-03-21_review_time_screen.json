    {
      "start": 859.29,
      "end": 860.37,
      "text": "간단하죠?"
    },
    {
      "start": 860.59,
      "end": 861.83,
      "text": "we did some sightseeing"
    },
    {
      "start": 861.83,
      "end": 865.05,
      "text": "저는 관광 버스를 탔어요."
    },
    {
