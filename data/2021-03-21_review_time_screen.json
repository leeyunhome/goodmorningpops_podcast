    {
      "start": 784.78,
      "end": 786.34,
      "text": "헤이스틀리"
    },
    {
      "start": 786.34,
      "end": 787.9,
      "text": "라는 단어였습니다."
    },
    {
      "start": 788.7,
      "end": 790.88,
      "text": "의미가 뭐였더라? 기억나십니까?"
    },
    {
      "start": 791.4,
      "end": 792.28,
      "text": "이거 헤이스틀리"
