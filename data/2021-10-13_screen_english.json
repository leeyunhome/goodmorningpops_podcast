    {
      "start": 492.58,
      "end": 493.52,
      "text": "입장이 다르네요."
    },
    {
      "start": 495.52,
      "end": 497.56,
      "text": "No, no, no, no."
    },
    {
      "start": 497.84,
      "end": 498.96,
      "text": "I was a kid."
    },
    {
      "start": 499.04,
      "end": 500.88,
      "text": "네, 오스카의 대답이었습니다."
    },
    {
      "start": 501.1,
      "end": 502.24,
      "text": "No, no, no."
    },
    {
      "start": 502.6,
      "end": 503.46,
      "text": "I was a kid."
    },
    {
      "start": 503.86,
      "end": 504.14,
      "text": "아니,"
    },
    {
      "start": 504.36,
      "end": 507.06,
      "text": "난 그땐 어린아이였어."
    },
    {
      "start": 507.14,
      "end": 508.46,
      "text": "난 그때 너무 어렸다고."
    },
    {
      "start": 509.56,
      "end": 511.08,
      "text": "아직도 어린아이 말투 같은데."
    },
    {
      "start": 511.64,
      "end": 512.38,
      "text": "No, no, no."
    },
    {
      "start": 512.62,
      "end": 513.16,
      "text": "No, no, no."
    },
    {
      "start": 513.22,
      "end": 513.62,
      "text": "이게 아니라"
    },
    {
      "start": 513.62,
      "end": 514.76,
      "text": "약간 좀 더 심각하게"
    },
    {
      "start": 514.76,
      "end": 515.48,
      "text": "했었어야 했죠."
    },
    {
      "start": 516.42,
