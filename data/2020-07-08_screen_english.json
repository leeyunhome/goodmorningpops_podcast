    {
      "start": 270.59,
      "end": 271.89,
      "text": "What is the point?"
    },
    {
      "start": 272.01,
      "end": 272.75,
      "text": "That's a good sentence."
    },
    {
      "start": 272.91,
      "end": 273.81,
      "text": "What's the point?"
    },
    {
      "start": 273.99,
      "end": 276.35,
      "text": "굉장히 많이 들어본 그런 유용한 표현이잖아요."
    },
    {
      "start": 276.87,
      "end": 277.83,
      "text": "What's the point?"
