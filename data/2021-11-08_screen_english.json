      "start": 470.49,
      "end": 471.05,
      "text": "다른 거죠"
    },
    {
      "start": 471.05,
      "end": 474.15,
      "text": "자 이 장면"
    },
    {
      "start": 474.15,
      "end": 474.57,
      "text": "다시 한번"
    },
    {
      "start": 474.57,
      "end": 475.93,
      "text": "들어보겠습니다"
    },
    {
      "start": 475.93,
      "end": 495.21,
      "text": "소린"
    },
    {
      "start": 495.21,
      "end": 496.05,
      "text": "삼촌이 있어서"
    },
    {
      "start": 496.05,
      "end": 497.01,
      "text": "얼마나 다행인지"
    },
    {
      "start": 497.01,
      "end": 497.63,
      "text": "몰라요"
    },
    {
      "start": 497.63,
      "end": 497.93,
      "text": "그죠"
    },
    {
      "start": 497.93,
      "end": 498.93,
      "text": "자 뭐라고"
    },
    {
      "start": 498.93,
      "end": 499.25,
      "text": "했는지"
    },
    {
      "start": 499.25,
      "end": 499.95,
      "text": "들어보겠습니다"
    },
    {
      "start": 499.95,
      "end": 501.65,
      "text": "For heaven's sake"
    },
    {
      "start": 501.65,
      "end": 502.71,
      "text": "아 맙소사"
    },
    {
      "start": 502.71,
      "end": 503.77,
      "text": "세상에"
    },
    {
      "start": 503.77,
      "end": 504.97,
      "text": "He wanted to"
    },
    {
      "start": 504.97,
      "end": 505.75,
      "text": "please you"
    },
    {
      "start": 505.75,
      "end": 507.29,
      "text": "아니 콘스탄틴은"
    },
    {
      "start": 507.29,
      "end": 508.07,
      "text": "너를 기쁘게"
    },
    {
      "start": 508.07,
      "end": 509.13,
      "text": "해주려고 한 거야"
    },
    {
      "start": 509.13,
      "end": 510.39,
      "text": "라고 동생인"
    },
    {
      "start": 510.39,
      "end": 511.11,
      "text": "이리나에게"
    },
    {
      "start": 511.11,
      "end": 512.09,
      "text": "이야기하는 거죠"
    },
    {
      "start": 512.09,
      "end": 514.01,
      "text": "And I was willing"
    },
    {
      "start": 514.01,
      "end": 514.61,
      "text": "to listen"
    },
    {
      "start": 514.61,
      "end": 515.81,
      "text": "even to his"
    },
    {
      "start": 515.81,
      "end": 516.43,
      "text": "ravings"
    },
    {
      "start": 516.43,
      "end": 517.53,
      "text": "이리나의"
    },
    {
      "start": 517.53,
      "end": 518.47,
      "text": "대답이었습니다"
    },
    {
      "start": 518.47,
      "end": 519.57,
      "text": "And I was willing"
    },
    {
      "start": 519.57,
      "end": 520.17,
      "text": "to listen"
    },
    {
      "start": 520.17,
      "end": 521.37,
      "text": "저는 기꺼이"
    },
    {
      "start": 521.37,
      "end": 522.43,
      "text": "들으려고 했잖아요"
    },
    {
      "start": 522.43,
      "end": 523.71,
      "text": "even to his"
    },
    {
      "start": 523.71,
      "end": 524.35,
      "text": "ravings"
    },
    {
      "start": 524.35,
      "end": 525.15,
      "text": "심지어"
    },
    {
      "start": 525.15,
      "end": 525.99,
      "text": "그의 헛소리"
    },
    {
      "start": 525.99,
      "end": 527.13,
      "text": "조차도요"
    },
    {
      "start": 527.13,
      "end": 527.89,
      "text": "But"
    },
    {
      "start": 527.89,
      "end": 528.83,
      "text": "his claims"
    },
    {
      "start": 528.83,
      "end": 529.41,
      "text": "to new"
    },
    {
      "start": 529.41,
      "end": 530.03,
      "text": "forms"
    },
    {
      "start": 530.03,
      "end": 530.77,
      "text": "they're"
    },
    {
      "start": 530.77,
      "end": 531.81,
      "text": "pretentious"
    },
    {
      "start": 531.81,
      "end": 532.47,
      "text": "But"
    },
    {
      "start": 532.47,
      "end": 533.23,
      "text": "그러나"
    },
    {
      "start": 533.23,
      "end": 535.31,
      "text": "새로운 형식이라는"
    },
    {
      "start": 535.31,
      "end": 536.35,
      "text": "그의 주장은"
    },
    {
      "start": 536.35,
      "end": 537.57,
      "text": "pretentious"
    },
    {
      "start": 537.57,
      "end": 538.85,
      "text": "허세를 부리는"
    },
    {
      "start": 538.85,
      "end": 540.67,
      "text": "가식적인 거예요"
    },
    {
      "start": 540.67,
      "end": 541.27,
      "text": "라는"
    },
    {
      "start": 541.27,
      "end": 542.25,
      "text": "순차적인 해석을"
    },
    {
      "start": 542.25,
      "end": 542.75,
      "text": "해봤어요"
    },
    {
      "start": 542.75,
      "end": 543.39,
      "text": "아이고 여기서"
    },
    {
      "start": 543.39,
      "end": 544.13,
      "text": "너무했다"
    },
    {
      "start": 544.13,
      "end": 545.09,
      "text": "아 그러니까요"
    },
    {
      "start": 545.09,
      "end": 546.31,
      "text": "This is her son"
    },
    {
      "start": 546.31,
      "end": 548.03,
      "text": "her birth son"
    },
    {
      "start": 548.03,
      "end": 549.11,
      "text": "아 아들한테"
    },
    {
      "start": 549.11,
      "end": 550.05,
      "text": "너무 가혹한"
    },
    {
      "start": 550.05,
      "end": 551.25,
      "text": "말을 이야기를 했네요"
    },
    {
      "start": 551.25,
      "end": 552.25,
      "text": "Yeah she should just"
    },
    {
      "start": 552.25,
      "end": 553.73,
      "text": "love him for who he is"
    },
    {
      "start": 553.73,
      "end": 554.81,
      "text": "She's like"
    },
    {
      "start": 554.81,
      "end": 555.61,
      "text": "critiquing"
    },
    {
      "start": 555.61,
      "end": 556.79,
      "text": "his art"
    },
    {
      "start": 556.79,
      "end": 557.63,
      "text": "무서워요"
    },
    {
      "start": 557.63,
      "end": 558.73,
      "text": "So she is kind of"
    },
    {
      "start": 558.73,
      "end": 559.15,
      "text": "scary"
    },
    {
      "start": 559.15,
      "end": 561.3,
      "text": "Since when"
    },
    {
      "start": 561.3,
      "end": 562.34,
      "text": "has the exhibition"
    },
    {
      "start": 562.34,
      "end": 563.76,
      "text": "of a morbid"
    },
    {
      "start": 563.76,
      "end": 564.64,
      "text": "a morbid"
    },
    {
      "start": 564.64,
      "end": 565.32,
      "text": "personality"
    },
    {
      "start": 565.32,
      "end": 566.12,
      "text": "been a new"
    },
    {
      "start": 566.12,
      "end": 566.82,
      "text": "art form"
    },
    {
      "start": 566.82,
      "end": 568.38,
      "text": "Since when"
    },
    {
      "start": 568.38,
      "end": 570.16,
      "text": "도대체 언제부터"
    },
    {
      "start": 570.16,
      "end": 571.6,
      "text": "morbid"
    },
    {
      "start": 571.6,
      "end": 572.22,
      "text": "personality"
    },
    {
      "start": 572.22,
      "end": 572.96,
      "text": "병적인"
    },
    {
      "start": 572.96,
      "end": 573.8,
      "text": "성격의"
    },
    {
      "start": 573.8,
      "end": 574.84,
      "text": "the exhibition"
    },
    {
      "start": 574.84,
      "end": 576.14,
      "text": "이 전시가"
    },
    {
      "start": 576.14,
      "end": 576.96,
      "text": "has been"
    },
    {
      "start": 576.96,
      "end": 577.54,
      "text": "a new"
    },
    {
      "start": 577.54,
      "end": 578.38,
      "text": "art form"
    },
    {
      "start": 578.38,
      "end": 579.42,
      "text": "이렇게 이해하시면"
    },
    {
      "start": 579.42,
      "end": 580.64,
      "text": "해석하시기가 편하겠죠"
    },
    {
      "start": 580.64,
      "end": 581.88,
      "text": "새로운 예술"
    },
    {
      "start": 581.88,
      "end": 583.14,
      "text": "형식이 된 거죠"
    },
    {
      "start": 583.14,
      "end": 583.7,
      "text": "라고"
    },
    {
      "start": 583.7,
      "end": 584.9,
      "text": "되묻습니다"
    },
    {
      "start": 584.9,
      "end": 585.68,
      "text": "언제부터"
    },
    {
      "start": 585.68,
      "end": 586.2,
      "text": "이 병적인"
    },
    {
      "start": 586.2,
      "end": 587.1,
      "text": "성격을 전시하는 게"
    },
    {
      "start": 587.1,
      "end": 587.62,
      "text": "새 예술"
    },
    {
      "start": 587.62,
      "end": 588.4,
      "text": "형식이 된 거예요"
    },
    {
      "start": 588.4,
      "end": 588.9,
      "text": "병적인"
    },
    {
      "start": 588.9,
      "end": 590.5,
      "text": "He's just crazy"
    },
    {
      "start": 590.5,
      "end": 591.9,
      "text": "This is not art"
    },
    {
      "start": 591.9,
      "end": 593.52,
      "text": "He's a depressed"
    },
    {
      "start": 593.52,
      "end": 595.04,
      "text": "just crazy"
    },
    {
      "start": 595.04,
      "end": 595.98,
      "text": "young fellow"
    },
    {
      "start": 595.98,
      "end": 596.42,
      "text": "Yeah"
    },
    {
      "start": 596.42,
      "end": 597.96,
      "text": "Oh poor guy"
    },
    {
      "start": 597.96,
      "end": 599.18,
      "text": "I feel for him"
    },
    {
      "start": 599.18,
      "end": 600.04,
      "text": "너무 불쌍해요"
    },
    {
      "start": 600.04,
      "end": 601.99,
      "text": "Everyone writes"
    },
    {
      "start": 601.99,
      "end": 602.85,
      "text": "what he wants"
    },
    {
      "start": 602.85,
      "end": 604.47,
      "text": "and as best"
    },
    {
      "start": 604.47,
      "end": 605.13,
      "text": "he can"
    },
    {
      "start": 605.13,
      "end": 605.97,
      "text": "이 목소리는"
    },
    {
      "start": 605.97,
      "end": 606.85,
      "text": "Boris가"
    },
    {
      "start": 606.85,
      "end": 608.21,
      "text": "대답을 한 목소리였습니다"
    },
    {
      "start": 608.21,
      "end": 608.61,
      "text": "Boris"
    },
    {
      "start": 608.61,
      "end": 610.11,
      "text": "He's the famous writer"
    },
    {
      "start": 610.11,
      "end": 610.57,
      "text": "Yeah"
    },
    {
      "start": 610.57,
      "end": 611.85,
      "text": "The popular author"
    },
    {
      "start": 611.85,
      "end": 612.15,
      "text": "그렇죠"
    },
    {
      "start": 612.15,
      "end": 613.33,
      "text": "이미 성공을 한"
    },
    {
      "start": 613.33,
      "end": 614.41,
      "text": "대작가였죠"
    },
    {
      "start": 614.41,
      "end": 615.97,
      "text": "Everyone writes"
    },
    {
      "start": 615.97,
      "end": 616.95,
      "text": "what he wants"
    },
    {
      "start": 616.95,
      "end": 617.49,
      "text": "and"
    },
    {
      "start": 617.49,
      "end": 618.53,
      "text": "as best"
    },
    {
      "start": 618.53,
      "end": 619.21,
      "text": "he can"
    },
    {
      "start": 619.21,
      "end": 620.09,
      "text": "이라고 했으니까"
    },
    {
      "start": 620.09,
      "end": 621.15,
      "text": "모두 다"
    },
    {
      "start": 621.15,
      "end": 622.61,
      "text": "자신이 원하는 걸 쓰죠"
    },
    {
      "start": 622.61,
      "end": 622.91,
      "text": "그리고"
    },
    {
      "start": 622.91,
      "end": 624.21,
      "text": "최선을 다해서"
    },
    {
      "start": 624.21,
      "end": 625.13,
      "text": "하는 거고요"
    },
    {
      "start": 625.13,
      "end": 625.61,
      "text": "라고"
    },
    {
      "start": 625.61,
      "end": 627.07,
      "text": "옆에서 이야기를 합니다"
    },
    {
      "start": 627.07,
      "end": 628.31,
      "text": "That's a voice of reason"
    },
    {
      "start": 628.31,
      "end": 629.03,
      "text": "Yeah"
    },
    {
      "start": 629.03,
      "end": 630.03,
      "text": "Soren and Boris"
    },
    {
      "start": 630.03,
      "end": 631.57,
      "text": "They're voices of reason"
    },
    {
      "start": 631.57,
      "end": 631.97,
      "text": "Yeah"
    },
    {
      "start": 631.97,
      "end": 633.59,
      "text": "옆에서 이렇게"
    },
    {
      "start": 633.59,
      "end": 634.87,
      "text": "컨스탄틴의 입장에서"
    },
    {
      "start": 634.87,
      "end": 635.63,
      "text": "최대한 도와주고"
    },
    {
      "start": 635.63,
      "end": 636.47,
      "text": "있기는 한데"
    },
    {
      "start": 636.47,
      "end": 637.13,
      "text": "자"
    },
    {
      "start": 637.13,
      "end": 637.57,
      "text": "이 내용"
    },
    {
      "start": 637.57,
      "end": 638.53,
      "text": "한 번 더 들어보겠습니다"
    },
    {
      "start": 638.53,
      "end": 659.94,
      "text": "김은나님께서"
    },
    {
      "start": 659.94,
      "end": 660.92,
      "text": "로라쌤"
    },
    {
      "start": 660.92,
      "end": 661.42,
      "text": "크쌤"
    },
    {
      "start": 661.42,
      "end": 662.5,
      "text": "설명 듣고 있으면"
    },
    {
      "start": 662.5,
      "end": 663.28,
      "text": "영어 대사가"
    },
    {
      "start": 663.28,
      "end": 664.6,
      "text": "들리는 게 신기해요"
    },
    {
      "start": 664.6,
      "end": 665.74,
      "text": "하셨습니다"
    },
    {
      "start": 665.74,
      "end": 667.24,
      "text": "너무 뿌듯하네요"
    },
    {
      "start": 667.24,
      "end": 668.02,
      "text": "보람차요"
    },
    {
      "start": 668.02,
      "end": 668.26,
      "text": "그렇죠"
    },
    {
      "start": 668.26,
      "end": 669.6,
      "text": "I feel good about that"
    },
    {
      "start": 669.6,
      "end": 670.42,
      "text": "Thank you"
    },
    {
      "start": 670.42,
      "end": 672.6,
      "text": "오늘 스크린 잉글리쉬는"
    },
    {
      "start": 672.6,
      "end": 673.92,
      "text": "여기에서 마무리할게요"
    }
  ]
}