      "end": 752.78,
      "text": "컨스탄틴의 입장에서"
    },
    {
      "start": 752.78,
      "end": 753.54,
      "text": "최대한 도와주고"
    },
    {
      "start": 753.54,
      "end": 754.38,
      "text": "있기는 한데"
    },
    {
      "start": 754.38,
      "end": 755.04,
      "text": "자"
    },
    {
      "start": 755.04,
      "end": 755.48,
      "text": "이 내용"
    },
    {
      "start": 755.48,
      "end": 756.44,
      "text": "한 번 더 들어보겠습니다"
    },
    {
      "start": 756.44,
      "end": 777.85,
      "text": "김은나님께서"
    },
    {
      "start": 777.85,
      "end": 778.83,
      "text": "로라쌤"
    },
    {
      "start": 778.83,
      "end": 779.33,
      "text": "크쌤"
    },
    {
      "start": 779.33,
      "end": 780.41,
      "text": "설명 듣고 있으면"
    },
    {
      "start": 780.41,
      "end": 781.19,
      "text": "영어 대사가"
    },
    {
      "start": 781.19,
      "end": 782.51,
      "text": "들리는 게 신기해요"
    },
    {
      "start": 782.51,
      "end": 783.65,
      "text": "하셨습니다"
    },
    {
      "start": 783.65,
      "end": 785.15,
      "text": "너무 뿌듯하네요"
    },
    {
      "start": 785.15,
      "end": 785.93,
      "text": "보람차요"
    },
    {
      "start": 785.93,
      "end": 786.17,
      "text": "그렇죠"
    },
    {
      "start": 786.17,
      "end": 787.51,
      "text": "I feel good about that"
    },
    {
      "start": 787.51,
      "end": 788.33,
      "text": "Thank you"
    },
    {
      "start": 788.33,
      "end": 790.51,
      "text": "오늘 스크린 잉글리쉬는"
    },
    {
      "start": 790.51,
      "end": 791.83,
      "text": "여기에서 마무리할게요"
    },
    {
      "start": 791.83,
      "end": 792.31,
      "text": "크쌤"
    },
    {
      "start": 792.31,
      "end": 793.05,
      "text": "내일 만나요"
    }
  ]
}