    {
      "start": 583.11,
      "end": 584.41,
      "text": "She has cancer"
    },
    {
      "start": 584.41,
      "end": 585.69,
      "text": "She's dying"
    },
    {
      "start": 585.69,
      "end": 586.83,
      "text": "Sherryl 이거"
    },
    {
      "start": 586.83,
      "end": 587.57,
      "text": "모르면서"
    },
    {
      "start": 587.57,
      "end": 589.05,
      "text": "정말 눈질도 없이"
    },
    {
      "start": 589.05,
      "end": 590.43,
      "text": "같이 장례식"
    },
    {
      "start": 590.43,
      "end": 591.63,
      "text": "얻어먹으러 가는 거죠"
    },
    {
      "start": 591.63,
      "end": 593.15,
      "text": "Yeah"
    },
    {
      "start": 593.15,
      "end": 594.99,
      "text": "네, Martha의 대답입니다"
    },
    {
      "start": 594.99,
      "end": 596.73,
      "text": "굉장히 당황스러웠겠죠"
    },
    {
      "start": 596.73,
      "end": 597.29,
      "text": "그래서"
    },
    {
      "start": 597.29,
      "end": 597.87,
      "text": "Yeah"
    },
    {
      "start": 597.87,
      "end": 599.35,
      "text": "And"
    },
    {
      "start": 599.35,
      "end": 600.59,
      "text": "There's always tons"
    },
    {
      "start": 600.59,
      "end": 601.57,
      "text": "of free food"
    },
    {
      "start": 601.57,
      "end": 602.01,
      "text": "Oh"
    },
    {
      "start": 602.01,
      "end": 603.25,
      "text": "네, 그러면서"
    },
    {
      "start": 603.25,
      "end": 603.99,
      "text": "부연 설명을"
    },
    {
      "start": 603.99,
      "end": 605.05,
      "text": "계속해 나가고 있어요"
    },
    {
      "start": 605.05,
      "end": 606.39,
      "text": "And there's always tons"
    },
    {
      "start": 606.39,
      "end": 607.47,
      "text": "of free food"
    },
    {
      "start": 607.47,
      "end": 608.99,
      "text": "장례식장에는"
    },
    {
      "start": 608.99,
      "end": 609.95,
      "text": "공짜 음식이"
    },
    {
      "start": 609.95,
      "end": 610.69,
      "text": "넘치잖아요"
    },
    {
      "start": 610.69,
      "end": 612.53,
      "text": "Here, put this in your purse"
    },
    {
      "start": 612.53,
      "end": 613.67,
      "text": "그러면서 이제"
    },
    {
      "start": 613.67,
      "end": 615.23,
      "text": "이 음식들을"
    },
    {
      "start": 615.23,
      "end": 615.99,
      "text": "빨리 가방에"
    },
    {
      "start": 615.99,
      "end": 616.71,
      "text": "넣어두라는"
    },
    {
      "start": 616.71,
      "end": 617.69,
      "text": "이야기를 합니다"
    },
    {
      "start": 617.69,
      "end": 618.61,
      "text": "To be honest"
    },
    {
      "start": 618.61,
      "end": 619.25,
      "text": "Totally honest"
    },
    {
      "start": 619.25,
      "end": 621.19,
      "text": "I cracked up"
    },
    {
      "start": 621.19,
      "end": 622.07,
      "text": "at this scene"
    },
    {
      "start": 622.07,
      "end": 622.37,
      "text": "그래요?"
    },
    {
      "start": 622.49,
      "end": 623.69,
      "text": "정말 빵돼졌어요"
    },
    {
      "start": 623.69,
      "end": 624.25,
      "text": "아, 진짜요?"
    },
    {
      "start": 624.25,
      "end": 625.15,
      "text": "It was funny"
    },
    {
      "start": 625.15,
      "end": 625.83,
      "text": "아하"
    },
    {
      "start": 625.83,
      "end": 626.99,
      "text": "이런 경우가"
    },
    {
      "start": 626.99,
      "end": 627.97,
      "text": "거의 없겠죠?"
    },
    {
      "start": 628.13,
      "end": 628.71,
      "text": "미국에서는"
    },
    {
      "start": 628.71,
      "end": 629.61,
      "text": "없길 바라요"
    },
    {
      "start": 629.61,
      "end": 630.15,
      "text": "네"
    },
    {
      "start": 630.15,
      "end": 632.41,
      "text": "없겠죠?"
    },
    {
      "start": 632.53,
      "end": 632.79,
      "text": "그렇죠"
    },
    {
      "start": 632.79,
      "end": 634.19,
      "text": "무례하기도 하고"
    },
    {
      "start": 634.19,
      "end": 636.07,
      "text": "참 당황스러운 상황입니다"
    },
    {
      "start": 636.07,
      "end": 636.53,
      "text": "네"
    },
    {
      "start": 636.53,
      "end": 637.87,
      "text": "가끔 한국에 있잖아요"
    },
    {
      "start": 637.87,
      "end": 638.51,
      "text": "주말에"
    },
    {
      "start": 638.51,
      "end": 639.55,
      "text": "결혼식 다니는 거"
    },
    {
      "start": 639.55,
      "end": 639.95,
      "text": "네"
    },
    {
      "start": 639.95,
      "end": 641.97,
      "text": "저 종종 목격을 했어요"
    },
    {
      "start": 641.97,
      "end": 642.67,
      "text": "아, really?"
    },
    {
      "start": 643.03,
      "end": 644.25,
      "text": "근데 축의금 내잖아요"
    },
    {
      "start": 644.25,
      "end": 645.09,
      "text": "그렇긴 하죠"
    },
    {
      "start": 645.09,
      "end": 646.41,
      "text": "아, 그런 차이가 있네요"
    },
    {
      "start": 646.41,
      "end": 647.29,
      "text": "식비 내잖아요"
    },
    {
      "start": 647.29,
      "end": 648.79,
      "text": "그래서 우리 결혼식 와도"
    },
    {
      "start": 648.79,
      "end": 649.93,
      "text": "뭐 손해 없으니까"
    },
    {
      "start": 649.93,
      "end": 650.41,
      "text": "그러니까요"
    },
    {
      "start": 650.41,
      "end": 651.75,
      "text": "아, 근데 결혼식장에서는"
    },
    {
      "start": 651.75,
      "end": 652.31,
      "text": "이런 경우를"
    },
    {
      "start": 652.31,
      "end": 654.07,
      "text": "종종 볼 수는 있는데"
    },
    {
      "start": 654.07,
      "end": 655.53,
      "text": "장례식장에는"
    },
    {
      "start": 655.53,
      "end": 656.65,
      "text": "한 번도 본 적이 없죠"
    },
    {
      "start": 656.65,
      "end": 656.67,
      "text": "No"
    },
    {
      "start": 656.67,
      "end": 657.55,
      "text": "That's crazy"
    },
    {
      "start": 657.55,
      "end": 657.87,
      "text": "그렇죠"
    },
    {
      "start": 657.87,
      "end": 658.85,
      "text": "Anyway"
    },
    {
      "start": 658.85,
      "end": 661.07,
      "text": "Here, put this in your purse"
    },
    {
      "start": 661.07,
      "end": 662.09,
      "text": "자, 여기 이거"
    },
    {
      "start": 662.09,
      "end": 662.89,
      "text": "가방에다가"
    },
    {
      "start": 662.89,
      "end": 663.87,
      "text": "넣어둬요"
    },
    {
      "start": 663.87,
      "end": 665.53,
      "text": "No, no, no, no, no"
    },
    {
      "start": 665.53,
      "end": 666.65,
      "text": "No"
    },
    {
      "start": 666.65,
      "end": 668.37,
      "text": "Put it in your own purse"
    },
    {
      "start": 668.37,
      "end": 668.83,
      "text": "Okay"
    },
    {
      "start": 668.83,
      "end": 669.67,
      "text": "Thanks"
    },
    {
      "start": 669.67,
      "end": 670.05,
      "text": "네"
    },
    {
      "start": 670.05,
      "end": 671.59,
      "text": "지금 말사의 대답을"
    },
    {
      "start": 671.59,
      "end": 672.37,
      "text": "들어보셨습니다"
    },
    {
      "start": 672.37,
      "end": 673.23,
      "text": "No, no, no, no"
    },
    {
      "start": 673.23,
      "end": 673.71,
      "text": "하면서"
    },
    {
      "start": 673.71,
      "end": 675.39,
      "text": "Put it in your own purse"
    },
    {
      "start": 675.39,
      "end": 677.05,
      "text": "당신 가방에나"
    },
    {
      "start": 677.05,
      "end": 677.87,
      "text": "넣어놔요"
    },
    {
      "start": 677.87,
      "end": 678.31,
      "text": "오케이"
    },
    {
      "start": 678.31,
      "end": 678.77,
      "text": "알겠죠?"
    },
    {
      "start": 678.93,
      "end": 679.27,
      "text": "Thanks"
    },
    {
      "start": 679.27,
      "end": 680.53,
      "text": "저는 됐어요"
    },
    {
      "start": 680.53,
      "end": 681.73,
      "text": "이렇게 거절을 합니다"
    },
    {
      "start": 681.73,
      "end": 683.59,
      "text": "Mine's already full"
    },
    {
      "start": 683.59,
      "end": 685.07,
      "text": "Just shove it in"
    },
    {
      "start": 685.07,
      "end": 686.65,
      "text": "와우"
    },
    {
      "start": 686.65,
      "end": 688.27,
      "text": "계속 뜨네요"
    },
    {
      "start": 688.27,
      "end": 688.95,
      "text": "한술 더"
    },
    {
      "start": 688.95,
      "end": 690.33,
      "text": "이 부분은 좀 웃겼어요"
    },
    {
      "start": 690.33,
      "end": 691.41,
      "text": "Mine's already full"
    },
    {
      "start": 691.41,
      "end": 692.95,
      "text": "내 거 벌써 다 찼어요"
    },
    {
      "start": 692.95,
      "end": 694.37,
      "text": "내 가방은 이미 다 찼거든요"
    },
    {
      "start": 694.37,
      "end": 695.81,
      "text": "Just shove it in"
    },
    {
      "start": 695.81,
      "end": 696.21,
      "text": "Yeah"
    },
    {
      "start": 696.21,
      "end": 696.91,
      "text": "그러니까"
    },
    {
      "start": 696.91,
      "end": 698.71,
      "text": "내 거 용도로"
    },
    {
      "start": 698.71,
      "end": 700.19,
      "text": "당신 가방에 넣어두라는"
    },
    {
      "start": 700.19,
      "end": 701.11,
      "text": "의도가 되겠네요"
    },
    {
      "start": 701.11,
      "end": 701.39,
      "text": "그렇죠?"
    },
    {
      "start": 701.57,
      "end": 702.61,
      "text": "Are you found it funny too?"
    },
    {
      "start": 702.91,
      "end": 703.25,
      "text": "Yeah"
    },
    {
      "start": 703.25,
      "end": 705.39,
      "text": "저도 이 미쿡식 미트에"
    },
    {
      "start": 705.39,
      "end": 706.89,
      "text": "살살 웃기 시작했다니"
    },
    {
      "start": 706.89,
      "end": 708.21,
      "text": "굉장히 충격적입니다"
    },
    {
      "start": 708.21,
      "end": 708.59,
      "text": "Yeah"
    },
    {
      "start": 708.59,
      "end": 710.23,
      "text": "이 초과장된 유머"
    },
    {
      "start": 710.23,
      "end": 710.91,
      "text": "Yeah"
    },
    {
      "start": 710.91,
      "end": 711.67,
      "text": "It's hilarious"
    },
    {
      "start": 711.67,
      "end": 712.29,
      "text": "Yeah"
    },
    {
      "start": 712.29,
      "end": 714.04,
      "text": "No"
    },
    {
      "start": 714.04,
      "end": 715.94,
      "text": "I don't really want to"
    },
    {
      "start": 715.94,
      "end": 716.2,
      "text": "네"
    },
    {
      "start": 716.2,
      "end": 717.38,
      "text": "한 번 더 거절을 하네요"
    },
    {
      "start": 717.38,
      "end": 717.74,
      "text": "No"
    },
    {
      "start": 717.74,
      "end": 719.2,
      "text": "I don't really want to"
    },
    {
      "start": 719.2,
      "end": 719.84,
      "text": "아니요"
    },
    {
      "start": 719.84,
      "end": 721.2,
      "text": "저 그러고 싶지 않아요"
    },
    {
      "start": 721.2,
      "end": 722.3,
      "text": "Oh"
    },
    {
      "start": 722.3,
      "end": 722.98,
      "text": "Okay"
    },
    {
      "start": 722.98,
      "end": 725.0,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 725.36,
      "end": 727.28,
      "text": "살짝 눈치를 보면서"
    },
    {
      "start": 727.28,
      "end": 728.14,
      "text": "음"
    },
    {
      "start": 728.14,
      "end": 728.34,
      "text": "뭐"
    },
    {
      "start": 728.34,
      "end": 728.94,
      "text": "알겠어요"
    },
    {
      "start": 728.94,
      "end": 730.76,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 730.78,
      "end": 732.16,
      "text": "That's why you go to a funeral"
    },
    {
      "start": 732.16,
      "end": 732.58,
      "text": "Yeah"
    },
    {
      "start": 732.58,
      "end": 733.8,
      "text": "To pay your respects"
    },
    {
      "start": 733.8,
      "end": 735.3,
      "text": "Not to get free food"
    },
    {
      "start": 735.3,
      "end": 735.68,
      "text": "그렇죠"
    },
    {
      "start": 735.68,
      "end": 737.44,
      "text": "이게 주 목적이어야 하는데"
    },
    {
      "start": 737.44,
      "end": 739.46,
      "text": "주객 전도가 된 상황입니다"
    },
    {
      "start": 739.46,
      "end": 740.62,
      "text": "이제야말로"
    },
    {
      "start": 740.62,
      "end": 742.42,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 742.6,
      "end": 743.5,
      "text": "이렇게 이야기를 한 거죠"
    },
    {
      "start": 743.5,
      "end": 745.7,
      "text": "조이를 그럼 표하러 가볼까요?"
    },
    {
      "start": 746.44,
      "end": 746.76,
      "text": "Okay"
    },
    {
      "start": 746.76,
      "end": 747.86,
      "text": "I'm out of here"
    },
    {
      "start": 747.86,
      "end": 751.32,
      "text": "이거는 동의하는 장면이 아니었죠"
    },
    {
      "start": 751.32,
      "end": 753.32,
      "text": "I'm out of here"
    },
    {
      "start": 753.32,
      "end": 754.4,
      "text": "저 먼저 갈게요"
    },
    {
      "start": 754.4,
      "end": 755.16,
      "text": "She runs away"
    },
    {
      "start": 755.16,
      "end": 755.52,
      "text": "Yeah"
    },
    {
      "start": 755.52,
      "end": 757.92,
      "text": "그래서 이 장소를 떠나는"
    },
    {
      "start": 757.92,
      "end": 759.82,
      "text": "마르타의 모습을 보셨습니다"
    },
    {
      "start": 759.82,
      "end": 761.86,
      "text": "그럼 한 번 더 확인해 보시죠"
    },
    {
      "start": 761.86,
      "end": 764.34,
      "text": "The real perk about this place"
    },
    {
      "start": 764.34,
      "end": 767.26,
      "text": "Is that people are constantly dying"
    },
    {
      "start": 767.26,
      "end": 770.04,
      "text": "They list all the funeral's and the papers"
    },
    {
      "start": 770.04,
      "end": 772.68,
      "text": "And there's always tons of free food"
    },
    {
      "start": 772.68,
      "end": 776.31,
      "text": "Put this in your purse"
    },
    {
      "start": 776.31,
      "end": 776.97,
      "text": "No, no, no, no"
    },
    {
      "start": 776.97,
      "end": 779.35,
      "text": "Put it in your own purse, okay?"
    },
    {
      "start": 779.41,
      "end": 779.65,
      "text": "Thanks"
    },
    {
      "start": 779.65,
      "end": 780.73,
      "text": "The line's already full"
    },
    {
      "start": 780.73,
      "end": 781.47,
      "text": "Just shove it in"
    },
    {
      "start": 781.47,
      "end": 782.55,
      "text": "No, I don't really want to"
    },
    {
      "start": 782.55,
      "end": 785.83,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 787.75,
      "end": 788.07,
      "text": "Okay"
    },
    {
      "start": 788.07,
      "end": 789.96,
      "text": "I'm out of here"
    },
    {
      "start": 789.96,
      "end": 792.04,
      "text": "네, Cheryl 덕분에"
    },
    {
      "start": 792.04,
      "end": 793.3,
      "text": "지금 마르사도 그렇고"
    },
    {
      "start": 793.3,
      "end": 794.2,
      "text": "저도 그렇고"
    },
    {
      "start": 794.2,
      "end": 796.38,
      "text": "심지어 우리 크쌤도 그렇고"
    },
    {
      "start": 796.38,
      "end": 798.7,
      "text": "We feel culture shock"
    },
    {
      "start": 798.7,
      "end": 799.46,
      "text": "Yeah"
    },
    {
      "start": 799.46,
      "end": 801.96,
