      "text": "at this scene"
    },
    {
      "start": 532.01,
      "end": 532.31,
      "text": "그래요?"
    },
    {
      "start": 532.43,
      "end": 533.63,
      "text": "정말 빵돼졌어요"
    },
    {
      "start": 533.63,
      "end": 534.19,
      "text": "아, 진짜요?"
    },
    {
      "start": 534.19,
      "end": 535.09,
      "text": "It was funny"
    },
    {
      "start": 535.09,
      "end": 535.77,
      "text": "아하"
    },
    {
      "start": 535.77,
      "end": 536.93,
      "text": "이런 경우가"
    },
    {
      "start": 536.93,
      "end": 537.91,
      "text": "거의 없겠죠?"
    },
    {
      "start": 538.07,
      "end": 538.65,
      "text": "미국에서는"
    },
    {
      "start": 538.65,
      "end": 539.55,
      "text": "없길 바라요"
    },
    {
      "start": 539.55,
      "end": 540.09,
      "text": "네"
    },
    {
      "start": 540.09,
      "end": 542.35,
      "text": "없겠죠?"
    },
    {
      "start": 542.47,
      "end": 542.73,
      "text": "그렇죠"
    },
    {
      "start": 542.73,
      "end": 544.13,
      "text": "무례하기도 하고"
    },
    {
      "start": 544.13,
      "end": 546.01,
      "text": "참 당황스러운 상황입니다"
    },
    {
      "start": 546.01,
      "end": 546.47,
      "text": "네"
    },
    {
      "start": 546.47,
      "end": 547.81,
      "text": "가끔 한국에 있잖아요"
    },
    {
      "start": 547.81,
      "end": 548.45,
      "text": "주말에"
    },
    {
      "start": 548.45,
      "end": 549.49,
      "text": "결혼식 다니는 거"
    },
    {
      "start": 549.49,
      "end": 549.89,
      "text": "네"
    },
    {
      "start": 549.89,
      "end": 551.91,
      "text": "저 종종 목격을 했어요"
    },
    {
      "start": 551.91,
      "end": 552.61,
      "text": "아, really?"
    },
    {
      "start": 552.97,
      "end": 554.19,
      "text": "근데 축의금 내잖아요"
    },
    {
      "start": 554.19,
      "end": 555.03,
      "text": "그렇긴 하죠"
    },
    {
      "start": 555.03,
      "end": 556.35,
      "text": "아, 그런 차이가 있네요"
    },
    {
      "start": 556.35,
      "end": 557.23,
      "text": "식비 내잖아요"
    },
    {
      "start": 557.23,
      "end": 558.73,
      "text": "그래서 우리 결혼식 와도"
    },
    {
      "start": 558.73,
      "end": 559.87,
      "text": "뭐 손해 없으니까"
    },
    {
      "start": 559.87,
      "end": 560.35,
      "text": "그러니까요"
    },
    {
      "start": 560.35,
      "end": 561.69,
      "text": "아, 근데 결혼식장에서는"
    },
    {
      "start": 561.69,
      "end": 562.25,
      "text": "이런 경우를"
    },
    {
      "start": 562.25,
      "end": 564.01,
      "text": "종종 볼 수는 있는데"
    },
    {
      "start": 564.01,
      "end": 565.47,
      "text": "장례식장에는"
    },
    {
      "start": 565.47,
      "end": 566.59,
      "text": "한 번도 본 적이 없죠"
    },
    {
      "start": 566.59,
      "end": 566.61,
      "text": "No"
    },
    {
      "start": 566.61,
      "end": 567.49,
      "text": "That's crazy"
    },
    {
      "start": 567.49,
      "end": 567.81,
      "text": "그렇죠"
    },
    {
      "start": 567.81,
      "end": 568.79,
      "text": "Anyway"
    },
    {
      "start": 568.79,
      "end": 571.01,
      "text": "Here, put this in your purse"
    },
    {
      "start": 571.01,
      "end": 572.03,
      "text": "자, 여기 이거"
    },
    {
      "start": 572.03,
      "end": 572.83,
      "text": "가방에다가"
    },
    {
      "start": 572.83,
      "end": 573.81,
      "text": "넣어둬요"
    },
    {
      "start": 573.81,
      "end": 575.47,
      "text": "No, no, no, no, no"
    },
    {
      "start": 575.47,
      "end": 576.59,
      "text": "No"
    },
    {
      "start": 576.59,
      "end": 578.31,
      "text": "Put it in your own purse"
    },
    {
      "start": 578.31,
      "end": 578.77,
      "text": "Okay"
    },
    {
      "start": 578.77,
      "end": 579.61,
      "text": "Thanks"
    },
    {
      "start": 579.61,
      "end": 579.99,
      "text": "네"
    },
    {
      "start": 579.99,
      "end": 581.53,
      "text": "지금 말사의 대답을"
    },
    {
      "start": 581.53,
      "end": 582.31,
      "text": "들어보셨습니다"
    },
    {
      "start": 582.31,
      "end": 583.17,
      "text": "No, no, no, no"
    },
    {
      "start": 583.17,
      "end": 583.65,
      "text": "하면서"
    },
    {
      "start": 583.65,
      "end": 585.33,
      "text": "Put it in your own purse"
    },
    {
      "start": 585.33,
      "end": 586.99,
      "text": "당신 가방에나"
    },
    {
      "start": 586.99,
      "end": 587.81,
      "text": "넣어놔요"
    },
    {
      "start": 587.81,
      "end": 588.25,
      "text": "오케이"
    },
    {
      "start": 588.25,
      "end": 588.71,
      "text": "알겠죠?"
    },
    {
      "start": 588.87,
      "end": 589.21,
      "text": "Thanks"
    },
    {
      "start": 589.21,
      "end": 590.47,
      "text": "저는 됐어요"
    },
    {
      "start": 590.47,
      "end": 591.67,
      "text": "이렇게 거절을 합니다"
    },
    {
      "start": 591.67,
      "end": 593.53,
      "text": "Mine's already full"
    },
    {
      "start": 593.53,
      "end": 595.01,
      "text": "Just shove it in"
    },
    {
      "start": 595.01,
      "end": 596.59,
      "text": "와우"
    },
    {
      "start": 596.59,
      "end": 598.21,
      "text": "계속 뜨네요"
    },
    {
      "start": 598.21,
      "end": 598.89,
      "text": "한술 더"
    },
    {
      "start": 598.89,
      "end": 600.27,
      "text": "이 부분은 좀 웃겼어요"
    },
    {
      "start": 600.27,
      "end": 601.35,
      "text": "Mine's already full"
    },
    {
      "start": 601.35,
      "end": 602.89,
      "text": "내 거 벌써 다 찼어요"
    },
    {
      "start": 602.89,
      "end": 604.31,
      "text": "내 가방은 이미 다 찼거든요"
    },
    {
      "start": 604.31,
      "end": 605.75,
      "text": "Just shove it in"
    },
    {
      "start": 605.75,
      "end": 606.15,
      "text": "Yeah"
    },
    {
      "start": 606.15,
      "end": 606.85,
      "text": "그러니까"
    },
    {
      "start": 606.85,
      "end": 608.65,
      "text": "내 거 용도로"
    },
    {
      "start": 608.65,
      "end": 610.13,
      "text": "당신 가방에 넣어두라는"
    },
    {
      "start": 610.13,
      "end": 611.05,
      "text": "의도가 되겠네요"
    },
    {
      "start": 611.05,
      "end": 611.33,
      "text": "그렇죠?"
    },
    {
      "start": 611.51,
      "end": 612.55,
      "text": "Are you found it funny too?"
    },
    {
      "start": 612.85,
      "end": 613.19,
      "text": "Yeah"
    },
    {
      "start": 613.19,
      "end": 615.33,
      "text": "저도 이 미쿡식 미트에"
    },
    {
      "start": 615.33,
      "end": 616.83,
      "text": "살살 웃기 시작했다니"
    },
    {
      "start": 616.83,
      "end": 618.15,
      "text": "굉장히 충격적입니다"
    },
    {
      "start": 618.15,
      "end": 618.53,
      "text": "Yeah"
    },
    {
      "start": 618.53,
      "end": 620.17,
      "text": "이 초과장된 유머"
    },
    {
      "start": 620.17,
      "end": 620.85,
      "text": "Yeah"
    },
    {
      "start": 620.85,
      "end": 621.61,
      "text": "It's hilarious"
    },
    {
      "start": 621.61,
      "end": 622.23,
      "text": "Yeah"
    },
    {
      "start": 622.23,
      "end": 623.98,
      "text": "No"
    },
    {
      "start": 623.98,
      "end": 625.88,
      "text": "I don't really want to"
    },
    {
      "start": 625.88,
      "end": 626.14,
      "text": "네"
    },
    {
      "start": 626.14,
      "end": 627.32,
      "text": "한 번 더 거절을 하네요"
    },
    {
      "start": 627.32,
      "end": 627.68,
      "text": "No"
    },
    {
      "start": 627.68,
      "end": 629.14,
      "text": "I don't really want to"
    },
    {
      "start": 629.14,
      "end": 629.78,
      "text": "아니요"
    },
    {
      "start": 629.78,
      "end": 631.14,
      "text": "저 그러고 싶지 않아요"
    },
    {
      "start": 631.14,
      "end": 632.24,
      "text": "Oh"
    },
    {
      "start": 632.24,
      "end": 632.92,
      "text": "Okay"
    },
    {
      "start": 632.92,
      "end": 634.94,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 635.3,
      "end": 637.22,
      "text": "살짝 눈치를 보면서"
    },
    {
      "start": 637.22,
      "end": 638.08,
      "text": "음"
    },
    {
      "start": 638.08,
      "end": 638.28,
      "text": "뭐"
    },
    {
      "start": 638.28,
      "end": 638.88,
      "text": "알겠어요"
    },
    {
      "start": 638.88,
      "end": 640.7,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 640.72,
      "end": 642.1,
      "text": "That's why you go to a funeral"
    },
    {
      "start": 642.1,
      "end": 642.52,
      "text": "Yeah"
    },
    {
      "start": 642.52,
      "end": 643.74,
      "text": "To pay your respects"
    },
    {
      "start": 643.74,
      "end": 645.24,
      "text": "Not to get free food"
    },
    {
      "start": 645.24,
      "end": 645.62,
      "text": "그렇죠"
    },
    {
      "start": 645.62,
      "end": 647.38,
      "text": "이게 주 목적이어야 하는데"
    },
    {
      "start": 647.38,
      "end": 649.4,
      "text": "주객 전도가 된 상황입니다"
    },
    {
      "start": 649.4,
      "end": 650.56,
      "text": "이제야말로"
    },
    {
      "start": 650.56,
      "end": 652.36,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 652.54,
      "end": 653.44,
      "text": "이렇게 이야기를 한 거죠"
    },
    {
      "start": 653.44,
      "end": 655.64,
      "text": "조이를 그럼 표하러 가볼까요?"
    },
    {
      "start": 656.38,
      "end": 656.7,
      "text": "Okay"
    },
    {
      "start": 656.7,
      "end": 657.8,
      "text": "I'm out of here"
    },
    {
      "start": 657.8,
      "end": 661.26,
      "text": "이거는 동의하는 장면이 아니었죠"
    },
    {
      "start": 661.26,
      "end": 663.26,
      "text": "I'm out of here"
    },
    {
      "start": 663.26,
      "end": 664.34,
      "text": "저 먼저 갈게요"
    },
    {
      "start": 664.34,
      "end": 665.1,
      "text": "She runs away"
    },
    {
      "start": 665.1,
      "end": 665.46,
      "text": "Yeah"
    },
    {
      "start": 665.46,
      "end": 667.86,
      "text": "그래서 이 장소를 떠나는"
    },
    {
      "start": 667.86,
      "end": 669.76,
      "text": "마르타의 모습을 보셨습니다"
    },
    {
      "start": 669.76,
      "end": 671.8,
      "text": "그럼 한 번 더 확인해 보시죠"
    },
    {
      "start": 671.8,
      "end": 674.28,
      "text": "The real perk about this place"
    },
    {
      "start": 674.28,
      "end": 677.2,
      "text": "Is that people are constantly dying"
    },
    {
      "start": 677.2,
      "end": 679.98,
      "text": "They list all the funeral's and the papers"
    },
    {
      "start": 679.98,
      "end": 682.62,
      "text": "And there's always tons of free food"
    },
    {
      "start": 682.62,
      "end": 686.25,
      "text": "Put this in your purse"
    },
    {
      "start": 686.25,
      "end": 686.91,
      "text": "No, no, no, no"
    },
    {
      "start": 686.91,
      "end": 689.29,
      "text": "Put it in your own purse, okay?"
    },
    {
      "start": 689.35,
      "end": 689.59,
      "text": "Thanks"
    },
    {
      "start": 689.59,
      "end": 690.67,
      "text": "The line's already full"
    },
    {
      "start": 690.67,
      "end": 691.41,
      "text": "Just shove it in"
    },
    {
      "start": 691.41,
      "end": 692.49,
      "text": "No, I don't really want to"
    },
    {
      "start": 692.49,
      "end": 695.77,
      "text": "Shall we go pay our respects?"
    },
    {
      "start": 697.69,
      "end": 698.01,
      "text": "Okay"
    },
    {
      "start": 698.01,
      "end": 699.9,
      "text": "I'm out of here"
    },
    {
      "start": 699.9,
      "end": 701.98,
      "text": "네, Cheryl 덕분에"
    },
    {
      "start": 701.98,
      "end": 703.24,
      "text": "지금 마르사도 그렇고"
    },
    {
      "start": 703.24,
      "end": 704.14,
      "text": "저도 그렇고"
    },
    {
      "start": 704.14,
      "end": 706.32,
      "text": "심지어 우리 크쌤도 그렇고"
    },
    {
      "start": 706.32,
      "end": 708.64,
      "text": "We feel culture shock"
    },
    {
      "start": 708.64,
      "end": 709.4,
      "text": "Yeah"
    },
    {
      "start": 709.4,
      "end": 711.9,
      "text": "네, 굉장히 쇼킹한 내용이었습니다"
    },
    {
      "start": 712.56,
      "end": 714.68,
      "text": "It's 분명히 my culture인데"
    },
    {
      "start": 714.68,
      "end": 715.96,
      "text": "Culture shock"
    },
    {
      "start": 715.96,
      "end": 716.7,
      "text": "Wow"
    },
    {
      "start": 716.7,
      "end": 718.96,
      "text": "메시지 소개해 드릴게요"
    },
    {
      "start": 718.96,
      "end": 720.28,
      "text": "권영미님께서"
    },
    {
      "start": 720.28,
      "end": 722.78,
      "text": "굿모닝 팝스가 점점 재미있어지네요"
    },
    {
      "start": 722.78,
      "end": 724.36,
      "text": "로라쌤, 크리스쌤 감사합니다"
    },
    {
      "start": 724.36,
      "end": 725.4,
      "text": "하트 3개"
    },
    {
      "start": 725.4,
      "end": 726.4,
      "text": "Thank you"
    },
    {
      "start": 726.4,
      "end": 728.4,
      "text": "그럼 전으로 갈까요, 전?"
    },
    {
      "start": 728.52,
      "end": 729.02,
      "text": "아, 좋아요"
    },
    {
      "start": 729.02,
      "end": 731.24,
      "text": "갑자기 전이 먹고 싶어집니다"
    },
    {
      "start": 731.24,
      "end": 731.88,
      "text": "아, 그럼요"
    },
    {
      "start": 731.88,
      "end": 732.72,
      "text": "땡기죠"
    },
    {
      "start": 732.72,
      "end": 734.42,
      "text": "네, 그럼 우리 내일 만나요"
    },
    {
      "start": 734.42,
      "end": 735.12,
      "text": "See you tomorrow"
    },
    {
      "start": 735.12,
      "end": 735.8,
      "text": "Bye"
    }
  ]
}