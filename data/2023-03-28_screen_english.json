    },
    {
      "start": 271.55,
      "end": 272.85,
      "text": "라는 표현입니다"
    },
    {
      "start": 272.85,
      "end": 274.81,
      "text": "There's more than this"
    },
    {
      "start": 274.81,
      "end": 276.31,
      "text": "There's more than this"
    },
    {
      "start": 276.31,
      "end": 277.03,
      "text": "이것"
    },
    {
      "start": 277.03,
      "end": 278.31,
      "text": "혹은 여기보다"
    },
    {
      "start": 278.31,
      "end": 280.03,
      "text": "더 많은 게 있어"
    },
    {
      "start": 280.03,
      "end": 280.77,
      "text": "라는 뜻이죠"
    },
    {
      "start": 280.77,
      "end": 282.03,
      "text": "There's more than this"
    },
    {
      "start": 282.03,
      "end": 282.85,
      "text": "to life"
    },
    {
      "start": 282.85,
      "end": 284.09,
      "text": "많이 들어봤네요"
    },
    {
      "start": 284.09,
      "end": 284.51,
      "text": "맞아요"
    },
    {
      "start": 284.51,
      "end": 285.33,
      "text": "There's more than this"
    },
    {
      "start": 285.33,
      "end": 285.95,
      "text": "to life"
    },
    {
      "start": 285.95,
      "end": 288.07,
