    {
      "start": 293.43,
      "end": 295.05,
      "text": "이렇게 강조하는 상황인 거죠"
    },
    {
      "start": 295.05,
      "end": 295.93,
      "text": "Go and get it"
    },
    {
      "start": 295.93,
      "end": 297.01,
      "text": "This is the day"
    },
    {
      "start": 297.01,
      "end": 297.59,
      "text": "Yeah"
    },
    {
      "start": 297.59,
      "end": 299.79,
      "text": "Gotta do what you know is right"
    },
    {
      "start": 299.79,
      "end": 300.45,
      "text": "Yeah"
    },
    {
      "start": 300.45,
      "end": 302.83,
      "text": "Gotta do what you know is right"
    },
    {
      "start": 302.83,
      "end": 304.29,
      "text": "이렇게 들어보셨고"
    },
    {
