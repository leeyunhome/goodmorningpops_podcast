  "script": [
    {
      "start": 0.0,
      "end": 1.78,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 1.78,
      "end": 23.02,
      "text": "항상 눈과 귀를 열어놓고 있어야 한다."
    },
    {
      "start": 24.18,
      "end": 28.6,
      "text": "세상과 보조를 맞추지 못하면 시대를 따라잡을 수 없다."
    },
    {
      "start": 30.07,
      "end": 32.89,
      "text": "미국 뮤지션 조어드 벤슨이 한 말입니다."
    },
    {
      "start": 34.58,
      "end": 36.58,
      "text": "하룻밤 사이에 변하는 세상이죠."
    },
    {
      "start": 36.58,
      "end": 42.68,
      "text": "아니, 시시각각 지금 이 순간에도 세상은 무서운 속도로 변하고 있죠."
    },
    {
      "start": 44.0,
      "end": 49.0,
      "text": "눈과 귀를 활짝 열어놓아도 그 속도를 따라잡기가 힘든데"
    },
    {
      "start": 49.0,
      "end": 55.41,
      "text": "하물며 눈과 귀를 닫으면 멀리 혼자 뒤처지게 되겠죠."
    },
    {
      "start": 56.69,
      "end": 59.19,
      "text": "물론 모든 걸 다 따라잡을 순 없고"
    },
    {
      "start": 59.19,
      "end": 62.8,
      "text": "적어도 자신의 영역이나 관심 분야만큼은"
    },
    {
      "start": 62.8,
      "end": 66.86,
      "text": "열린 자세로 새로움을 받아들여야 한다는 겁니다."
    },
    {
      "start": 68.28,
      "end": 70.82,
      "text": "You have to keep your eyes and ears open."
    },
    {
      "start": 71.54,
      "end": 74.52,
      "text": "If you can't keep up, you ain't gonna catch up."
    },
    {
      "start": 75.33,
      "end": 77.35,
      "text": "조정현의 굿모닝 팝스 시작하겠습니다."
    },
    {
      "start": 78.41,
      "end": 79.93,
      "text": "네, 아름다운 멜로디로"
    },
    {
      "start": 79.93,
      "end": 83.37,
      "text": "맨티몰의 Extraordinary 들어보셨습니다."
    },
    {
      "start": 84.55,
      "end": 87.01,
      "text": "오늘 첫 사연으로 윤정원님"
    },
    {
      "start": 87.01,
      "end": 91.69,
      "text": "오늘부터 GMP와 함께하게 된 학생 GMPR입니다."
    },
    {
      "start": 92.53,
      "end": 96.73,
      "text": "학교 가기 전에 GMP와 함께 산뜻한 아침을 시작할 수 있어서"
    },
    {
      "start": 96.73,
      "end": 98.87,
      "text": "영광입니다. 하트 두 개."
    },
    {
      "start": 99.47,
      "end": 102.45,
      "text": "앞으로도 같이 영어신령 업 해봐요."
    },
    {
      "start": 102.83,
      "end": 103.33,
      "text": "하트."
    },
    {
      "start": 103.33,
      "end": 106.01,
      "text": "이거는 뽀뽀 표시인가요?"
    },
    {
      "start": 107.07,
      "end": 107.67,
      "text": "감사합니다."
    },
    {
      "start": 108.87,
      "end": 110.77,
      "text": "우리 윤정원님"
    },
    {
      "start": 110.77,
      "end": 112.29,
      "text": "학생이라고 했는데"
    },
    {
      "start": 112.29,
      "end": 114.65,
      "text": "왠지 배움에 대해서"
    },
    {
      "start": 114.65,
      "end": 117.59,
      "text": "아주 긍정적인 마음으로"
    },
    {
      "start": 117.59,
      "end": 119.77,
      "text": "또 즐거워하는 분인 것 같아요."
    },
    {
      "start": 119.87,
      "end": 122.41,
      "text": "마음이 활짝 열린 분인 것 같습니다."
    },
    {
      "start": 123.49,
      "end": 126.63,
      "text": "앞으로도 굿모닝 팝스 애청자 꼭 되어주시고요."
    },
    {
      "start": 127.41,
      "end": 129.17,
      "text": "윤정원님 덕분에"
    },
    {
      "start": 129.17,
      "end": 130.99,
      "text": "제 기분도 업 됩니다."
    },
    {
      "start": 131.47,
      "end": 132.05,
      "text": "감사해요."
    },
    {
      "start": 133.2,
      "end": 134.12,
      "text": "우광은님"
    },
    {
      "start": 134.12,
      "end": 136.44,
      "text": "2019년 이후로"
    },
    {
      "start": 136.44,
      "end": 138.36,
      "text": "정말 오랜만에 들으러 왔어요."
    },
    {
      "start": 139.02,
      "end": 141.3,
      "text": "한동안은 바쁜 일상을 핑계로"
    },
    {
      "start": 141.3,
      "end": 142.84,
      "text": "영어 공부를 멀리 했었는데"
    },
    {
      "start": 142.84,
      "end": 145.02,
      "text": "같은 사무실 직원분이"
    },
    {
      "start": 145.02,
      "end": 147.32,
      "text": "영어 공부를 너무 열심히 하는 모습에"
    },
    {
      "start": 147.32,
      "end": 149.32,
      "text": "굿모닝 팝스를 다시 듣게 되었어요."
    },
    {
      "start": 150.06,
      "end": 152.24,
      "text": "오늘부터 다시 듣기도 시작하고"
    },
    {
      "start": 152.24,
      "end": 154.1,
      "text": "열심히 공부도 하면서"
    },
    {
      "start": 154.1,
      "end": 156.82,
      "text": "굿모닝 팝스를 늘 가까이에 두려고 합니다."
    },
    {
      "start": 157.44,
      "end": 158.16,
      "text": "응원해 주세요."
    },
    {
      "start": 158.16,
      "end": 160.98,
      "text": "우광은님"
    },
    {
      "start": 160.98,
      "end": 162.34,
      "text": "잘 오셨습니다."
    },
    {
      "start": 163.78,
      "end": 165.24,
      "text": "우리 우광은님께"
    },
    {
      "start": 165.24,
      "end": 166.9,
      "text": "동기부여를 해주신"
    },
    {
      "start": 166.9,
      "end": 167.92,
      "text": "그 직원분도"
    },
    {
      "start": 167.92,
      "end": 170.48,
      "text": "우리 굿모닝 팝스 애청자이시면"
    },
    {
      "start": 170.48,
      "end": 171.7,
      "text": "너무너무 좋겠는데요."
    },
    {
      "start": 173.08,
      "end": 175.0,
      "text": "앞으로 애청하시면서"
    },
    {
      "start": 175.0,
      "end": 177.62,
      "text": "2023년 내내"
    },
    {
      "start": 177.62,
      "end": 179.26,
      "text": "더 뿌듯함으로"
    },
    {
      "start": 179.26,
      "end": 180.56,
      "text": "채워가실 거예요."
    },
    {
      "start": 181.48,
      "end": 183.7,
      "text": "오늘도 기운차게 열공하시면서"
    },
    {
      "start": 183.7,
      "end": 185.46,
      "text": "또 열일까지 하시길"
    },
    {
      "start": 185.46,
      "end": 186.18,
      "text": "응원합니다."
    },
    {
      "start": 186.18,
      "end": 188.9,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 188.9,
      "end": 191.64,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 191.64,
      "end": 195.34,
      "text": "GMP열의 에너지를 업 해드릴 이벤트"
    },
    {
      "start": 195.34,
      "end": 197.06,
      "text": "GMP로 영어실력 업"
    },
    {
      "start": 197.06,
      "end": 198.3,
      "text": "에너지도 업"
    },
    {
      "start": 198.3,
      "end": 200.72,
      "text": "맛있는 것이 정말 가득한"
    },
    {
      "start": 200.72,
      "end": 203.42,
      "text": "편의점에서 유용하게 사용하실 수 있는"
    },
    {
      "start": 203.42,
      "end": 205.62,
      "text": "편의점 모바일 쿠폰 준비해놨어요."
    },
    {
      "start": 206.3,
      "end": 208.24,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 208.24,
      "end": 211.18,
      "text": "행운의 주인공 총 5분 뽑아서 보내드릴게요."
    },
    {
      "start": 211.18,
      "end": 215.76,
      "text": "다문 50원과 장문 100원에 추가 요금이 부과되는 문자 샵 8910"
    },
    {
      "start": 215.76,
      "end": 218.58,
      "text": "아니면 샵 1061로 신청하시거나"
    },
    {
      "start": 218.58,
      "end": 221.34,
      "text": "무료인 콩 또는 마이케이로 참여해주세요."
    },
    {
      "start": 221.34,
      "end": 229.97,
      "text": "1일 아침 6시"
    },
    {
      "start": 229.97,
      "end": 233.05,
      "text": "조정현의 굿모닝"
    },
    {
      "start": 236.13,
      "end": 238.19,
      "text": "해봐요 굿모닝"
    },
    {
      "start": 238.19,
      "end": 241.76,
      "text": "조정현의 굿모닝"
    },
    {
      "start": 241.76,
      "end": 247.44,
      "text": "조정현의 굿모닝 팝"
    },
    {
      "start": 247.44,
      "end": 281.79,
      "text": "English와 영어 공부를 동시에"
    },
    {
      "start": 281.79,
      "end": 283.35,
      "text": "Screen English Time"
    },
    {
      "start": 283.35,
      "end": 285.25,
      "text": "3월에 함께하고 있는 영화는"
    },
    {
      "start": 285.25,
      "end": 287.39,
      "text": "호주의 대자연 속에서"
    },
    {
      "start": 287.39,
      "end": 289.97,
      "text": "펠리칸과 특별한 우정을 나누는"
    },
    {
      "start": 289.97,
      "end": 291.47,
      "text": "한 소년에 관한 이야기"
    },
    {
      "start": 291.47,
      "end": 292.45,
      "text": "Storm Boy"
    },
    {
      "start": 292.45,
      "end": 293.53,
      "text": "어서 오세요"
    },
    {
      "start": 293.53,
      "end": 294.37,
      "text": "Hello"
    },
    {
      "start": 294.37,
      "end": 296.15,
      "text": "네 굿모닝입니다"
    },
    {
      "start": 296.15,
      "end": 297.51,
      "text": "굿모닝입니다"
    },
    {
      "start": 297.51,
      "end": 301.01,
      "text": "아주 브라이트하게 인사를 나눠봤고요"
    },
    {
      "start": 301.01,
      "end": 303.79,
      "text": "어제도 이야기를 했던 것처럼"
    },
    {
      "start": 303.79,
      "end": 307.07,
      "text": "처음에는 이 Colin Teal이라는 작가의"
    },
    {
      "start": 307.07,
      "end": 309.99,
      "text": "1964년 작품이었잖아요"
    },
    {
      "start": 309.99,
      "end": 311.37,
      "text": "그에 이어서"
    },
    {
      "start": 311.37,
      "end": 314.39,
      "text": "There was a movie based on that novel"
    },
    {
      "start": 314.39,
      "end": 320.37,
      "text": "그 영화가 1976년에 먼저 만들어진 게 있었어요"
    },
    {
      "start": 320.37,
      "end": 321.47,
      "text": "Not too long ago"
    },
    {
      "start": 321.47,
      "end": 323.07,
      "text": "Back in 1976"
    },
    {
      "start": 323.07,
      "end": 326.25,
      "text": "From a long-time TV director"
    },
    {
      "start": 326.25,
      "end": 326.85,
      "text": "Yeah"
    },
    {
      "start": 326.85,
      "end": 328.11,
      "text": "It was his first movie"
    },
    {
      "start": 328.11,
      "end": 328.63,
      "text": "Yeah"
    },
    {
      "start": 328.63,
      "end": 329.75,
      "text": "근데 그때에도"
    },
    {
      "start": 329.75,
      "end": 331.13,
      "text": "It was a success, wasn't it?"
    },
    {
      "start": 331.57,
      "end": 333.53,
      "text": "It was a success at the time"
    },
    {
      "start": 333.53,
      "end": 334.29,
      "text": "Yeah"
    },
    {
      "start": 334.29,
      "end": 336.13,
      "text": "So this TV director made his"
    },
    {
      "start": 336.13,
      "end": 337.51,
      "text": "first feature film"
    },
    {
      "start": 337.51,
      "end": 338.59,
      "text": "Storm Boy"
    },
    {
      "start": 338.59,
      "end": 339.69,
      "text": "1976"
    },
    {
      "start": 339.69,
      "end": 342.83,
      "text": "And it went on to become a classic"
    },
    {
      "start": 342.83,
      "end": 345.51,
      "text": "It also won four awards"
    },
    {
      "start": 345.51,
      "end": 347.15,
      "text": "Including best film"
    },
    {
      "start": 347.15,
      "end": 347.67,
      "text": "Wow"
    },
    {
      "start": 347.67,
      "end": 350.35,
      "text": "At Australia's Academy Awards"
    },
    {
      "start": 350.35,
      "end": 351.95,
      "text": "The AACIA"
    },
    {
      "start": 351.95,
      "end": 352.71,
      "text": "Yeah"
    },
    {
      "start": 352.71,
      "end": 355.47,
      "text": "And it was nominated for six more awards"
    },
    {
      "start": 355.47,
      "end": 356.27,
      "text": "Wow"
    },
    {
      "start": 356.27,
      "end": 356.31,
      "text": "Wow"
    },
    {
      "start": 356.31,
      "end": 357.87,
      "text": "그 당시에도"
    },
    {
      "start": 357.87,
      "end": 359.85,
      "text": "영화로 상영하자마자"
    },
    {
      "start": 359.85,
      "end": 363.35,
      "text": "아주 흥행을 했었다라는 이야기를 들어봤습니다"
    },
    {
      "start": 363.35,
      "end": 364.17,
      "text": "Yeah"
    },
    {
      "start": 364.17,
      "end": 364.87,
      "text": "Money-wise"
    },
    {
      "start": 364.87,
      "end": 367.41,
      "text": "It made about 2.645 million"
    },
    {
      "start": 367.41,
      "end": 368.13,
      "text": "Wow"
    },
    {
      "start": 368.13,
      "end": 369.99,
      "text": "2 million 645,000 dollars"
    },
    {
      "start": 369.99,
      "end": 372.51,
      "text": "It's actually not that much"
    },
    {
      "start": 372.51,
      "end": 372.95,
      "text": "아"
    },
    {
      "start": 372.95,
      "end": 374.07,
      "text": "그래도 그 당시니까"
    },
    {
      "start": 374.07,
      "end": 374.65,
      "text": "Yeah"
    },
    {
      "start": 374.65,
      "end": 376.75,
      "text": "Today's money about 17 million"
    },
    {
      "start": 376.75,
      "end": 377.29,
      "text": "Oh"
    },
    {
      "start": 377.29,
      "end": 378.05,
      "text": "그러면"
    },
    {
      "start": 378.05,
      "end": 379.65,
      "text": "It's not that much?"
    },
    {
      "start": 379.83,
      "end": 380.39,
      "text": "Well, I don't know"
    },
    {
      "start": 380.39,
      "end": 382.03,
      "text": "I'm from California"
    },
    {
      "start": 382.03,
      "end": 383.15,
      "text": "So I think"
    },
    {
      "start": 383.15,
      "end": 384.63,
      "text": "I compare it to Hollywood"
    },
    {
      "start": 384.63,
      "end": 385.29,
      "text": "Ah"
    },
    {
      "start": 385.29,
      "end": 386.27,
      "text": "So I'm not sure"
    },
    {
      "start": 386.27,
      "end": 388.13,
      "text": "About the Australian box office"
    },
    {
      "start": 388.13,
      "end": 388.43,
      "text": "Ah"
    },
    {
      "start": 388.43,
      "end": 389.61,
      "text": "But apparently"
    },
    {
      "start": 389.61,
      "end": 391.09,
      "text": "It was a hit back then"
    },
    {
      "start": 391.09,
      "end": 391.41,
      "text": "Oh"
    },
    {
      "start": 391.41,
      "end": 392.83,
      "text": "And the important thing is"
    },
    {
      "start": 392.83,
      "end": 394.47,
      "text": "It's a timeless classic"
    },
    {
      "start": 394.47,
      "end": 395.05,
      "text": "맞아요"
    },
    {
      "start": 395.05,
      "end": 397.07,
      "text": "We're still talking about it today"
    },
    {
      "start": 397.07,
      "end": 397.55,
      "text": "Exactly"
    },
    {
      "start": 397.55,
      "end": 398.77,
      "text": "And it"
    },
    {
      "start": 398.77,
      "end": 399.19,
      "text": "You know"
    },
    {
      "start": 399.19,
      "end": 400.17,
      "text": "It transcends time"
    },
    {
