    {
      "start": 505.77,
      "end": 506.35,
      "text": "맞아요"
    },
    {
      "start": 506.35,
      "end": 508.39,
      "text": "And this director thought the same thing"
    },
    {
      "start": 508.39,
      "end": 509.79,
