    {
      "start": 692.31,
      "end": 694.15,
      "text": "Oh, it's our pleasure"
    },
    {
      "start": 694.15,
      "end": 694.61,
      "text": "네"
    },
    {
      "start": 694.61,
      "end": 696.95,
      "text": "Thanks so much for the positive feedback"
    },
    {
      "start": 696.95,
      "end": 697.27,
      "text": "네"
    },
    {
      "start": 697.27,
      "end": 699.63,
      "text": "Have a lovely day 하시고요"
    },
    {
      "start": 699.63,
      "end": 700.71,
      "text": "우리는 see you tomorrow"
    },
    {
      "start": 700.71,
      "end": 702.33,
      "text": "I'll see you then, have a great day"
