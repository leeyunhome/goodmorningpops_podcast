    {
      "start": 491.31,
      "end": 492.83,
      "text": "they're all riled up"
    },
    {
      "start": 492.83,
      "end": 493.99,
      "text": "They're not upset"
    },
    {
      "start": 493.99,
      "end": 494.87,
