    },
    {
      "start": 549.09,
      "end": 550.37,
      "text": "He's famous"
    },
    {
      "start": 550.37,
      "end": 551.75,
      "text": "and he has a happy"
    },
    {
      "start": 551.75,
      "end": 553.29,
      "text": "carefree life"
    },
    {
      "start": 553.29,
      "end": 553.61,
      "text": "맞아요"
    },
    {
      "start": 553.61,
      "end": 555.17,
      "text": "니나의 입장에서"
    },
    {
      "start": 555.17,
      "end": 555.71,
      "text": "본다면"
    },
    {
      "start": 555.71,
      "end": 557.07,
      "text": "가진자"
    },
    {
      "start": 557.07,
      "end": 559.73,
      "text": "가진자의 삶을"
