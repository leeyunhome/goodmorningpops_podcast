    {
      "start": 513.09,
      "end": 513.85,
      "text": "Day and night"
    },
    {
      "start": 513.85,
      "end": 515.61,
      "text": "I am haunted"
    },
    {
      "start": 515.61,
      "end": 517.25,
      "text": "by a single"
    },
    {
      "start": 517.25,
      "end": 518.93,
      "text": "obsessive thought"
    },
    {
      "start": 518.93,
      "end": 520.43,
      "text": "I must write"
    },
    {
      "start": 520.43,
      "end": 521.25,
      "text": "I must write"
    },
    {
      "start": 521.25,
      "end": 522.15,
      "text": "I must write"
    },
    {
      "start": 522.15,
      "end": 524.55,
      "text": "No sooner do I finish one story"
    },
    {
      "start": 524.55,
      "end": 526.55,
      "text": "then for God knows what reason"
    },
    {
      "start": 526.55,
      "end": 527.41,
      "text": "I have to write another"
