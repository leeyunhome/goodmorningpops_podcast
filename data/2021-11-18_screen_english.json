    },
    {
      "start": 416.81,
      "end": 417.17,
      "text": "Yeah"
    },
    {
      "start": 417.17,
      "end": 418.39,
      "text": "뭔가에"
    },
    {
      "start": 418.39,
      "end": 419.39,
      "text": "사로잡힌"
    },
    {
      "start": 419.39,
      "end": 420.39,
      "text": "시달리는"
    },
    {
      "start": 420.39,
      "end": 421.69,
      "text": "이라는 의미입니다"
    },
    {
      "start": 421.69,
      "end": 423.87,
      "text": "Ah, you could be haunted by your work"
    },
    {
      "start": 423.87,
      "end": 425.29,
      "text": "In his case"
    },
    {
      "start": 425.29,
      "end": 426.35,
      "text": "he's haunted by his work"
    },
    {
      "start": 426.35,
      "end": 426.69,
      "text": "Yeah"
    },
    {
      "start": 426.69,
      "end": 429.03,
      "text": "Obsessive thought"
    },
    {
      "start": 429.03,
      "end": 429.33,
      "text": "네"
    },
    {
      "start": 429.33,
      "end": 431.27,
      "text": "Obsessive thought"
    },
    {
      "start": 431.27,
      "end": 431.97,
      "text": "라고 해서"
    },
    {
      "start": 431.97,
      "end": 433.55,
