    {
      "start": 508.31,
      "end": 508.91,
      "text": "Relax"
    },
    {
      "start": 508.91,
      "end": 509.27,
      "text": "Yeah"
    },
    {
      "start": 509.27,
      "end": 510.47,
      "text": "자 이 장면"
    },
    {
      "start": 510.47,
      "end": 511.41,
      "text": "다시 한번 들어볼게요"
    },
    {
      "start": 511.41,
      "end": 512.85,
      "text": "How do I begin?"
