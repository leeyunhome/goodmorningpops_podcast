    },
    {
      "start": 541.51,
      "end": 542.45,
      "text": "Yeah"
    },
    {
      "start": 542.45,
      "end": 544.15,
      "text": "The life that we didn't know"
    },
    {
      "start": 544.15,
      "end": 544.89,
      "text": "She"
    },
    {
      "start": 544.89,
      "end": 545.99,
      "text": "this lady"
    },
    {
      "start": 545.99,
      "end": 546.55,
      "text": "this girl"
    },
    {
      "start": 546.55,
      "end": 547.71,
      "text": "She thought"
    },
    {
      "start": 547.71,
      "end": 548.21,
      "text": "his life"
    },
    {
      "start": 548.21,
      "end": 549.09,
