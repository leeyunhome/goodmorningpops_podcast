    {
      "start": 559.73,
      "end": 560.53,
      "text": "지금"
    },
    {
      "start": 560.53,
      "end": 562.09,
      "text": "솔직한 내면을"
    },
    {
      "start": 562.09,
      "end": 562.81,
      "text": "들여다볼 수"
    },
    {
      "start": 562.81,
      "end": 564.01,
      "text": "있었던 장면입니다"
    },
    {
      "start": 564.01,
      "end": 564.33,
      "text": "Yeah"
    },
    {
      "start": 564.33,
      "end": 564.99,
      "text": "the real story"
    },
    {
      "start": 564.99,
      "end": 565.65,
      "text": "is a little different"
    },
    {
      "start": 565.65,
      "end": 566.59,
      "text": "than what she thought"
    },
    {
      "start": 566.59,
      "end": 567.07,
      "text": "그렇죠"
    },
    {
      "start": 567.07,
      "end": 568.65,
      "text": "자 보리스의 이야기"
    },
    {
      "start": 568.65,
      "end": 569.95,
      "text": "들어볼까요?"
    },
    {
      "start": 570.03,
      "end": 571.07,
      "text": "How do I begin?"
    },
    {
      "start": 571.41,
      "end": 572.47,
      "text": "How do I begin?"
    },
    {
      "start": 572.79,
      "end": 573.75,
      "text": "내가 무슨 말부터"
    },
    {
      "start": 573.75,
      "end": 574.53,
      "text": "할까요?"
    },
    {
      "start": 575.13,
      "end": 576.21,
      "text": "Day and night"
    },
    {
      "start": 576.21,
      "end": 577.35,
      "text": "I am haunted"
    },
    {
      "start": 577.35,
      "end": 578.11,
      "text": "by a single"
    },
    {
      "start": 578.11,
      "end": 579.57,
      "text": "obsessive thought"
    },
    {
      "start": 579.57,
      "end": 580.91,
      "text": "Day and night"
    },
    {
      "start": 580.91,
      "end": 581.99,
      "text": "밤낮으로"
    },
    {
      "start": 581.99,
      "end": 583.41,
      "text": "I am haunted"
    },
    {
      "start": 583.41,
      "end": 584.39,
      "text": "by a single"
    },
    {
      "start": 584.39,
      "end": 586.05,
      "text": "obsessive thought"
    },
    {
      "start": 586.05,
      "end": 587.35,
      "text": "잘 들리셨죠?"
    },
