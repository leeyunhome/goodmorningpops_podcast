      "start": 527.41,
      "end": 528.57,
      "text": "and another"
    },
    {
      "start": 528.57,
      "end": 529.25,
      "text": "and another"
    },
    {
      "start": 529.25,
      "end": 530.91,
      "text": "What's so beautiful"
    },
    {
      "start": 530.91,
      "end": 531.79,
      "text": "and brilliant about that?"
    },
    {
      "start": 531.89,
      "end": 532.95,
      "text": "It's a ridiculous life"
    },
    {
      "start": 532.95,
      "end": 534.3,
      "text": "Here I am"
    },
    {
      "start": 534.3,
      "end": 535.64,
      "text": "I'm talking to you"
    },
    {
      "start": 535.64,
      "end": 537.42,
      "text": "I'm getting all riled up"
    },
    {
      "start": 537.42,
      "end": 539.75,
      "text": "So we were able"
