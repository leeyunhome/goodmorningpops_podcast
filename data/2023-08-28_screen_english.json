    {
      "start": 627.51,
      "end": 628.65,
      "text": "forget everything"
    },
    {
      "start": 628.65,
      "end": 630.61,
      "text": "and then I'm happy"
    },
    {
      "start": 630.61,
      "end": 631.11,
      "text": "every day"
    },
    {
      "start": 631.11,
      "end": 634.23,
      "text": "매일매일 새롭게 탄생을 하고 계시는군요"
    },
    {
      "start": 634.23,
      "end": 636.87,
      "text": "아주 긍정적인 태도입니다"
    },
    {
      "start": 636.87,
      "end": 638.11,
      "text": "뭐 안 좋을 수 있죠"
    },
    {
      "start": 638.11,
      "end": 638.37,
      "text": "네?"
    },
    {
      "start": 639.21,
      "end": 640.17,
      "text": "와이프한테 물어봐요"
    },
    {
      "start": 640.17,
      "end": 641.01,
      "text": "아, 맞네"
