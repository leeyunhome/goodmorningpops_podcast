    {
      "start": 608.0,
      "end": 608.4,
      "text": "Together."
    },
    {
      "start": 608.66,
      "end": 610.66,
      "text": "아, 내일도 벌써부터 기대됩니다."
    },
    {
      "start": 611.06,
      "end": 611.88,
      "text": "See you tomorrow!"
