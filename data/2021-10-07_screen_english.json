    {
      "start": 616.84,
      "end": 618.18,
      "text": "I got it right away"
    },
    {
      "start": 618.18,
      "end": 618.8,
      "text": "이런 표현도"
    },
    {
      "start": 618.8,
      "end": 619.52,
      "text": "You got it?"
    },
    {
      "start": 619.64,
