    {
      "start": 724.23,
      "end": 725.27,
      "text": "만화책을 봐도"
    },
    {
      "start": 725.27,
      "end": 725.97,
      "text": "도움이 될까요?"
    },
    {
      "start": 726.27,
      "end": 727.47,
      "text": "도움이 많이 되죠"
    },
    {
      "start": 727.47,
      "end": 729.35,
      "text": "근데 조금 가려서"
    },
    {
      "start": 729.35,
      "end": 730.55,
      "text": "볼 필요가 있죠"
    },
    {
      "start": 730.55,
      "end": 731.33,
      "text": "아, 꿀팁"
    },
    {
      "start": 731.33,
      "end": 731.97,
      "text": "막 보면 안 되고"
    },
    {
      "start": 731.97,
      "end": 732.93,
      "text": "아, 그렇군요"
    },
    {
      "start": 732.93,
      "end": 734.17,
      "text": "무엇보다도"
    },
    {
      "start": 734.17,
      "end": 735.79,
