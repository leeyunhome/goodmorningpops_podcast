    {
      "start": 698.71,
      "end": 700.15,
      "text": "Thank you for a nice message"
    },
    {
      "start": 700.15,
      "end": 700.65,
      "text": "Mr. Park"
    },
    {
      "start": 700.65,
      "end": 702.25,
      "text": "저 이 프로그램 못 봤어요"
    },
    {
      "start": 702.25,
      "end": 703.15,
      "text": "너무 아쉬워요"
    },
    {
      "start": 703.15,
      "end": 704.35,
      "text": "I learned a lot about"
