    {
      "start": 565.29,
      "end": 565.63,
      "text": "Yeah"
    },
    {
      "start": 565.63,
      "end": 566.67,
      "text": "So she has three kids"
    },
    {
      "start": 566.67,
      "end": 567.31,
      "text": "Yeah, totally"
    },
    {
      "start": 567.31,
      "end": 568.05,
      "text": "Two boys and a girl"
