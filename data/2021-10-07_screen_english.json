    },
    {
      "start": 844.13,
      "end": 845.79,
      "text": "한국말 배우기도 좋고"
    },
    {
      "start": 845.79,
      "end": 847.05,
      "text": "사자성어 배우기도 좋아요"
    },
    {
      "start": 847.05,
      "end": 848.87,
      "text": "삼국지 만화책"
    },
    {
      "start": 848.87,
      "end": 850.93,
      "text": "네, 그러면 우리 영어를 배울 때도"
    },
    {
      "start": 850.93,
      "end": 851.97,
      "text": "만화책을 봐도"
    },
    {
      "start": 851.97,
      "end": 852.67,
      "text": "도움이 될까요?"
    },
    {
      "start": 852.97,
      "end": 854.17,
      "text": "도움이 많이 되죠"
    },
    {
      "start": 854.17,
      "end": 856.05,
      "text": "근데 조금 가려서"
    },
    {
      "start": 856.05,
      "end": 857.25,
      "text": "볼 필요가 있죠"
    },
    {
      "start": 857.25,
      "end": 858.03,
      "text": "아, 꿀팁"
    },
    {
      "start": 858.03,
      "end": 858.67,
      "text": "막 보면 안 되고"
    },
    {
      "start": 858.67,
      "end": 859.63,
      "text": "아, 그렇군요"
    },
    {
      "start": 859.63,
      "end": 860.87,
      "text": "무엇보다도"
    },
    {
      "start": 860.87,
      "end": 862.49,
      "text": "검증된 GMP"
    },
    {
      "start": 862.49,
      "end": 864.29,
      "text": "Yeah"
    },
    {
      "start": 864.29,
      "end": 866.43,
      "text": "Everything goes to GMP"
    },
    {
      "start": 866.43,
      "end": 867.47,
      "text": "기승전 GMP"
    },
    {
      "start": 867.47,
      "end": 868.05,
      "text": "그럼요"
    },
    {
      "start": 868.05,
      "end": 868.81,
      "text": "와우"
    },
    {
      "start": 868.81,
      "end": 869.17,
      "text": "아무튼"
    },
    {
      "start": 869.17,
      "end": 870.25,
      "text": "이 적벽 대전도"
    },
    {
      "start": 870.25,
      "end": 870.93,
      "text": "맞추셨다니"
    },
    {
      "start": 870.93,
      "end": 872.05,
      "text": "정말 박수"
    },
    {
      "start": 872.05,
      "end": 873.11,
      "text": "와우"
    },
    {
      "start": 873.11,
      "end": 873.91,
      "text": "멋지십니다"
    },
    {
      "start": 873.91,
      "end": 874.73,
      "text": "재밌었어요"
    },
    {
      "start": 874.73,
      "end": 876.39,
      "text": "Thank you for the message"
    },
    {
      "start": 876.39,
      "end": 878.73,
      "text": "네, 메시지 너무너무 감사하고요"
    },
    {
      "start": 878.73,
      "end": 880.09,
      "text": "오늘 스크린 잉글리쉬는"
    },
    {
      "start": 880.09,
      "end": 881.59,
      "text": "여기에서 마무리할게요"
    },
    {
      "start": 881.59,
      "end": 883.17,
      "text": "어머, 우리는 크리스 씨"
    },
    {
      "start": 883.17,
      "end": 884.95,
      "text": "다음 주에 만나도록 하겠습니다"
    }
  ]
