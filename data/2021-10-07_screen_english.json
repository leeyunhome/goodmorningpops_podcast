    {
      "start": 656.87,
      "end": 658.57,
      "text": "Yeah, I get it"
    },
    {
      "start": 658.57,
      "end": 659.01,
      "text": "It's a lot"
    },
    {
      "start": 659.01,
      "end": 660.85,
      "text": "It's really a lot to manage both"
    },
    {
      "start": 660.85,
      "end": 661.91,
      "text": "I just always wanted both"
    },
    {
      "start": 661.91,
      "end": 662.91,
      "text": "So I sort of worked hard"
    },
    {
      "start": 662.91,
      "end": 665.25,
      "text": "I have twin boys too"
    },
    {
      "start": 665.25,
      "end": 666.95,
      "text": "I worked hard to get them"
    },
    {
      "start": 666.95,
      "end": 667.67,
      "text": "Believe me"
    },
    {
      "start": 667.67,
      "end": 670.43,
      "text": "So we do have a list of priorities"
    },
    {
      "start": 670.43,
      "end": 672.33,
      "text": "If you're interested in seeing that"
    },
    {
      "start": 672.33,
      "end": 675.13,
      "text": "박정욱님께서"
    },
    {
      "start": 675.13,
      "end": 676.37,
      "text": "메시지 보내주신 거"
    },
    {
      "start": 676.37,
      "end": 677.11,
      "text": "소개해 드릴게요"
