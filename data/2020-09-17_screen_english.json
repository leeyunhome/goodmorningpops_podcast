      "start": 244.81,
      "end": 245.55,
      "text": "Yes"
    },
    {
      "start": 245.55,
      "end": 245.99,
      "text": "딱"
    },
    {
      "start": 245.99,
      "end": 246.73,
      "text": "AVA"
    },
    {
      "start": 246.73,
      "end": 247.75,
      "text": "이 경험과"
