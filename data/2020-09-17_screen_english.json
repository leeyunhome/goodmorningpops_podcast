      "start": 213.97,
      "end": 215.27,
      "text": "briefly in a"
    },
    {
      "start": 215.27,
      "end": 216.15,
      "text": "professional kitchen"
    },
    {
      "start": 216.15,
      "end": 217.41,
      "text": "and"
    },
    {
      "start": 217.41,
      "end": 218.81,
      "text": "I was not"
    },
    {
      "start": 218.81,
      "end": 219.91,
      "text": "in a very good mood"
    },
    {
      "start": 219.91,
      "end": 220.45,
      "text": "every day"
    },
    {
      "start": 220.45,
      "end": 222.09,
      "text": "especially because"
    },
    {
      "start": 222.09,
      "end": 222.81,
      "text": "I was new"
    },
    {
      "start": 222.81,
      "end": 224.25,
      "text": "and I was terrible"
    },
    {
      "start": 224.25,
      "end": 225.39,
      "text": "So stressful"
    },
    {
      "start": 225.39,
      "end": 226.53,
      "text": "with the knife"
