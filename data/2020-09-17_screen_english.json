    {
      "start": 154.79,
      "end": 156.93,
      "text": "multicultural 했던 거예요"
    },
    {
      "start": 156.93,
      "end": 158.63,
      "text": "그래서 영화에도"
    },
    {
      "start": 158.63,
      "end": 159.71,
      "text": "더 자연스럽게"
    },
    {
      "start": 159.71,
      "end": 161.11,
      "text": "잘 녹아내려 있지 않나"
