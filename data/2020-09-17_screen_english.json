    },
    {
      "start": 240.91,
      "end": 241.91,
      "text": "Wow"
    },
    {
      "start": 241.91,
      "end": 243.43,
      "text": "그래서 직접"
    },
    {
      "start": 243.43,
      "end": 243.83,
