    {
      "start": 107.05,
      "end": 109.11,
      "text": "were also interested in"
    },
    {
      "start": 109.11,
      "end": 111.37,
      "text": "Cosmopolitanism"
    },
    {
      "start": 111.37,
      "end": 112.43,
      "text": "Good job"
    },
    {
      "start": 112.43,
      "end": 113.73,
      "text": "It's a mouthful"
    },
    {
      "start": 113.73,
      "end": 114.11,
      "text": "Yeah"
    },
    {
      "start": 114.11,
      "end": 115.03,
      "text": "발음 어려운 단어 있죠?"
