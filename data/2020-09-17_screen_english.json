    {
      "start": 138.09,
      "end": 138.83,
      "text": "in the film"
    },
    {
      "start": 138.83,
      "end": 140.59,
      "text": "The film is about diversity"
    },
    {
      "start": 140.59,
      "end": 142.59,
      "text": "and people from different backgrounds"
    },
    {
      "start": 142.59,
      "end": 144.03,
      "text": "trying to get along"
    },
    {
      "start": 144.03,
      "end": 146.31,
      "text": "So the crew itself"
    },
    {
      "start": 146.31,
      "end": 147.53,
      "text": "themselves were from"
    },
    {
      "start": 147.53,
      "end": 148.75,
      "text": "very different backgrounds"
    },
    {
      "start": 148.75,
      "end": 149.85,
      "text": "오 그렇구나"
    },
    {
      "start": 149.85,
      "end": 150.75,
