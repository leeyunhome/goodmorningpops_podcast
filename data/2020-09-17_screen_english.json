    },
    {
      "start": 52.35,
      "end": 53.03,
      "text": "해볼까요?"
    },
    {
      "start": 53.59,
      "end": 54.31,
      "text": "같이 할까요?"
    },
    {
      "start": 54.33,
      "end": 54.49,
      "text": "예"
    },
    {
      "start": 54.49,
      "end": 57.77,
      "text": "Cosmopolitanism"
    },
    {
      "start": 57.77,
      "end": 59.11,
      "text": "좀 다른 것 같은데"
    },
    {
      "start": 59.11,
      "end": 60.69,
      "text": "Cosmopolitanism"
    },
    {
      "start": 60.69,
      "end": 62.61,
      "text": "Cosmopolitanism"
    },
    {
      "start": 62.61,
      "end": 64.21,
      "text": "네"
    },
    {
      "start": 64.21,
      "end": 65.21,
      "text": "무슨 의미일까요?"
    },
    {
      "start": 65.39,
      "end": 66.45,
      "text": "세 번 말해요 나와요"
    },
    {
      "start": 66.45,
      "end": 66.93,
      "text": "맞아요"
    },
    {
      "start": 66.93,
      "end": 68.45,
      "text": "Do you know?"
    },
    {
      "start": 68.57,
      "end": 69.69,
      "text": "Have you heard this word before?"
    },
    {
      "start": 70.01,
      "end": 70.33,
      "text": "어"
    },
    {
      "start": 70.33,
      "end": 70.77,
      "text": "예"
    },
    {
      "start": 70.77,
      "end": 73.19,
      "text": "특히 이게 잡지책이 갑자기 생각이 나는데"
    },
    {
      "start": 73.19,
      "end": 73.67,
      "text": "아"
