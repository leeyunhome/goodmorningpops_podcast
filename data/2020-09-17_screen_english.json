    {
      "start": 470.67,
      "end": 471.25,
      "text": "모르겠네"
    },
    {
      "start": 471.25,
      "end": 472.01,
      "text": "막 팍팍 넣나?"
    },
    {
      "start": 472.63,
      "end": 473.37,
      "text": "빰빰빰"
    },
    {
      "start": 473.37,
      "end": 474.03,
      "text": "그런가봐요"
    },
    {
      "start": 474.03,
      "end": 474.69,
      "text": "화끈하게"
    },
    {
      "start": 474.69,
      "end": 475.93,
      "text": "더 맵게 나올 것 같아"
    },
    {
      "start": 475.93,
      "end": 476.55,
      "text": "그런가봐요"
    },
    {
      "start": 476.55,
      "end": 477.19,
      "text": "엄청 맵게"
    },
    {
      "start": 477.19,
      "end": 478.45,
      "text": "막 청양고추 막 넣고"
    },
    {
      "start": 478.45,
      "end": 479.17,
      "text": "어떻게 알았지?"
    },
    {
      "start": 480.99,
      "end": 482.17,
      "text": "Gets in the food"
    },
    {
      "start": 482.17,
      "end": 485.56,
      "text": "What about how you're always cursing"
    },
    {
      "start": 485.56,
      "end": 487.7,
      "text": "and yelling at mandioca?"
    },
    {
      "start": 487.92,
      "end": 488.58,
      "text": "어머나"
    },
    {
      "start": 488.58,
      "end": 488.98,
      "text": "오"
    },
    {
      "start": 488.98,
      "end": 490.14,
      "text": "걸렸어요"
    },
    {
      "start": 490.14,
      "end": 499.5,
      "text": "당신이 항상 이 mandioca에게"
    },
    {
      "start": 499.5,
      "end": 500.98,
      "text": "어떻게 욕하고"
    },
    {
      "start": 500.98,
      "end": 502.78,
      "text": "또 소리 지르는 건 어떻구요?"
    },
    {
      "start": 503.1,
      "end": 504.06,
      "text": "라는 이야기입니다"
    },
    {
      "start": 504.06,
      "end": 506.84,
      "text": "That's why we have to speak and act better"
    },
    {
      "start": 506.84,
      "end": 508.14,
      "text": "in front of the kids"
    },
    {
      "start": 508.14,
      "end": 508.7,
      "text": "Oh yes"
    },
    {
      "start": 508.7,
      "end": 510.42,
      "text": "But he's the only kid"
    },
    {
      "start": 510.42,
      "end": 511.42,
      "text": "in the kitchen"
    },
    {
      "start": 511.42,
      "end": 511.88,
      "text": "Yeah"
    },
    {
      "start": 511.88,
      "end": 514.32,
      "text": "He was not supposed to be there"
    },
    {
      "start": 514.32,
      "end": 514.8,
      "text": "네"
    },
    {
      "start": 514.8,
      "end": 516.49,
      "text": "Okay"
    },
    {
      "start": 516.49,
      "end": 517.79,
      "text": "Take a break"
    },
    {
      "start": 517.79,
      "end": 519.47,
      "text": "and get a snack for us"
    },
    {
      "start": 519.47,
      "end": 521.03,
      "text": "네 치코의 대답이었죠"
    },
    {
      "start": 521.03,
      "end": 523.15,
      "text": "왠지 급하게 화제 전환을 하는"
    },
    {
      "start": 523.15,
      "end": 524.39,
      "text": "그런 분위기였어요"
    },
    {
      "start": 524.39,
      "end": 525.51,
      "text": "Change the subject"
    },
    {
      "start": 525.51,
      "end": 526.75,
      "text": "그런가봐요"
    },
    {
      "start": 526.75,
      "end": 527.37,
      "text": "Okay"
    },
    {
      "start": 527.37,
      "end": 528.23,
      "text": "그래"
    },
    {
      "start": 528.23,
      "end": 529.25,
      "text": "Take a break"
    },
    {
      "start": 529.25,
      "end": 531.03,
      "text": "and get a snack for us"
    },
    {
      "start": 531.03,
      "end": 531.69,
      "text": "라고 했어요"
    },
    {
      "start": 531.69,
      "end": 533.45,
      "text": "잠시 좀 쉬면서"
    },
    {
      "start": 533.45,
      "end": 535.01,
      "text": "Get a snack for us"
    },
    {
      "start": 535.01,
      "end": 536.29,
      "text": "간식이나 좀 먹자"
    },
    {
      "start": 536.29,
      "end": 537.35,
      "text": "라는 이야기로"
    },
    {
      "start": 537.35,
      "end": 538.19,
      "text": "좀 돌려서"
    },
    {
      "start": 538.19,
      "end": 539.17,
      "text": "이야기를 합니다"
    },
    {
      "start": 539.17,
      "end": 541.11,
      "text": "너무 정곡을 찌르는 이야기"
    },
    {
      "start": 541.11,
      "end": 541.89,
      "text": "그랬나봐요"
    },
    {
      "start": 541.89,
      "end": 543.19,
      "text": "양심이 찔렸나 봅니다"
    },
    {
      "start": 543.19,
      "end": 543.95,
      "text": "Okay"
    },
    {
      "start": 543.95,
      "end": 544.95,
      "text": "Let's just take a break"
    },
    {
      "start": 544.95,
      "end": 546.01,
      "text": "and have a snack"
    },
    {
      "start": 546.01,
      "end": 546.75,
      "text": "Okay"
    },
    {
      "start": 546.75,
      "end": 547.67,
      "text": "Everything's okay"
    },
    {
      "start": 547.67,
      "end": 548.11,
      "text": "Yeah"
    },
    {
      "start": 548.11,
      "end": 552.05,
      "text": "네 아주 적절한 반응이었던 것 같아요"
    },
    {
      "start": 552.05,
      "end": 553.53,
      "text": "자 이 내용 떠올리시면서"
    },
    {
      "start": 553.53,
      "end": 554.73,
      "text": "한 번 더 들어보겠습니다"
    },
    {
      "start": 554.73,
      "end": 556.61,
      "text": "How lot's coming at you"
    },
    {
      "start": 556.61,
      "end": 556.85,
      "text": "huh?"
    },
    {
      "start": 557.29,
      "end": 557.79,
      "text": "I guess"
    },
    {
      "start": 557.79,
      "end": 558.99,
      "text": "Well"
    },
    {
      "start": 558.99,
      "end": 560.39,
      "text": "You shouldn't even cook"
    },
    {
      "start": 560.39,
      "end": 561.99,
      "text": "when you are in a bad mood"
    },
    {
      "start": 561.99,
      "end": 562.91,
      "text": "Why?"
    },
    {
      "start": 563.45,
      "end": 564.17,
      "text": "Get in the food"
    },
    {
      "start": 564.17,
      "end": 566.29,
      "text": "What about how you're always cursing"
    },
    {
      "start": 566.29,
      "end": 567.95,
      "text": "and yelling at mandioca"
    },
    {
      "start": 567.95,
      "end": 569.03,
      "text": "Okay"
    },
    {
      "start": 569.03,
      "end": 569.65,
      "text": "Take a break"
    },
    {
      "start": 569.65,
      "end": 570.73,
      "text": "and get a snack for us"
    },
    {
      "start": 570.73,
      "end": 572.08,
      "text": "맞아요"
    },
    {
      "start": 572.08,
      "end": 572.64,
      "text": "Okay"
    },
    {
      "start": 572.64,
      "end": 573.42,
      "text": "라고 할 때"
    },
    {
      "start": 573.42,
      "end": 575.42,
      "text": "굉장히 다급함이 느껴졌습니다"
    },
    {
      "start": 575.42,
      "end": 575.84,
      "text": "Okay"
    },
    {
      "start": 575.84,
      "end": 577.68,
      "text": "네 그래도 이렇게"
    },
    {
      "start": 577.68,
      "end": 579.56,
      "text": "다행히 좋은 아저씨인"
    },
    {
      "start": 579.56,
      "end": 580.6,
      "text": "치코를 만나가지고"
    },
    {
      "start": 580.6,
      "end": 581.48,
      "text": "우리 에이브가"
    },
    {
      "start": 581.48,
      "end": 583.22,
      "text": "엇나가지는 않을 것 같은"
    },
    {
      "start": 583.22,
      "end": 584.34,
      "text": "예감이 들어요"
    },
    {
      "start": 584.34,
      "end": 585.24,
      "text": "What's that?"
    },
    {
      "start": 585.46,
      "end": 586.84,
      "text": "엇나가지 않을 것 같다고요"
    },
    {
      "start": 586.84,
      "end": 587.86,
      "text": "아 끝나지 않습니다"
    },
    {
      "start": 587.86,
      "end": 588.12,
      "text": "네"
    },
    {
      "start": 588.12,
      "end": 588.94,
      "text": "올바르게 합니다"
    },
    {
      "start": 588.94,
      "end": 590.42,
      "text": "아 이것도 알아들으시고"
    },
    {
      "start": 590.42,
      "end": 590.78,
      "text": "훌륭합니다"
    },
    {
      "start": 590.78,
      "end": 591.0,
      "text": "똑바로"
    },
    {
      "start": 591.0,
      "end": 591.78,
      "text": "네"
    },
    {
      "start": 591.78,
      "end": 593.44,
      "text": "오늘 스크린 잉글리쉬는"
    },
    {
      "start": 593.44,
      "end": 594.32,
      "text": "여기까지입니다"
    }
  ]
}