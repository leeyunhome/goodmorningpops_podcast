      "start": 226.53,
      "end": 227.87,
      "text": "그 갈질"
    },
    {
      "start": 227.87,
      "end": 228.29,
      "text": "Yeah"
    },
    {
      "start": 228.29,
      "end": 229.33,
      "text": "Cutting things"
    },
    {
      "start": 229.33,
      "end": 230.35,
      "text": "and cleaning"
    },
    {
      "start": 230.35,
      "end": 231.43,
      "text": "My main job"
    },
    {
      "start": 231.43,
      "end": 232.55,
      "text": "when I got there"
