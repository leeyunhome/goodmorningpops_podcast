    {
      "start": 161.11,
      "end": 161.71,
      "text": "싶습니다"
    },
    {
      "start": 161.71,
      "end": 163.31,
      "text": "일단 오늘 장미안"
    },
    {
      "start": 163.31,
      "end": 164.94,
      "text": "듣고 올게요"
