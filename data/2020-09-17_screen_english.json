    {
      "start": 87.45,
      "end": 87.85,
      "text": "네"
    },
    {
      "start": 87.85,
      "end": 90.37,
      "text": "그래서 범세계주의"
    },
    {
      "start": 90.37,
      "end": 92.61,
      "text": "이 정도로 해석하면 어떨까 싶습니다"
    },
    {
      "start": 92.61,
      "end": 93.15,
      "text": "오케이"
    },
    {
      "start": 93.15,
      "end": 94.81,
      "text": "범세계주의"
    },
    {
      "start": 94.81,
      "end": 95.95,
      "text": "범세계주의"
    },
    {
      "start": 95.95,
      "end": 96.31,
      "text": "예"
    },
    {
      "start": 96.31,
      "end": 97.71,
      "text": "세계시민주의"
    },
    {
      "start": 97.71,
      "end": 98.83,
      "text": "이것도 괜찮을 것 같고요"
