    },
    {
      "start": 184.46,
      "end": 184.82,
      "text": "Wow."
    },
    {
      "start": 185.5,
      "end": 187.76,
      "text": "Amazing한 듀엣 것도 같았습니다."
    },
    {
      "start": 188.18,
      "end": 189.56,
      "text": "Sounds like a poem?"
    },
    {
      "start": 189.78,
      "end": 190.3,
      "text": "맞아요."
    },
    {
      "start": 190.54,
      "end": 191.5,
      "text": "Every line rhymes?"
    },
    {
      "start": 191.68,
      "end": 192.1,
      "text": "그러네."
    },
    {
      "start": 192.22,
      "end": 194.06,
