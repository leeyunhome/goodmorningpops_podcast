{
  "id": "2023-05-04_screen_english",
  "date": "2023-05-04",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "치어리딩 클럽 (Poms)",
  "duration_sec": 863.65,
  "audio_url": "https://pub-7f9ded590f88439d8f48752f6639e723.r2.dev/2023-05-04_screen_english.mp3",
  "artwork_generated_url": "",
  "script": [
    {
      "start": 0.0,
      "end": 1.52,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 1.52,
      "end": 2.46,
      "text": "시작하겠습니다."
    },
    {
      "start": 3.49,
      "end": 4.49,
      "text": "네, 오늘 첫 곡으로"
    },
    {
      "start": 4.49,
      "end": 7.51,
      "text": "듀아 리바의 Harder Than Hell 들어보셨어요."
    },
    {
      "start": 8.33,
      "end": 10.77,
      "text": "선택과 집중 정말 필요하죠."
    },
    {
      "start": 11.65,
      "end": 13.55,
      "text": "첫 사연으로 강미선님"
    },
    {
      "start": 13.55,
      "end": 14.59,
      "text": "안녕하세요."
    },
    {
      "start": 15.31,
      "end": 19.17,
      "text": "저 오늘부터 영어 공부 시작하려고 굿모닝 팝스 듣기 시작했어요."
    },
    {
      "start": 19.95,
      "end": 22.75,
      "text": "첫날이라 영어가 너무 적응이 안 되지만"
    },
    {
      "start": 22.75,
      "end": 24.93,
      "text": "조쌤과 열심히 해보려고요."
    },
    {
      "start": 25.37,
      "end": 26.09,
      "text": "응원해 주세요."
    },
    {
      "start": 26.09,
      "end": 31.15,
      "text": "특히 느낌표들을 많이 적어주셨어요."
    },
    {
      "start": 31.15,
      "end": 35.81,
      "text": "그래서인지 적극적인 열정이 느껴지는 분이십니다."
    },
    {
      "start": 35.97,
      "end": 37.19,
      "text": "강미선님"
    },
    {
      "start": 37.19,
      "end": 43.4,
      "text": "친절하고 또 귀에 썩썩 들리게 저의 진심을 담아서 전해드릴게요."
    },
    {
      "start": 44.5,
      "end": 45.78,
      "text": "적응 잘 하실 거고요."
    },
    {
      "start": 46.32,
      "end": 50.24,
      "text": "앞으로 날개짓을 활활 하시는 모습 기대하겠습니다."
    },
    {
      "start": 50.24,
      "end": 52.69,
      "text": "조한경님"
    },
    {
      "start": 52.69,
      "end": 56.54,
      "text": "회사까지 1시간 반은 기본으로 걸려서"
    },
    {
      "start": 56.54,
      "end": 60.74,
      "text": "일찍 서둘러서 차에 타면 GMP가 딱 시작하네요."
    },
    {
      "start": 61.48,
      "end": 63.34,
      "text": "받았으면서 듣고는 싶은데"
    },
    {
      "start": 63.34,
      "end": 64.44,
      "text": "그럴 상황은 아니라"
    },
    {
      "start": 64.44,
      "end": 67.02,
      "text": "큰 소리로 따라해보고는 합니다."
    },
    {
      "start": 67.86,
      "end": 69.66,
      "text": "학창시절에는 싫어했던 영어를"
    },
    {
      "start": 69.66,
      "end": 71.42,
      "text": "덕분에 열심히 하고 있네요."
    },
    {
      "start": 71.84,
      "end": 72.28,
      "text": "감사합니다."
    },
    {
      "start": 73.34,
      "end": 74.68,
      "text": "저도 감사합니다."
    },
    {
      "start": 74.68,
      "end": 80.42,
      "text": "상황에 맞게 너무너무 잘 적용하고 계시는 분이세요."
    },
    {
      "start": 80.74,
      "end": 81.66,
      "text": "조한경님"
    },
    {
      "start": 81.66,
      "end": 85.9,
      "text": "우리가 주로 영어라는 외국어도"
    },
    {
      "start": 85.9,
      "end": 89.76,
      "text": "특히 쓰면서 공부하는 버릇이 있잖아요."
    },
    {
      "start": 90.0,
      "end": 91.12,
      "text": "그런 습관도 있잖아요."
    },
    {
      "start": 91.48,
      "end": 96.3,
      "text": "근데 말하는 연습이 상대적으로 진짜 진짜 부족하거든요."
    },
    {
      "start": 96.3,
      "end": 98.03,
      "text": "그리고 또 중요한 게"
    },
    {
      "start": 98.03,
      "end": 102.21,
      "text": "가능하면 이렇게 큰 소리로 연습하시는 게"
    },
    {
      "start": 102.21,
      "end": 104.35,
      "text": "진짜 중요한 부분입니다."
    },
    {
      "start": 105.09,
      "end": 107.09,
      "text": "그런 의미로 더욱더 칭찬해 드립니다."
    },
    {
      "start": 107.25,
      "end": 108.27,
      "text": "조한경님"
    },
    {
      "start": 108.27,
      "end": 109.95,
      "text": "잘하고 계시니까요."
    },
    {
      "start": 110.33,
      "end": 113.27,
      "text": "앞으로 영어에 더 자신감 쌓아보세요."
    },
    {
      "start": 114.13,
      "end": 115.87,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 115.87,
      "end": 118.45,
      "text": "월간 굿모닝팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 119.57,
      "end": 120.93,
      "text": "GMP로 영어실력 업!"
    },
    {
      "start": 121.27,
      "end": 122.07,
      "text": "에너지도 업!"
    },
    {
      "start": 122.07,
      "end": 126.94,
      "text": "오늘은 아이스 아메리카노와 조각 케이크 모바일 쿠폰 준비했습니다."
    },
    {
      "start": 127.44,
      "end": 129.38,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 129.38,
      "end": 131.42,
      "text": "다섯 분 뽑아서 보내드릴게요."
    },
    {
      "start": 132.4,
      "end": 135.14,
      "text": "단문 50원과 장문 100원에 추가 요금이 부과되는"
    },
    {
      "start": 135.14,
      "end": 137.38,
      "text": "KBS 쿨 FM 문자 샵 8910"
    },
    {
      "start": 137.38,
      "end": 141.46,
      "text": "아니면 KBS 2라디오 문자 샵 1061로 신청하시거나"
    },
    {
      "start": 141.46,
      "end": 145.2,
      "text": "무료 KBS 애플리케이션 콩 또는 마이케이로 참여해 주세요."
    },
    {
      "start": 145.2,
      "end": 154.84,
      "text": "English"
    },
    {
      "start": 154.84,
      "end": 175.93,
      "text": "영화 배달 서비스 스크린 English time"
    },
    {
      "start": 175.93,
      "end": 178.18,
      "text": "5월에 함께하고 있는 영화는"
    },
    {
      "start": 178.18,
      "end": 180.52,
      "text": "POMS, cheerleading club"
    },
    {
      "start": 180.52,
      "end": 181.92,
      "text": "A movie starring"
    },
    {
      "start": 181.92,
      "end": 185.06,
      "text": "Diane Keaton, Jackie Weaver, Pam Greer,"
    },
    {
      "start": 185.46,
      "end": 189.98,
      "text": "Celia Weston, Alicia Boe, Phyllis Somerville,"
    },
    {
      "start": 190.2,
      "end": 193.84,
      "text": "Charlie Tahan, Bruce McGill, and Rhea Pearlman"
    },
    {
      "start": 193.84,
      "end": 195.78,
      "text": "Nice work!"
    },
    {
      "start": 196.18,
      "end": 198.46,
      "text": "이제 조샘의 고생을 알겠네요."
    },
    {
      "start": 199.29,
      "end": 200.29,
      "text": "이름들..."
    },
    {
      "start": 200.29,
      "end": 202.79,
      "text": "중간에 한숨 쉬시는 줄 알았어요."
    },
    {
      "start": 203.35,
      "end": 204.45,
      "text": "네, 한숨이었어요."
    },
    {
      "start": 204.79,
      "end": 205.65,
      "text": "답답했어요."
    },
    {
      "start": 205.65,
      "end": 210.73,
      "text": "그쵸, 그쵸? 아, 주요 배우들 이름을 들어봤습니다. 너무 감사드립니다."
    },
    {
      "start": 211.23,
      "end": 211.53,
      "text": "Yes!"
    },
    {
      "start": 211.75,
      "end": 213.39,
      "text": "아주 멋진 소개였어요."
    },
    {
      "start": 213.47,
      "end": 214.03,
      "text": "한 번만 합니다."
    },
    {
      "start": 214.27,
      "end": 217.24,
      "text": "네, 이렇게 선포를 해주셨습니다."
    },
    {
      "start": 217.6,
      "end": 219.66,
      "text": "왠지 다음번에 한 번 더 부탁드리고 싶잖아요."
    },
    {
      "start": 220.24,
      "end": 221.52,
      "text": "주연만, 주연만 합시다."
    },
    {
      "start": 221.52,
      "end": 226.82,
      "text": "아, 참, 어쨌든 이 소중한 아홉 명 이름들을 쫙 들어봤는데"
    },
    {
      "start": 226.82,
      "end": 231.02,
      "text": "네, they have a lot of acting experience 사실, 그쵸?"
    },
    {
      "start": 231.1,
      "end": 232.32,
      "text": "Yes, they are."
    },
    {
      "start": 232.48,
      "end": 235.4,
      "text": "In the movie, they play senior citizens, most of them."
    },
    {
      "start": 235.56,
      "end": 239.56,
      "text": "So if you add up all their acting experience, it's a lot of years."
    },
    {
      "start": 239.94,
      "end": 242.62,
      "text": "거의 over 300 years in total."
    },
    {
      "start": 243.0,
      "end": 244.7,
      "text": "Wow, 300년이나."
    },
    {
      "start": 244.96,
      "end": 251.6,
      "text": "거의, 그러면 한 사람당 한 30여 년 이상씩 경력이 있다는 계산이 나오기는 하는데요."
    },
    {
      "start": 251.6,
      "end": 254.34,
      "text": "Yeah, just think of Diane Keaton by herself."
    },
    {
      "start": 254.48,
      "end": 256.16,
      "text": "Diane Keaton, the legend."
    },
    {
      "start": 256.68,
      "end": 260.82,
      "text": "She debuted in 1968, over 50 years ago."
    },
    {
      "start": 261.0,
      "end": 263.64,
      "text": "So she started with a musical called Hair."
    },
    {
      "start": 264.2,
      "end": 267.24,
      "text": "And so that's over 50 years just for one actress."
    },
    {
      "start": 267.88,
      "end": 272.9,
      "text": "Diane Keaton, 이 한 사람만 해도 데뷔가 한 50년이 넘은 상태래요."
    },
    {
      "start": 273.12,
      "end": 273.54,
      "text": "Yes."
    },
    {
      "start": 273.7,
      "end": 276.18,
      "text": "And then the 남부 양반?"
    },
    {
      "start": 276.5,
      "end": 279.54,
      "text": "아, 남부 양반 말고, Diane Keaton의 바로 옆집."
    },
    {
      "start": 279.76,
      "end": 281.02,
      "text": "옆집, 이웃."
    },
    {
      "start": 281.02,
      "end": 282.46,
      "text": "아, 그 둘이 되는."
    },
    {
      "start": 282.46,
      "end": 282.66,
      "text": "Jackie Weaver."
    },
    {
      "start": 282.86,
      "end": 283.58,
      "text": "Jackie Weaver."
    },
    {
      "start": 283.7,
      "end": 283.96,
      "text": "Yeah."
    },
    {
      "start": 284.2,
      "end": 286.48,
      "text": "She's also an accomplished actress."
    },
    {
      "start": 286.66,
      "end": 291.02,
      "text": "She was nominated for an Academy Award for Best Supporting Actress."
    },
    {
      "start": 291.22,
      "end": 294.16,
      "text": "And I was shocked to find that she's not American."
    },
    {
      "start": 294.64,
      "end": 296.16,
      "text": "She's not from the South."
    },
    {
      "start": 296.16,
      "end": 296.6,
      "text": "Really?"
    },
    {
      "start": 296.6,
      "end": 297.86,
      "text": "She's from Australia."
    },
    {
      "start": 298.22,
      "end": 303.76,
      "text": "근데 뭔가 그 다이애렉트가 굉장히 남부 느낌으로 자라지 않았어요?"
    },
    {
      "start": 303.86,
      "end": 305.3,
      "text": "아, 이거 경력직."
    },
    {
      "start": 305.86,
      "end": 306.58,
      "text": "경험."
    },
    {
      "start": 306.66,
      "end": 307.3,
      "text": "역시."
    },
    {
      "start": 307.42,
      "end": 308.48,
      "text": "경험은 소중해요."
    },
    {
      "start": 308.5,
      "end": 309.1,
      "text": "Great, yeah."
    },
    {
      "start": 309.1,
      "end": 310.84,
      "text": "She was amazing."
    },
    {
      "start": 311.02,
      "end": 312.18,
      "text": "She fooled me."
    },
    {
      "start": 312.4,
      "end": 315.68,
      "text": "I thought she was just a Southern, beautiful Southern lady."
    },
    {
      "start": 315.86,
      "end": 316.26,
      "text": "맞아요."
    },
    {
      "start": 316.68,
      "end": 319.2,
      "text": "성격 묘사도 굉장히 잘한 것 같더라고요."
    },
    {
      "start": 319.74,
      "end": 324.3,
      "text": "And they learned the cheerleading moves, step by step, from the basics."
    },
    {
      "start": 324.3,
      "end": 334.0,
      "text": "와, 진짜 하나하나 그 cheerleading에 필요한 동작들을 이분들이 다이안 키튼만 해도 1946년생이고요."
    },
    {
      "start": 334.4,
      "end": 338.42,
      "text": "그 다음에 Jackie Weaver 같은 경우는 1947년생이시거든요."
    },
    {
      "start": 338.42,
      "end": 345.26,
      "text": "와, 그럼에도 불구하고 70대 후반인데도 아주 동작들을 멋지게 배웠다고 합니다."
    },
    {
      "start": 345.26,
      "end": 350.34,
      "text": "그리고 그 나이에 좀 편안하게 성우일만 하는 배우들이 많은데요."
    },
    {
      "start": 350.34,
      "end": 352.74,
      "text": "She is working really hard."
    },
    {
      "start": 352.74,
      "end": 354.58,
      "text": "예, 끝없는 도전 멋지네요."
    },
    {
      "start": 355.3,
      "end": 357.28,
      "text": "자, 오늘 준비된 장면 듣고 오시죠."
    },
    {
      "start": 357.28,
      "end": 359.84,
      "text": "Hey, you don't play poker, do you?"
    },
    {
      "start": 359.94,
      "end": 362.08,
      "text": "Because I run a weekly game."
    },
    {
      "start": 362.2,
      "end": 364.84,
      "text": "And we could sure use another player."
    },
    {
      "start": 365.2,
      "end": 366.36,
      "text": "It's all very hush-hush."
    },
    {
      "start": 366.5,
      "end": 369.08,
      "text": "Because gambling's not allowed around here."
    },
    {
      "start": 369.16,
      "end": 370.6,
      "text": "Like most things that are worthwhile."
    },
    {
      "start": 371.0,
      "end": 373.98,
      "text": "You should drop by tonight and say hi to the guys."
    },
    {
      "start": 374.06,
      "end": 375.66,
      "text": "God, you know, it's been a very..."
    },
    {
      "start": 375.66,
      "end": 377.32,
      "text": "Look, it's a long day for me."
    },
    {
      "start": 377.4,
      "end": 378.22,
      "text": "I just moved in."
    },
    {
      "start": 378.38,
      "end": 378.86,
      "text": "But thanks."
    },
    {
      "start": 378.96,
      "end": 380.48,
      "text": "I really appreciate what you're..."
    },
    {
      "start": 380.48,
      "end": 381.56,
      "text": "The invitation is sweet."
    },
    {
      "start": 381.56,
      "end": 386.01,
      "text": "음, 자, 드디어 이 옆집 주민 역할을 맡은"
    },
    {
      "start": 386.01,
      "end": 388.21,
      "text": "Jackie Weaver 목소리를 들어보셨습니다."
    },
    {
      "start": 388.33,
      "end": 389.01,
      "text": "Jackie Weaver."
    },
    {
      "start": 389.01,
      "end": 394.07,
      "text": "이 목소리만 들어도 성격을 약간 예상하실 수 있을 것 같기는 해요."
    },
    {
      "start": 394.23,
      "end": 394.69,
      "text": "Bright."
    },
    {
      "start": 394.91,
      "end": 397.55,
      "text": "Yeah, and she's even annoying Marissa."
    },
    {
      "start": 398.47,
      "end": 399.35,
      "text": "Annoying her."
    },
    {
      "start": 399.99,
      "end": 401.33,
      "text": "Do you like the annoying style?"
    },
    {
      "start": 401.39,
      "end": 402.49,
      "text": "You don't like the annoying style."
    },
    {
      "start": 402.59,
      "end": 403.49,
      "text": "아, 별로 안 좋아해요."
    },
    {
      "start": 404.15,
      "end": 405.33,
      "text": "I like it."
    },
    {
      "start": 405.41,
      "end": 405.71,
      "text": "아, 그래요?"
    },
    {
      "start": 405.91,
      "end": 406.23,
      "text": "Yes."
    },
    {
