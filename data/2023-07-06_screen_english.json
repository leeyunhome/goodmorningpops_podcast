      "text": "for Mona Lisa's"
    },
    {
      "start": 844.64,
      "end": 845.18,
      "text": "portrait"
    },
    {
      "start": 845.18,
      "end": 848.02,
      "text": "But"
    },
    {
      "start": 848.02,
      "end": 849.12,
      "text": "I want to ask"
    },
    {
      "start": 849.12,
      "end": 850.28,
      "text": "what I want to ask"
    },
    {
      "start": 850.28,
      "end": 850.72,
      "text": "what I want to ask"
    },
    {
      "start": 850.72,
      "end": 850.92,
      "text": "to ask"
    },
    {
      "start": 850.92,
      "end": 851.48,
      "text": "suck so"
    },
    {
      "start": 851.48,
      "end": 852.4,
      "text": "라는 것에"
    },
    {
      "start": 852.4,
      "end": 852.8,
      "text": "해당하는"
    },
    {
      "start": 852.8,
      "end": 854.0,
      "text": "영어적인 표현이"
    },
    {
      "start": 854.0,
      "end": 855.16,
      "text": "뭐가 어울릴까요?"
    },
    {
      "start": 855.76,
      "end": 858.22,
      "text": "I had an"
    },
    {
      "start": 858.22,
      "end": 859.86,
      "text": "awkward smile"
    },
    {
      "start": 859.86,
      "end": 861.16,
      "text": "이런 걸 생각했어요"
    },
    {
      "start": 861.16,
      "end": 862.2,
      "text": "awkward smile"
    },
    {
      "start": 862.2,
      "end": 863.54,
      "text": "awkward laugh"
    },
    {
      "start": 863.54,
      "end": 864.76,
      "text": "그것도 뭐"
    },
    {
      "start": 864.76,
      "end": 865.64,
      "text": "해당하긴 한데요"
    },
    {
      "start": 865.64,
      "end": 866.84,
      "text": "썩은 미소"
    },
    {
      "start": 866.84,
      "end": 868.84,
      "text": "rotten smile"
    },
    {
      "start": 868.84,
      "end": 869.16,
      "text": "아"
    },
    {
      "start": 869.16,
      "end": 869.8,
      "text": "고지곳대로"
    },
    {
      "start": 869.8,
      "end": 871.52,
      "text": "rancid smile"
    },
    {
      "start": 871.52,
      "end": 872.0,
      "text": "아"
    },
    {
      "start": 872.0,
      "end": 872.72,
      "text": "그렇군요"
    },
    {
      "start": 872.72,
      "end": 872.86,
      "text": "or"
    },
    {
      "start": 872.86,
      "end": 874.38,
      "text": "it just wasn't funny"
    },
    {
      "start": 874.38,
      "end": 875.34,
      "text": "이렇게 하죠"
    },
    {
      "start": 875.34,
      "end": 875.68,
      "text": "네"
    },
    {
      "start": 875.68,
      "end": 876.22,
      "text": "이렇게"
    },
    {
      "start": 876.22,
      "end": 877.04,
      "text": "돌려서"
    },
    {
      "start": 877.04,
      "end": 878.0,
      "text": "이야기를 할 수도"
    },
    {
      "start": 878.0,
      "end": 878.46,
      "text": "있으니까"
    }
  ]
}