    },
    {
      "start": 507.43,
      "end": 509.99,
      "text": "Like a mood ring changing colors"
    },
    {
      "start": 509.99,
      "end": 511.81,
      "text": "당신의 모든"
    },
    {
      "start": 511.81,
      "end": 513.13,
      "text": "All your blues"
    },
    {
      "start": 513.13,
      "end": 513.97,
      "text": "라고 했으니까"
    },
    {
      "start": 513.97,
      "end": 516.27,
      "text": "우울함도 다 알았다"
    },
    {
      "start": 516.27,
      "end": 517.07,
      "text": "라는 뜻입니다"
    },
    {
      "start": 517.07,
      "end": 517.81,
      "text": "그러면서"
    },
    {
      "start": 517.81,
      "end": 520.31,
      "text": "Like a mood ring changing colors"
    },
    {
      "start": 520.31,
      "end": 520.95,
      "text": "라고 했어요"
    },
    {
      "start": 520.95,
      "end": 523.31,
