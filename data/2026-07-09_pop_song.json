    },
    {
      "start": 527.89,
      "end": 528.69,
      "text": "이라는 게"
    },
    {
      "start": 528.69,
      "end": 530.33,
      "text": "기분에 따라서"
    },
    {
      "start": 530.33,
      "end": 531.33,
      "text": "반지의 색깔이"
    },
