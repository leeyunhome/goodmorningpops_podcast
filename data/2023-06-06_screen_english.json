    },
    {
      "start": 867.76,
      "end": 868.52,
      "text": "Don't say that"
    },
    {
      "start": 868.52,
      "end": 871.02,
      "text": "My next address is a tombstone"
    },
    {
      "start": 871.02,
      "end": 873.96,
      "text": "You still wear me?"
    },
