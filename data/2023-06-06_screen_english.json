      "end": 732.61,
      "text": "네."
    },
    {
      "start": 732.81,
      "end": 734.97,
      "text": "이거는 뭐 지금 크쌤도 너무 완벽했어요."
    },
    {
      "start": 735.09,
      "end": 736.15,
      "text": "Bella Bella Bella"
    },
    {
      "start": 736.15,
      "end": 737.45,
