      "end": 874.26,
      "text": "Yeah"
    },
    {
      "start": 874.26,
      "end": 876.34,
      "text": "Ah, San Antonio"
    },
    {
      "start": 876.34,
      "end": 879.6,
      "text": "Ah, patron saint of wayward children"
    },
    {
      "start": 879.6,
      "end": 881.36,
      "text": "I knew he'd bring you all"
    },
    {
      "start": 881.36,
      "end": 896.54,
      "text": "Oh, you would if you learned to FaceTime"
    },
    {
      "start": 896.54,
      "end": 900.65,
      "text": "Oh, 이렇게 Little Italy라는 영화는"
    },
    {
      "start": 900.65,
      "end": 902.51,
      "text": "매 장면마다 참"
    },
    {
      "start": 902.51,
      "end": 904.45,
      "text": "Makes me feel so good"
    },
    {
      "start": 904.45,
      "end": 904.95,
      "text": "Yeah"
    },
    {
      "start": 904.95,
      "end": 905.93,
      "text": "너무 기분이 좋아요"
    },
    {
      "start": 905.93,
      "end": 908.69,
      "text": "Family, food, and beautiful Little Italy"
