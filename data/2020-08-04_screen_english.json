    {
      "start": 422.38,
      "end": 423.2,
      "text": "Oh, your family"
    },
    {
      "start": 423.2,
      "end": 424.18,
      "text": "We had three boys"
    },
    {
      "start": 424.18,
      "end": 426.22,
      "text": "We loved calling each other"
    },
    {
      "start": 426.22,
      "end": 428.26,
      "text": "Idiot, Jerk, Weirdo"
    },
    {
      "start": 428.26,
      "end": 429.86,
      "text": "나 생욕 안 썼고요"
    },
    {
      "start": 429.86,
      "end": 430.92,
      "text": "타병원욕"
    },
    {
      "start": 430.92,
      "end": 431.94,
      "text": "Weirdo"
    },
    {
      "start": 431.94,
      "end": 434.04,
      "text": "생욕을 안 썼고"
    },
    {
      "start": 434.04,
      "end": 435.98,
      "text": "이렇게 좀 귀엽게"
    },
    {
      "start": 435.98,
      "end": 437.46,
      "text": "돌려가지고"
    },
    {
      "start": 437.46,
      "end": 439.08,
      "text": "이야기를 많이 하셨다고 합니다"
    },
    {
      "start": 439.08,
      "end": 440.1,
      "text": "별로 안 키웠어요"
