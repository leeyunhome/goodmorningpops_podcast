      "start": 365.44,
      "end": 366.88,
      "text": "she drops her phone"
    },
    {
      "start": 366.88,
      "end": 369.2,
      "text": "and it falls in the sewer"
    },
    {
      "start": 369.2,
      "end": 370.0,
      "text": "You know"
    },
    {
      "start": 370.0,
      "end": 370.8,
      "text": "like the gutter"
    },
    {
      "start": 370.8,
      "end": 371.44,
      "text": "on the street"
    },
    {
      "start": 371.44,
      "end": 372.4,
      "text": "Yeah"
    },
    {
      "start": 372.4,
      "end": 372.44,
      "text": "Yeah"
    },
    {
      "start": 372.44,
      "end": 372.74,
      "text": "Yeah"
    },
    {
      "start": 372.74,
      "end": 374.68,
      "text": "And yeah"
    },
    {
      "start": 374.68,
      "end": 376.44,
      "text": "She is not having a good day"
    },
    {
      "start": 376.44,
      "end": 378.24,
      "text": "자 그러면"
    },
    {
      "start": 378.24,
      "end": 379.24,
      "text": "어떤 단어들을"
    },
    {
      "start": 379.24,
      "end": 380.14,
      "text": "미리 들어볼까요?"
    },
    {
      "start": 380.86,
      "end": 381.82,
      "text": "Precisely"
    },
    {
      "start": 381.82,
      "end": 382.28,
      "text": "네"
    },
    {
      "start": 382.28,
      "end": 383.4,
      "text": "Precisely"
    },
    {
      "start": 383.4,
      "end": 385.16,
      "text": "라는 부사를 들으실 텐데요"
    },
    {
      "start": 385.16,
      "end": 386.02,
      "text": "이것은"
    },
    {
      "start": 386.02,
      "end": 386.74,
      "text": "철자를 먼저"
    },
    {
      "start": 386.74,
      "end": 387.74,
      "text": "소개를 시켜드리면"
    },
    {
      "start": 387.74,
      "end": 391.48,
      "text": "P-R-E-C-I-S-E-L-Y"
    },
    {
      "start": 391.48,
      "end": 392.54,
      "text": "라고 생겼어요"
    },
    {
      "start": 392.54,
      "end": 393.4,
      "text": "Very precise"
    },
    {
      "start": 393.4,
      "end": 393.9,
      "text": "Yeah"
    },
    {
      "start": 393.9,
      "end": 394.94,
      "text": "정확히"
    },
    {
      "start": 394.94,
      "end": 395.48,
      "text": "꼭"
    },
    {
      "start": 395.48,
      "end": 396.14,
      "text": "바로"
    },
    {
      "start": 396.14,
      "end": 397.16,
      "text": "라는 의미입니다"
    },
    {
      "start": 397.16,
      "end": 398.7,
      "text": "대체할 수 있는 것도 뭐가 있을까요?"
    },
    {
      "start": 399.2,
      "end": 399.76,
      "text": "Precisely"
    },
    {
      "start": 399.76,
      "end": 400.2,
      "text": "Exactly"
    },
    {
      "start": 400.2,
      "end": 400.9,
      "text": "Exactly"
    },
    {
      "start": 400.9,
      "end": 402.48,
      "text": "That's it"
