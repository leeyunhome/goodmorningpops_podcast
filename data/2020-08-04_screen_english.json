    {
      "start": 346.58,
      "end": 346.78,
      "text": "그렇죠?"
    },
    {
      "start": 347.18,
      "end": 347.98,
      "text": "모든 게 진짜"
    },
    {
      "start": 347.98,
      "end": 349.2,
      "text": "다 엉망진창"
    },
    {
      "start": 349.2,
      "end": 350.82,
      "text": "뒤죽박죽 되는 날이 있잖아요"
    },
    {
      "start": 350.82,
      "end": 352.54,
      "text": "Emma's having one of those days"
