      "start": 443.08,
      "end": 445.22,
      "text": "W-E-I-R-D-O"
    },
    {
      "start": 445.22,
      "end": 445.56,
      "text": "이죠"
    },
    {
      "start": 445.56,
      "end": 446.98,
      "text": "그래서 괴짜라든지"
    },
    {
      "start": 446.98,
      "end": 449.04,
      "text": "별난 사람을 칭할 때"
