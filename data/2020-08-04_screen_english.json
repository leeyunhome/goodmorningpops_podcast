    {
      "start": 407.36,
      "end": 408.3,
      "text": "You got it"
    },
    {
      "start": 408.3,
      "end": 410.16,
      "text": "이렇게도 표현을 하면 아주 좋겠습니다"
    },
    {
      "start": 410.16,
      "end": 410.84,
      "text": "반응을 줘요"
