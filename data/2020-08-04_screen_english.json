    {
      "start": 452.1,
      "end": 452.9,
      "text": "돌덩�"
    },
    {
      "start": 452.9,
      "end": 454.38,
      "text": "이렇게 이런 거"
    },
    {
      "start": 454.38,
      "end": 455.14,
      "text": "딱딱이에요"
    },
    {
      "start": 455.14,
      "end": 456.24,
      "text": "아, 네"
    },
    {
      "start": 456.24,
      "end": 457.04,
      "text": "재미있습니다"
    },
    {
      "start": 457.04,
      "end": 458.64,
      "text": "자, 이 내용 다시 한번 들어볼게요"
    },
    {
      "start": 458.64,
      "end": 461.6,
      "text": "Do you know what today is not, Cheyenne?"
    },
    {
      "start": 462.02,
      "end": 462.94,
      "text": "Your day?"
    },
    {
      "start": 463.52,
      "end": 464.4,
      "text": "Precisely"
    },
    {
      "start": 464.4,
      "end": 465.52,
      "text": "Darling"
    },
    {
      "start": 465.52,
      "end": 467.28,
      "text": "You said that everyday"
    },
    {
      "start": 467.28,
      "end": 468.38,
