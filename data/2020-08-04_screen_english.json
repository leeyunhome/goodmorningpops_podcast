    {
      "start": 325.34,
      "end": 326.34,
      "text": "Yeah"
    },
    {
      "start": 326.34,
      "end": 327.26,
      "text": "믿거나 말거나"
    },
    {
      "start": 327.26,
      "end": 327.86,
      "text": "아니면 진짜"
    },
    {
      "start": 327.86,
      "end": 328.88,
      "text": "No, this is a true story"
    },
    {
      "start": 328.88,
      "end": 329.46,
      "text": "Oh, 진짜요?"
    },
    {
      "start": 329.48,
      "end": 330.14,
      "text": "100%"
    },
    {
      "start": 330.14,
      "end": 330.64,
      "text": "Wow"
    },
    {
      "start": 330.64,
      "end": 331.44,
      "text": "Believe me"
    },
    {
      "start": 331.44,
      "end": 331.98,
      "text": "Yeah"
    },
    {
      "start": 331.98,
      "end": 334.06,
      "text": "한번 빠뜨리신 분들은"
    },
    {
      "start": 334.06,
      "end": 335.9,
      "text": "그래도 한번 해보시는 것도"
    },
    {
      "start": 335.9,
      "end": 337.22,
      "text": "나쁘진 않을 것 같습니다"
    },
    {
      "start": 337.22,
      "end": 337.62,
      "text": "Yeah"
    },
    {
      "start": 337.62,
      "end": 338.24,
      "text": "It was in the water"
    },
    {
      "start": 338.24,
      "end": 339.12,
      "text": "for like one second"
    },
    {
      "start": 339.12,
      "end": 339.62,
      "text": "Yeah"
    },
    {
      "start": 339.62,
      "end": 340.54,
      "text": "And it actually worked"
