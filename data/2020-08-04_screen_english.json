    {
      "start": 410.84,
      "end": 411.12,
      "text": "Yeah"
    },
    {
      "start": 411.12,
      "end": 412.66,
      "text": "Instead of"
    },
    {
      "start": 412.66,
      "end": 413.9,
      "text": "Instead of"
    },
    {
      "start": 413.9,
      "end": 415.84,
      "text": "이것도 많이 들어보신 표현일 거예요"
    },
    {
      "start": 415.84,
      "end": 416.96,
      "text": "뭐뭐 대신해"
    },
    {
      "start": 416.96,
      "end": 417.8,
