    {
      "start": 352.54,
      "end": 353.16,
      "text": "맞습니다"
    },
    {
      "start": 353.16,
      "end": 355.24,
      "text": "지금 딱 Emma가 그런 상황인데요"
    },
    {
      "start": 355.24,
      "end": 355.92,
      "text": "Yeah"
    },
    {
      "start": 355.92,
      "end": 357.44,
      "text": "She's on her way to work"
    },
    {
      "start": 357.44,
      "end": 358.86,
      "text": "So she owns a bookstore"
    },
    {
      "start": 358.86,
      "end": 360.54,
      "text": "She's walking to work"
    },
    {
      "start": 360.54,
      "end": 362.6,
      "text": "and that's when she makes that phone call"
    },
    {
      "start": 362.6,
      "end": 363.6,
