{
  "id": "2023-08-09_screen_english",
  "date": "2023-08-09",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "컴온 컴온 (C'mon C'mon)",
  "duration_sec": 712.01,
  "audio_url": "https://pub-7f9ded590f88439d8f48752f6639e723.r2.dev/2023-08-09_screen_english.mp3",
  "artwork_generated_url": "",
  "script": [
    {
      "start": 0.0,
      "end": 2.64,
      "text": "함께 굿모닝 팝스 들으시는 모든 분들"
    },
    {
      "start": 2.64,
      "end": 4.5,
      "text": "행복한 하루 되십시오!"
    },
    {
      "start": 4.86,
      "end": 6.18,
      "text": "라고 외쳐주셨네요."
    },
    {
      "start": 6.18,
      "end": 9.92,
      "text": "아, 지금 일본 출장 중이시군요."
    },
    {
      "start": 10.7,
      "end": 13.14,
      "text": "아, 저도 일본 여행을 한 적이 있는데"
    },
    {
      "start": 13.14,
      "end": 17.4,
      "text": "그때 지하철을 굉장히 자주 타게 되더라고요."
    },
    {
      "start": 17.62,
      "end": 20.74,
      "text": "또 엘리베이터도 자주 타게 되죠."
    },
    {
      "start": 21.3,
      "end": 22.96,
      "text": "이런 이야기를 왜 드리냐면"
    },
    {
      "start": 22.96,
      "end": 27.06,
      "text": "저절로 외워졌던 한 문장이 있었거든요."
    },
    {
      "start": 28.0,
      "end": 30.12,
      "text": "도아가 시마리마스"
    },
    {
      "start": 30.12,
      "end": 32.07,
      "text": "하도 많이 들어서"
    },
    {
      "start": 32.07,
      "end": 33.47,
      "text": "아, 이게 무슨 뜻일까?"
    },
    {
      "start": 33.47,
      "end": 36.47,
      "text": "근데 이 상황이 그걸 다 설명을 해주더라고요."
    },
    {
      "start": 37.21,
      "end": 38.67,
      "text": "문이 닫힙니다."
    },
    {
      "start": 39.23,
      "end": 40.33,
      "text": "이 문장이었어요."
    },
    {
      "start": 41.23,
      "end": 43.17,
      "text": "그때 다시금 깨달은 게"
    },
    {
      "start": 43.17,
      "end": 46.05,
      "text": "아, 역시 언어는 자주 들어야 되는구나."
    },
    {
      "start": 46.59,
      "end": 49.39,
      "text": "그리고 반복해서 들어야 되는구나."
    },
    {
      "start": 49.67,
      "end": 51.31,
      "text": "이 반복이 정말 중요하구나."
    },
    {
      "start": 51.55,
      "end": 52.73,
      "text": "라는 생각을 하게 되었습니다."
    },
    {
      "start": 53.63,
      "end": 54.07,
      "text": "그렇잖아요."
    },
    {
      "start": 54.25,
      "end": 55.53,
      "text": "지하철에서 내릴 때마다"
    },
    {
      "start": 55.53,
      "end": 58.65,
      "text": "그리고 엘리베이터에서 문이 닫힐 때마다"
    },
    {
      "start": 58.65,
      "end": 59.93,
      "text": "문이 닫힙니다."
    },
    {
      "start": 60.01,
      "end": 60.69,
      "text": "문이 닫힙니다."
    },
    {
      "start": 60.77,
      "end": 61.55,
      "text": "계속 들리니까"
    },
    {
      "start": 61.55,
      "end": 63.45,
      "text": "잊을만 하면 다시 들리고"
    },
    {
      "start": 63.45,
      "end": 65.47,
      "text": "잊을만 하면 또 다시 들리고"
    },
    {
      "start": 65.47,
      "end": 67.33,
      "text": "그렇게 반복이 되다 보니까"
    },
    {
      "start": 67.33,
      "end": 69.47,
      "text": "지금까지도 생각에 남는 것 같아요."
    },
    {
      "start": 70.47,
      "end": 72.47,
      "text": "출장 잘 다녀오시고요."
    },
    {
      "start": 72.47,
      "end": 78.27,
      "text": "다음 출장 때는 더 멋진 영어 실력을 상상하시면서"
    },
    {
      "start": 78.27,
      "end": 79.83,
      "text": "꼭 함께해 주세요."
    },
    {
      "start": 79.83,
      "end": 82.09,
      "text": "김연숙 님"
    },
    {
      "start": 82.09,
      "end": 83.43,
      "text": "굿모닝"
    },
    {
      "start": 83.43,
      "end": 85.89,
      "text": "오늘도 시원한 팝송을 들으니"
    },
    {
      "start": 85.89,
      "end": 86.83,
      "text": "더위가 날아갑니다."
    },
    {
      "start": 87.83,
      "end": 89.57,
      "text": "정연쌤 덕분에 계속해서"
    },
    {
      "start": 89.57,
      "end": 91.29,
      "text": "일찍 일어나게 되는 것 같아요."
    },
    {
      "start": 92.03,
      "end": 94.25,
      "text": "팝스 잉글리시 코너가 특히 재밌네요."
    },
    {
      "start": 94.73,
      "end": 96.29,
      "text": "옛 추억이 방울방울"
    },
    {
      "start": 96.29,
      "end": 97.93,
      "text": "정겨움도 느껴지고요."
    },
    {
      "start": 98.69,
      "end": 102.01,
      "text": "친구들이랑 LP로 들었던 팝송도 생각나네요."
    },
    {
      "start": 102.01,
      "end": 104.43,
      "text": "모두들 즐거운 하루 보내세요."
    },
    {
      "start": 104.59,
      "end": 104.99,
      "text": "하트"
    },
    {
      "start": 104.99,
      "end": 108.45,
      "text": "추억이 방울방울 하셨어요."
    },
    {
      "start": 109.51,
      "end": 110.17,
      "text": "맞아요."
    },
    {
      "start": 110.33,
      "end": 112.39,
      "text": "저도 그런 곡을 들으면"
    },
    {
      "start": 112.39,
      "end": 116.53,
      "text": "그 곡을 들었었던 과거의 그때로"
    },
    {
      "start": 116.53,
      "end": 118.15,
      "text": "시간여행을 하는 것 같고"
    },
    {
      "start": 118.15,
      "end": 120.41,
      "text": "또 가끔은 가사 때문에"
    },
    {
      "start": 120.41,
      "end": 122.45,
      "text": "뭉클해질 때도 있고 그러더라고요."
    },
    {
      "start": 123.01,
      "end": 125.07,
      "text": "그리고 새로운 곡을 듣게 되면"
    },
    {
      "start": 125.07,
      "end": 127.29,
      "text": "또 이런 좋은 곡이 있네"
    },
    {
      "start": 127.29,
      "end": 129.53,
      "text": "이러면서 되게 반갑기도 하고"
    },
    {
      "start": 129.53,
      "end": 132.75,
      "text": "또 나중에 시간이 지나고 나서는"
    },
    {
      "start": 132.75,
      "end": 135.01,
      "text": "그 새로운 곡이 나에게"
    },
    {
      "start": 135.01,
      "end": 137.05,
      "text": "추억의 곡이 되겠죠."
    },
    {
      "start": 137.29,
      "end": 138.23,
      "text": "그럼 또 그때 돼서"
    },
    {
      "start": 138.23,
      "end": 139.93,
      "text": "추억이 방울방울해지겠죠."
    },
    {
      "start": 140.85,
      "end": 142.39,
      "text": "우리 김연숙님"
    },
    {
      "start": 142.39,
      "end": 144.01,
      "text": "오늘도 좋은 팝송을"
    },
    {
      "start": 144.01,
      "end": 145.67,
      "text": "마음껏 즐겨주시길 바랍니다."
    },
    {
      "start": 146.69,
      "end": 148.23,
      "text": "오늘 사연 소개되신 두 분께는"
    },
    {
      "start": 148.23,
      "end": 149.35,
      "text": "월간 굿모닝 팝"
    },
    {
      "start": 149.35,
      "end": 151.01,
      "text": "3개월 구독권 보내드릴게요."
    },
    {
      "start": 151.97,
      "end": 153.81,
      "text": "GMP월의 행복한 하루를 위한"
    },
    {
      "start": 153.81,
      "end": 154.93,
      "text": "깜짝 이벤트"
    },
    {
      "start": 154.93,
      "end": 156.45,
      "text": "GMP로 영어실력"
    },
    {
      "start": 156.45,
      "end": 156.69,
      "text": "엉?"
    },
    {
      "start": 156.97,
      "end": 157.85,
      "text": "에너지도 엉?"
    },
    {
      "start": 157.85,
      "end": 160.3,
      "text": "더운 날씨를 이겨내기 위해"
    },
    {
      "start": 160.3,
      "end": 162.02,
      "text": "상큼한 땅 충전"
    },
    {
      "start": 162.02,
      "end": 162.64,
      "text": "하고 가세요."
    },
    {
      "start": 163.16,
      "end": 164.4,
      "text": "오늘 준비한 선물은"
    },
    {
      "start": 164.4,
      "end": 166.08,
      "text": "레모네이드 모바일 쿠폰입니다."
    },
    {
      "start": 166.86,
      "end": 168.76,
      "text": "신청 메시지 보내주신 분들 중에서"
    },
    {
      "start": 168.76,
      "end": 170.58,
      "text": "다섯 분 뽑아서 보내드릴게요."
    },
    {
      "start": 171.2,
      "end": 172.84,
      "text": "담으 50원과 장문 100원에"
    },
    {
      "start": 172.84,
      "end": 173.98,
      "text": "추가 요금이 부과되는"
    },
    {
      "start": 173.98,
      "end": 175.46,
      "text": "문자 샵 890"
    },
    {
      "start": 175.46,
      "end": 178.32,
      "text": "아니면 샵 1061로 신청하시거나"
    },
    {
      "start": 178.32,
      "end": 180.22,
      "text": "무료인 콩 또는 마이케이로"
    },
    {
      "start": 180.22,
      "end": 181.12,
      "text": "참여해주세요."
    },
    {
      "start": 181.12,
      "end": 192.11,
      "text": "6시 조정현의"
    },
    {
      "start": 192.11,
      "end": 206.88,
      "text": "굿모닝 팝"
    },
    {
      "start": 206.88,
      "end": 220.68,
      "text": "스크린 잉글리쉬"
    },
    {
      "start": 220.68,
      "end": 240.74,
      "text": "영어가 즐거워지는 영어 놀이터"
    },
    {
      "start": 240.74,
      "end": 242.1,
      "text": "스크린 잉글리쉬 타임"
    },
    {
      "start": 242.1,
      "end": 244.11,
      "text": "8월에 함께하고 있는 영화는"
    },
    {
      "start": 244.11,
      "end": 245.19,
      "text": "컴온 컴온"
    },
    {
      "start": 245.19,
      "end": 247.37,
      "text": "directed by mike mills"
    },
    {
      "start": 247.37,
      "end": 248.09,
      "text": "and starring"
    },
    {
      "start": 248.09,
      "end": 249.23,
      "text": "화킹 피닉스"
    },
    {
      "start": 249.23,
      "end": 250.61,
      "text": "and woody norman."
    },
    {
      "start": 250.71,
      "end": 251.51,
      "text": "워호우!"
    },
    {
      "start": 251.75,
      "end": 253.01,
      "text": "우리 벤쌤 오셨어요."
    },
    {
      "start": 253.15,
      "end": 254.05,
      "text": "Good morning!"
    },
    {
      "start": 254.53,
      "end": 254.83,
      "text": "와우!"
    },
    {
      "start": 254.91,
      "end": 256.43,
      "text": "박주헌님께서도"
    },
    {
      "start": 256.43,
      "end": 257.41,
      "text": "와우!"
    },
    {
      "start": 257.47,
      "end": 258.77,
      "text": "벤쌤 너무 반갑습니다."
    },
    {
      "start": 258.97,
      "end": 259.57,
      "text": "어서 오세요."
    },
    {
      "start": 259.81,
      "end": 261.11,
      "text": "Everyone's so kind."
    },
    {
      "start": 261.59,
      "end": 263.03,
      "text": "I enjoy coming here"
    },
    {
      "start": 263.03,
      "end": 264.31,
      "text": "during the week too."
    },
    {
      "start": 264.43,
      "end": 265.99,
      "text": "너무 반갑습니다."
    },
    {
      "start": 266.15,
      "end": 266.93,
      "text": "You're very welcome."
    },
    {
      "start": 266.93,
      "end": 276.17,
      "text": "And I feel more excited"
    },
    {
      "start": 276.17,
      "end": 276.91,
      "text": "to get and know"
    },
    {
      "start": 276.91,
      "end": 278.09,
      "text": "about these two"
    },
    {
      "start": 278.09,
      "end": 279.63,
      "text": "amazing actors."
    },
    {
      "start": 279.85,
      "end": 280.11,
      "text": "Yeah."
    },
    {
      "start": 280.35,
      "end": 281.03,
      "text": "와우!"
    },
    {
      "start": 281.15,
      "end": 281.81,
      "text": "그리고 이번에"
    },
    {
      "start": 281.81,
      "end": 282.99,
      "text": "이 제시 역할을"
    },
    {
      "start": 282.99,
      "end": 283.61,
      "text": "맡았던"
    },
    {
      "start": 283.61,
      "end": 285.29,
      "text": "워디 노르만에 대해서"
    },
    {
      "start": 285.29,
      "end": 286.95,
      "text": "우리가 지난 시간부터"
    },
    {
      "start": 286.95,
      "end": 288.35,
      "text": "알아보고 있기는 한데"
    },
    {
      "start": 288.35,
      "end": 289.53,
      "text": "I think he's actually"
    },
    {
      "start": 289.53,
      "end": 290.99,
      "text": "a grown-up kid"
    },
    {
      "start": 290.99,
      "end": 292.93,
      "text": "in real world."
    },
    {
      "start": 293.11,
      "end": 294.03,
      "text": "In real life,"
    },
    {
      "start": 294.21,
      "end": 295.31,
      "text": "he's a grown-up kid."
    },
    {
      "start": 295.31,
      "end": 297.51,
      "text": "He said in an interview"
    },
    {
      "start": 297.51,
      "end": 299.15,
      "text": "I really liked"
    },
    {
      "start": 299.15,
      "end": 299.63,
      "text": "Jesse,"
    },
    {
      "start": 299.97,
      "end": 300.71,
      "text": "the character."
    },
    {
      "start": 300.85,
      "end": 301.57,
      "text": "I really liked"
    },
    {
      "start": 301.57,
      "end": 302.45,
      "text": "the character Jesse."
    },
    {
      "start": 302.81,
      "end": 304.99,
      "text": "It's a very deep role."
    },
    {
      "start": 305.41,
      "end": 306.59,
      "text": "It's very challenging"
    },
    {
      "start": 306.59,
      "end": 308.63,
      "text": "because it's a very"
    },
    {
      "start": 308.63,
      "end": 309.53,
      "text": "complex character."
    },
    {
      "start": 309.75,
      "end": 311.59,
      "text": "There are lots of layers"
    },
    {
      "start": 311.59,
      "end": 312.47,
      "text": "in Jesse"
    },
    {
      "start": 312.47,
      "end": 314.17,
      "text": "and it was very fun"
    },
    {
      "start": 314.17,
      "end": 315.37,
      "text": "to get into that."
    },
    {
      "start": 316.15,
      "end": 317.57,
      "text": "Jesse is extremely"
    },
    {
      "start": 317.57,
      "end": 318.99,
      "text": "different from me."
    },
    {
      "start": 319.73,
      "end": 321.25,
      "text": "He's this very"
    },
    {
      "start": 321.25,
      "end": 322.63,
      "text": "introverted,"
    },
    {
      "start": 322.63,
      "end": 324.03,
      "text": "very kind of"
    },
    {
      "start": 324.03,
      "end": 324.95,
      "text": "quirky,"
    },
    {
      "start": 324.95,
      "end": 326.29,
      "text": "strange kid"
    },
    {
      "start": 326.29,
      "end": 327.71,
      "text": "and I'm quite"
    },
    {
      "start": 327.71,
      "end": 328.83,
      "text": "extroverted."
    },
    {
      "start": 329.63,
      "end": 330.39,
      "text": "그러니까"
    },
    {
      "start": 330.39,
      "end": 331.67,
      "text": "이런 이야기를"
    },
    {
      "start": 331.67,
      "end": 332.63,
      "text": "한다는 것은"
    },
    {
      "start": 332.63,
      "end": 334.05,
      "text": "이 캐릭터에 대해서"
    },
    {
      "start": 334.05,
      "end": 335.39,
      "text": "충분히"
    },
    {
      "start": 335.39,
      "end": 336.39,
      "text": "자기 스스로가"
    },
    {
      "start": 336.39,
      "end": 337.07,
      "text": "이해를 하고"
    },
    {
      "start": 337.07,
      "end": 337.97,
      "text": "있다는 거잖아요."
    },
    {
      "start": 338.61,
      "end": 338.83,
      "text": "와,"
    },
    {
      "start": 338.99,
      "end": 339.87,
      "text": "I can't believe."
    },
    {
      "start": 340.21,
      "end": 341.21,
