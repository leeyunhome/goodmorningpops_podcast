    {
      "start": 66.71,
      "end": 67.29,
      "text": "아무래도"
    },
    {
      "start": 67.29,
      "end": 69.67,
      "text": "I think I know who you're talking about"
    },
    {
      "start": 69.67,
      "end": 71.21,
      "text": "진짜요 누굴까요"
    },
    {
      "start": 71.21,
      "end": 73.39,
      "text": "Mr. Firth"
    },
    {
      "start": 73.39,
      "end": 74.31,
      "text": "네 그렇겠죠"
