    {
      "start": 95.79,
      "end": 97.03,
      "text": "알면 알수록"
    },
    {
      "start": 97.03,
      "end": 98.73,
      "text": "약간 감성적으로"
    },
    {
      "start": 98.73,
      "end": 100.39,
      "text": "좀 동감이 되는 부분도"
    },
    {
      "start": 100.39,
      "end": 101.37,
      "text": "생기더라고요"
    },
    {
      "start": 101.37,
      "end": 102.09,
      "text": "Anyway"
    },
    {
      "start": 102.09,
      "end": 102.93,
      "text": "especially I like"
    },
    {
      "start": 102.93,
      "end": 104.11,
      "text": "his acting as role"
    },
    {
      "start": 104.11,
      "end": 105.29,
