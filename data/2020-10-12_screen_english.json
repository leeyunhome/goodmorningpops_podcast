    },
    {
      "start": 59.45,
      "end": 62.89,
      "text": "어쩌면 우리 청취자분들 중에도"
    },
    {
      "start": 62.89,
      "end": 65.65,
      "text": "아주 많이 궁금해하실 인물이"
    },
    {
      "start": 65.65,
      "end": 66.71,
      "text": "한 명이 있을 거예요"
