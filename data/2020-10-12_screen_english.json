    },
    {
      "start": 75.89,
      "end": 77.13,
      "text": "가 아닐까 싶습니다"
    },
    {
      "start": 77.13,
      "end": 80.01,
      "text": "He played a role of Mary's uncle here right?"
    },
    {
      "start": 80.73,
      "end": 81.73,
      "text": "Yes yes"
    },
    {
      "start": 81.73,
      "end": 85.05,
      "text": "여기에서 Mary의 이모부의 역할을 맡았는데"
    },
    {
      "start": 85.05,
      "end": 85.63,
      "text": "The uncle"
    },
    {
      "start": 85.63,
      "end": 86.45,
      "text": "네 맞아요"
    },
    {
      "start": 86.45,
      "end": 87.27,
      "text": "The crazy uncle"
    },
    {
      "start": 87.27,
      "end": 88.79,
      "text": "crazy합니까"
    },
    {
      "start": 88.79,
      "end": 90.29,
      "text": "안타깝네요"
    },
    {
      "start": 90.29,
      "end": 91.59,
      "text": "He's a little eccentric"
