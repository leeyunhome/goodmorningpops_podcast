    },
    {
      "start": 270.37,
      "end": 272.15,
      "text": "명령을 아주 잘 내리긴 했어요."
    },
    {
      "start": 272.45,
      "end": 273.71,
      "text": "He's just eating all day."
    },
    {
      "start": 273.85,
      "end": 275.03,
      "text": "Eating ice cream."
    },
    {
      "start": 275.11,
      "end": 275.47,
      "text": "Yeah."
    },
    {
      "start": 275.55,
      "end": 276.67,
      "text": "He likes it."
    },
    {
      "start": 276.89,
      "end": 277.33,
      "text": "완전."
    },
    {
      "start": 277.33,
      "end": 278.01,
      "text": "Oh yeah."
    },
    {
      "start": 278.07,
      "end": 279.61,
      "text": "What is it with the fins?"
