      "start": 286.89,
      "end": 287.67,
      "text": "a TV star"
    },
    {
      "start": 287.67,
      "end": 288.81,
      "text": "Yeah, 게다가"
    },
    {
      "start": 288.81,
      "end": 290.87,
      "text": "이스펜서라는 영화의"
    },
