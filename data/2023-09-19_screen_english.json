      "start": 290.87,
      "end": 292.51,
      "text": "파급 효과가"
    },
    {
      "start": 292.51,
      "end": 293.93,
      "text": "좀 굉장했잖아요"
    },
    {
      "start": 293.93,
      "end": 295.01,
      "text": "그래서 더"
    },
    {
      "start": 295.01,
      "end": 296.03,
      "text": "월드와이드하게"
    },
    {
      "start": 296.03,
      "end": 297.43,
      "text": "명성을 얻게 되지"
    },
    {
      "start": 297.43,
      "end": 298.55,
      "text": "않았나 싶습니다"
    },
    {
      "start": 298.55,
      "end": 300.35,
      "text": "He was also in a Netflix"
    },
    {
      "start": 300.35,
      "end": 301.33,
      "text": "romantic comedy"
    },
    {
      "start": 301.33,
      "end": 302.53,
      "text": "I saw this comedy"
