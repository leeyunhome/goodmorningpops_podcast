      "start": 538.59,
      "end": 539.49,
      "text": "문장인가 봐요"
    },
    {
      "start": 539.49,
      "end": 540.33,
      "text": "Two face"
    },
    {
      "start": 540.33,
      "end": 541.91,
      "text": "Evil and good"
    },
    {
      "start": 541.91,
      "end": 543.63,
      "text": "The public face"
    },
    {
      "start": 543.63,
      "end": 544.67,
      "text": "Public persona"
    },
    {
      "start": 544.67,
      "end": 546.11,
      "text": "And the private persona"
    },
    {
      "start": 546.11,
      "end": 547.11,
      "text": "그렇군요"
    },
    {
      "start": 547.11,
      "end": 547.61,
      "text": "피곤하죠"
    },
    {
      "start": 547.61,
      "end": 548.27,
      "text": "그렇죠"
    },
    {
      "start": 548.27,
      "end": 549.39,
      "text": "There has to be two of you"
    },
    {
      "start": 549.39,
      "end": 550.31,
      "text": "와이프한테"
    },
    {
      "start": 550.31,
      "end": 551.31,
      "text": "사모님한테"
    },
    {
      "start": 551.31,
      "end": 552.07,
      "text": "혹시 이렇게"
    },
    {
      "start": 552.07,
      "end": 554.21,
      "text": "투어 비유의 모습이 있으신지"
    },
    {
      "start": 554.21,
      "end": 555.57,
      "text": "그거 뭐 누구나"
    },
    {
      "start": 555.57,
      "end": 557.07,
      "text": "오늘 정도 있지 않아요"
    },
    {
      "start": 557.07,
      "end": 558.15,
      "text": "아 그렇군요"
    },
    {
      "start": 558.15,
      "end": 559.85,
      "text": "왠지 우리 크쌤은"
    },
    {
      "start": 559.85,
      "end": 560.87,
      "text": "그런 거 없어요"
    },
    {
      "start": 560.87,
      "end": 561.85,
      "text": "라고 하실 줄 알았는데"
    },
    {
      "start": 561.85,
      "end": 563.29,
      "text": "비슷비슷해요"
    },
    {
      "start": 563.29,
      "end": 563.77,
      "text": "비슷비슷해요"
    },
    {
      "start": 563.77,
      "end": 565.29,
      "text": "비슷해야 살기 편해요"
    },
    {
      "start": 565.29,
      "end": 567.39,
      "text": "너무 격차 나면"
    },
    {
      "start": 567.39,
      "end": 567.65,
      "text": "그렇죠"
    },
    {
      "start": 567.65,
      "end": 568.17,
      "text": "못해요"
    },
    {
      "start": 568.17,
      "end": 569.33,
      "text": "못 살겠어요"
    },
    {
      "start": 569.33,
      "end": 571.45,
      "text": "역시 이렇게 솔직함이"
    },
    {
      "start": 571.45,
      "end": 572.39,
      "text": "매력이신 것 같습니다"
    },
    {
      "start": 572.39,
      "end": 573.25,
      "text": "조쌤은요"
    },
    {
      "start": 573.25,
      "end": 574.53,
      "text": "저도 마찬가지예요"
    },
    {
      "start": 574.53,
      "end": 575.65,
      "text": "아 네"
    },
    {
      "start": 575.65,
      "end": 576.51,
      "text": "same same"
    },
    {
      "start": 576.51,
      "end": 578.05,
      "text": "one face"
    },
    {
      "start": 578.05,
      "end": 579.33,
      "text": "이렇게 웃음이 나오다니"
    },
    {
      "start": 579.33,
      "end": 581.25,
      "text": "일정먹은 face"
    },
    {
      "start": 581.25,
      "end": 583.29,
      "text": "네 아무도 몰라요"
    },
    {
      "start": 583.29,
      "end": 584.75,
      "text": "secret"
    },
    {
      "start": 584.75,
      "end": 587.33,
      "text": "다음 표현도 알려주시죠"
    },
    {
      "start": 587.33,
      "end": 587.81,
      "text": "아 네"
    },
    {
      "start": 587.81,
      "end": 590.03,
      "text": "We are given tasks"
    },
    {
      "start": 590.03,
      "end": 592.33,
      "text": "We are given tasks"
    },
    {
      "start": 592.33,
      "end": 593.55,
      "text": "우리에게는"
    },
    {
      "start": 593.55,
      "end": 595.41,
      "text": "주어진 임무가 있어"
    },
    {
      "start": 595.41,
      "end": 595.93,
      "text": "우리에겐"
    },
    {
      "start": 595.93,
      "end": 597.63,
      "text": "주어진 의무가 있어"
    },
    {
      "start": 597.63,
      "end": 598.61,
      "text": "라는 문장입니다"
    },
    {
      "start": 598.61,
      "end": 600.43,
      "text": "어떠한 뉘앙스로"
    },
    {
      "start": 600.43,
      "end": 601.39,
      "text": "이런 문장들을"
    },
    {
      "start": 601.39,
      "end": 602.31,
      "text": "이야기를 했는지는"
    },
    {
      "start": 602.31,
      "end": 603.61,
      "text": "다시 한번 들어보시면서"
    },
    {
      "start": 603.61,
      "end": 604.27,
      "text": "확인해 보세요"
    },
    {
      "start": 617.15,
      "end": 653.62,
      "text": "her husband was too harsh on her"
    },
    {
      "start": 653.62,
      "end": 654.26,
      "text": "Yeah"
    },
    {
      "start": 654.26,
      "end": 656.84,
      "text": "We can't live without love"
    },
    {
      "start": 656.84,
      "end": 657.4,
      "text": "Yeah"
    },
    {
      "start": 657.4,
      "end": 658.88,
      "text": "But he's just about business"
    },
    {
      "start": 658.88,
      "end": 659.56,
      "text": "그러니까요"
    },
    {
      "start": 659.56,
      "end": 661.2,
      "text": "Business of the royal family"
    },
    {
      "start": 661.2,
      "end": 663.88,
      "text": "You need to protect the royal family"
    },
    {
      "start": 663.88,
      "end": 666.86,
      "text": "한 여성의 입장으로"
    },
    {
      "start": 666.86,
      "end": 668.52,
      "text": "다이아나를 바라본다면"
    },
    {
      "start": 668.52,
      "end": 671.42,
      "text": "너무나도 지옥과 같은"
    },
    {
      "start": 671.42,
      "end": 673.52,
      "text": "그런 결혼생활이 아니었을까"
    },
    {
      "start": 673.52,
      "end": 674.56,
      "text": "생각합니다"
    },
    {
      "start": 674.56,
      "end": 675.52,
      "text": "Yes"
    },
    {
      "start": 675.52,
      "end": 676.56,
      "text": "Hell"
    },
    {
      "start": 676.56,
      "end": 678.92,
      "text": "자 다이아나가"
    },
    {
      "start": 678.92,
      "end": 680.72,
      "text": "이야기하는 말 들어보시죠"
    },
    {
      "start": 680.72,
      "end": 681.02,
      "text": "네"
    },
    {
      "start": 681.02,
      "end": 682.36,
      "text": "들어봅시다"
    },
    {
      "start": 682.36,
      "end": 684.13,
      "text": "I would like it"
    },
    {
      "start": 684.13,
      "end": 685.45,
      "text": "if you didn't make him"
    },
    {
      "start": 685.45,
      "end": 687.45,
      "text": "shoot real birds tomorrow"
    },
    {
      "start": 687.45,
      "end": 688.07,
      "text": "네"
    },
    {
      "start": 688.07,
      "end": 689.17,
      "text": "I would like it"
    },
    {
      "start": 689.17,
