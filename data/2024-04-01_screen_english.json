      "start": 523.36,
      "end": 524.06,
      "text": "다음요."
    },
    {
      "start": 524.06,
      "end": 524.36,
      "text": "오케이."
    },
    {
      "start": 525.24,
      "end": 527.2,
      "text": "Don't just let the current push you."
