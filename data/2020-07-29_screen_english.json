      "start": 129.8,
      "end": 133.82,
      "text": "and also the next film after Misbehavior"
    },
    {
      "start": 133.82,
      "end": 135.82,
      "text": "is also directed by a woman"
    },
    {
      "start": 135.82,
      "end": 138.76,
      "text": "and then another film after that"
    },
    {
      "start": 138.76,
      "end": 140.82,
      "text": "which she is currently negotiating"
