    },
    {
      "start": 420.06,
      "end": 422.16,
      "text": "거기도 물 나고 난리 났어요."
    },
    {
      "start": 422.16,
      "end": 422.54,
      "text": "맞아요."
    },
    {
      "start": 423.8,
