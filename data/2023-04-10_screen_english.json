    },
    {
      "start": 426.42,
      "end": 428.48,
      "text": "You don't know my human at all."
    },
    {
      "start": 428.82,
      "end": 428.96,
      "text": "네."
    },
    {
      "start": 429.22,
      "end": 431.72,
      "text": "이렇게 많은 이들 앞에서 외칩니다."
    },
    {
      "start": 431.98,
      "end": 433.9,
