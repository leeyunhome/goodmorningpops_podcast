    },
    {
      "start": 933.04,
      "end": 935.18,
      "text": "This time it's my way."
    },
    {
      "start": 935.8,
      "end": 936.64,
      "text": "My way."
    },
    {
      "start": 937.34,
      "end": 940.2,
      "text": "이번엔 내 방식대로 할 거예요."
    },
    {
      "start": 940.64,
      "end": 941.46,
      "text": "내 방식대로."
    },
    {
      "start": 943.08,
      "end": 948.08,
      "text": "자신의 주관이 아주 철저히 느껴지는 가사였습니다."
    },
    {
      "start": 948.08,
      "end": 951.08,
      "text": "Be a little proper, they say."
