    },
    {
      "start": 923.6,
      "end": 924.4,
      "text": "여기서 들으셨죠?"
    },
    {
      "start": 925.2,
      "end": 926.52,
      "text": "오는 게 있으면"
    },
    {
      "start": 926.52,
      "end": 928.84,
      "text": "가는 게 있어야 한다고 하죠."
    },
    {
