  "script": [
    {
      "start": 0.0,
      "end": 1.88,
      "text": "조정현의 굿모닝 팝스"
    },
    {
      "start": 1.88,
      "end": 16.18,
      "text": "Think of all the beauties still left around you and be happy."
    },
    {
      "start": 17.36,
      "end": 22.6,
      "text": "주위에 아직 남아있는 아름다운 모든 것을 생각하고 즐거워하라."
    },
    {
      "start": 23.8,
      "end": 26.88,
      "text": "안내의 일기를 쓴 앤 프랑크가 한 말입니다."
    },
    {
      "start": 28.39,
      "end": 32.79,
      "text": "이미 사라져버린 것이나 아직 갖지 못한 것에 집착하면"
    },
    {
      "start": 32.79,
      "end": 38.57,
      "text": "지금 현재 우리 곁에 있는 아름다운 것들은 눈에 들어오지 않겠죠."
    },
    {
      "start": 38.57,
      "end": 44.99,
      "text": "지금 이 순간을 온전히 즐기고 모든 것에 감사한 마음을 갖고 싶다면"
    },
    {
      "start": 44.99,
      "end": 49.23,
      "text": "눈을 크게 뜨고 잠시 주위를 둘러보세요."
    },
    {
      "start": 50.73,
      "end": 56.13,
      "text": "이전엔 보이지 않았던 소중하고 아름다운 것들이 눈에 들어올지도 모르니까요."
    },
    {
      "start": 57.34,
      "end": 59.76,
      "text": "주말 아침을 특별하게 보낼 수 있는 방법"
    },
    {
      "start": 59.76,
      "end": 64.38,
      "text": "Think of all the beauty still left around you and be happy."
    },
    {
      "start": 65.35,
      "end": 67.31,
      "text": "조정현의 굿모닝 팝스 시작하겠습니다."
    },
    {
      "start": 67.31,
      "end": 74.99,
      "text": "첫 곡으로 마더나의 뮤직 들어보셨습니다."
    },
    {
      "start": 76.83,
      "end": 77.07,
      "text": "김정아님"
    },
    {
      "start": 77.07,
      "end": 80.81,
      "text": "모처럼 휴일에 굿모닝 팝스 듣고 자려고"
    },
    {
      "start": 80.81,
      "end": 83.11,
      "text": "잠깐 일어나서 듣고 있어요."
    },
    {
      "start": 83.59,
      "end": 85.25,
      "text": "너무 생생하고 재밌네요."
    },
    {
      "start": 86.23,
      "end": 89.37,
      "text": "침대에서 편안히 들으니 이게 바로 행복이죠."
    },
    {
      "start": 89.87,
      "end": 90.95,
      "text": "감사해요. 정현쌤"
    },
    {
      "start": 90.95,
      "end": 99.51,
      "text": "우리 정아님 지금 소확행으로 잘 즐기고 계시는 모습 저도 상상 중입니다."
    },
    {
      "start": 101.05,
      "end": 104.35,
      "text": "일요일에도 이렇게 변함없이 함께해 주셔서 너무 감사해요."
    },
    {
      "start": 105.35,
      "end": 111.17,
      "text": "오늘 하루 종일 휴일이라는 의미가 아주 행복이잖아요."
    },
    {
      "start": 111.25,
      "end": 111.93,
      "text": "소확행"
    },
    {
      "start": 111.93,
      "end": 115.43,
      "text": "이 행복을 만끽하시길 바랍니다."
    },
    {
      "start": 116.75,
      "end": 117.91,
      "text": "송경진님"
    },
    {
      "start": 117.91,
      "end": 121.25,
      "text": "영어 회화의 길은 길고 머네요."
    },
    {
      "start": 122.05,
      "end": 125.63,
      "text": "입안에서만 맴도는 아직 옹알이 수준인 것 같아요."
    },
    {
      "start": 126.63,
      "end": 131.31,
      "text": "정현쌤만큼 피, 땀, 눈물의 노력을 하지 않아서겠죠?"
    },
    {
      "start": 132.15,
      "end": 135.23,
      "text": "굳어진 혀가 내 뜻대로 움직이지 않네요."
    },
    {
      "start": 135.23,
      "end": 139.83,
      "text": "그래도 포기하지 않고 영어 회화에 박차를 가하려고요."
    },
    {
      "start": 140.71,
      "end": 143.55,
      "text": "첫 번째 꿈은 외국 자유여행하기랍니다."
    },
    {
      "start": 144.17,
      "end": 145.21,
      "text": "5년 계획이에요."
    },
    {
      "start": 145.93,
      "end": 147.23,
      "text": "쌤 응원해 주세요."
    },
    {
      "start": 148.23,
      "end": 153.53,
      "text": "5년 계획이시면 지금부터 준비하시면 충분히 하실 수 있어요."
    },
    {
      "start": 154.21,
      "end": 156.97,
      "text": "아마 그것보다도 훨씬 더 빨리 이루실 것 같은데요."
    },
    {
      "start": 158.05,
      "end": 160.79,
      "text": "왜냐하면 특히 여행 영어라는 것은 더 그런 것 같아요."
    },
    {
      "start": 160.79,
      "end": 165.35,
      "text": "우리가 직접 말하는 모습을 상상을 하면서"
    },
    {
      "start": 165.35,
      "end": 168.55,
      "text": "그러니까 감정을 이입하면서 하기에도 되게 좋잖아요."
    },
    {
      "start": 170.19,
      "end": 172.71,
      "text": "일정을 예약을 해놓으시고"
    },
    {
      "start": 172.71,
      "end": 177.05,
      "text": "그 일정이 점점 다가올수록 더 몰입이 되고 긴장도 되니까"
    },
    {
      "start": 177.05,
      "end": 180.05,
      "text": "더 잘 해내실 수 있을 겁니다."
    },
    {
      "start": 181.73,
      "end": 186.01,
      "text": "일단 5년 이내로 예매 준비하고 계시면 좋을 것 같고"
    },
    {
      "start": 186.01,
      "end": 190.79,
      "text": "또 설레는 마음으로 저랑 같이 쭉 해보시면 좋을 것 같아요."
    },
    {
      "start": 192.28,
      "end": 194.08,
      "text": "그리고 아까 말씀하신 것처럼 저는"
    },
    {
      "start": 194.08,
      "end": 196.76,
      "text": "이 영어 때문에 피, 땀, 눈물"
    },
    {
      "start": 196.76,
      "end": 198.92,
      "text": "아 진짜 다 흘렸습니다."
    },
    {
      "start": 199.64,
      "end": 203.16,
      "text": "피, 특히 입술을 깨물다가 피도 한 번 흘려봤고"
    },
    {
      "start": 203.16,
      "end": 205.72,
      "text": "땀, 눈물 다 와닿네요."
    },
    {
      "start": 206.56,
      "end": 210.26,
      "text": "그래도 저만큼 그렇게까지 고생은 안 하시게끔"
    },
    {
      "start": 210.9,
      "end": 214.12,
      "text": "제가 최대한 노하우로 전해드리도록 할게요."
    },
    {
      "start": 214.12,
      "end": 215.02,
      "text": "화이팅입니다."
    },
    {
      "start": 215.02,
      "end": 217.46,
      "text": "사연 소개되신 두 분께는"
    },
    {
      "start": 217.46,
      "end": 220.16,
      "text": "월간 굿모닝팝 3개월 구독권 보내드릴게요."
    },
    {
      "start": 221.14,
      "end": 223.7,
      "text": "이렇게 굿모닝팝스에 사연 보내고 싶으신 분들은"
    },
    {
      "start": 223.7,
      "end": 226.4,
      "text": "홈페이지 청취자 게시판에 남겨주세요."
    },
    {
      "start": 227.18,
      "end": 228.66,
      "text": "실시간으로 두고 계신 분들은"
    },
    {
      "start": 228.66,
      "end": 230.48,
      "text": "지금 바로 참여하실 수 있습니다."
    },
    {
      "start": 231.2,
      "end": 234.04,
      "text": "단문 50원과 장문 100원에 추가 요금이 부과되는"
    },
    {
      "start": 234.04,
      "end": 236.6,
      "text": "KBS 쿨 FM 문자샵 8910"
    },
    {
      "start": 236.6,
      "end": 240.92,
      "text": "아니면 KBS 2라디오 문자샵 1061로 보내주시거나"
    },
    {
      "start": 240.92,
      "end": 244.88,
      "text": "무료 KBS 애플리케이션 콩 또는 마이케이로 참여해주세요."
    },
    {
      "start": 245.02,
      "end": 253.73,
      "text": "일아침 6시"
    },
    {
      "start": 253.73,
      "end": 257.49,
      "text": "조정현의 굿모닝팝스"
    },
    {
      "start": 257.49,
      "end": 261.81,
      "text": "해봐요 굿모닝"
    },
    {
      "start": 261.81,
      "end": 266.33,
      "text": "조정현의 굿모닝팝스"
    },
    {
      "start": 267.55,
