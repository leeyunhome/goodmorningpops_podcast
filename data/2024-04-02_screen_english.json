    {
      "start": 680.84,
      "end": 682.96,
      "text": "You could at least say"
    },
    {
      "start": 682.96,
      "end": 684.1,
      "text": "excuse me"
    },
    {
      "start": 684.1,
      "end": 685.8,
      "text": "지나가는 카탉을 향해서 하는 말입니다"
