      "start": 125.15,
      "end": 126.95,
      "text": "Franklin Pope"
    },
    {
      "start": 126.95,
      "end": 128.21,
      "text": "Yeah, like the Pope"
    },
    {
      "start": 128.21,
      "end": 129.15,
      "text": "Like the 황"
    },
    {
      "start": 129.15,
      "end": 129.69,
      "text": "뭐라고 하냐"
    },
    {
