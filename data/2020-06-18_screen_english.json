    {
      "start": 97.75,
      "end": 98.41,
      "text": "에디슨이"
    },
    {
      "start": 98.41,
      "end": 101.43,
      "text": "결국 그런 사고가 발생하게 되죠"
    },
    {
      "start": 101.43,
      "end": 103.21,
      "text": "He died of electrocution"
    },
    {
      "start": 103.21,
      "end": 104.89,
      "text": "by 3000 volts"
    },
    {
      "start": 104.89,
      "end": 107.37,
      "text": "in his basement in his own house"
    },
    {
      "start": 107.37,
      "end": 112.71,
      "text": "진짜 한 번의 정전이 탁 되는 그런 장면이 기억이 납니다"
    },
    {
      "start": 112.71,
      "end": 113.35,
      "text": "Yeah"
    },
    {
      "start": 113.35,
      "end": 115.09,
      "text": "So Edison's warnings"
