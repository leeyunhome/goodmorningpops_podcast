    {
      "start": 117.85,
      "end": 118.33,
      "text": "Yeah"
    },
    {
      "start": 118.33,
      "end": 119.89,
      "text": "미리 다 예측을 했잖아요"
    },
    {
      "start": 119.89,
      "end": 122.95,
      "text": "근데 이 사람 이름이 Franklin Pope라는 사람인데"
