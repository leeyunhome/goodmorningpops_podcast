{
  "id": "2020-06-29_screen_english",
  "date": "2020-06-29",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "커런트 워 (The Current War)",
  "duration_sec": 873.26,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2020-06-29_screen_english.mp3",
  "script": [
    {
      "start": 0.0,
      "end": 5.72,
      "text": "하나라도 제대로 하자는 마음으로 이번 한 주도 힘차게 시작해봐요."
    },
    {
      "start": 5.72,
      "end": 11.38,
      "text": "6월 29일 월요일 조정현의 굿모닝 팝스 시작하겠습니다."
    },
    {
      "start": 11.38,
      "end": 74.52,
      "text": "영화 랄랄랜드 딱 떠오르지 않으십니까?"
    },
    {
      "start": 74.62,
      "end": 77.02,
      "text": "아, 라라랜드이신 줄 알았다고요?"
    },
    {
      "start": 77.42,
      "end": 81.4,
      "text": "영어적인 표현으로는 랄랄랜드라고 해주셔야 되겠죠?"
    },
    {
      "start": 81.56,
      "end": 83.0,
      "text": "우리 GM Peers이니까"
    },
    {
      "start": 83.0,
      "end": 88.46,
      "text": "네, 랄랄랜드 캐스티의 Another Day of Sun 이라는 곡이었어요."
    },
    {
      "start": 88.46,
      "end": 91.68,
      "text": "이 영화의 첫 장면이었죠."
    },
    {
      "start": 92.12,
      "end": 95.02,
      "text": "저도 정말 인상 깊게 봤던 장면이었는데요."
    },
    {
      "start": 96.24,
      "end": 98.32,
      "text": "그 이후로도 이 노래만 딱 들으면"
    },
    {
      "start": 98.32,
      "end": 102.64,
      "text": "그 첫 장면이 뮤지컬로 딱 연상되는 그런 매력이 있더라고요."
    },
    {
      "start": 102.64,
      "end": 107.12,
      "text": "As morning rolls around, another day of sun."
    },
    {
      "start": 107.98,
      "end": 110.44,
      "text": "여러분, 아침은 다시 돌아오고"
    },
    {
      "start": 110.44,
      "end": 112.94,
      "text": "오늘의 새로운 태양이 뜹니다."
    },
    {
      "start": 112.94,
      "end": 114.78,
      "text": "자, 우리 청취자 여러분"
    },
    {
      "start": 114.78,
      "end": 116.84,
      "text": "눈을 뜨십시오."
    },
    {
      "start": 119.12,
      "end": 120.04,
      "text": "1261님"
    },
    {
      "start": 120.04,
      "end": 123.1,
      "text": "아침 운동 가면서 영어 공부할 겸"
    },
    {
      "start": 123.1,
      "end": 124.64,
      "text": "GMP 듣기 시작했는데"
    },
    {
      "start": 124.64,
      "end": 125.68,
      "text": "너무 좋아요."
    },
    {
      "start": 126.5,
      "end": 128.8,
      "text": "라디오 방송에 처음으로 문자 보내는데요."
    },
    {
      "start": 129.48,
      "end": 131.34,
      "text": "한 번만 읽어주세요."
    },
    {
      "start": 132.38,
      "end": 134.28,
      "text": "아휴, 한 번만 읽어주세요."
    },
    {
      "start": 134.36,
      "end": 136.74,
      "text": "라고 애교스럽게 또 보내주셨네요."
    },
    {
      "start": 137.44,
      "end": 138.32,
      "text": "1261님"
    },
    {
      "start": 138.32,
      "end": 140.22,
      "text": "운동 어떤 거 하세요?"
    },
    {
      "start": 140.22,
      "end": 143.88,
      "text": "운동하러 가실 때 GMP를 들으시고"
    },
    {
      "start": 143.88,
      "end": 146.88,
      "text": "에너지가 팍팍 충전되시면 좋겠어요."
    },
    {
      "start": 147.68,
      "end": 149.24,
      "text": "앞으로도 함께 해주세요."
    },
    {
      "start": 150.06,
      "end": 151.18,
      "text": "박규영님"
    },
    {
      "start": 151.18,
      "end": 154.22,
      "text": "호주에 있는 첫째 딸과 통화하는데"
    },
    {
      "start": 154.22,
      "end": 157.88,
      "text": "갑자기 우리 외국인 사위 호서방이"
    },
    {
      "start": 157.88,
      "end": 161.2,
      "text": "영어로 블라블라블라 말을 걸어서 당황했어요."
    },
    {
      "start": 162.02,
      "end": 164.08,
      "text": "좀 더 열심히 영어 공부해야겠다는"
    },
    {
      "start": 164.08,
      "end": 165.38,
      "text": "굳은 다짐을 하고"
    },
    {
      "start": 165.38,
      "end": 166.76,
      "text": "GMP 고정합니다."
    },
    {
      "start": 167.08,
      "end": 167.84,
      "text": "웃음!"
    },
    {
      "start": 167.84,
      "end": 170.32,
      "text": "어머, 호서방"
    },
    {
      "start": 170.32,
      "end": 171.66,
      "text": "이거 애칭인가요?"
    },
    {
      "start": 171.82,
      "end": 172.34,
      "text": "별칭?"
    },
    {
      "start": 172.54,
      "end": 173.56,
      "text": "너무 재밌네요."
    },
    {
      "start": 174.32,
      "end": 176.3,
      "text": "다음에 호서방님과"
    },
    {
      "start": 176.3,
      "end": 178.12,
      "text": "전화 통화하실 때"
    },
    {
      "start": 178.12,
      "end": 181.02,
      "text": "미리 이렇게 딱 준비해 두셨다가"
    },
    {
      "start": 181.02,
      "end": 181.92,
      "text": "말씀해 보시면"
    },
    {
      "start": 181.92,
      "end": 183.92,
      "text": "진짜 깜짝 놀랄걸요?"
    },
    {
      "start": 184.34,
      "end": 185.56,
      "text": "엄지척 할 거예요."
    },
    {
      "start": 185.56,
      "end": 186.92,
      "text": "아마 따님도"
    },
    {
      "start": 186.92,
      "end": 189.7,
      "text": "어머니를 아주 자랑스러워할 것 같고요."
    },
    {
      "start": 190.28,
      "end": 191.08,
      "text": "박규영님"
    },
    {
      "start": 191.08,
      "end": 192.14,
      "text": "화이팅입니다."
    },
    {
      "start": 193.1,
      "end": 194.62,
      "text": "사연 보내주신 분들 모두"
    },
    {
      "start": 194.62,
      "end": 195.82,
      "text": "월간 굿모닝 팝"
    },
    {
      "start": 195.82,
      "end": 197.52,
      "text": "3개월 구독권 보내드릴게요."
    },
    {
      "start": 198.3,
      "end": 200.64,
      "text": "굿모닝 팝스의 사연 보내고 싶은 분들"
    },
    {
      "start": 200.64,
      "end": 203.54,
      "text": "공식 홈페이지 청취자 게시판에 남겨주세요."
    },
    {
      "start": 204.52,
      "end": 207.6,
      "text": "여러분의 잃어버린 아침을 찾아드립니다."
    },
    {
      "start": 208.6,
      "end": 210.36,
      "text": "정말 아침 시간을 찾으면"
    },
    {
      "start": 210.36,
      "end": 212.3,
      "text": "매일매일이 보람차죠."
    },
    {
      "start": 212.3,
      "end": 213.96,
      "text": "그래서 준비한"
    },
    {
      "start": 213.96,
      "end": 216.12,
      "text": "아침 6시에 전송되는"
    },
    {
      "start": 216.12,
      "end": 218.3,
      "text": "커피 모바일 쿠폰"
    },
    {
      "start": 218.3,
      "end": 220.36,
      "text": "행운의 커피 알람 이벤트"
    },
    {
      "start": 220.36,
      "end": 223.8,
      "text": "내일 꼭꼭 쿠폰 받고 싶으신 분들은"
    },
    {
      "start": 223.8,
      "end": 226.32,
      "text": "지금부터 방송이 끝날 때까지"
    },
    {
      "start": 226.32,
      "end": 228.54,
      "text": "계속해서 신청해 주시면 됩니다."
    },
    {
      "start": 229.28,
      "end": 231.2,
      "text": "총 10분 뽑을 거거든요."
    },
    {
      "start": 231.94,
      "end": 234.0,
      "text": "단문 50원과 장문 100원에"
    },
    {
      "start": 234.0,
      "end": 235.2,
      "text": "추가요금이 부과되는"
    },
    {
      "start": 235.2,
      "end": 238.42,
      "text": "KBS 쿨 FM 문자 샵 8910"
    },
    {
      "start": 238.42,
      "end": 242.98,
      "text": "아니면 KBS 이라디오 문자 샵 1061로 보내주시거나"
    },
    {
      "start": 242.98,
      "end": 247.68,
      "text": "무료 KBS 어플리케이션 콩 또는 마이케이로 참여하실 수도 있습니다."
    },
    {
      "start": 247.68,
      "end": 310.72,
      "text": "6월에 함께하고 있는 영화는"
    },
    {
      "start": 310.72,
      "end": 313.18,
      "text": "발명왕 에디슨을 둘러싼"
    },
    {
      "start": 313.18,
      "end": 315.48,
      "text": "역사적인 전류전쟁 이야기"
    },
    {
      "start": 315.48,
      "end": 317.22,
      "text": "The Current War"
    },
    {
      "start": 317.22,
      "end": 320.64,
      "text": "우리 크리스 씨의 인기척을"
    },
    {
      "start": 320.64,
      "end": 322.8,
      "text": "임의도 느끼고 계신 분들 계실 겁니다."
    },
    {
      "start": 323.06,
      "end": 324.14,
      "text": "이 시간은 기다리셨죠?"
    },
    {
      "start": 324.26,
      "end": 324.84,
      "text": "I'm here."
    },
    {
      "start": 325.58,
      "end": 326.32,
      "text": "Good morning, everyone."
    },
    {
      "start": 326.84,
      "end": 328.44,
      "text": "Welcome to a brand new week."
    },
    {
      "start": 328.62,
      "end": 330.02,
      "text": "Beautiful Monday morning."
    },
    {
      "start": 330.16,
      "end": 330.72,
      "text": "그렇습니다."
    },
    {
      "start": 331.04,
      "end": 332.64,
      "text": "월요일도 이렇게 아름답게"
    },
    {
      "start": 332.64,
      "end": 334.1,
      "text": "아침을 맞이할 수 있는"
    },
    {
      "start": 334.1,
      "end": 336.08,
      "text": "우리 GMP, 맞죠?"
    },
    {
      "start": 336.5,
      "end": 337.04,
      "text": "Yes, GMP."
    },
    {
      "start": 337.52,
      "end": 339.04,
      "text": "I think this movie"
    },
    {
      "start": 339.04,
      "end": 340.54,
      "text": "우리가 계속 The Current War"
    },
    {
      "start": 340.54,
      "end": 342.04,
      "text": "이라는 영화를 알아보고 있는데"
    },
    {
      "start": 342.04,
      "end": 343.32,
      "text": "it's very informative."
    },
    {
      "start": 343.74,
      "end": 343.9,
      "text": "그쵸?"
    },
    {
      "start": 344.02,
      "end": 345.1,
      "text": "Informative, yes."
    },
    {
      "start": 345.42,
      "end": 346.46,
      "text": "Historically informative."
    },
    {
      "start": 346.46,
      "end": 346.96,
      "text": "Yeah."
    },
    {
      "start": 347.16,
      "end": 348.82,
      "text": "And it really inspired me"
    },
    {
      "start": 348.82,
      "end": 350.58,
      "text": "to be more passionate"
    },
    {
      "start": 350.58,
      "end": 353.28,
      "text": "and more about life."
    },
    {
      "start": 353.42,
      "end": 354.08,
      "text": "Ah, life."
    },
    {
      "start": 354.26,
      "end": 355.32,
      "text": "Stick to one thing,"
    },
    {
      "start": 355.54,
      "end": 356.96,
      "text": "be passionate about it,"
    },
    {
      "start": 357.04,
      "end": 358.96,
      "text": "and have grit."
    },
    {
      "start": 359.22,
      "end": 359.64,
      "text": "Yeah."
    },
    {
      "start": 359.68,
      "end": 360.76,
      "text": "Do you know what grit is?"
    },
    {
      "start": 360.88,
      "end": 361.5,
      "text": "Yeah, yeah."
    },
    {
      "start": 361.58,
      "end": 362.98,
      "text": "G-R-I-T, grit."
    },
    {
      "start": 362.98,
      "end": 365.38,
      "text": "어떻게 표현할 수 있을까요?"
    },
    {
      "start": 365.58,
      "end": 367.04,
      "text": "I'm reading a book about grit."
    },
    {
      "start": 367.22,
      "end": 370.6,
      "text": "Grit is basically passion plus perseverance."
    },
    {
      "start": 370.9,
      "end": 371.18,
      "text": "Yeah."
    },
    {
      "start": 371.24,
      "end": 372.04,
      "text": "Not giving up."
    },
    {
      "start": 372.1,
      "end": 372.38,
      "text": "Yeah."
    },
    {
      "start": 372.74,
      "end": 373.88,
      "text": "So when it comes to language,"
    },
    {
      "start": 373.98,
      "end": 374.2,
      "text": "Yeah."
    },
    {
      "start": 374.48,
      "end": 376.52,
      "text": "Grit is the most important thing."
    },
    {
      "start": 376.52,
      "end": 376.84,
      "text": "그렇습니다."
    },
    {
      "start": 376.84,
      "end": 378.88,
      "text": "여러분, 정말 열정을 넘은"
    },
    {
      "start": 378.88,
      "end": 380.76,
      "text": "뭔가 이런 불타오르는"
    },
    {
      "start": 380.76,
      "end": 382.5,
      "text": "그런 심장을 가지실 수 있으면"
    },
    {
      "start": 382.5,
      "end": 383.12,
      "text": "좋을 것 같아요."
    },
    {
      "start": 383.22,
      "end": 384.18,
      "text": "이 영화를 통해서요."
    },
    {
      "start": 385.04,
      "end": 387.22,
      "text": "정말 과학적인 그런 역사적인"
    },
    {
      "start": 387.22,
      "end": 389.42,
      "text": "상식까지 풍부해진 기분입니다."
    },
    {
      "start": 389.52,
      "end": 391.38,
      "text": "Oh, and we're learning about science, too."
    },
    {
      "start": 391.5,
      "end": 391.86,
      "text": "Yeah."
    },
    {
      "start": 392.3,
      "end": 394.48,
      "text": "Yeah, basic scientific knowledge."
    },
    {
      "start": 394.64,
      "end": 395.82,
      "text": "It can be difficult,"
    },
    {
      "start": 396.06,
      "end": 398.58,
      "text": "but one step at a time."
    },
    {
      "start": 398.58,
      "end": 399.22,
      "text": "맞아요."
    },
    {
      "start": 399.7,
      "end": 401.02,
      "text": "그리고 저는 이제"
    },
    {
      "start": 401.02,
      "end": 403.46,
      "text": "배우들하고 헤어지려고 생각하니까"
    },
    {
      "start": 403.46,
      "end": 404.3,
      "text": "좀 아쉬운데"
    },
    {
      "start": 404.3,
      "end": 406.18,
      "text": "이게 역사적으로는"
    },
    {
      "start": 406.18,
      "end": 407.9,
      "text": "에디슨이 전류전쟁에서"
    },
    {
      "start": 407.9,
      "end": 408.68,
      "text": "패하잖아요."
    },
    {
      "start": 408.96,
      "end": 410.16,
      "text": "승리하지 못하잖아요."
    },
    {
      "start": 410.2,
      "end": 410.7,
      "text": "He lost."
    },
    {
      "start": 410.9,
      "end": 411.18,
      "text": "Yeah."
    },
    {
      "start": 411.46,
      "end": 413.7,
      "text": "하지만 저는 에디슨이"
    },
    {
      "start": 413.7,
      "end": 414.62,
      "text": "패한 것보다는"
    },
    {
      "start": 414.62,
      "end": 416.12,
      "text": "베네딕트 컴버뱅치를"
    },
    {
      "start": 416.12,
      "end": 418.08,
      "text": "더 이상 그 아름다운"
    },
    {
      "start": 418.08,
      "end": 419.42,
      "text": "패스네이팅 목소리를"
    },
    {
      "start": 419.42,
      "end": 421.28,
      "text": "못 들어서 너무 아쉬워요."
    },
    {
      "start": 421.48,
      "end": 422.86,
      "text": "Mr. Cumberbatch."
    },
    {
      "start": 422.92,
      "end": 423.68,
      "text": "I'm so sad."
    },
    {
      "start": 423.74,
      "end": 424.36,
      "text": "It's okay."
    },
    {
      "start": 424.56,
      "end": 426.02,
      "text": "He's a popular actor."
    },
    {
      "start": 426.14,
      "end": 427.14,
      "text": "I'm sure he'll be back"
    },
    {
      "start": 427.14,
      "end": 428.4,
      "text": "in another great movie."
    },
    {
      "start": 428.58,
      "end": 429.46,
      "text": "Very soon."
    },
    {
      "start": 429.54,
      "end": 430.9,
      "text": "I'm looking forward to it."
    },
    {
      "start": 431.0,
      "end": 432.38,
      "text": "Yes, look forward to it."
    },
    {
      "start": 432.5,
      "end": 432.7,
      "text": "네."
    },
    {
      "start": 433.18,
      "end": 434.04,
      "text": "자, 그럼 오늘 내용"
    },
    {
      "start": 434.04,
      "end": 434.9,
      "text": "먼저 듣고 오겠습니다."
    },
    {
      "start": 436.07,
      "end": 436.89,
      "text": "I only wondered"
    },
    {
      "start": 436.89,
      "end": 437.77,
      "text": "what it felt like."
    },
    {
      "start": 438.13,
      "end": 438.39,
      "text": "What?"
    },
    {
      "start": 438.63,
      "end": 439.13,
      "text": "The bulb."
    },
    {
      "start": 439.75,
      "end": 440.33,
      "text": "When you knew."
    },
    {
      "start": 440.91,
      "end": 441.93,
      "text": "What was the feeling"
    },
    {
      "start": 441.93,
      "end": 442.63,
      "text": "in that moment?"
    },
    {
      "start": 443.17,
      "end": 443.91,
      "text": "I can't tell you."
    },
    {
      "start": 444.03,
      "end": 444.23,
      "text": "I mean,"
    },
    {
      "start": 445.11,
      "end": 446.33,
      "text": "impossible to describe"
    },
    {
      "start": 446.33,
      "end": 446.97,
      "text": "the feeling"
    },
    {
      "start": 446.97,
      "end": 448.63,
      "text": "because it was impossible."
    },
    {
      "start": 450.26,
      "end": 450.64,
      "text": "Ooh."
    },
    {
      "start": 451.61,
      "end": 452.05,
      "text": "A meeting."
    },
    {
      "start": 452.25,
      "end": 452.99,
      "text": "This is a big,"
    },
    {
      "start": 452.99,
      "end": 454.41,
      "text": "big encounter."
    },
    {
      "start": 454.65,
      "end": 455.03,
      "text": "Yeah."
    },
    {
      "start": 455.19,
      "end": 456.07,
      "text": "Between the two"
    },
    {
      "start": 456.07,
      "end": 457.05,
      "text": "big rivals."
    },
    {
      "start": 457.31,
      "end": 457.53,
      "text": "Uh-huh."
    },
    {
      "start": 457.63,
      "end": 459.11,
      "text": "Westinghouse and Edison."
    },
    {
      "start": 459.43,
      "end": 460.03,
      "text": "Yeah, right."
    },
    {
      "start": 460.09,
      "end": 460.83,
      "text": "At the fair."
    },
    {
      "start": 460.95,
      "end": 461.21,
      "text": "Yeah."
    },
    {
      "start": 461.47,
      "end": 462.11,
      "text": "지금 아주"
    },
    {
      "start": 462.11,
      "end": 463.63,
      "text": "박람회에서"
    },
    {
      "start": 463.63,
      "end": 464.59,
      "text": "이 두 사람이"
    },
    {
      "start": 464.59,
      "end": 465.67,
      "text": "탁 마주친"
    },
    {
      "start": 465.67,
      "end": 466.61,
      "text": "그런 장면입니다."
    },
    {
      "start": 467.15,
      "end": 467.39,
      "text": "그리고"
    },
    {
      "start": 467.39,
      "end": 468.19,
      "text": "Westinghouse가"
    },
    {
      "start": 468.19,
      "end": 469.27,
      "text": "질문을 막 하는데요."
    },
    {
      "start": 470.09,
      "end": 471.59,
      "text": "특히 에디슨이"
    },
    {
      "start": 471.59,
      "end": 472.61,
      "text": "전구에 처음"
    },
    {
      "start": 472.61,
      "end": 474.19,
      "text": "탁 불이 켜졌을 때"
    },
    {
      "start": 474.19,
      "end": 474.63,
      "text": "순간"
    },
    {
      "start": 474.63,
      "end": 475.91,
      "text": "기분이 어땠는지를"
    },
    {
      "start": 475.91,
      "end": 476.79,
      "text": "막 묻고 있잖아요."
    },
    {
      "start": 476.79,
      "end": 478.05,
      "text": "Isn't that incredible?"
    },
    {
      "start": 478.37,
      "end": 478.57,
      "text": "Wow."
    },
    {
      "start": 478.65,
      "end": 478.95,
      "text": "I mean,"
    },
    {
      "start": 479.05,
      "end": 480.33,
      "text": "he's his arch rival."
    },
    {
      "start": 480.47,
      "end": 480.83,
      "text": "Uh-huh."
    },
    {
      "start": 480.91,
      "end": 481.91,
      "text": "His biggest enemy,"
    },
    {
      "start": 482.03,
      "end": 482.75,
      "text": "business enemy."
    },
    {
      "start": 482.93,
      "end": 483.17,
      "text": "Yeah."
    },
    {
      "start": 483.35,
      "end": 484.83,
      "text": "But he has a very"
    },
    {
      "start": 484.83,
      "end": 486.83,
      "text": "clever and good question."
    },
    {
      "start": 486.95,
      "end": 487.21,
      "text": "Yeah."
    },
    {
      "start": 487.31,
      "end": 488.05,
      "text": "And he shows"
    },
    {
      "start": 488.05,
      "end": 488.85,
      "text": "his respect"
    },
    {
      "start": 488.85,
      "end": 489.83,
      "text": "for Edison."
    },
    {
      "start": 490.07,
      "end": 490.35,
      "text": "Yeah."
    },
    {
      "start": 490.47,
      "end": 490.97,
      "text": "So I think"
    },
    {
      "start": 490.97,
      "end": 491.91,
      "text": "they respect each other."
    },
    {
      "start": 491.99,
      "end": 492.25,
      "text": "Uh-huh."
    },
    {
      "start": 492.25,
      "end": 492.69,
      "text": "At least"
    },
    {
      "start": 492.69,
      "end": 493.59,
      "text": "Westinghouse"
    },
    {
      "start": 493.59,
      "end": 494.77,
      "text": "respects Edison."
    },
    {
      "start": 494.77,
      "end": 495.59,
      "text": "Sounds so cool."
    },
    {
      "start": 495.59,
      "end": 496.89,
      "text": "진짜 멋진 것 같아요."
    },
    {
      "start": 497.17,
      "end": 497.49,
      "text": "I think"
    },
    {
      "start": 497.49,
      "end": 498.71,
      "text": "Westinghouse는요."
    },
    {
      "start": 498.77,
      "end": 500.47,
      "text": "좀 드문 캐릭터인 것 같아요."
    },
    {
      "start": 500.59,
      "end": 500.77,
      "text": "왜냐하면"
    },
    {
      "start": 500.77,
      "end": 502.11,
      "text": "He's a businessman."
    },
    {
      "start": 502.39,
      "end": 502.69,
      "text": "Yes."
    },
    {
      "start": 502.87,
      "end": 504.59,
      "text": "And has a humble personality."
    },
    {
      "start": 504.79,
      "end": 505.15,
      "text": "Yes."
    },
    {
      "start": 505.17,
      "end": 505.89,
      "text": "At the same time."
    },
    {
      "start": 506.23,
      "end": 507.79,
      "text": "He's a special character."
    },
    {
      "start": 507.99,
      "end": 508.31,
      "text": "Yeah."
    },
    {
      "start": 508.61,
      "end": 510.47,
      "text": "볼수록 매력적인 캐릭터인데요."
    },
    {
      "start": 511.03,
      "end": 511.87,
      "text": "일단 표현들"
    },
    {
      "start": 511.87,
      "end": 512.93,
      "text": "먼저 살펴볼까요?"
    },
    {
      "start": 513.65,
      "end": 514.33,
      "text": "Wondered."
    },
    {
      "start": 514.55,
      "end": 514.77,
      "text": "Yeah."
    },
    {
      "start": 515.05,
      "end": 515.77,
      "text": "Wondered"
    },
    {
      "start": 515.77,
      "end": 517.85,
      "text": "라는 단어가 들릴 텐데"
    },
    {
      "start": 517.85,
      "end": 520.37,
      "text": "궁금해하다라고 할 때도"
    },
    {
      "start": 520.37,
      "end": 521.61,
      "text": "wonder을 쓸 수가 있고"
    },
    {
      "start": 521.61,
      "end": 522.23,
      "text": "뭐 뭐"
    },
    {
      "start": 522.23,
      "end": 523.91,
      "text": "일지 모르겠다라고 할 때도"
    },
    {
      "start": 523.91,
      "end": 524.59,
      "text": "쓸 수 있고"
    },
    {
      "start": 524.59,
      "end": 525.41,
      "text": "또 경탄"
    },
    {
      "start": 525.41,
      "end": 526.79,
      "text": "혹은 경위라는"
    },
    {
      "start": 526.79,
      "end": 527.61,
      "text": "명사로도"
    },
    {
      "start": 527.61,
      "end": 528.87,
      "text": "활용이 가능한 단어인데"
    },
    {
      "start": 528.87,
      "end": 529.23,
      "text": "Or"
    },
    {
      "start": 529.23,
      "end": 529.89,
      "text": "감탄사"
    },
    {
      "start": 529.89,
      "end": 530.33,
      "text": "Yeah."
    },
    {
      "start": 530.47,
      "end": 531.17,
      "text": "No wonder"
    },
    {
      "start": 531.17,
      "end": 532.73,
      "text": "아 어쩐지"
    },
    {
      "start": 532.73,
      "end": 533.89,
      "text": "우리 배웠던 표현이에요."
    },
    {
      "start": 533.97,
      "end": 534.43,
      "text": "Oh really?"
    },
    {
      "start": 534.65,
      "end": 534.91,
      "text": "Yeah."
    },
    {
      "start": 535.03,
      "end": 535.75,
      "text": "No wonder"
    },
    {
      "start": 535.75,
      "end": 537.05,
      "text": "놀랍지도 않아"
    },
    {
      "start": 537.05,
      "end": 538.21,
      "text": "이런 상황에서도"
    },
    {
      "start": 538.21,
      "end": 539.33,
      "text": "우리가 감탄할 때도"
    },
    {
      "start": 539.33,
      "end": 540.17,
      "text": "활용을 했었죠."
    },
    {
      "start": 540.43,
      "end": 541.03,
      "text": "Ah"
    },
    {
      "start": 541.03,
      "end": 542.19,
      "text": "You missed breakfast."
    },
    {
      "start": 542.31,
      "end": 542.49,
      "text": "Yeah."
    },
    {
      "start": 542.89,
      "end": 543.35,
      "text": "No wonder"
    },
    {
      "start": 543.35,
      "end": 544.85,
      "text": "Your stomach is growling."
    },
    {
      "start": 545.17,
      "end": 545.33,
      "text": "Right."
    },
    {
      "start": 546.39,
      "end": 547.89,
      "text": "In that moment"
    },
    {
      "start": 547.89,
      "end": 549.27,
      "text": "In that moment"
    },
    {
      "start": 549.27,
      "end": 550.17,
      "text": "무슨 의미일까요?"
    },
    {
      "start": 550.51,
      "end": 551.63,
      "text": "그 순간에"
    },
    {
      "start": 551.63,
      "end": 552.71,
      "text": "라는 표현입니다."
    },
    {
      "start": 552.73,
      "end": 553.17,
      "text": "In that"
    },
    {
      "start": 553.17,
      "end": 554.01,
      "text": "that moment"
    },
    {
      "start": 554.01,
      "end": 555.19,
      "text": "How did you feel"
    },
    {
      "start": 555.19,
      "end": 556.57,
      "text": "In that moment"
    },
    {
      "start": 556.57,
      "end": 556.87,
      "text": "Right."
    },
    {
      "start": 557.87,
      "end": 560.09,
      "text": "Impossible to describe"
    },
    {
      "start": 560.09,
      "end": 561.75,
      "text": "Impossible"
    },
    {
      "start": 561.75,
      "end": 562.69,
      "text": "들으셨죠?"
    },
    {
      "start": 563.03,
      "end": 564.45,
      "text": "그러니까 불가능하다는 거고"
    },
    {
      "start": 564.45,
      "end": 565.63,
      "text": "To describe"
    },
    {
      "start": 565.63,
      "end": 567.71,
      "text": "묘사하기 불가능한"
    },
    {
      "start": 567.71,
      "end": 569.33,
      "text": "설명하기 불가능한"
    },
    {
      "start": 569.33,
      "end": 570.23,
      "text": "이라는 표현까지"
    },
    {
      "start": 570.23,
      "end": 571.33,
      "text": "들으실 수가 있습니다."
    },
    {
      "start": 571.43,
      "end": 571.51,
      "text": "Yeah."
    },
    {
      "start": 571.65,
      "end": 573.69,
      "text": "Feelings are often hard to describe"
    },
    {
      "start": 573.69,
      "end": 574.23,
      "text": "That's right."
    },
    {
      "start": 574.25,
      "end": 575.35,
      "text": "Very useful expression."
    },
    {
      "start": 575.49,
      "end": 575.65,
      "text": "네."
    },
    {
      "start": 575.91,
      "end": 576.53,
      "text": "이 표현들"
    },
    {
      "start": 576.53,
      "end": 577.57,
      "text": "염두에 두시고요."
    },
    {
      "start": 577.67,
      "end": 578.83,
      "text": "내용 다시 한번 들어볼게요."
    },
    {
      "start": 578.83,
      "end": 580.59,
      "text": "I only wondered"
    },
    {
      "start": 580.59,
      "end": 581.49,
      "text": "what it felt like"
    },
    {
      "start": 581.49,
      "end": 582.11,
      "text": "What?"
    },
    {
      "start": 582.35,
      "end": 582.83,
      "text": "The bulb"
    },
    {
      "start": 582.83,
      "end": 584.05,
      "text": "when you knew"
    },
    {
      "start": 584.05,
      "end": 585.61,
      "text": "What was the feeling"
    },
    {
      "start": 585.61,
      "end": 586.35,
      "text": "in that moment?"
    },
    {
      "start": 586.87,
      "end": 587.61,
      "text": "Can't tell you"
    },
    {
      "start": 587.61,
      "end": 587.93,
      "text": "I mean"
    },
    {
      "start": 587.93,
      "end": 590.02,
      "text": "impossible to describe"
    },
    {
      "start": 590.02,
      "end": 590.66,
      "text": "the feeling"
    },
    {
      "start": 590.66,
      "end": 591.74,
      "text": "because it was"
    },
    {
      "start": 591.74,
      "end": 592.36,
      "text": "impossible"
    },
    {
      "start": 592.36,
      "end": 594.02,
      "text": "Whoa"
    },
    {
      "start": 594.02,
      "end": 596.34,
      "text": "Mr. Westinghouse"
    },
    {
      "start": 596.34,
      "end": 597.76,
      "text": "wanted to know"
    },
    {
      "start": 597.76,
      "end": 598.46,
      "text": "the feeling"
    },
    {
      "start": 598.46,
      "end": 599.64,
      "text": "of the success"
    },
    {
      "start": 599.64,
      "end": 600.28,
      "text": "of"
    },
    {
      "start": 600.28,
      "end": 601.48,
      "text": "invention"
    },
    {
      "start": 601.48,
      "end": 602.04,
      "text": "Yeah."
    },
    {
      "start": 602.28,
      "end": 602.62,
      "text": "Yeah."
    },
    {
      "start": 602.82,
      "end": 603.92,
      "text": "Because he's a successful"
    },
    {
      "start": 603.92,
      "end": 605.16,
      "text": "businessman himself"
    },
    {
      "start": 605.16,
      "end": 605.66,
      "text": "Yeah."
    },
    {
      "start": 605.78,
      "end": 606.9,
      "text": "But he's never had a"
    },
    {
      "start": 606.9,
      "end": 607.48,
      "text": "BAM"
    },
    {
      "start": 607.48,
      "end": 608.9,
      "text": "A huge invention"
    },
    {
      "start": 608.9,
      "end": 609.32,
      "text": "Right."
    },
    {
      "start": 609.32,
      "end": 611.08,
      "text": "That he created himself"
    },
    {
      "start": 611.08,
      "end": 611.48,
      "text": "Yeah."
    },
    {
      "start": 611.68,
      "end": 612.88,
      "text": "이거는 어떤 상황이냐면"
    },
    {
      "start": 612.88,
      "end": 613.18,
      "text": "약간"
    },
    {
      "start": 613.18,
      "end": 614.34,
      "text": "beyond the competition"
    },
    {
      "start": 614.34,
      "end": 615.02,
      "text": "그죠?"
    },
    {
      "start": 615.52,
      "end": 616.92,
      "text": "경쟁을 넘어선"
    },
    {
      "start": 616.92,
      "end": 618.14,
      "text": "그러한 대화인 것 같아요"
    },
    {
      "start": 618.14,
      "end": 618.7,
      "text": "인간적으로"
    },
    {
      "start": 618.7,
      "end": 619.12,
      "text": "Yeah."
    },
    {
      "start": 619.36,
      "end": 619.84,
      "text": "Hey"
    },
    {
      "start": 619.84,
      "end": 621.06,
      "text": "I know you're"
    },
    {
      "start": 621.06,
      "end": 622.04,
      "text": "an incredible genius"
    },
    {
      "start": 622.04,
      "end": 623.6,
      "text": "Tell me how you felt"
    },
    {
      "start": 623.6,
      "end": 623.96,
      "text": "Right."
    },
    {
      "start": 624.08,
      "end": 624.72,
      "text": "When you invented"
    },
    {
      "start": 624.72,
      "end": 625.66,
      "text": "that light bulb"
    },
    {
      "start": 625.66,
      "end": 626.08,
      "text": "Yeah."
    },
    {
      "start": 626.24,
      "end": 627.46,
      "text": "Very beautiful conversation"
    },
    {
      "start": 627.46,
      "end": 629.26,
      "text": "I like this kind of attitude"
    },
    {
      "start": 629.26,
      "end": 630.5,
      "text": "이러한 대화"
    },
    {
      "start": 630.5,
      "end": 631.36,
      "text": "이러한 태도"
    },
    {
      "start": 631.36,
      "end": 633.12,
      "text": "제가 되게 좋아하는 태도예요"
    },
    {
      "start": 633.12,
      "end": 634.58,
      "text": "Could you approach"
    },
    {
      "start": 634.58,
      "end": 635.16,
      "text": "your rival?"
    },
    {
      "start": 635.44,
      "end": 636.62,
