    },
    {
      "start": 632.06,
      "end": 633.06,
      "text": "그 다음"
    },
    {
      "start": 633.06,
      "end": 635.22,
      "text": "You're an expert in show business"
    },
    {
      "start": 635.22,
      "end": 636.96,
      "text": "But you know"
    },
    {
      "start": 636.96,
      "end": 639.58,
      "text": "You're an expert in show business"
    },
    {
      "start": 639.58,
      "end": 640.52,
      "text": "But you know"
    },
    {
      "start": 640.52,
      "end": 641.86,
      "text": "여기까지 들으셨어요"
    },
    {
      "start": 641.86,
      "end": 645.5,
      "text": "너는 공연 분야에서 전문가야"
    },
    {
      "start": 645.5,
      "end": 646.44,
      "text": "But you know"
    },
    {
      "start": 646.44,
      "end": 646.9,
      "text": "하지만"
    },
    {
      "start": 646.9,
      "end": 649.3,
      "text": "You know what"
    },
    {
      "start": 649.3,
      "end": 650.42,
      "text": "뭐 한다고"
    },
    {
      "start": 650.42,
      "end": 652.34,
      "text": "네, 뒷부분에 아주 끊겼어요"
    },
    {
      "start": 652.34,
      "end": 653.6,
      "text": "Exactly"
    },
    {
      "start": 653.6,
      "end": 654.68,
      "text": "네, 여기에서"
    },
    {
      "start": 654.68,
      "end": 655.86,
      "text": "Lucille이 치고 들어옵니다"
    },
    {
      "start": 655.86,
      "end": 656.44,
      "text": "Exactly"
    },
    {
      "start": 656.44,
      "end": 657.9,
      "text": "바로 그거야"
    },
    {
      "start": 657.9,
      "end": 659.1,
      "text": "정확해"
    },
    {
      "start": 659.1,
      "end": 660.5,
      "text": "라고 치고 들어왔어요"
    },
    {
      "start": 660.5,
      "end": 661.58,
      "text": "그게 뭐예요?"
    },
    {
      "start": 661.76,
      "end": 662.2,
      "text": "그러니까요"
    },
    {
      "start": 662.2,
      "end": 662.78,
      "text": "애매한데요"
    },
    {
      "start": 662.78,
      "end": 664.26,
      "text": "애매모호하게 이렇게 얘기하네요"
    },
    {
      "start": 664.26,
      "end": 665.82,
      "text": "마치 암호처럼"
    },
    {
      "start": 665.82,
      "end": 667.42,
      "text": "이야기를 해주고 있는 장면입니다"
    },
    {
      "start": 667.42,
      "end": 668.8,
      "text": "이제 구체적으로"
    },
    {
      "start": 668.8,
      "end": 670.48,
      "text": "이들이 어떻게 진행을 할지"
    },
    {
      "start": 670.48,
      "end": 672.08,
      "text": "두고 봐야 되는 순간이네요"
    },
    {
      "start": 672.08,
      "end": 673.54,
      "text": "아, remember Lucille?"
    },
    {
      "start": 673.68,
      "end": 675.74,
      "text": "She has a performance coming up"
    },
    {
      "start": 675.74,
      "end": 676.2,
      "text": "Right"
    },
    {
      "start": 676.2,
      "end": 678.22,
      "text": "A performance with the commissioner"
    },
    {
      "start": 678.22,
      "end": 680.14,
      "text": "Maybe they're going to use"
    },
    {
      "start": 680.14,
      "end": 681.54,
      "text": "her show business skills"
    },
    {
      "start": 681.54,
      "end": 683.78,
      "text": "to make a plan"
    },
    {
      "start": 683.78,
      "end": 685.2,
      "text": "to save the little flea"
    },
    {
      "start": 685.2,
      "end": 688.08,
      "text": "이렇게 예측을 할 수 있게 해주셨네요"
    },
    {
      "start": 688.08,
      "end": 689.28,
      "text": "네, 이 부분"
    },
    {
      "start": 689.28,
      "end": 690.94,
      "text": "마지막으로 한 번 더 들어보겠습니다"
    },
    {
      "start": 690.94,
      "end": 693.19,
      "text": "If only we could shrink him down"
    },
    {
      "start": 693.19,
      "end": 694.39,
      "text": "to his normal size"
    },
    {
      "start": 694.39,
      "end": 695.85,
      "text": "then no one would ever find him"
    },
    {
      "start": 695.85,
      "end": 696.65,
      "text": "Smaller you are"
    },
    {
      "start": 696.65,
      "end": 697.63,
      "text": "the less people look at you"
    },
    {
      "start": 697.63,
      "end": 699.63,
      "text": "At least that's been my experience"
    },
    {
      "start": 699.63,
      "end": 700.89,
      "text": "There's only one person"
    },
    {
      "start": 700.89,
      "end": 701.85,
      "text": "who could save Franco"
    },
    {
      "start": 701.85,
      "end": 703.63,
      "text": "and he's in New York right now"
    },
    {
      "start": 703.63,
      "end": 705.65,
      "text": "But we don't need him"
    },
    {
      "start": 705.65,
      "end": 706.77,
      "text": "Lucille"
    },
    {
      "start": 706.77,
      "end": 708.19,
      "text": "No offense"
    },
    {
      "start": 708.19,
      "end": 710.33,
      "text": "We're talking big-time science here, okay?"
    },
    {
      "start": 710.47,
      "end": 711.49,
      "text": "All I know is deliveries"
    },
    {
      "start": 711.49,
      "end": 712.95,
      "text": "Emile's all about movies"
    },
    {
      "start": 712.95,
      "end": 714.41,
      "text": "You're an expert in show business"
    },
    {
      "start": 714.41,
      "end": 714.91,
      "text": "but, you know"
    },
    {
      "start": 714.91,
      "end": 715.49,
      "text": "Exactly"
    },
    {
      "start": 715.49,
      "end": 718.57,
      "text": "네, 이 종자님께서"
    },
    {
      "start": 718.57,
      "end": 719.79,
      "text": "Thanks a lot"
    },
    {
      "start": 719.79,
      "end": 721.03,
      "text": "Have a happy day"
    },
    {
      "start": 721.03,
      "end": 724.87,
      "text": "You too have a wonderful, happy, beautiful, happy day"
    },
    {
      "start": 724.87,
      "end": 726.79,
      "text": "Happy 두 번 썼네요"
    },
    {
      "start": 726.79,
      "end": 728.77,
      "text": "네, 무슨 랩을 하시는 줄 알았어요"
    },
    {
      "start": 728.77,
      "end": 730.69,
      "text": "오늘 기분 좋게 여기에서"
    },
    {
      "start": 730.69,
      "end": 731.91,
      "text": "마무리해보도록 할게요"
    },
    {
      "start": 731.91,
      "end": 733.05,
      "text": "우리는 see you tomorrow"
    }
  ]
}