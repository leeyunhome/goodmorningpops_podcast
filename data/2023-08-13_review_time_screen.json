    },
    {
      "start": 955.7,
      "end": 959.17,
      "text": "결국에는 그거 좋을 거예요."
    },
    {
      "start": 959.65,
      "end": 960.09,
      "text": "해볼까요?"
    },
    {
      "start": 961.02,
      "end": 963.9,
      "text": "It'll be good in the long run."
    },
    {
      "start": 964.72,
