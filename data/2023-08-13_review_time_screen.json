    },
    {
      "start": 866.85,
      "end": 868.35,
      "text": "가끔 이런 말을 하게 됩니다."
    },
    {
      "start": 869.07,
      "end": 871.13,
      "text": "저는 여기에 정착하고 싶어요."
    },
    {
      "start": 871.99,
      "end": 874.01,
      "text": "네, 저는 여기에 정착하고 싶네요."
    },
    {
      "start": 874.25,
      "end": 874.79,
      "text": "어떻게 할까요?"
    },
    {
      "start": 875.51,
      "end": 879.11,
      "text": "I'd like to settle down 여기 here."
    },
    {
      "start": 879.11,
      "end": 880.05,
      "text": "좋아요."
    },
    {
      "start": 880.77,
      "end": 882.87,
      "text": "이번엔 8월 8일 화요일 표현입니다."
    },
    {
      "start": 884.89,
      "end": 886.55,
      "text": "Keep it to yourself."
    },
    {
      "start": 887.19,
      "end": 888.67,
      "text": "Keep it to oneself."
    },
    {
      "start": 889.31,
      "end": 891.43,
      "text": "이 구조 기억하고 계실 텐데"
    },
