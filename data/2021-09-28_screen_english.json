      "text": "When they're really really mad"
    },
    {
      "start": 520.1,
      "end": 521.32,
      "text": "That's even scarier"
    },
    {
      "start": 521.32,
      "end": 522.34,
      "text": "진짜 무서워지는"
    },
    {
      "start": 522.34,
      "end": 523.36,
      "text": "그런 장면이었어요"
