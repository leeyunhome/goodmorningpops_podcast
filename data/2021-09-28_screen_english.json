    },
    {
      "start": 510.88,
      "end": 512.52,
      "text": "The 황소 is coming out"
    },
    {
      "start": 512.52,
      "end": 514.8,
      "text": "근데 진짜 진짜 화나면"
    },
    {
      "start": 514.8,
      "end": 515.38,
      "text": "진짜"
    },
    {
      "start": 515.38,
      "end": 516.3,
      "text": "Some people become"
    },
