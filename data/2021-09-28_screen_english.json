      "end": 337.16,
      "text": "Thankfully"
    },
    {
      "start": 337.16,
      "end": 338.22,
      "text": "Yeah, good lesson"
    },
    {
      "start": 338.22,
      "end": 340.16,
      "text": "It released the cow inside you"
    },
    {
      "start": 340.16,
      "end": 342.16,
      "text": "와, 정말 자유를 얻었네요"
    },
    {
      "start": 342.16,
      "end": 343.5,
      "text": "The angry bull"
    },
    {
      "start": 343.5,
      "end": 345.74,
      "text": "네, 오늘 장면 듣고 오겠습니다"
    },
    {
      "start": 345.74,
      "end": 347.37,
      "text": "Do you want to know"
    },
    {
      "start": 347.37,
      "end": 347.89,
      "text": "I'm a teacher?"
    },
    {
      "start": 348.45,
      "end": 349.43,
      "text": "I'm good at this"
    },
    {
      "start": 349.43,
      "end": 351.37,
      "text": "But I can't do my job"
    },
    {
      "start": 351.37,
      "end": 352.43,
      "text": "unless you do yours"
    },
    {
      "start": 352.43,
      "end": 354.31,
      "text": "And I certainly don't need"
    },
    {
      "start": 354.31,
      "end": 355.17,
      "text": "a lesson in failure"
    },
    {
      "start": 355.17,
      "end": 356.09,
      "text": "from someone who's"
    },
    {
      "start": 356.09,
      "end": 357.67,
      "text": "too afraid to even try"
    },
    {
      "start": 357.67,
      "end": 359.19,
      "text": "I've never done anything"
    },
    {
      "start": 359.19,
      "end": 360.67,
      "text": "without my family before"
    },
    {
      "start": 360.67,
      "end": 362.76,
      "text": "와우"
    },
    {
      "start": 362.76,
      "end": 364.54,
      "text": "She was late again"
