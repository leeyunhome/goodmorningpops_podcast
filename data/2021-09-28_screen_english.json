    {
      "start": 481.54,
      "end": 482.46,
      "text": "누군가"
    },
    {
      "start": 482.46,
      "end": 484.0,
      "text": "정도 해석이 되겠네요"
    },
    {
      "start": 484.0,
      "end": 485.44,
      "text": "이 장면"
    },
    {
      "start": 485.44,
      "end": 486.42,
      "text": "다시 한번 들어보시죠"
    },
    {
      "start": 486.42,
      "end": 487.74,
      "text": "You want to know"
    },
    {
      "start": 487.74,
      "end": 488.26,
      "text": "who I'm a teacher?"
    },
    {
      "start": 488.8,
      "end": 489.82,
      "text": "I'm good at this"
    },
    {
      "start": 489.82,
      "end": 491.74,
      "text": "But I can't do my job"
    },
    {
      "start": 491.74,
      "end": 492.78,
      "text": "unless you do yours"
    },
    {
      "start": 492.78,
      "end": 494.12,
      "text": "And I certainly"
    },
    {
      "start": 494.12,
      "end": 495.02,
      "text": "don't need a lesson"
    },
    {
      "start": 495.02,
      "end": 495.52,
      "text": "in failure"
    },
    {
      "start": 495.52,
      "end": 496.12,
      "text": "from someone"
    },
    {
      "start": 496.12,
      "end": 497.34,
      "text": "who's too afraid"
    },
    {
      "start": 497.34,
      "end": 498.02,
      "text": "to even try"
    },
    {
      "start": 498.02,
      "end": 499.58,
      "text": "I've never done anything"
    },
    {
      "start": 499.58,
      "end": 500.46,
      "text": "without my family"
    },
    {
      "start": 500.46,
      "end": 500.98,
      "text": "before"
    },
    {
      "start": 500.98,
      "end": 504.26,
      "text": "It's a scarier scene"
    },
    {
      "start": 504.26,
      "end": 505.36,
      "text": "than last time"
    },
    {
      "start": 505.36,
      "end": 506.2,
      "text": "Even scarier?"
    },
    {
      "start": 506.28,
      "end": 506.66,
      "text": "Yeah"
    },
    {
      "start": 506.66,
      "end": 507.8,
      "text": "Your favorite character"
    },
    {
      "start": 507.8,
      "end": 508.68,
      "text": "is angry"
    },
    {
      "start": 508.68,
      "end": 509.76,
      "text": "He's releasing"
    },
    {
      "start": 509.76,
