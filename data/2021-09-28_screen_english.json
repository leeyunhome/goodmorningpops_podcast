      "end": 529.16,
      "text": "평상시와는"
    },
    {
      "start": 529.16,
      "end": 530.34,
      "text": "확실히 달랐어요"
    },
    {
      "start": 530.34,
      "end": 531.92,
      "text": "굉장히 다운되어 있는"
    },
    {
      "start": 531.92,
      "end": 532.66,
      "text": "목소리였습니다"
    },
    {
      "start": 532.66,
      "end": 533.54,
      "text": "네"
    },
    {
      "start": 533.54,
      "end": 534.44,
      "text": "뭐라고 하시는지"
    },
    {
      "start": 534.44,
      "end": 534.96,
      "text": "들어볼게요"
    },
    {
      "start": 534.96,
      "end": 536.94,
      "text": "You want to know"
    },
    {
      "start": 536.94,
      "end": 537.98,
      "text": "why I'm a teacher?"
    },
    {
      "start": 538.44,
      "end": 539.18,
      "text": "You want to know"
    },
    {
      "start": 539.18,
      "end": 540.52,
      "text": "why I'm a teacher?"
    },
    {
      "start": 541.52,
      "end": 543.62,
      "text": "내가 왜 교사를 하는지"
    },
    {
      "start": 543.62,
      "end": 544.18,
      "text": "아니?"
    },
    {
      "start": 544.96,
      "end": 545.26,
      "text": "Wow"
    },
    {
      "start": 545.26,
      "end": 545.86,
      "text": "What a question"
    },
    {
      "start": 545.86,
      "end": 546.16,
      "text": "Yeah"
    },
    {
      "start": 546.16,
      "end": 548.06,
      "text": "I'm good at this"
    },
    {
      "start": 548.06,
      "end": 549.4,
      "text": "내가 잘하니까"
    },
    {
      "start": 549.4,
      "end": 550.6,
      "text": "Okay"
    },
    {
      "start": 550.6,
      "end": 552.54,
      "text": "명쾌한 정답이었어요"
    },
    {
      "start": 552.54,
      "end": 552.8,
      "text": "그죠?"
    },
    {
      "start": 552.94,
      "end": 553.64,
      "text": "그래서요"
    },
    {
      "start": 553.64,
      "end": 554.38,
      "text": "I'm good at this"
    },
    {
      "start": 554.38,
      "end": 555.58,
      "text": "내가 이걸 잘하니까"
    },
    {
      "start": 555.58,
      "end": 556.48,
      "text": "교사를 하는 거야"
    },
    {
      "start": 556.48,
      "end": 558.02,
      "text": "Why are you telling me this?"
    },
    {
      "start": 558.32,
      "end": 559.0,
      "text": "I wonder"
    },
    {
      "start": 559.0,
      "end": 562.22,
      "text": "But I can't do my job"
    },
    {
      "start": 562.22,
      "end": 563.54,
      "text": "unless you do yours"
    },
    {
      "start": 563.54,
      "end": 564.86,
      "text": "그래요"
    },
    {
      "start": 564.86,
      "end": 566.28,
      "text": "Responsibility에 대해서"
    },
    {
      "start": 566.28,
      "end": 567.42,
      "text": "이야기해주고 있는 것 같아요"
    },
    {
      "start": 567.42,
      "end": 569.14,
      "text": "I can't do my job"
    },
    {
      "start": 569.14,
      "end": 570.54,
      "text": "나는 이 일을 할 수 없어"
    },
    {
      "start": 570.54,
      "end": 572.74,
      "text": "Unless you do yours"
    },
    {
      "start": 572.74,
      "end": 576.22,
      "text": "네가 너의 일을 하지 않는다면"
    },
    {
      "start": 576.22,
      "end": 577.06,
      "text": "이라는 겁니다"
    },
    {
      "start": 577.06,
      "end": 579.36,
      "text": "네가 네 역할을 하지 않으면"
    },
    {
      "start": 579.36,
      "end": 581.04,
      "text": "나는 이 일을 할 수 없어"
    },
    {
      "start": 581.04,
      "end": 582.54,
      "text": "I need a student"
    },
    {
      "start": 582.54,
      "end": 583.54,
      "text": "to be a teacher"
    },
    {
      "start": 583.54,
      "end": 583.98,
      "text": "Yeah"
    },
    {
      "start": 583.98,
      "end": 584.38,
      "text": "그리고"
    },
    {
      "start": 584.38,
      "end": 585.76,
      "text": "diligent하게"
    },
    {
      "start": 585.76,
      "end": 586.24,
      "text": "Yeah"
    },
    {
      "start": 586.24,
      "end": 588.08,
      "text": "And you're late every time"
    },
    {
      "start": 588.08,
      "end": 589.66,
      "text": "You're not being diligent"
    },
    {
      "start": 589.66,
      "end": 592.19,
      "text": "And I certainly"
    },
    {
      "start": 592.19,
      "end": 593.57,
      "text": "don't need a lesson"
    },
    {
      "start": 593.57,
      "end": 594.79,
      "text": "in failure"
    },
    {
      "start": 594.79,
      "end": 595.75,
      "text": "from someone"
    },
    {
      "start": 595.75,
      "end": 596.49,
      "text": "who's too afraid"
    },
    {
      "start": 596.49,
      "end": 597.45,
      "text": "to even try"
    },
    {
      "start": 597.45,
      "end": 599.53,
      "text": "And I certainly"
    },
    {
      "start": 599.53,
      "end": 600.93,
      "text": "don't need a lesson"
    },
    {
      "start": 600.93,
      "end": 601.59,
      "text": "이라고 했어요"
    },
    {
      "start": 601.59,
      "end": 603.31,
      "text": "여기서의 lesson이라는 것은"
    },
    {
      "start": 603.31,
      "end": 604.71,
      "text": "수업을 이야기하는 건"
    },
    {
      "start": 604.71,
      "end": 605.45,
      "text": "아닐 것 같고요"
    },
    {
      "start": 605.45,
      "end": 607.23,
      "text": "교훈이 되겠죠"
    },
    {
      "start": 607.23,
      "end": 607.69,
      "text": "Lesson"
    },
    {
      "start": 607.69,
      "end": 608.41,
      "text": "Life lesson"
    },
    {
      "start": 608.41,
      "end": 608.69,
      "text": "Yeah"
    },
    {
      "start": 608.69,
      "end": 609.21,
      "text": "그렇죠"
    },
    {
      "start": 609.21,
      "end": 610.15,
      "text": "교훈인데"
    },
    {
      "start": 610.15,
      "end": 611.23,
      "text": "어떤 교훈이냐면"
    },
    {
      "start": 611.23,
      "end": 612.49,
      "text": "in failure"
    },
    {
      "start": 612.49,
      "end": 613.13,
      "text": "이라고 했어요"
    },
    {
      "start": 613.13,
      "end": 615.99,
      "text": "실패해서 얻은 교훈은"
    },
    {
      "start": 615.99,
      "end": 617.77,
      "text": "I certainly don't need"
    },
    {
      "start": 617.77,
      "end": 618.45,
      "text": "라고 했으니까"
    },
    {
      "start": 618.45,
      "end": 620.29,
      "text": "나는 확실히 필요 없어"
    },
    {
      "start": 620.29,
      "end": 621.33,
      "text": "라는 의미입니다"
    },
    {
      "start": 621.33,
      "end": 622.07,
      "text": "근데"
    },
    {
      "start": 622.07,
      "end": 623.07,
      "text": "from someone"
    },
    {
      "start": 623.07,
      "end": 624.41,
      "text": "who's too afraid"
    },
    {
      "start": 624.41,
      "end": 625.33,
      "text": "to even try"
    },
    {
      "start": 625.33,
      "end": 627.59,
      "text": "라고 이어서 이야기해주고 있는 거죠"
    },
    {
      "start": 627.59,
      "end": 630.43,
      "text": "나는 두려워서"
    },
    {
      "start": 630.43,
      "end": 632.61,
      "text": "도전조차 못하는 누구 때문에"
    },
    {
      "start": 632.61,
      "end": 634.07,
      "text": "그 실패로 인해서"
    },
    {
      "start": 634.07,
      "end": 635.65,
      "text": "교훈을 얻고 싶은 생각은"
    },
    {
      "start": 635.65,
      "end": 636.49,
      "text": "전혀 없어"
    },
    {
      "start": 636.49,
      "end": 637.37,
      "text": "1도 없어"
    },
    {
      "start": 637.37,
      "end": 638.17,
      "text": "라는 말이에요"
    },
    {
      "start": 638.17,
      "end": 638.63,
      "text": "Oh"
    },
    {
      "start": 638.63,
      "end": 639.65,
      "text": "He doesn't want to learn"
    },
    {
      "start": 639.65,
      "end": 640.31,
      "text": "about failure"
    },
    {
      "start": 640.31,
      "end": 641.51,
      "text": "from Ruby"
    },
    {
      "start": 641.51,
      "end": 642.99,
      "text": "Because if Ruby"
    },
    {
      "start": 642.99,
      "end": 643.91,
      "text": "doesn't show up"
    },
    {
      "start": 643.91,
      "end": 644.59,
      "text": "to class"
    },
    {
      "start": 644.59,
      "end": 645.77,
      "text": "he can't teach her"
    },
    {
      "start": 645.77,
      "end": 646.73,
      "text": "he will fail"
    },
    {
      "start": 646.73,
      "end": 647.51,
      "text": "as a teacher"
    },
    {
      "start": 647.51,
      "end": 649.63,
      "text": "So he's kind of upset"
    },
    {
      "start": 649.63,
      "end": 650.69,
      "text": "I don't need"
    },
    {
      "start": 650.69,
      "end": 651.07,
      "text": "a lesson"
    },
    {
      "start": 651.07,
      "end": 651.63,
      "text": "in failure"
    },
    {
      "start": 651.63,
      "end": 652.35,
      "text": "from you"
    },
    {
      "start": 652.35,
      "end": 652.75,
      "text": "그렇죠"
    },
    {
      "start": 652.75,
      "end": 654.09,
      "text": "이제 학생이"
    },
    {
      "start": 654.09,
      "end": 655.17,
      "text": "어떻게 역할을 하는지도"
    },
    {
      "start": 655.17,
      "end": 656.01,
      "text": "참 중요합니다"
    },
    {
      "start": 656.01,
      "end": 659.25,
      "text": "I've never done anything"
    },
    {
      "start": 659.25,
      "end": 660.71,
      "text": "without my family"
    },
    {
      "start": 660.71,
      "end": 661.39,
      "text": "before"
    },
    {
      "start": 661.39,
      "end": 663.31,
      "text": "이제 사실대로"
    },
    {
      "start": 663.31,
      "end": 663.97,
      "text": "이야기하네요"
    },
    {
      "start": 663.97,
      "end": 664.83,
      "text": "She's being honest"
    },
    {
      "start": 664.83,
      "end": 667.61,
      "text": "I've never done anything"
    },
    {
      "start": 667.61,
      "end": 668.87,
      "text": "without my family"
    },
    {
      "start": 668.87,
      "end": 669.59,
      "text": "before"
    },
    {
      "start": 669.59,
      "end": 672.39,
      "text": "저 가족들과 떨어져서"
    },
    {
      "start": 672.39,
      "end": 673.37,
      "text": "뭘 해본 적이"
    },
    {
      "start": 673.37,
      "end": 674.43,
      "text": "한 번도 없어요"
    },
    {
      "start": 674.43,
      "end": 675.79,
      "text": "라는 말이었습니다"
    },
    {
      "start": 675.79,
      "end": 677.21,
      "text": "She is afraid"
    },
    {
      "start": 677.21,
      "end": 679.07,
      "text": "얼마나"
    },
    {
      "start": 679.07,
      "end": 681.13,
      "text": "이 상황이"
    },
    {
      "start": 681.13,
      "end": 681.95,
      "text": "난처할까요"
    },
    {
      "start": 681.95,
      "end": 683.27,
      "text": "자기로서는"
    },
    {
      "start": 683.27,
      "end": 684.35,
      "text": "어떻게 할 수가 없는 거잖아요"
    },
    {
      "start": 684.35,
      "end": 684.83,
      "text": "그렇죠"
    },
    {
      "start": 684.83,
      "end": 686.19,
      "text": "She spent her whole life"
    },
    {
      "start": 686.19,
      "end": 686.81,
      "text": "with her family"
    },
    {
      "start": 686.81,
      "end": 688.55,
      "text": "and now she's"
    },
    {
      "start": 688.55,
      "end": 689.33,
      "text": "going to go off"
    },
    {
      "start": 689.33,
      "end": 691.11,
      "text": "to a new college"
    },
    {
      "start": 691.11,
      "end": 692.59,
      "text": "and she's afraid of that"
    },
    {
      "start": 692.59,
      "end": 693.65,
      "text": "she doesn't know"
    },
    {
      "start": 693.65,
      "end": 694.27,
      "text": "what to do"
    },
    {
      "start": 694.27,
      "end": 694.63,
      "text": "그러니까"
    },
    {
      "start": 694.63,
      "end": 695.79,
      "text": "앞으로 어떻게 될지"
    },
    {
      "start": 695.79,
      "end": 696.95,
      "text": "너무너무 기대가 됩니다"
    },
    {
      "start": 696.95,
      "end": 697.83,
      "text": "이 장면"
    },
    {
      "start": 697.83,
      "end": 698.37,
      "text": "마지막으로"
    },
    {
      "start": 698.37,
      "end": 699.87,
      "text": "한 번 더 들어볼게요"
    },
    {
      "start": 699.87,
      "end": 700.59,
      "text": "You want to know"
    },
    {
      "start": 700.59,
      "end": 701.11,
      "text": "how I'm a teacher?"
    },
    {
      "start": 701.67,
      "end": 702.65,
      "text": "I'm good at this"
    },
    {
      "start": 702.65,
      "end": 704.57,
      "text": "But I can't do my job"
    },
    {
      "start": 704.57,
      "end": 705.63,
      "text": "unless you do yours"
    },
    {
      "start": 705.63,
      "end": 706.95,
      "text": "And I certainly"
    },
    {
      "start": 706.95,
      "end": 707.89,
      "text": "don't need a lesson"
    },
    {
      "start": 707.89,
      "end": 708.37,
      "text": "in failure"
    },
    {
      "start": 708.37,
      "end": 708.97,
      "text": "from someone"
    },
    {
      "start": 708.97,
      "end": 710.21,
      "text": "who's too afraid"
    },
    {
      "start": 710.21,
      "end": 710.87,
      "text": "to even try"
    },
    {
      "start": 710.87,
      "end": 712.43,
      "text": "I've never done anything"
    },
    {
      "start": 712.43,
      "end": 713.31,
      "text": "without my family"
    },
    {
      "start": 713.31,
      "end": 713.87,
      "text": "before"
    },
    {
      "start": 713.87,
      "end": 715.05,
      "text": "네"
    },
    {
      "start": 715.05,
      "end": 716.37,
      "text": "특히 루비가"
    },
    {
      "start": 716.37,
      "end": 717.01,
      "text": "마지막에"
    },
    {
      "start": 717.01,
      "end": 717.63,
      "text": "이야기했던"
    },
    {
      "start": 717.63,
      "end": 718.67,
      "text": "그 대사는"
    },
    {
      "start": 718.67,
      "end": 719.37,
      "text": "정말"
    },
    {
      "start": 719.37,
      "end": 720.69,
      "text": "Here comes her biggest"
    },
    {
      "start": 720.69,
      "end": 721.99,
      "text": "inner problem"
    },
    {
      "start": 721.99,
      "end": 723.07,
      "text": "이라고 생각해요"
    },
    {
      "start": 723.07,
      "end": 724.05,
      "text": "In her problem"
    },
    {
      "start": 724.05,
      "end": 725.85,
      "text": "She's letting him know"
    },
    {
      "start": 725.85,
      "end": 727.19,
      "text": "뭔가 내면에 있었던"
    },
    {
      "start": 727.19,
      "end": 728.55,
      "text": "그런 문제를"
    },
    {
      "start": 728.55,
      "end": 729.87,
      "text": "자기 입 밖으로"
    },
    {
      "start": 729.87,
      "end": 730.95,
      "text": "처음으로 내뱉은"
    },
    {
      "start": 730.95,
      "end": 732.13,
      "text": "그런 순간이 아닐까"
    },
    {
      "start": 732.13,
      "end": 733.91,
      "text": "이런 생각 해보게 됩니다"
    },
    {
      "start": 733.91,
      "end": 734.63,
      "text": "She's admitting"
    },
    {
      "start": 734.63,
      "end": 736.25,
      "text": "to being afraid"
    },
    {
      "start": 736.25,
      "end": 737.25,
      "text": "She is afraid"
    },
    {
      "start": 737.25,
      "end": 738.93,
      "text": "of leaving her family"
    },
    {
      "start": 738.93,
      "end": 740.47,
      "text": "the comfort of her family"
    },
    {
      "start": 740.47,
      "end": 741.97,
      "text": "자 오늘"
    },
    {
      "start": 741.97,
      "end": 742.93,
      "text": "스크린 잉글리쉬는"
    },
    {
      "start": 742.93,
      "end": 743.93,
      "text": "여기까지입니다"
    }
  ]
}