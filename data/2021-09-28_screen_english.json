    },
    {
      "start": 413.9,
      "end": 414.8,
      "text": "We need your help"
    },
    {
      "start": 414.8,
      "end": 416.26,
      "text": "This is an important interview"
    },
    {
      "start": 416.26,
      "end": 418.04,
      "text": "So for their job"
    },
    {
      "start": 418.04,
      "end": 419.0,
      "text": "For their work"
    },
    {
      "start": 419.0,
      "end": 421.96,
      "text": "가운데 끼어 있는 입장이라서"
    },
    {
      "start": 421.96,
      "end": 422.86,
      "text": "루비의 마음도"
    },
    {
      "start": 422.86,
      "end": 424.5,
      "text": "참 굉장히 공감이"
    },
    {
      "start": 424.5,
      "end": 425.58,
      "text": "많이 되었었습니다"
    },
    {
      "start": 425.58,
      "end": 426.26,
      "text": "I don't think"
    },
    {
      "start": 426.26,
      "end": 427.14,
      "text": "Did he open the door?"
    },
    {
      "start": 427.22,
      "end": 428.22,
      "text": "I think she just went in"
    },
    {
      "start": 428.22,
      "end": 428.88,
      "text": "by herself"
    },
    {
      "start": 428.88,
      "end": 430.6,
      "text": "And he was playing the piano"
    },
    {
      "start": 430.6,
      "end": 432.18,
      "text": "He looked depressed"
    },
    {
      "start": 432.18,
      "end": 433.6,
      "text": "He was playing the piano"
    },
    {
      "start": 433.6,
      "end": 434.14,
      "text": "by himself"
    },
    {
      "start": 434.14,
      "end": 435.84,
      "text": "And she just went in"
    },
    {
      "start": 435.84,
      "end": 437.56,
      "text": "and was watching him"
    },
    {
      "start": 437.56,
      "end": 440.28,
      "text": "It was a very nervous moment"
    },
    {
      "start": 440.28,
      "end": 441.36,
      "text": "anxious moment"
    },
    {
      "start": 441.36,
      "end": 442.58,
      "text": "네, 긴장되는"
    },
    {
      "start": 442.58,
      "end": 444.18,
      "text": "그런 장면들이 이어지겠죠"
    },
    {
      "start": 444.18,
      "end": 445.74,
      "text": "일단 표현들"
    },
    {
      "start": 445.74,
      "end": 446.56,
      "text": "살펴볼까요?"
    },
    {
      "start": 447.3,
      "end": 448.26,
      "text": "I'm good at this"
    },
    {
      "start": 448.26,
      "end": 449.42,
      "text": "I'm good at this"
    },
    {
      "start": 449.42,
      "end": 451.4,
      "text": "난 이것을 잘해"
    },
    {
      "start": 451.4,
      "end": 452.84,
      "text": "Are you good at this?"
    },
    {
      "start": 453.14,
      "end": 454.72,
      "text": "질문도 할 수 있겠죠"
    },
    {
      "start": 454.72,
      "end": 455.86,
      "text": "Are you good at this?"
    },
    {
      "start": 456.04,
      "end": 456.92,
      "text": "Are you good at that?"
    },
    {
      "start": 457.38,
      "end": 458.36,
      "text": "Are you good at that?"
    },
    {
      "start": 458.5,
      "end": 459.64,
      "text": "Yeah, I'm good at this"
    },
    {
      "start": 459.64,
      "end": 460.76,
      "text": "I'm good at this"
    },
    {
      "start": 460.76,
      "end": 462.5,
      "text": "계속 따라하게 됩니다"
    },
    {
      "start": 462.5,
      "end": 463.88,
      "text": "계속 자랑해보세요"
    },
    {
      "start": 463.88,
      "end": 464.1,
      "text": "Yeah"
    },
    {
      "start": 464.1,
      "end": 466.85,
      "text": "In failure"
    },
    {
      "start": 466.85,
      "end": 468.21,
      "text": "In failure"
    },
    {
      "start": 468.21,
      "end": 471.32,
      "text": "실패로라는 의미가 되겠네요"
    },
    {
      "start": 471.32,
      "end": 472.92,
      "text": "Someone who's too afraid"
    },
    {
      "start": 472.92,
      "end": 473.86,
      "text": "to even try"
    },
    {
      "start": 473.86,
      "end": 476.26,
      "text": "Someone who's too afraid"
    },
    {
      "start": 476.26,
      "end": 477.48,
      "text": "to even try"
    },
    {
      "start": 477.48,
      "end": 478.16,
      "text": "라고 했으니까"
    },
    {
      "start": 478.16,
      "end": 480.18,
      "text": "시도조차"
    },
    {
      "start": 480.18,
      "end": 481.54,
      "text": "너무 두려워하는"
