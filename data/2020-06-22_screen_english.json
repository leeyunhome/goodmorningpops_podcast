      "start": 591.86,
      "end": 593.06,
      "text": "when you talk about"
    },
    {
      "start": 593.06,
      "end": 593.78,
      "text": "for example"
    },
    {
      "start": 593.78,
      "end": 594.56,
      "text": "바자웨이"
    },
    {
      "start": 594.56,
      "end": 596.12,
      "text": "or some kind of"
    },
    {
      "start": 596.12,
      "end": 596.66,
      "text": "fundraiser"
    },
    {
      "start": 596.66,
      "end": 597.0,
      "text": "Yeah"
    },
    {
      "start": 597.0,
      "end": 598.68,
      "text": "Where will the proceeds"
