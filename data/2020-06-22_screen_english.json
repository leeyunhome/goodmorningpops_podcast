    {
      "start": 583.36,
      "end": 584.22,
      "text": "혹은 나아가다"
    },
    {
      "start": 584.22,
      "end": 585.14,
      "text": "라는 동사잖아요"
    },
    {
      "start": 585.14,
      "end": 586.2,
      "text": "근데 여기서는"
    },
    {
      "start": 586.2,
      "end": 586.88,
      "text": "proceeds"
    },
    {
      "start": 586.88,
      "end": 587.48,
      "text": "라고 해서"
    },
    {
      "start": 587.48,
      "end": 588.24,
      "text": "S가 붙어서"
    },
    {
      "start": 588.24,
      "end": 589.78,
      "text": "돈, 수익금"
    },
    {
      "start": 589.78,
      "end": 590.82,
      "text": "이라는 의미예요"
    },
    {
      "start": 590.82,
      "end": 591.86,
      "text": "Yeah, usually"
    },
