    },
    {
      "start": 599.06,
      "end": 600.14,
      "text": "The proceeds"
    },
    {
      "start": 600.14,
      "end": 600.9,
      "text": "will go to"
    },
    {
      "start": 600.9,
      "end": 601.78,
      "text": "support"
    },
    {
      "start": 601.78,
      "end": 603.4,
      "text": "this organization"
    },
    {
      "start": 603.4,
      "end": 604.7,
      "text": "or this cause"
    },
    {
      "start": 604.7,
      "end": 605.46,
      "text": "그럴 때"
    },
    {
      "start": 605.46,
      "end": 605.92,
      "text": "proceeds"
    },
    {
      "start": 605.92,
      "end": 606.58,
      "text": "많이 쓰는데"
    },
    {
      "start": 606.58,
      "end": 607.92,
      "text": "딱딱 느낌이 오시죠"
    },
    {
      "start": 607.92,
      "end": 609.34,
      "text": "그래서 매각 대금"
    },
    {
      "start": 609.34,
      "end": 610.4,
      "text": "수입금은"
    },
    {
      "start": 610.4,
      "end": 612.1,
      "text": "We'll go to"
    },
    {
      "start": 612.1,
      "end": 612.86,
      "text": "preserve"
    },
    {
      "start": 612.86,
      "end": 614.08,
      "text": "our other"
    },
    {
      "start": 614.08,
      "end": 614.8,
      "text": "failing"
    },
    {
      "start": 614.8,
      "end": 615.76,
      "text": "enterprises"
    },
    {
      "start": 615.76,
      "end": 616.56,
      "text": "라고 했으니까"
    },
    {
      "start": 616.56,
      "end": 617.6,
      "text": "우리의 다른"
    },
    {
      "start": 617.6,
      "end": 618.54,
      "text": "실패하고 있는"
    },
    {
      "start": 618.54,
      "end": 619.16,
