    },
    {
      "start": 619.16,
      "end": 620.04,
      "text": "지켜낼 거야"
    },
    {
      "start": 620.04,
      "end": 621.06,
      "text": "라고 하면서"
    },
    {
      "start": 621.06,
      "end": 622.58,
      "text": "And time itself"
    },
    {
      "start": 622.58,
      "end": 623.16,
      "text": "그리고"
    },
    {
      "start": 623.16,
      "end": 624.22,
      "text": "시간 자체가"
    },
    {
      "start": 624.22,
      "end": 625.46,
      "text": "will mend"
    },
    {
      "start": 625.46,
      "end": 626.28,
      "text": "에디슨's"
    },
    {
      "start": 626.28,
      "end": 626.94,
      "text": "mistakes"
    },
    {
      "start": 626.94,
      "end": 627.94,
      "text": "에디슨의"
    },
    {
      "start": 627.94,
      "end": 628.44,
      "text": "실수를"
    },
    {
      "start": 628.44,
      "end": 629.38,
      "text": "고칠 거야"
    },
    {
      "start": 629.38,
      "end": 630.66,
      "text": "라고 이야기를 합니다"
    },
    {
      "start": 630.66,
      "end": 631.52,
      "text": "Yeah, I can't"
    },
    {
      "start": 631.52,
      "end": 632.48,
      "text": "fix his mistakes"
    },
    {
      "start": 632.48,
      "end": 633.9,
      "text": "Time will do that"
    },
    {
      "start": 633.9,
      "end": 634.72,
      "text": "But"
    },
    {
      "start": 634.72,
      "end": 635.46,
      "text": "지금"
    },
    {
      "start": 635.46,
      "end": 635.98,
      "text": "내가"
    },
    {
      "start": 635.98,
      "end": 637.16,
      "text": "내 코가 석재예요"
    },
    {
      "start": 637.16,
      "end": 638.6,
      "text": "너무 좋은 표현이에요"
    },
    {
      "start": 638.6,
      "end": 639.9,
      "text": "My businesses are failing"
    },
    {
      "start": 639.9,
      "end": 641.54,
      "text": "I have to save them"
    },
    {
      "start": 641.54,
      "end": 643.68,
      "text": "This is a big"
    },
    {
      "start": 643.68,
      "end": 644.8,
      "text": "urgent situation"
    },
    {
      "start": 644.8,
      "end": 645.3,
      "text": "Yeah"
    },
    {
      "start": 645.3,
      "end": 648.28,
      "text": "You are not a captain"
    },
    {
      "start": 648.28,
      "end": 649.28,
      "text": "who changes"
    },
    {
      "start": 649.28,
      "end": 649.94,
      "text": "his course"
    },
    {
      "start": 649.94,
      "end": 650.9,
      "text": "with the sea"
    },
    {
      "start": 650.9,
      "end": 651.86,
      "text": "굉장히"
    },
    {
      "start": 651.86,
      "end": 653.04,
      "text": "전곡을 찌릅니다"
    },
    {
      "start": 653.04,
      "end": 654.92,
      "text": "You are not a captain"
    },
    {
      "start": 654.92,
      "end": 655.8,
      "text": "당신은"
    },
    {
      "start": 655.8,
      "end": 656.8,
      "text": "captain이 아니에요"
    },
    {
      "start": 656.8,
      "end": 657.92,
      "text": "Who changes"
    },
    {
      "start": 657.92,
      "end": 658.74,
      "text": "his course"
    },
    {
      "start": 658.74,
      "end": 659.8,
      "text": "with the sea"
    },
    {
      "start": 659.8,
      "end": 661.04,
      "text": "Captain 맞는데"
    },
    {
      "start": 661.04,
      "end": 662.62,
      "text": "You're not a captain"
    },
    {
      "start": 662.62,
      "end": 663.22,
      "text": "without"
    },
    {
      "start": 663.22,
      "end": 664.16,
      "text": "중심 없는"
    },
    {
      "start": 664.16,
      "end": 664.82,
      "text": "captain 아니에요"
    },
    {
      "start": 664.82,
      "end": 665.36,
      "text": "맞아요"
    },
    {
      "start": 665.36,
      "end": 666.68,
      "text": "그러니까 당신은"
    },
    {
      "start": 666.68,
      "end": 668.58,
      "text": "에디슨에 대해서"
    },
    {
      "start": 668.58,
      "end": 669.34,
      "text": "에디슨의"
    },
    {
      "start": 669.34,
      "end": 670.3,
      "text": "그 항로를"
    },
    {
      "start": 670.3,
      "end": 671.28,
      "text": "바꿔주는"
    },
    {
      "start": 671.28,
      "end": 672.72,
      "text": "선장이 아니에요"
    },
    {
      "start": 672.72,
      "end": 673.34,
      "text": "라고 하는"
    },
    {
      "start": 673.34,
      "end": 674.24,
      "text": "부분이었습니다"
    },
    {
      "start": 674.24,
      "end": 675.1,
      "text": "I think you're"
    },
    {
      "start": 675.1,
      "end": 675.98,
      "text": "you don't go"
    },
    {
      "start": 675.98,
      "end": 676.54,
      "text": "this way"
    },
    {
      "start": 676.54,
      "end": 677.2,
      "text": "If the waves"
    },
    {
      "start": 677.2,
      "end": 678.14,
      "text": "go west"
    },
    {
      "start": 678.14,
      "end": 679.12,
      "text": "you go west"
    },
    {
      "start": 679.12,
      "end": 679.98,
      "text": "If the waves"
    },
    {
      "start": 679.98,
      "end": 680.78,
      "text": "go east"
    },
    {
      "start": 680.78,
      "end": 681.7,
      "text": "you go east"
    },
    {
      "start": 681.7,
      "end": 682.6,
      "text": "이렇게"
    },
    {
      "start": 682.6,
      "end": 684.22,
      "text": "파도에 휩쓸려"
    },
    {
      "start": 684.22,
      "end": 685.16,
      "text": "왔다 갔다"
    },
    {
      "start": 685.16,
      "end": 685.92,
      "text": "그런 남자가"
    },
    {
      "start": 685.92,
      "end": 686.46,
      "text": "아니잖아요"
    },
    {
      "start": 686.46,
      "end": 687.84,
      "text": "You're my husband"
    },
    {
      "start": 687.84,
      "end": 689.1,
      "text": "You are centered"
    },
    {
      "start": 689.1,
      "end": 689.94,
      "text": "정신 차려"
    },
    {
      "start": 689.94,
      "end": 691.26,
      "text": "You're a strong man"
    },
    {
      "start": 691.26,
      "end": 692.14,
      "text": "정신 차려"
    },
    {
      "start": 692.14,
      "end": 692.58,
      "text": "하는 거죠"
    },
    {
      "start": 692.58,
      "end": 692.94,
      "text": "Yeah"
    },
    {
      "start": 692.94,
      "end": 695.7,
      "text": "We're not on a course"
    },
    {
      "start": 695.7,
      "end": 697.22,
      "text": "We're drowning"
    },
    {
      "start": 697.22,
      "end": 698.34,
      "text": "여기에서"
    },
    {
      "start": 698.34,
      "end": 699.6,
      "text": "굉장히 큰 소리로"
    },
    {
      "start": 699.6,
      "end": 700.5,
      "text": "소리를 지르는"
    },
    {
      "start": 700.5,
      "end": 701.34,
      "text": "부분이었는데요"
    },
    {
      "start": 701.34,
      "end": 703.34,
      "text": "We're not on a course"
    },
    {
      "start": 703.34,
      "end": 703.98,
      "text": "우리는"
    },
    {
      "start": 703.98,
      "end": 705.36,
      "text": "궤도에 있는 게 아니야"
    },
    {
      "start": 705.36,
      "end": 707.28,
      "text": "We're drowning"
    },
    {
      "start": 707.28,
      "end": 707.96,
      "text": "이라고 했어요"
    },
    {
      "start": 707.96,
      "end": 708.92,
      "text": "우리는 지금"
    },
    {
      "start": 708.92,
      "end": 710.16,
      "text": "침몰하고 있다고"
    },
    {
      "start": 710.16,
      "end": 711.28,
      "text": "라고 합니다"
    },
    {
      "start": 711.28,
      "end": 715.04,
      "text": "So they do not see eye to eye"
    },
    {
      "start": 715.04,
      "end": 715.74,
      "text": "on this matter"
    },
    {
      "start": 715.74,
      "end": 717.02,
      "text": "They see the matter"
    },
    {
      "start": 717.02,
      "end": 718.16,
      "text": "very differently"
    },
    {
      "start": 718.16,
      "end": 718.72,
      "text": "Yeah"
    },
    {
      "start": 718.72,
      "end": 719.56,
      "text": "지금"
    },
    {
      "start": 719.56,
      "end": 720.5,
      "text": "웨스팅하우스는"
    },
    {
      "start": 720.5,
      "end": 720.78,
      "text": "지금"
    },
    {
      "start": 720.78,
      "end": 721.7,
      "text": "사업적으로"
    },
    {
      "start": 721.7,
      "end": 723.28,
      "text": "아주 심각한"
    },
    {
      "start": 723.28,
      "end": 724.54,
      "text": "위기 상황이라는 것을"
    },
    {
      "start": 724.54,
      "end": 725.66,
      "text": "아내에게"
    },
    {
      "start": 725.66,
      "end": 726.32,
      "text": "이야기해주는"
    },
    {
      "start": 726.32,
      "end": 727.52,
      "text": "그런 말이었어요"
    },
    {
      "start": 727.52,
      "end": 729.04,
      "text": "자 이 내용 떠올리시면서"
    },
    {
      "start": 729.04,
      "end": 730.14,
      "text": "한 번 더 들어보겠습니다"
    },
    {
      "start": 730.14,
      "end": 733.73,
      "text": "I thought impossible wasn't a word in your vocabulary"
    },
    {
      "start": 733.73,
      "end": 735.33,
      "text": "I am dissolving"
    },
    {
      "start": 735.33,
      "end": 736.41,
      "text": "웨스팅하우스 electric"
    },
    {
      "start": 736.41,
      "end": 740.47,
      "text": "The proceeds will go to preserve our other failing enterprises"
    },
    {
      "start": 740.47,
      "end": 744.59,
      "text": "and time itself will mend Edison's mistakes"
    },
    {
      "start": 744.59,
      "end": 748.79,
      "text": "You are not a captain who changes his course with the sea"
    },
    {
      "start": 748.79,
      "end": 750.33,
      "text": "We are not on a course"
    },
    {
      "start": 750.33,
      "end": 751.71,
      "text": "We're drowning"
    },
    {
      "start": 751.71,
      "end": 753.29,
      "text": "네"
    },
    {
      "start": 753.29,
      "end": 755.29,
      "text": "보면 볼수록"
    },
    {
      "start": 755.29,
      "end": 757.23,
      "text": "우리 웨스팅하우스의"
    },
    {
      "start": 757.23,
      "end": 758.19,
      "text": "성격"
    },
    {
      "start": 758.19,
      "end": 758.95,
      "text": "성품이"
    },
    {
      "start": 758.95,
      "end": 760.69,
      "text": "볼수록 괜찮은 사람인 것 같아요"
    },
    {
      "start": 760.69,
      "end": 761.41,
      "text": "제가 보기에는"
    },
    {
      "start": 761.41,
      "end": 761.99,
      "text": "Really?"
    },
    {
      "start": 762.53,
      "end": 763.57,
      "text": "사업적으로 좀"
    },
    {
      "start": 763.57,
      "end": 764.81,
      "text": "아내하고 다투기는 해도"
    },
    {
      "start": 764.81,
      "end": 767.07,
      "text": "그래도 귀담아드는 성격이잖아요"
    },
    {
      "start": 767.07,
      "end": 768.99,
      "text": "Is that like your current hubby?"
    },
    {
      "start": 769.83,
      "end": 770.19,
      "text": "Yeah"
    },
    {
      "start": 770.19,
      "end": 772.33,
      "text": "I believe so"
    },
    {
      "start": 772.33,
      "end": 773.49,
      "text": "That's why you fell for him"
    },
    {
      "start": 773.49,
      "end": 773.95,
      "text": "Yeah"
    },
    {
      "start": 773.95,
      "end": 775.05,
      "text": "좋습니다"
    },
    {
      "start": 775.05,
      "end": 775.93,
      "text": "제 스타일이에요"
    },
    {
      "start": 775.93,
      "end": 776.51,
      "text": "점차적으로"
    },
    {
      "start": 776.51,
      "end": 777.59,
      "text": "I hope he listens to you"
    },
    {
      "start": 777.59,
      "end": 777.93,
      "text": "Yeah"
    },
    {
      "start": 777.93,
      "end": 780.03,
      "text": "Thank you very much"
    },
    {
      "start": 780.03,
      "end": 782.17,
      "text": "자 스크린 잉글리쉬는 여기까지고요"
    }
  ]
}