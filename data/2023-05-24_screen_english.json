{
  "id": "2023-05-24_screen_english",
  "date": "2023-05-24",
  "corner": "screen_english",
  "corner_label": "Screen English",
  "title": "",
  "movie": "치어리딩 클럽 (Poms)",
  "duration_sec": 954.54,
  "audio_url": "https://rtyzdyyfahddqshgyjvn.supabase.co/storage/v1/object/public/gmp-audio/2023-05-24_screen_english.mp3",
  "artwork_generated_url": "",
  "script": [
    {
      "start": 0.0,
      "end": 4.26,
      "text": "김선업님, 새해부터 굿모닝 팝스를 꾸준히 듣고 있는데"
    },
    {
      "start": 4.26,
      "end": 8.48,
      "text": "수영장에서 만난 외국인의 영어가 들리는 것으로 보아"
    },
    {
      "start": 8.48,
      "end": 9.88,
      "text": "잘하고 있는 거겠죠?"
    },
    {
      "start": 10.5,
      "end": 12.66,
      "text": "외국인과 대화를 하고 싶었으나"
    },
    {
      "start": 12.66,
      "end": 14.78,
      "text": "아직 용기가 나지는 않네요."
    },
    {
      "start": 15.62,
      "end": 18.26,
      "text": "연말에는 외국인과의 대화를 기약하며"
    },
    {
      "start": 18.26,
      "end": 19.68,
      "text": "연습, 또 연습!"
    },
    {
      "start": 20.2,
      "end": 20.44,
      "text": "음!"
    },
    {
      "start": 20.44,
      "end": 23.78,
      "text": "5개월 동안 꾸준히 들으신 결과"
    },
    {
      "start": 23.78,
      "end": 26.66,
      "text": "이렇게 귀가 딱 먼저 열리셨어요."
    },
    {
      "start": 27.52,
      "end": 28.66,
      "text": "아주 잘하고 계신 겁니다."
    },
    {
      "start": 30.43,
      "end": 33.23,
      "text": "수영장은 아무래도 좀 울림이 있었을 텐데"
    },
    {
      "start": 33.23,
      "end": 34.53,
      "text": "그럼에도 불구하고"
    },
    {
      "start": 34.53,
      "end": 37.23,
      "text": "이 영어가 잘 들리셨다면"
    },
    {
      "start": 37.23,
      "end": 40.65,
      "text": "진짜 이거는 박수 쳐드려야 되는 그런 상황인 거예요."
    },
    {
      "start": 41.59,
      "end": 46.01,
      "text": "이야, 그 외국인 분하고 나중에 대화를 하실 준비가 되신다면"
    },
    {
      "start": 46.01,
      "end": 51.05,
      "text": "슬쩍 미리 눈인사를, 미소를 머금고"
    },
    {
      "start": 51.05,
      "end": 52.43,
      "text": "먼저 해보시면"
    },
    {
      "start": 52.43,
      "end": 56.71,
      "text": "아마 그분이 어느 날 대화를 먼저 걸어올 수도 있어요."
    },
    {
      "start": 57.67,
      "end": 59.39,
      "text": "왠지 그 후기도 기대가 됩니다."
    },
    {
      "start": 60.13,
      "end": 62.29,
      "text": "그러면 꼭 알려주실 거죠, 김선업님?"
    },
    {
      "start": 63.23,
      "end": 65.31,
      "text": "우리 김선업님 사연에"
    },
    {
      "start": 65.31,
      "end": 68.23,
      "text": "저도 기분이 더욱더 업업 되고 있습니다."
    },
    {
      "start": 69.21,
      "end": 71.03,
      "text": "이렇게 사연 소개되신 두 분께"
    },
    {
      "start": 71.03,
      "end": 74.31,
      "text": "월간 굿모닝 팝 3개월 구독권 보내드릴 거고요."
    },
    {
      "start": 74.31,
      "end": 77.61,
      "text": "굿모닝 팝스가 준비한 모닝 바이라민 이벤트"
    },
    {
      "start": 77.61,
      "end": 79.27,
      "text": "GMP로 영어 실력 업?"
    },
    {
      "start": 79.65,
      "end": 80.61,
      "text": "에너지도 업?"
    },
    {
      "start": 81.33,
      "end": 82.63,
      "text": "업? 더 올릴까요?"
    },
    {
      "start": 83.51,
      "end": 86.49,
      "text": "네, 오늘은 GMP 여러분들의 든든한 아침을 위해서"
    },
    {
      "start": 86.49,
      "end": 88.31,
      "text": "샌드위치 모바일 쿠폰 준비했습니다."
    },
    {
      "start": 89.41,
      "end": 91.17,
      "text": "신청 메시지 보내주신 분들 중에"
    },
    {
      "start": 91.17,
      "end": 93.23,
      "text": "다섯 분 뽑아서 보내드릴게요."
    },
    {
      "start": 93.99,
      "end": 98.07,
      "text": "단문 50원과 장문 100원에 추가 요금이 부과되는 문자 샵 8910"
    },
    {
      "start": 98.07,
      "end": 100.31,
      "text": "아니면 샵 1061로 신청하시거나"
    },
    {
      "start": 100.91,
      "end": 103.53,
      "text": "무료인 콩 또는 마이케로 참여해 주세요."
    },
    {
      "start": 110.42,
      "end": 112.04,
      "text": "아침 여섯 시"
    },
    {
      "start": 112.04,
      "end": 116.1,
      "text": "조정현의 굿모닝 팝"
    },
    {
      "start": 116.1,
      "end": 129.39,
      "text": "조정현의 굿모닝 팝"
    },
    {
      "start": 129.39,
      "end": 143.13,
      "text": "잉글리쉬"
    },
    {
      "start": 143.13,
      "end": 163.46,
      "text": "즐거워지는 영어 놀이터"
    },
    {
      "start": 163.46,
      "end": 165.02,
      "text": "스크린 잉글리쉬 타임"
    },
    {
      "start": 165.02,
      "end": 166.82,
      "text": "5월에 함께하고 있는 영화는"
    },
    {
      "start": 166.82,
      "end": 169.94,
      "text": "시니어 치어리더들의 유쾌한 반란"
    },
    {
      "start": 169.94,
      "end": 170.64,
      "text": "팝"
    },
    {
      "start": 170.64,
      "end": 170.66,
      "text": "팝"
    },
    {
      "start": 170.66,
      "end": 174.6,
      "text": "우리 크리스쌤 들어오셨습니다."
    },
    {
      "start": 174.9,
      "end": 176.04,
      "text": "와우, 잘 오셨어요."
    },
    {
      "start": 176.16,
      "end": 177.78,
      "text": "헬로우 조쌤, 헬로우 GMP"
    },
    {
      "start": 177.78,
      "end": 182.54,
      "text": "아, 왠지 더 유쾌한 느낌이 뿜뿜 차오르는 아침입니다."
    },
    {
      "start": 182.54,
      "end": 184.92,
      "text": "박미현님께서도요."
    },
    {
      "start": 185.0,
      "end": 186.36,
      "text": "크리스쌤 반갑습니다."
    },
    {
      "start": 186.52,
      "end": 187.54,
      "text": "웃음 웃음 하트"
    },
    {
      "start": 187.54,
      "end": 188.68,
      "text": "반갑습니다."
    },
    {
      "start": 189.16,
      "end": 189.72,
      "text": "네, 이렇게"
    },
    {
      "start": 189.72,
      "end": 193.46,
      "text": "러블리한 메시지와 함께 시작을 해볼게요."
    },
    {
      "start": 193.46,
      "end": 196.26,
      "text": "어, 다이앤 키튼 뿐 아니라"
    },
    {
      "start": 196.26,
      "end": 198.58,
      "text": "이렇게 쉐리엘 역할을 맡은"
    },
    {
      "start": 198.58,
      "end": 199.94,
      "text": "이 잭이 위버 있잖아요."
    },
    {
      "start": 200.12,
      "end": 200.76,
      "text": "잭이 위버."
    },
    {
      "start": 200.92,
      "end": 201.1,
      "text": "네."
    },
    {
      "start": 201.32,
      "end": 202.46,
      "text": "The lovely 잭이 위버."
    },
    {
      "start": 202.66,
      "end": 205.04,
      "text": "와우, 정말 사랑스럽다라는 형용사가"
    },
    {
      "start": 205.04,
      "end": 206.82,
      "text": "너무 잘 어울리는 배우입니다."
    },
    {
      "start": 207.04,
      "end": 207.82,
      "text": "She was lovely."
    },
    {
      "start": 208.04,
      "end": 208.32,
      "text": "맞아요."
    },
    {
      "start": 208.56,
      "end": 209.04,
      "text": "And bubbly."
    },
    {
      "start": 209.16,
      "end": 209.72,
      "text": "어, 맞아요."
    },
    {
      "start": 209.8,
      "end": 210.4,
      "text": "So bubbly."
    },
    {
      "start": 210.62,
      "end": 212.96,
      "text": "아주 발랄한 성격이기도 한데요."
    },
    {
      "start": 213.36,
      "end": 214.78,
      "text": "She did a great job."
    },
    {
      "start": 215.0,
      "end": 217.76,
      "text": "정말 연기를 너무 잘한다라는 생각이 들더라고요."
    },
    {
      "start": 217.96,
      "end": 218.98,
      "text": "She made me smile."
    },
    {
      "start": 219.24,
      "end": 219.56,
      "text": "맞아요."
    },
    {
      "start": 219.56,
      "end": 221.06,
      "text": "Every time she came on screen."
    },
    {
      "start": 221.2,
      "end": 221.38,
      "text": "Yeah."
    },
    {
      "start": 221.38,
      "end": 224.7,
      "text": "She was so bubbly, like champagne or sparkling water."
    },
    {
      "start": 225.02,
      "end": 225.52,
      "text": "맞습니다."
    },
    {
      "start": 225.72,
      "end": 227.76,
      "text": "딱 적당히 어울리는 표현들이었어요."
    },
    {
      "start": 227.84,
      "end": 229.36,
      "text": "Sparkling water와 같은"
    },
    {
      "start": 229.36,
      "end": 230.78,
      "text": "톡톡 튀는"
    },
    {
      "start": 230.78,
      "end": 234.68,
      "text": "상큼 발랄한 성격의 소유자가 맞는 것 같더라고요."
    },
    {
      "start": 234.86,
      "end": 236.66,
      "text": "아주 맛깔나는 연기를 하고 있습니다."
    },
    {
      "start": 236.9,
      "end": 239.48,
      "text": "And we had no idea she was from Australia."
    },
    {
      "start": 239.7,
      "end": 240.7,
      "text": "She's Australian."
    },
    {
      "start": 240.98,
      "end": 242.4,
      "text": "She's a great actress."
    },
    {
      "start": 242.68,
      "end": 244.24,
      "text": "She is from Australia."
    },
    {
      "start": 244.4,
      "end": 246.58,
      "text": "She got her start in Australia."
    },
    {
      "start": 246.58,
      "end": 250.02,
      "text": "And she's been working on stage and television"
    },
    {
      "start": 250.02,
      "end": 252.16,
      "text": "since the 1960s."
    },
    {
      "start": 252.28,
      "end": 253.86,
      "text": "So a long career."
    },
    {
      "start": 254.93,
      "end": 254.99,
      "text": "네."
    },
    {
      "start": 255.15,
      "end": 258.59,
      "text": "정말 이 Jackie Weaver이 가지고 있는 능력이"
    },
    {
      "start": 258.59,
      "end": 260.35,
      "text": "굉장히 훌륭할 수밖에 없다."
    },
    {
      "start": 260.65,
      "end": 264.53,
      "text": "그런 과거의 경력을 많이 가지고 있다라고 생각이 들고요."
    },
    {
      "start": 264.99,
      "end": 265.13,
      "text": "네."
    },
    {
      "start": 265.29,
      "end": 268.89,
      "text": "I heard she thought she was gonna play the leading role."
    },
    {
      "start": 268.89,
      "end": 269.83,
      "text": "Yes."
    },
    {
      "start": 269.99,
      "end": 271.21,
      "text": "The Meryl Streep role."
    },
    {
      "start": 271.41,
      "end": 273.95,
      "text": "Because actually her real-life personality"
    },
    {
      "start": 273.95,
      "end": 277.31,
      "text": "is not as bubbly and cheerful as Cheryl."
    },
    {
      "start": 277.63,
      "end": 280.91,
      "text": "She's not always smiling like champagne or sparkling water."
    },
    {
      "start": 281.15,
      "end": 281.55,
      "text": "Oh, 그래요?"
    },
    {
      "start": 281.63,
      "end": 283.79,
      "text": "And she said that when she saw the movie,"
    },
    {
      "start": 284.03,
      "end": 286.87,
      "text": "she didn't even recognize herself on screen."
    },
    {
      "start": 287.07,
      "end": 287.59,
      "text": "Oh, wow."
    },
    {
      "start": 287.59,
      "end": 290.09,
      "text": "Every time she appears, she has this huge grin."
    },
    {
      "start": 290.27,
      "end": 291.39,
      "text": "Really big grin."
    },
    {
      "start": 291.67,
      "end": 293.41,
      "text": "Like she called it a cat."
    },
    {
      "start": 293.51,
      "end": 295.03,
      "text": "A Cheshire cat."
    },
    {
      "start": 295.25,
      "end": 299.81,
      "text": "아, Cheshire cat 이렇게 불리기도 하는 것 같던데요."
    },
    {
      "start": 299.97,
      "end": 301.15,
      "text": "아, 그렇군요."
    },
    {
      "start": 301.55,
      "end": 303.77,
      "text": "저는 cat도 뭐 미소 질 수도 있죠."
    },
    {
      "start": 303.93,
      "end": 304.15,
      "text": "네."
    },
    {
      "start": 304.65,
      "end": 308.51,
      "text": "그 animated films가 되게 많이 연상이 되는 단어이기도 하잖아요."
    },
    {
      "start": 308.91,
      "end": 310.85,
      "text": "이 Cheshire cat라고 하는 게"
    },
    {
      "start": 310.85,
      "end": 313.79,
      "text": "약간 희죽희죽 웃고 있는 그 고양이 그림을"
    },
    {
      "start": 313.79,
      "end": 315.39,
      "text": "연상하시면 도움이 될 거고."
    },
    {
      "start": 315.57,
      "end": 316.73,
      "text": "아, Alice in Wonderland인가?"
    },
    {
      "start": 316.73,
      "end": 317.59,
      "text": "아, 맞아요."
    },
    {
      "start": 317.71,
      "end": 319.47,
      "text": "거기, 그 이상한 나라, 그 Alice in Wonderland."
    },
    {
      "start": 319.49,
      "end": 319.91,
      "text": "네, 네, 네."
    },
    {
      "start": 320.33,
      "end": 322.57,
      "text": "그래서 약간 항상 웃는 사람한테"
    },
    {
      "start": 322.57,
      "end": 327.45,
      "text": "이렇게 cat로 비유를 하게 되는 이유이기도 합니다."
    },
    {
      "start": 327.77,
      "end": 329.77,
      "text": "약간 fictional cat이기는 하는데"
    },
    {
      "start": 329.77,
      "end": 333.91,
      "text": "항상 mischievous한 grin을 가지고 있는 대상이죠."
    },
    {
      "start": 334.57,
      "end": 336.13,
      "text": "I like her grin."
    },
    {
      "start": 336.41,
      "end": 337.79,
      "text": "It looked real to me."
    },
    {
      "start": 337.95,
      "end": 338.19,
      "text": "Yeah."
    },
    {
      "start": 338.61,
      "end": 341.61,
      "text": "그러니까 이 영화를 촬영을 하면서"
    },
    {
      "start": 341.61,
      "end": 344.37,
      "text": "얼마나 스스로가 즐겁게 일했는지를"
    },
    {
      "start": 344.37,
      "end": 346.81,
      "text": "느낄 수가 있는 부분이었습니다."
    },
    {
      "start": 347.37,
      "end": 349.23,
      "text": "그럼 오늘 준비된 부분 듣고 오시죠."
    },
    {
      "start": 349.23,
      "end": 350.99,
      "text": "I blame myself."
    },
    {
      "start": 351.63,
      "end": 354.71,
      "text": "I mean, this is just the sort of thing that I knew would happen."
    },
    {
      "start": 355.35,
      "end": 359.75,
      "text": "Not only has one of our residents suffered a serious injury,"
    },
    {
      "start": 359.75,
      "end": 363.95,
      "text": "but now her son is threatening a lawsuit."
    },
    {
      "start": 364.59,
      "end": 367.41,
      "text": "Is there anything that you ladies care to say?"
    },
    {
      "start": 367.99,
      "end": 368.27,
      "text": "No."
    },
    {
      "start": 369.1,
      "end": 370.74,
      "text": "Then let's put it to a vote."
    },
    {
      "start": 371.44,
      "end": 373.5,
      "text": "All of those in favor of the ban."
    },
    {
      "start": 375.1,
      "end": 376.18,
      "text": "It's unanimous."
    },
    {
      "start": 376.18,
      "end": 380.37,
      "text": "You will hear about order to cease all club activities."
    },
    {
      "start": 381.5,
      "end": 383.13,
      "text": "Thank you."
    },
    {
      "start": 383.21,
      "end": 387.73,
      "text": "음, 약간 부정적인 느낌이 와닿으셨을 겁니다."
    },
    {
      "start": 387.93,
      "end": 388.55,
      "text": "It's over."
    },
    {
      "start": 389.07,
      "end": 389.55,
      "text": "Cheerleading."
    },
    {
      "start": 390.11,
      "end": 394.17,
      "text": "사실 이 Cheryl하고 Martha 사이에"
    },
    {
      "start": 394.17,
      "end": 398.01,
      "text": "There was a huge miscommunication between the two."
    },
    {
      "start": 398.13,
      "end": 398.51,
      "text": "Uh-oh."
    },
    {
      "start": 398.51,
      "end": 402.31,
      "text": "Martha 같은 경우는 연습할 수 있는 그 공간을"
    },
    {
      "start": 402.31,
      "end": 404.37,
      "text": "알아봐달라라고 부탁을 한 건데"
    },
    {
      "start": 404.37,
      "end": 404.67,
      "text": "네."
    },
    {
      "start": 405.25,
      "end": 405.29,
      "text": "네."
    },
    {
      "start": 405.29,
      "end": 405.31,
      "text": "네."
    },
    {
      "start": 405.31,
      "end": 405.33,
      "text": "네."
    },
    {
      "start": 405.33,
      "end": 405.39,
      "text": "네."
    },
    {
      "start": 405.39,
      "end": 405.89,
      "text": "네."
    },
    {
      "start": 405.89,
      "end": 405.99,
      "text": "네."
    },
    {
      "start": 405.99,
      "end": 409.01,
      "text": "손자인 벤이 다니는 그 고등학교에서"
    },
    {
      "start": 409.01,
      "end": 410.93,
      "text": "특히 그 고등학교에"
    },
    {
      "start": 410.93,
      "end": 413.07,
      "text": "There was a cheerleading contest가 있었어요."
    },
    {
      "start": 413.21,
      "end": 413.45,
      "text": "Yes."
    },
    {
      "start": 413.45,
      "end": 414.55,
      "text": "An actual contest."
    },
    {
      "start": 414.73,
      "end": 415.45,
      "text": "A competition."
    },
    {
      "start": 415.79,
      "end": 418.73,
      "text": "학생들이 이미 만반의 준비가 되는 상황이었고"
    },
    {
      "start": 418.73,
      "end": 421.31,
      "text": "그런 학생들이 이제 응원 대항전"
    },
    {
      "start": 421.31,
      "end": 422.79,
      "text": "이렇게 표현할 수 있을 것 같은데"
    },
    {
      "start": 422.79,
      "end": 425.43,
      "text": "그런 컨테스트가 열리는 상황인데"
    },
    {
      "start": 425.43,
      "end": 430.11,
      "text": "거기에다가 끼어서 리허설, 연습을 하겠다라고"
    },
    {
      "start": 430.11,
      "end": 431.41,
      "text": "다 데리고 간 겁니다."
    },
    {
      "start": 431.51,
      "end": 432.49,
      "text": "아, 연습하러 가는데."
    },
    {
      "start": 433.05,
      "end": 433.83,
      "text": "Oh, my gosh."
    },
    {
      "start": 434.23,
      "end": 434.41,
      "text": "네."
    },
    {
      "start": 434.49,
      "end": 436.55,
      "text": "근데 고등학생들을 봤을 때"
    },
    {
      "start": 436.55,
      "end": 438.83,
      "text": "The cheerleaders did a great job."
    },
    {
      "start": 439.11,
      "end": 441.13,
      "text": "Oh, a great job."
    },
    {
      "start": 441.15,
      "end": 442.09,
      "text": "진짜 잘했어요."
    },
    {
      "start": 442.17,
      "end": 443.65,
      "text": "Kind of in a sarcastic way."
    },
    {
      "start": 443.65,
      "end": 444.83,
      "text": "아, 아니요."
    },
    {
      "start": 445.11,
      "end": 448.77,
      "text": "저는 되게 긍정적인 방법으로 표현을 한 거예요."
    },
    {
      "start": 448.89,
      "end": 449.57,
      "text": "진짜 잘했어요."
    },
    {
      "start": 449.57,
      "end": 449.63,
      "text": "그래요?"
    },
    {
      "start": 449.81,
      "end": 449.95,
      "text": "네."
    },
    {
      "start": 450.07,
      "end": 451.29,
      "text": "But they made fun of them."
    },
    {
      "start": 452.07,
      "end": 453.61,
      "text": "할머니들 못 칠리등해."
    },
    {
      "start": 453.73,
      "end": 454.59,
      "text": "아, 그러니까."
    },
    {
      "start": 454.59,
      "end": 457.87,
      "text": "I saw them doing some acrobatic movements."
    },
    {
      "start": 458.17,
      "end": 458.89,
      "text": "The grandmas?"
    },
    {
      "start": 459.09,
      "end": 459.51,
      "text": "No, no."
    },
    {
      "start": 459.55,
      "end": 460.79,
      "text": "Oh, the high school students."
    },
    {
      "start": 461.17,
      "end": 461.91,
      "text": "Oh, the high school students."
    },
    {
      "start": 461.91,
      "end": 462.93,
      "text": "그 할머니들 얘기하는 줄 알고."
    },
    {
      "start": 463.21,
      "end": 463.41,
      "text": "진짜."
    },
    {
      "start": 463.75,
      "end": 465.03,
      "text": "The high school students, of course."
    },
    {
      "start": 465.09,
      "end": 465.91,
      "text": "진짜 잘했어요."
    },
    {
      "start": 465.95,
      "end": 466.79,
      "text": "They're great."
    },
    {
      "start": 467.11,
      "end": 468.11,
      "text": "당연히 잘하고."
    },
    {
      "start": 468.23,
      "end": 468.47,
      "text": "그죠."
    },
    {
      "start": 468.71,
      "end": 470.85,
      "text": "근데 거기에다가 할머니들 껴 있으니까."
    },
    {
      "start": 471.07,
      "end": 472.53,
      "text": "너무 달랐죠."
    },
    {
      "start": 472.53,
      "end": 473.35,
      "text": "There was an accident."
    },
    {
      "start": 473.67,
      "end": 474.79,
      "text": "There was an injury."
    },
    {
      "start": 475.05,
      "end": 475.35,
      "text": "맞아요."
    },
    {
      "start": 475.47,
      "end": 477.31,
      "text": "And someone embarrassed them."
    },
    {
      "start": 477.31,
      "end": 487.37,
      "text": "특히 다쳤던 멤버는 헬렌이라는 할머니였는데, 아주 우연의 사고로 sprained her ankle."
    },
    {
      "start": 487.89,
      "end": 489.29,
      "text": "발목을 삐었죠."
    },
    {
      "start": 489.45,
      "end": 492.37,
      "text": "In the middle of the contest, everybody's watching."
    },
    {
      "start": 492.51,
      "end": 494.07,
      "text": "And someone's taking a video."
    },
    {
      "start": 494.31,
      "end": 495.93,
      "text": "So they're really embarrassed."
    },
    {
      "start": 495.93,
      "end": 498.69,
      "text": "정말 총체적 난국입니다."
    },
    {
      "start": 499.21,
      "end": 500.63,
      "text": "라고 표현할 수 있습니다."
    },
    {
      "start": 500.93,
      "end": 501.15,
      "text": "이제 끝."
    },
    {
      "start": 501.51,
      "end": 502.49,
      "text": "이동원이 끝."
    },
    {
      "start": 503.05,
      "end": 503.59,
      "text": "The end."
    },
    {
      "start": 503.93,
      "end": 507.73,
      "text": "미리 살펴볼 표현 중 첫 번째 소개해 주세요."
    },
    {
      "start": 508.39,
      "end": 509.51,
      "text": "I blame myself."
    },
    {
      "start": 509.89,
      "end": 511.21,
      "text": "I blame myself."
    },
    {
      "start": 511.21,
      "end": 512.51,
      "text": "내 잘못이에요."
    },
    {
      "start": 513.27,
      "end": 514.19,
      "text": "이런 뜻입니다."
    },
    {
      "start": 514.97,
      "end": 516.27,
      "text": "Let's put it to a vote."
    },
    {
      "start": 516.75,
      "end": 518.17,
      "text": "Let's put it to a vote."
    },
    {
      "start": 518.59,
      "end": 520.09,
      "text": "그럼 표결에 붙이죠."
    },
    {
      "start": 520.71,
      "end": 521.61,
      "text": "나설길로 합시다."
    },
    {
      "start": 521.85,
      "end": 522.69,
      "text": "Let's put it to a vote."
    },
    {
      "start": 522.85,
      "end": 524.97,
      "text": "Who votes that we continue the club?"
    },
    {
      "start": 525.53,
      "end": 527.19,
      "text": "Everybody votes that it's over."
    },
    {
      "start": 527.31,
      "end": 527.63,
      "text": "맞아요."
    },
    {
      "start": 527.83,
      "end": 528.35,
      "text": "So sad."
    },
    {
      "start": 529.19,
      "end": 530.67,
      "text": "It's unanimous."
    },
    {
      "start": 530.93,
      "end": 532.31,
      "text": "It's unanimous."
    },
    {
      "start": 532.33,
      "end": 533.15,
      "text": "It was unanimous."
    },
    {
      "start": 533.33,
      "end": 535.85,
      "text": "Everybody voted to end the club."
    },
    {
      "start": 536.57,
      "end": 539.13,
      "text": "특히 철자로 알려드리면 좋을 것 같은데,"
    },
    {
      "start": 539.13,
      "end": 543.69,
      "text": "U-N-A-N-I-M-O-U-S"
    },
    {
      "start": 543.69,
      "end": 544.65,
      "text": "라는 철자입니다."
    },
    {
      "start": 545.19,
      "end": 547.97,
      "text": "이게 만장일치인이라는 뜻이 되는 거잖아요."
    },
    {
      "start": 548.43,
      "end": 549.99,
      "text": "그래서 It's unanimous."
    },
    {
      "start": 550.39,
      "end": 551.27,
      "text": "만장일치네요."
    },
    {
      "start": 551.55,
      "end": 553.57,
      "text": "라는 문장까지 살펴보시고요."
    },
    {
      "start": 553.99,
      "end": 555.31,
      "text": "그럼 한 번 더 들어보시죠."
    },
    {
      "start": 556.12,
      "end": 557.38,
      "text": "I blame myself."
    },
    {
      "start": 558.04,
      "end": 559.88,
      "text": "I mean, this is just the sort of thing"
    },
    {
      "start": 559.88,
      "end": 561.1,
      "text": "that I knew would happen."
    },
    {
      "start": 561.74,
      "end": 566.16,
      "text": "Not only has one of our residents suffered a serious injury,"
    },
    {
      "start": 566.16,
      "end": 570.34,
      "text": "but now her son is threatening a lawsuit."
    },
    {
      "start": 570.98,
      "end": 573.82,
      "text": "Is there anything that you ladies care to say?"
    },
    {
      "start": 574.38,
      "end": 574.66,
      "text": "No."
    },
    {
      "start": 575.52,
      "end": 577.14,
      "text": "Then let's put it to a vote."
    },
    {
      "start": 577.84,
      "end": 579.92,
      "text": "All of those in favor of the ban."
    },
    {
      "start": 581.52,
      "end": 582.58,
      "text": "It's unanimous."
    },
    {
      "start": 583.86,
      "end": 586.76,
      "text": "You will hear by order to cease all club activities."
    },
    {
      "start": 586.76,
      "end": 588.41,
      "text": "Thank you."
    },
    {
      "start": 589.5,
      "end": 592.42,
      "text": "네, 아까 미리 설명을 들으신 것처럼"
    },
    {
      "start": 592.42,
      "end": 594.16,
      "text": "그 학생들 중에"
    },
    {
      "start": 594.16,
      "end": 595.68,
      "text": "one of the students가"
    },
    {
      "start": 595.68,
      "end": 597.64,
      "text": "posted the video."
    },
    {
      "start": 598.22,
      "end": 599.26,
      "text": "Yeah, on SNS."
    },
    {
      "start": 599.38,
      "end": 601.22,
      "text": "Of the grandmother's cheerleading."
    },
    {
      "start": 601.36,
      "end": 602.92,
      "text": "And getting injured."
    },
    {
      "start": 603.12,
      "end": 604.92,
      "text": "So it blew up."
    },
    {
      "start": 605.0,
      "end": 605.6,
      "text": "맞아요."
    },
    {
      "start": 605.96,
      "end": 607.78,
      "text": "정말 엎친 데 덮친 격."
    },
    {
      "start": 607.92,
      "end": 609.5,
      "text": "상황이 더 악화가 되었습니다."
    },
    {
      "start": 610.36,
      "end": 613.1,
      "text": "그리고 그 녹화 영상을 게시를 하자마자"
    },
    {
      "start": 613.1,
      "end": 615.38,
      "text": "It went viral so quickly."
    },
    {
      "start": 615.46,
      "end": 615.82,
      "text": "Yes."
    },
    {
      "start": 616.14,
      "end": 617.12,
      "text": "완전 떡."
    },
    {
      "start": 617.42,
      "end": 618.22,
      "text": "떡상."
    },
    {
      "start": 618.52,
      "end": 619.3,
      "text": "It blew up."
    },
    {
      "start": 619.52,
      "end": 620.1,
      "text": "영어로."
    },
    {
      "start": 620.22,
      "end": 621.14,
      "text": "It blew up."
    },
    {
      "start": 622.22,
      "end": 625.38,
      "text": "엄청난 위기에 또 직면을 한 상황인데요."
    },
    {
      "start": 625.88,
      "end": 628.84,
      "text": "그래서 위기가 이 회의를 주선을 했습니다."
    },
    {
      "start": 629.22,
      "end": 631.68,
      "text": "그러면서 첫 번째로 이런 말을 하죠."
    },
    {
      "start": 632.47,
      "end": 633.65,
      "text": "I blame myself."
    },
    {
      "start": 634.13,
      "end": 635.39,
      "text": "아, 내 탓이에요."
    },
    {
      "start": 635.63,
      "end": 636.41,
      "text": "내 잘못이에요."
    },
    {
      "start": 636.41,
      "end": 640.05,
      "text": "This is just the sort of thing I knew would happen."
    },
    {
      "start": 640.05,
      "end": 643.93,
      "text": "음, 이런 종류의 사고가 일어날 줄 알았어요."
    },
    {
      "start": 644.63,
      "end": 648.67,
      "text": "Not only has one of our residents suffered a serious injury,"
    },
    {
      "start": 648.93,
      "end": 652.07,
      "text": "but now her son is threatening a lawsuit."
    },
    {
      "start": 652.29,
      "end": 657.57,
      "text": "음, not only has one of our residents suffered a serious injury,"
    },
    {
      "start": 658.03,
      "end": 662.73,
      "text": "우리 주민들 중 한 명이 심각한 부상을 입은 것뿐 아니라"
    },
    {
      "start": 662.73,
      "end": 666.21,
      "text": "But now her son is threatening a lawsuit."
    },
    {
      "start": 666.21,
      "end": 671.05,
      "text": "지금 그분의 아들이 소송을 하겠다며 위협하고 있어요."
    },
    {
      "start": 671.09,
      "end": 671.67,
      "text": "Oh, lawsuit."
    },
    {
      "start": 672.15,
      "end": 672.81,
      "text": "So scary."
    },
    {
      "start": 673.03,
      "end": 673.93,
      "text": "So expensive."
    },
    {
      "start": 674.29,
      "end": 677.01,
      "text": "특히 헬렌의 아들은 기억나십니까?"
    },
    {
      "start": 677.23,
      "end": 678.33,
      "text": "Yes, the scary guy."
    },
    {
      "start": 678.47,
      "end": 682.39,
      "text": "네, 아주 위협적으로 이야기를 하던 사람이었어요."
    },
    {
      "start": 682.47,
      "end": 684.05,
      "text": "계속 그 돈 안 쓰려고."
    },
    {
      "start": 684.15,
      "end": 684.41,
      "text": "맞아요."
    },
    {
      "start": 684.65,
      "end": 684.81,
      "text": "네."
    },
    {
      "start": 686.97,
      "end": 689.17,
      "text": "Is there anything that you ladies care to say?"
    },
    {
      "start": 689.55,
      "end": 691.47,
      "text": "그러면서 비키가 이런 질문을 했습니다."
    },
    {
      "start": 691.47,
      "end": 694.25,
      "text": "Is there anything that you ladies care to say?"
    },
    {
      "start": 694.25,
      "end": 697.23,
      "text": "당신들은 무슨 할 말 없으세요?"
    },
    {
      "start": 697.49,
      "end": 698.27,
      "text": "라는 의미인데요."
    },
    {
      "start": 698.79,
      "end": 703.49,
      "text": "여기 끝부분에 care to say 라는 동사 구가 들렸단 말이에요."
    },
    {
      "start": 704.31,
      "end": 707.83,
      "text": "근데 주로 이렇게 care to say, 말하고자 하다,"
    },
    {
      "start": 707.97,
      "end": 712.75,
      "text": "care to help, 돕고자 하다, 이런 뉘앙스들을 담고 있는 거죠."
    },
    {
      "start": 713.13,
      "end": 718.29,
      "text": "이 care라는 거 자체만 집중해서 보면은 어디어디에 관심을 갖다라는 것이니까"
    },
    {
      "start": 718.29,
      "end": 723.71,
      "text": "다시 말해 말할 마음이 있다, 뭐 도울 의향이 있다라는 의미가"
    },
    {
      "start": 723.71,
      "end": 728.75,
      "text": "care to say, care to help, 이런 예문에서 덧붙여지게 되는 거겠죠?"
    },
    {
      "start": 728.87,
      "end": 730.97,
      "text": "좀 고급지고 부드러운 표현."
    },
    {
      "start": 731.65,
      "end": 733.23,
      "text": "Is there anything you care to say?"
    },
    {
      "start": 733.97,
      "end": 737.05,
      "text": "여기서는 그렇게 예의바르게 안 들리죠?"
    },
    {
      "start": 737.13,
      "end": 737.39,
      "text": "맞아요."
    },
    {
      "start": 737.43,
      "end": 738.17,
      "text": "비키 입장이니까."
    },
    {
      "start": 738.43,
      "end": 742.15,
      "text": "말투는 예의바른 척하지만 속내용은 전혀 아니었습니다."
    },
    {
      "start": 743.5,
      "end": 743.88,
      "text": "No."
    },
    {
      "start": 744.5,
      "end": 745.08,
      "text": "그래서 no."
    },
    {
      "start": 745.08,
      "end": 747.9,
      "text": "네, 마르사가 no 이렇게 대답했어요."
    },
    {
      "start": 747.9,
      "end": 749.18,
      "text": "I care to say nothing."
    },
    {
      "start": 749.44,
      "end": 750.74,
      "text": "I'm not going to say anything."
    },
    {
      "start": 751.92,
      "end": 753.52,
      "text": "Then let's put it to a vote."
    },
    {
      "start": 754.18,
      "end": 756.26,
      "text": "자, 그럼 우리 표결에 붙이죠."
    },
    {
      "start": 756.4,
      "end": 757.7,
      "text": "우리 투표로 정합시다."
    },
    {
      "start": 758.32,
      "end": 760.32,
      "text": "All of those in favor of the ban."
    },
    {
      "start": 760.86,
      "end": 762.06,
      "text": "Raise your hand."
    },
    {
      "start": 762.74,
      "end": 763.98,
      "text": "손 들어 들었겠죠?"
    },
    {
      "start": 764.18,
      "end": 764.74,
      "text": "네, 맞아요."
    },
    {
      "start": 765.28,
      "end": 766.12,
      "text": "그러면서 이제"
    },
    {
      "start": 766.12,
      "end": 768.76,
      "text": "All of those in favor of the ban."
    },
    {
      "start": 769.16,
      "end": 770.32,
      "text": "이렇게 이야기를 했는데"
    },
    {
      "start": 770.32,
      "end": 775.36,
      "text": "금지에 찬성하는 사람들 모두 여기까지 이야기를 했지만"
    },
    {
      "start": 775.36,
      "end": 780.08,
      "text": "사실 손을 들으라라는 이야기가 다 함축이 되어 있는 문장과도 같죠."
    },
    {
      "start": 780.08,
      "end": 785.38,
      "text": "네, 근데 이 중에서 그 Carl이라고 하는 그 마을의 셰이프 있잖아요."
    },
    {
      "start": 785.64,
      "end": 786.12,
      "text": "The sheriff."
    },
    {
      "start": 786.48,
      "end": 787.46,
      "text": "눈치 보는 셰이프."
    },
    {
      "start": 787.54,
      "end": 787.84,
      "text": "맞아요."
    },
    {
      "start": 788.32,
      "end": 791.24,
      "text": "처음에는 didn't raise his hand first."
    },
    {
      "start": 791.66,
      "end": 795.34,
      "text": "그러다가 비키의 눈치를 보고 손을 또 들게 됩니다."
    },
    {
      "start": 795.46,
      "end": 798.1,
      "text": "아, 속마음은 cheerleading 편인데."
    },
    {
      "start": 798.18,
      "end": 798.84,
      "text": "그랬나 봐요."
    },
    {
      "start": 798.84,
      "end": 806.74,
      "text": "자신의 뜻대로 모든 사람들이 다 손을 들었으니까"
    },
    {
      "start": 806.74,
      "end": 808.36,
      "text": "It's unanimous."
    },
    {
      "start": 808.66,
      "end": 810.02,
      "text": "완전 일지군요."
    },
    {
      "start": 810.16,
      "end": 810.96,
      "text": "라고 이야기합니다."
    },
    {
      "start": 811.02,
      "end": 811.44,
      "text": "The sheriff."
    },
    {
      "start": 811.6,
      "end": 812.78,
      "text": "You glared at the sheriff."
    },
    {
      "start": 813.14,
      "end": 814.46,
      "text": "Sheriff 째려봤으니까 그렇죠."
    },
    {
      "start": 814.68,
      "end": 814.94,
      "text": "맞아요."
    },
    {
      "start": 815.18,
      "end": 815.8,
      "text": "안 그렇으면"
    },
    {
      "start": 815.8,
      "end": 817.98,
      "text": "It would not be unanimous."
    },
    {
      "start": 818.08,
      "end": 818.76,
      "text": "그러니까요."
    },
    {
      "start": 818.76,
      "end": 834.9,
      "text": "여러분은 이로써 동아리 활동을 전면 중단하라는"
    },
    {
      "start": 834.9,
      "end": 838.04,
      "text": "자, 여기서 멈추다, 중단하다라는 동사로"
    },
    {
      "start": 838.04,
      "end": 840.12,
      "text": "seize 라는 단어가 활용이 되었습니다."
    },
    {
      "start": 840.3,
      "end": 841.64,
      "text": "네, 그 발음 조심해야 돼요."
    },
    {
      "start": 842.2,
      "end": 845.58,
      "text": "seize는 이렇게 뭐 이거 가져가는 거고"
    },
    {
      "start": 845.58,
      "end": 847.12,
      "text": "네, 잡다, 뭐 가져가다"
    },
    {
      "start": 847.12,
      "end": 847.58,
      "text": "억지로."
    },
    {
      "start": 848.28,
      "end": 849.34,
      "text": "이거는 seize."
    },
    {
      "start": 850.02,
      "end": 850.62,
      "text": "seize."
    },
    {
      "start": 851.02,
      "end": 852.22,
      "text": "아, 감사해요."
    },
    {
      "start": 852.36,
      "end": 853.68,
      "text": "약간 S 발음이 강하네요."
    },
    {
      "start": 853.8,
      "end": 857.48,
      "text": "네, 이런 디테일 살려서 우리가 연습을 하면 좋겠네요."
    },
    {
      "start": 857.9,
      "end": 858.36,
      "text": "seize."
    },
    {
      "start": 858.94,
      "end": 859.28,
      "text": "맞나요?"
    },
    {
      "start": 859.38,
      "end": 859.8,
      "text": "seize."
    },
    {
      "start": 860.14,
      "end": 860.54,
      "text": "seize."
    },
    {
      "start": 860.7,
      "end": 860.84,
      "text": "네."
    },
    {
      "start": 860.98,
      "end": 861.36,
      "text": "오, 예."
    },
    {
      "start": 861.9,
      "end": 862.24,
      "text": "오, 좋아요."
    },
    {
      "start": 862.54,
      "end": 863.06,
      "text": "일치원장."
    },
    {
      "start": 863.22,
      "end": 864.02,
      "text": "네, 좋습니다."
    },
    {
      "start": 864.02,
      "end": 866.44,
      "text": "네, 이렇게 전면 중단하라는"
    },
    {
      "start": 866.44,
      "end": 869.3,
      "text": "You are here by ordered to 라고 했으니까"
    },
    {
      "start": 869.3,
      "end": 871.06,
      "text": "명령을 받은 겁니다."
    },
    {
      "start": 872.1,
      "end": 873.02,
      "text": "Thank you."
    },
    {
      "start": 873.1,
      "end": 875.34,
      "text": "네, 아니 되게 의외이지 않아요?"
    },
    {
      "start": 875.34,
      "end": 878.34,
      "text": "Martha는 didn't even defend herself."
    },
    {
      "start": 878.64,
      "end": 881.64,
      "text": "I think, you know, 말해봤자 안 통하는 사람이니까"
    },
    {
      "start": 881.64,
      "end": 882.84,
      "text": "어차피 안 통해요."
    },
    {
      "start": 883.06,
      "end": 883.98,
      "text": "So, thank you."
    },
    {
      "start": 884.48,
      "end": 886.06,
      "text": "좀 안타까운 장면입니다."
    },
    {
      "start": 886.44,
      "end": 887.94,
      "text": "네, 그럼 한 번 더 확인해 보시죠."
    },
    {
      "start": 887.94,
      "end": 890.02,
      "text": "I blame myself."
    },
    {
      "start": 890.48,
      "end": 893.54,
      "text": "I mean, this is just the sort of thing that I knew would happen."
    },
    {
      "start": 894.2,
      "end": 898.58,
      "text": "Not only has one of our residents suffered a serious injury,"
    },
    {
      "start": 898.58,
      "end": 902.62,
      "text": "but now her son is threatening a lawsuit."
    },
    {
      "start": 903.42,
      "end": 906.24,
      "text": "Is there anything that you ladies care to say?"
    },
    {
      "start": 906.8,
      "end": 907.1,
      "text": "No."
    },
    {
      "start": 907.96,
      "end": 909.56,
      "text": "Then let's put it to a vote."
    },
    {
      "start": 910.2,
      "end": 912.34,
      "text": "All of those in favor of the ban."
    },
    {
      "start": 913.92,
      "end": 915.02,
      "text": "It's unanimous."
    },
    {
      "start": 916.31,
      "end": 919.19,
      "text": "You will hear by ordered to cease all club activities."
    },
    {
      "start": 920.35,
      "end": 920.81,
      "text": "Thank you."
    },
    {
      "start": 920.81,
      "end": 928.2,
      "text": "네, 아무래도 Martha가 마음이 매우 무겁고 힘든 것 같아 보여요."
    },
    {
      "start": 928.54,
      "end": 931.46,
      "text": "I wonder if she'll give up her dream like this."
    },
    {
      "start": 931.62,
      "end": 932.34,
      "text": "Don't give up."
    },
    {
      "start": 932.82,
      "end": 938.52,
      "text": "절대 포기하지 않기를 응원하는 마음으로 오늘 여기에서 마무리해 보도록 하겠습니다."
    },
    {
      "start": 938.56,
      "end": 939.42,
      "text": "Never give up."
    },
    {
      "start": 939.42,
      "end": 942.44,
      "text": "Silver Time 이동하더라도, 딴 데 가더라도."
    },
    {
      "start": 942.6,
      "end": 944.1,
      "text": "Do not give up on your dream."
    },
    {
      "start": 944.32,
      "end": 947.6,
      "text": "네, 이렇게 꿈은 계속해서 쫓아가야 되는 거죠."
    },
    {
      "start": 948.18,
      "end": 950.78,
      "text": "그러면 우리 크쌤 내일 다시 만나요."
    },
    {
      "start": 950.82,
      "end": 951.34,
      "text": "Bye, 조쌤."
    },
    {
      "start": 951.4,
      "end": 951.8,
      "text": "Bye, everyone."
    },
    {
      "start": 951.8,
      "end": 954.54,
      "text": "네, 그럼 노래 한 곡 들어볼게요."
    }
  ]
}