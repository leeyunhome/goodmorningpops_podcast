      "text": "이 장면"
    },
    {
      "start": 702.96,
      "end": 703.86,
      "text": "한 번 더 들어보겠습니다."
    },
    {
      "start": 705.0,
      "end": 705.62,
      "text": "When we were little,"
    },
    {
      "start": 705.74,
      "end": 707.24,
      "text": "I used to see you guys in town."
    },
    {
      "start": 707.68,
      "end": 707.94,
      "text": "Yeah."
    },
    {
      "start": 708.78,
      "end": 709.64,
      "text": "We were hard to miss."
    },
    {
      "start": 710.18,
      "end": 710.88,
      "text": "There was this one time"
    },
    {
      "start": 710.88,
      "end": 711.6,
      "text": "I think it was like"
    },
    {
      "start": 711.6,
      "end": 713.29,
      "text": "third grade."
    },
    {
      "start": 713.99,
      "end": 714.79,
      "text": "You were at the"
    },
    {
      "start": 714.79,
      "end": 715.37,
      "text": "Seatport Grill"
    },
    {
      "start": 715.37,
      "end": 716.35,
      "text": "and you were ordering"
    },
    {
      "start": 716.35,
      "end": 717.05,
      "text": "for your parents"
    },
    {
      "start": 717.05,
      "end": 719.17,
      "text": "and you were talking"
    },
    {
      "start": 719.17,
      "end": 719.55,
      "text": "to the Whiter"
    },
    {
      "start": 719.55,
      "end": 720.55,
      "text": "like a total baller"
    },
    {
      "start": 720.55,
      "end": 722.28,
      "text": "and then you ordered"
    },
    {
      "start": 722.28,
      "end": 722.88,
      "text": "two beers."
    },
    {
      "start": 723.79,
      "end": 724.93,
      "text": "I thought it was so cool."
    },
    {
      "start": 725.37,
      "end": 725.67,
      "text": "Really?"
    },
    {
      "start": 726.47,
      "end": 726.77,
      "text": "Yeah."
    },
    {
      "start": 727.89,
      "end": 728.65,
      "text": "My parents wouldn't even"
    },
    {
      "start": 728.65,
      "end": 729.27,
      "text": "let me ride the bus"
    },
    {
      "start": 729.27,
      "end": 729.83,
      "text": "by myself."
    },
    {
      "start": 731.17,
      "end": 732.37,
      "text": "이 지혜님께서"
    },
    {
      "start": 732.37,
      "end": 734.25,
      "text": "크리스쌤이 노래도 하는"
    },
    {
      "start": 734.25,
      "end": 736.05,
      "text": "어메이징한 G&B"
    },
    {
      "start": 736.05,
      "end": 737.75,
      "text": "갑자기 노래 언제 했나요?"
    },
    {
      "start": 737.91,
      "end": 739.73,
      "text": "City of stars"
    },
    {
      "start": 739.73,
      "end": 741.65,
      "text": "Oh my, please."
    },
    {
      "start": 741.95,
      "end": 743.13,
      "text": "갑자기 옆에서 막"
    },
    {
      "start": 743.13,
      "end": 744.27,
      "text": "무슨 말인지"
    },
    {
      "start": 744.27,
      "end": 745.35,
      "text": "못 알아듣겠어요"
    },
    {
      "start": 745.35,
      "end": 746.49,
      "text": "막 이러는 경우도"
    },
    {
      "start": 746.49,
      "end": 747.19,
      "text": "생기지 않나요?"
    },
    {
      "start": 747.37,
      "end": 748.47,
      "text": "City of stars"
    },
    {
      "start": 748.47,
      "end": 748.95,
      "text": "할 때"
    },
    {
      "start": 748.95,
      "end": 750.45,
      "text": "아무튼"
    },
    {
      "start": 750.45,
      "end": 751.25,
      "text": "What are you saying?"
    },
    {
      "start": 751.41,
      "end": 751.83,
      "text": "아, 네."
    },
    {
      "start": 751.95,
      "end": 752.89,
      "text": "나중에 설명을 드릴게요."
    },
    {
      "start": 753.11,
      "end": 753.45,
      "text": "Oh my."
    },
    {
      "start": 753.77,
      "end": 754.69,
      "text": "자, 오늘 스크린"
    },
    {
      "start": 754.69,
      "end": 755.31,
      "text": "잉글리쉬는"
    },
    {
      "start": 755.31,
      "end": 756.23,
      "text": "여기까지입니다."
    }
  ]
}