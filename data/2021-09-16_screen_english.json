    },
    {
      "start": 417.96,
      "end": 419.4,
      "text": "내가 어렸을 적에 말이야."
    },
    {
      "start": 419.76,
      "end": 422.98,
      "text": "I used to see you guys in town."
    },
    {
      "start": 423.02,
      "end": 423.66,
      "text": "You guys."
    },
    {
      "start": 423.66,
