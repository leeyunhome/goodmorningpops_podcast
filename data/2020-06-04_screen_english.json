    },
    {
      "start": 473.85,
      "end": 474.95,
      "text": "or less"
    },
    {
      "start": 474.95,
      "end": 476.11,
      "text": "굳이"
    },
    {
      "start": 476.11,
      "end": 477.01,
      "text": "or less까지"
    },
    {
      "start": 477.01,
      "end": 477.59,
      "text": "Oh, yeah"
    },
    {
      "start": 477.59,
      "end": 478.47,
      "text": "여기에서 약간"
    },
    {
      "start": 478.47,
      "end": 480.01,
      "text": "사장님 마음대로"
    },
    {
      "start": 480.01,
      "end": 481.13,
      "text": "라는 느낌이 듭니다"
    },
    {
      "start": 481.13,
      "end": 482.61,
      "text": "당신 실력이"
    },
    {
      "start": 482.61,
      "end": 483.41,
      "text": "입증이 되면"
    },
    {
      "start": 483.41,
      "end": 483.99,
      "text": "그러니까"
    },
    {
      "start": 483.99,
      "end": 485.17,
      "text": "월급을 더 줄지"
    },
    {
      "start": 485.17,
      "end": 485.83,
      "text": "아닐지"
    },
    {
      "start": 485.83,
      "end": 486.49,
      "text": "입증되면"
    },
    {
      "start": 486.49,
      "end": 487.41,
      "text": "다시 조정하죠"
    },
    {
      "start": 487.41,
      "end": 488.95,
      "text": "라는 뉘앙스라는 거예요"
    },
    {
      "start": 488.95,
      "end": 489.71,
      "text": "Wow"
    },
    {
      "start": 489.71,
      "end": 490.93,
      "text": "He sounds very vicious"
    },
    {
      "start": 490.93,
      "end": 491.95,
      "text": "Vicious"
    },
    {
      "start": 491.95,
      "end": 493.13,
      "text": "Yeah, a little bit"
    },
    {
      "start": 493.13,
      "end": 494.05,
      "text": "잘해봐"
    },
    {
      "start": 494.05,
      "end": 495.59,
      "text": "I'll give you $100"
    },
    {
      "start": 495.59,
      "end": 497.35,
      "text": "If you do a good job"
    },
    {
      "start": 497.35,
      "end": 498.27,
      "text": "I'll give you a raise"
    },
    {
      "start": 498.27,
      "end": 499.73,
      "text": "If you do a bad job"
    },
    {
      "start": 499.73,
      "end": 501.21,
      "text": "I'll take that money"
    },
    {
      "start": 501.21,
      "end": 502.15,
      "text": "and make it lower"
    },
    {
      "start": 502.15,
      "end": 503.85,
      "text": "or fire you"
    },
    {
      "start": 503.85,
      "end": 504.91,
      "text": "Oh, 무섭다"
    },
    {
      "start": 504.91,
      "end": 506.09,
      "text": "He's putting the pressure on"
    },
    {
      "start": 506.09,
      "end": 506.75,
      "text": "from the beginning"
    },
    {
      "start": 506.75,
      "end": 507.23,
      "text": "Yeah"
    },
    {
      "start": 507.23,
      "end": 508.51,
      "text": "첫 장면부터"
    },
    {
      "start": 508.51,
      "end": 510.11,
      "text": "취업한 첫날인데"
    },
    {
      "start": 510.11,
      "end": 512.45,
      "text": "굉장히 부담스러운 상황이었어요"
    },
    {
      "start": 512.45,
      "end": 513.63,
      "text": "Nowadays, however"
    },
    {
      "start": 513.63,
      "end": 515.33,
      "text": "without these scientists"
    },
    {
      "start": 515.33,
      "end": 516.53,
      "text": "지금 테슬라도 나오고"
    },
    {
      "start": 516.53,
      "end": 517.57,
      "text": "에디슨도 나왔는데"
    },
    {
      "start": 517.57,
      "end": 518.51,
      "text": "이런 사람들이"
    },
    {
      "start": 518.51,
      "end": 519.57,
      "text": "만약에 없었더라면"
    },
    {
      "start": 519.57,
      "end": 520.33,
      "text": "we'd be living"
    },
    {
      "start": 520.33,
      "end": 522.17,
      "text": "very uncomfortable lives"
    },
    {
      "start": 522.17,
      "end": 523.37,
      "text": "Well, I'm sure"
    },
    {
      "start": 523.37,
      "end": 524.29,
      "text": "someone like Laura"
    },
    {
      "start": 524.29,
      "end": 525.05,
      "text": "or myself"
    },
    {
      "start": 525.05,
      "end": 526.21,
      "text": "would have developed"
    },
    {
      "start": 526.21,
      "end": 526.77,
      "text": "electricity"
    },
    {
      "start": 526.77,
      "end": 528.11,
      "text": "instead of them"
    },
    {
      "start": 528.11,
      "end": 530.21,
      "text": "I really don't know"
    },
    {
      "start": 530.21,
      "end": 531.73,
      "text": "They were just"
    },
    {
      "start": 531.73,
      "end": 532.43,
      "text": "the first ones"
    },
    {
      "start": 532.43,
      "end": 532.97,
      "text": "to do it"
    },
    {
      "start": 532.97,
      "end": 533.23,
      "text": "Okay"
    },
    {
      "start": 533.23,
      "end": 534.81,
      "text": "자, 이 내용"
    },
    {
      "start": 534.81,
      "end": 536.37,
      "text": "다시 한번 들어보시죠"
    },
    {
      "start": 536.37,
      "end": 538.54,
      "text": "Expanding to 12 cities"
    },
    {
      "start": 538.54,
      "end": 540.18,
      "text": "building direct current systems"
    },
    {
      "start": 540.18,
      "end": 540.84,
      "text": "The red current"
    },
    {
      "start": 540.84,
      "end": 542.18,
      "text": "alternating current"
    },
    {
      "start": 542.18,
      "end": 543.04,
      "text": "is far more efficient"
    },
    {
      "start": 543.04,
      "end": 545.24,
      "text": "Higher voltage"
    },
    {
      "start": 545.24,
      "end": 546.5,
      "text": "Greater distance"
    },
    {
      "start": 546.5,
      "end": 547.96,
      "text": "Less copper conductors"
    },
    {
      "start": 547.96,
      "end": 548.32,
      "text": "It's lethal"
    },
    {
      "start": 548.32,
      "end": 549.06,
      "text": "and it's far too much"
    },
    {
      "start": 549.06,
      "end": 550.34,
      "text": "power for a motor to handle"
    },
    {
      "start": 550.34,
      "end": 551.26,
      "text": "I'm going to start you"
    },
    {
      "start": 551.26,
      "end": 552.34,
      "text": "on $100 a month"
    },
    {
      "start": 552.34,
      "end": 553.18,
      "text": "until you prove yourself"
    },
    {
      "start": 553.18,
      "end": 554.06,
      "text": "worth more or less"
    },
    {
      "start": 554.06,
      "end": 556.33,
      "text": "네, 이 대화 중에"
    },
    {
      "start": 556.33,
      "end": 556.55,
      "text": "막"
    },
    {
      "start": 556.55,
      "end": 558.98,
      "text": "이런 소리 났잖아요"
    },
    {
      "start": 558.98,
      "end": 560.38,
      "text": "그건 애기가 아니에요"
    },
    {
      "start": 560.38,
      "end": 561.32,
      "text": "What is that?"
    },
    {
      "start": 561.38,
      "end": 563.34,
      "text": "이거는 에디슨이 발명한"
    },
    {
      "start": 563.34,
      "end": 564.46,
      "text": "그 전기로"
    },
    {
      "start": 564.46,
      "end": 566.52,
      "text": "작동하는 인형이었어요"
    },
    {
      "start": 566.52,
      "end": 569.04,
      "text": "혹시 놀라실까봐"
    },
    {
      "start": 569.04,
      "end": 570.16,
      "text": "설명을 해드립니다"
    },
    {
      "start": 570.16,
      "end": 570.54,
      "text": "Electric doll"
    },
    {
      "start": 570.54,
      "end": 571.04,
      "text": "Yeah"
    },
    {
      "start": 571.04,
      "end": 572.5,
      "text": "That sounds scary"
    },
    {
      "start": 572.5,
      "end": 574.14,
      "text": "오, 약간 무서웠어요"
    },
    {
      "start": 574.14,
      "end": 575.56,
      "text": "자, 오늘 Screen English"
    },
    {
      "start": 575.56,
      "end": 576.82,
      "text": "여기서 마무리하고요"
    }
  ]
}